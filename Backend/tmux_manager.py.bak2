"""
tmux_manager.py — tmux Session-Manager for ACW V2

Manages persistent tmux sessions for Claude Code agents.
Each agent runs as a living terminal session (acw_{agent_id}).

Spec reference: SPEC_V2.md sections 3.2, 3.3, 5.1, 7
"""

import json
import re
import subprocess
import sys
import textwrap
from pathlib import Path


_VALID_AGENT_ID = re.compile(r"^[a-zA-Z0-9_]+$")


def _validate_agent_id(agent_id: str) -> None:
    """Validate agent_id against whitelist (alphanumeric + underscore)."""
    if not agent_id or not _VALID_AGENT_ID.match(agent_id):
        raise ValueError(f"invalid agent_id: {agent_id!r} (must be alphanumeric + underscore)")


# ---------------------------------------------------------------------------
# Agent settings — bypasses all permission prompts for autonomous operation
# ---------------------------------------------------------------------------

def _agent_settings(project_path: str) -> dict:
    """Generate settings.json for an agent — full permissions + Hooks + Statusline + MCP."""
    hook_dir = Path(__file__).parent
    stop_hook_path = str(hook_dir / "stop_hook.sh")
    post_tool_hook_path = str(hook_dir / "post_tool_hook.sh")
    statusline_path = str(hook_dir / "context_statusline.sh")
    return {
        "permissions": {
            "additionalDirectories": [project_path],
            "allow": [
                "Bash(**)",
                "Read(**)",
                "Edit(**)",
                "Write(**)",
                "Glob(**)",
                "Grep(**)",
                "WebFetch(**)",
                "Task(**)",
                "mcp__bridge(**)",
            ],
            "defaultMode": "bypassPermissions",
        },
        "hooks": {
            "Stop": [
                {
                    "hooks": [
                        {
                            "type": "command",
                            "command": stop_hook_path,
                        }
                    ]
                }
            ],
            "PostToolUse": [
                {
                    "hooks": [
                        {
                            "type": "command",
                            "command": post_tool_hook_path,
                        }
                    ]
                }
            ],
        },
        "statusLine": {
            "type": "command",
            "command": statusline_path,
        },
    }

AGENT_INITIAL_PROMPT = (
    "Lies deine CLAUDE.md. Registriere dich SOFORT via bridge_register MCP Tool. "
    "Dann pruefe bridge_receive auf Nachrichten und arbeite autonom."
)


# ---------------------------------------------------------------------------
# tmux Session Management
# ---------------------------------------------------------------------------

def create_agent_session(
    agent_id: str,
    role: str,
    project_path: str,
    team_members: list,
    bridge_port: int = 9111,
    role_description: str = "",
) -> bool:
    """Creates tmux session and starts claude CLI inside it.

    Lifecycle (SPEC_V2.md 5.1):
      1. Generate CLAUDE.md for this agent
      2. Write CLAUDE.md to the project path
      3. Create tmux session: tmux new-session -d -s acw_{agent_id} -c {project_path}
      4. Start claude inside: tmux send-keys -t acw_{agent_id} 'claude' Enter
      5. Return True if session is running
    """
    _validate_agent_id(agent_id)
    session_name = f"acw_{agent_id}"
    proj = Path(project_path)

    # Per-agent workspace directory.
    # Claude Code reads CLAUDE.md from CWD *and* parent directories,
    # so the agent gets its own instructions AND the project-level CLAUDE.md.
    workspace = proj / ".agent_sessions" / agent_id
    workspace.mkdir(parents=True, exist_ok=True)

    # 1+2  Generate and write CLAUDE.md into agent workspace (never overwrite project root)
    claude_md = generate_agent_claude_md(
        agent_id=agent_id,
        role=role,
        role_description=role_description,
        project_path=project_path,
        team_members=team_members,
        bridge_port=bridge_port,
    )
    try:
        (workspace / "CLAUDE.md").write_text(claude_md, encoding="utf-8")
    except OSError as exc:
        print(f"[tmux_manager] ERROR writing CLAUDE.md: {exc}", file=sys.stderr)
        return False

    # 2b  Write .claude/settings.json — full permissions within project path
    settings_dir = workspace / ".claude"
    settings_dir.mkdir(parents=True, exist_ok=True)
    try:
        (settings_dir / "settings.json").write_text(
            json.dumps(_agent_settings(project_path), indent=2), encoding="utf-8"
        )
    except OSError as exc:
        print(f"[tmux_manager] ERROR writing settings.json: {exc}", file=sys.stderr)
        return False

    # 2c  Write .mcp.json — bridge MCP server config for agent
    mcp_config = {
        "mcpServers": {
            "bridge": {
                "type": "stdio",
                "command": "python3",
                "args": [str(Path(__file__).parent.parent.parent / "bridge" / "bridge_mcp.py")],
                "env": {},
            }
        }
    }
    try:
        (workspace / ".mcp.json").write_text(
            json.dumps(mcp_config, indent=2), encoding="utf-8"
        )
    except OSError as exc:
        print(f"[tmux_manager] ERROR writing .mcp.json: {exc}", file=sys.stderr)
        return False

    # 3  Create tmux session (CWD = agent workspace)
    rc = _run(["tmux", "new-session", "-d", "-s", session_name, "-c", str(workspace)])
    if rc != 0:
        print(f"[tmux_manager] ERROR creating tmux session {session_name}", file=sys.stderr)
        return False

    # 4  Unset CLAUDECODE env var (prevents "nested session" error when server
    #    itself runs inside a Claude Code session) and start claude CLI.
    rc = _run(["tmux", "send-keys", "-t", session_name, "unset CLAUDECODE && claude", "Enter"])
    if rc != 0:
        print(f"[tmux_manager] ERROR sending claude start to {session_name}", file=sys.stderr)
        return False

    # 5  Verify session is running
    if not is_session_alive(agent_id):
        return False

    # 6  Send initial activation prompt after Claude CLI has loaded.
    #    Spawned as detached subprocess so it survives parent process exit.
    init_script = str(Path(__file__).parent / "init_agent_prompt.sh")
    try:
        subprocess.Popen(
            [init_script, session_name, AGENT_INITIAL_PROMPT, "30"],
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except (OSError, FileNotFoundError) as exc:
        print(f"[tmux_manager] ERROR starting init_agent_prompt.sh: {exc}", file=sys.stderr)

    return True


def kill_agent_session(agent_id: str) -> bool:
    """Kill tmux session: tmux kill-session -t acw_{agent_id}"""
    _validate_agent_id(agent_id)
    session_name = f"acw_{agent_id}"
    rc = _run(["tmux", "kill-session", "-t", session_name])
    if rc != 0:
        print(f"[tmux_manager] WARN kill-session failed for {session_name}", file=sys.stderr)
        return False
    return True


def list_agent_sessions() -> list:
    """List all acw_* sessions.

    Returns: [{session_name, last_activity, alive}]
    """
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name} #{session_activity}"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except FileNotFoundError:
        print("[tmux_manager] ERROR tmux not found", file=sys.stderr)
        return []
    except subprocess.TimeoutExpired:
        print("[tmux_manager] ERROR tmux list-sessions timed out", file=sys.stderr)
        return []

    if result.returncode != 0:
        # No server running or no sessions — not an error
        return []

    sessions = []
    for line in result.stdout.strip().splitlines():
        parts = line.split(" ", 1)
        if len(parts) < 2:
            continue
        name = parts[0]
        if not name.startswith("acw_"):
            continue
        try:
            activity_ts = int(parts[1])
        except ValueError:
            activity_ts = 0
        sessions.append({
            "session_name": name,
            "last_activity": activity_ts,
            "alive": True,
        })
    return sessions


def is_session_alive(agent_id: str) -> bool:
    """Check if tmux session exists: tmux has-session -t acw_{agent_id}

    Intentionally quiet — a missing session is expected (not an error).
    """
    _validate_agent_id(agent_id)
    session_name = f"acw_{agent_id}"
    try:
        result = subprocess.run(
            ["tmux", "has-session", "-t", session_name],
            capture_output=True, text=True, timeout=5,
        )
        return result.returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def send_to_session(agent_id: str, text: str) -> bool:
    """Send text to tmux session: tmux send-keys -t acw_{agent_id} '{text}' Enter

    WARNING: Only for initial messages and emergency.
    Normal communication goes through the Bridge API.
    """
    _validate_agent_id(agent_id)
    session_name = f"acw_{agent_id}"
    rc = _run(["tmux", "send-keys", "-t", session_name, text, "Enter"])
    if rc != 0:
        print(f"[tmux_manager] ERROR send-keys failed for {session_name}", file=sys.stderr)
        return False
    return True


# ---------------------------------------------------------------------------
# CLAUDE.md Template Generation
# ---------------------------------------------------------------------------

def generate_agent_claude_md(
    agent_id: str,
    role: str,
    role_description: str,
    project_path: str,
    team_members: list,
    bridge_port: int = 9111,
) -> str:
    """Generate CLAUDE.md content for an agent.

    The template matches SPEC_V2.md section 7 exactly:
    - Agent identity (id, role)
    - Team members list
    - Bridge-API instructions (register, poll-loop, send, heartbeat, history)
    - Work rules (7 rules)
    - Role-specific description
    """
    # Format team members list
    team_lines = _format_team_members(team_members)

    # Build the template — MCP-First with Stop-Hook Loop
    template = textwrap.dedent("""\
        # Agent: {agent_id}
        Rolle: {role}
        Projekt: {project_path}

        ## Du bist Teil eines Multi-Agent-Teams

        Team:
        {team_members}

        ## DAUERHAFT-REGEL (wichtigste Regel)

        Du wirst durch einen Stop-Hook am Beenden gehindert. Das ist gewollt.
        Nach JEDER abgeschlossenen Aufgabe rufst du `bridge_receive` auf.
        - Nachrichten da? → Bearbeiten, antworten, dann erneut `bridge_receive`.
        - Keine Nachrichten? → Kurz warten, dann erneut `bridge_receive`.
        Du bist ein persistenter Agent. Du stoppst NIE von dir aus.

        ## Kommunikation via Bridge MCP (primaer)

        Du hast einen Bridge MCP Server. Nutze die MCP-Tools — NICHT curl.

        ### Bei Start: Registrieren
        Rufe SOFORT auf:
        ```
        bridge_register(agent_id="{agent_id}", role="{role}")
        ```
        Das startet automatisch WebSocket-Listener und Heartbeat im Hintergrund.

        ### Nachrichten empfangen
        ```
        bridge_receive()
        ```
        Gibt gepufferte Nachrichten zurueck (non-blocking). WebSocket-Listener laeuft im Hintergrund.

        ### Nachrichten senden
        ```
        bridge_send(to="<empfaenger>", content="<nachricht>")
        ```
        Gueltige Empfaenger: user, projektleiter, claude_b, all

        ### Aktivitaet melden
        ```
        bridge_activity(action="editing", target="<datei>", description="<was>")
        ```

        ### History lesen
        ```
        bridge_history(limit=20)
        ```

        ### Heartbeat
        Laeuft automatisch alle 30 Sekunden nach bridge_register. Kein manueller Aufruf noetig.

        ## Fallback (nur bei MCP-Ausfall)

        Falls MCP nicht verfuegbar, nutze curl:
        ```bash
        curl -s -X POST http://127.0.0.1:{bridge_port}/register -H "Content-Type: application/json" -d '{{"agent_id":"{agent_id}","role":"{role}"}}'
        curl -s "http://127.0.0.1:{bridge_port}/receive/{agent_id}?wait=15&limit=5"
        curl -s -X POST http://127.0.0.1:{bridge_port}/send -H "Content-Type: application/json" -d '{{"from":"{agent_id}","to":"<empfaenger>","content":"<nachricht>"}}'
        ```

        ## Guardrails (NICHT VERHANDELBAR)

        1. **Keine Dateien ausserhalb deines Zustaendigkeitsbereichs aendern.** Verstoss = sofortiger Revert.
        2. **Keine Annahmen.** Was nicht belegt ist, ist UNKNOWN. Lies den Code, pruefe die Logs. Kein "vermutlich", "wahrscheinlich", "moeglicherweise".
        3. **Backup vor jeder Datei-Aenderung.** `cp datei datei.bak` — keine Ausnahme.
        4. **Keine destruktiven git-Operationen** (force-push, reset --hard, branch -D) ohne explizite Freigabe.
        5. **Keine Secrets in Code oder Logs.** Keine API-Keys, Passwoerter, Tokens in Dateien committen.
        6. **Bei Unsicherheit: fragen statt raten.** Sende Frage via bridge_send an den zustaendigen Agent oder manager.

        ## Arbeitsregeln

        1. **bridge_receive nach JEDER Aufgabe.** Ohne Nachrichtencheck bist du taub.
        2. **Dynamisches Routing.** Sende an jeden Agent — waehle den Empfaenger nach Aufgabe.
        3. **Autonomie.** Du entscheidest selbst wann du arbeitest, wann du fragst, wann du meldest.
        4. **Context-Management.** Wenn dein Context zu gross wird, nutze /compact. Bei >95% wird dich der PostToolUse-Hook warnen.
        5. **Vor Datei-Aenderungen:** bridge_activity melden + Backup erstellen.
        6. **Zustaendigkeitsgrenzen einhalten.** Nur in deinem Bereich arbeiten.
        7. **Code-Qualitaet.** Kein Over-Engineering. Nur das bauen was gebraucht wird. Tests schreiben fuer kritische Funktionen.

        ## Deine Rolle: {role}

        {role_description}
    """)

    return template.format(
        agent_id=agent_id,
        role=role,
        project_path=project_path,
        team_members=team_lines,
        bridge_port=bridge_port,
        role_description=role_description if role_description else "(keine spezifische Rollenbeschreibung)",
    )


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

def _format_team_members(team_members: list) -> str:
    """Format team_members list into readable lines.

    Accepts list of dicts: [{"id": "teamlead", "role": "Koordination"}, ...]
    Returns multiline string:
      - teamlead (Koordination)
      - agent_a (Implementer)
    """
    if not team_members:
        return "- (keine Team-Mitglieder definiert)"
    lines = []
    for member in team_members:
        mid = member.get("id", "unknown")
        mrole = member.get("role", "")
        if mrole:
            lines.append(f"- {mid} ({mrole})")
        else:
            lines.append(f"- {mid}")
    return "\n".join(lines)


def _run(cmd: list, timeout: int = 10) -> int:
    """Run a subprocess command, return exit code. Logs errors to stderr."""
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        if result.returncode != 0 and result.stderr:
            print(f"[tmux_manager] {' '.join(cmd)}: {result.stderr.strip()}", file=sys.stderr)
        return result.returncode
    except FileNotFoundError:
        print(f"[tmux_manager] ERROR command not found: {cmd[0]}", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print(f"[tmux_manager] ERROR command timed out: {' '.join(cmd)}", file=sys.stderr)
        return 1
