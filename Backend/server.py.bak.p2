# ===== APPROVAL GATE FRAMEWORK =====
# In-memory store for approval requests. Thread-safe via APPROVAL_LOCK.
# Spec: /home/leo/Desktop/CC/BRIDGE/Strategy/APPROVAL_GATE_SPEC.md
APPROVAL_REQUESTS: dict[str, dict[str, Any]] = {}
APPROVAL_LOCK = threading.Lock()
APPROVAL_DEFAULT_TIMEOUT = 300  # 5 minutes


def _approval_generate_id() -> str:
    """Generate a unique approval request ID with prefix."""
    return f"appr_{uuid.uuid4().hex[:12]}"


def _approval_expire_check() -> list[dict[str, Any]]:
    """Lazy expire check: mark timed-out requests as 'expired'.

    Called inside GET/POST approval endpoints — no background thread needed.
    Returns list of newly expired requests (for notification).
    """
    now = datetime.now(timezone.utc)
    expired: list[dict[str, Any]] = []
    with APPROVAL_LOCK:
        for req in APPROVAL_REQUESTS.values():
            if req["status"] != "pending":
                continue
            expires_at = datetime.fromisoformat(req["expires_at"])
            if now >= expires_at:
                req["status"] = "expired"
                req["decided_at"] = now.isoformat()
                req["comment"] = "timeout — keine Antwort innerhalb des Zeitlimits"
                expired.append(dict(req))
    # Notifications outside lock to avoid deadlock with LOCK (used by append_message)
    for req in expired:
        agent_id = req["agent_id"]
        action = req["action"]
        desc = req["description"]
        append_message(
            "system", agent_id,
            f"[APPROVAL EXPIRED] Deine Anfrage wurde nicht rechtzeitig beantwortet.\n"
            f"Aktion: {action}\nBeschreibung: {desc}",
            meta={"type": "approval_expired", "request_id": req["request_id"]},
        )
        ws_broadcast("approval_decided", {
            "request_id": req["request_id"],
            "agent_id": agent_id,
            "decision": "expired",
            "action": action,
        })
    return expired


