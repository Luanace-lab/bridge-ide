# =============================================================================
# Bridge IDE — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# All variables are optional — defaults work for standard installations.

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
# BRIDGE_HTTP_PORT=9111          # HTTP API port
# BRIDGE_WS_PORT=9112            # WebSocket port
# BRIDGE_HTTP_HOST=127.0.0.1     # Bind address
# UI_PORT removed — UI served from main HTTP port (9111)

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# BRIDGE_PROJECT_PATH=            # Project root (default: auto-detected from config.py location)
# BRIDGE_SKILLS_DIR=              # Skills directory (default: ~/.claude/skills)

# ---------------------------------------------------------------------------
# External MCP Servers (optional — only needed if you use these tools)
# ---------------------------------------------------------------------------
# AASE_MCP_PATH=                  # Path to aase_mcp.py (security scanner)
# GHOST_MCP_PATH=                 # Path to ghost_mcp_server.py (stealth browser)

# ---------------------------------------------------------------------------
# WhatsApp Integration (optional — only needed if WhatsApp bridge is set up)
# ---------------------------------------------------------------------------
# WHATSAPP_CONFIG_PATH=~/.config/bridge/whatsapp_config.json
# WHATSAPP_DB_PATH=~/.config/bridge/whatsapp-bridge/store/messages.db
# WHATSAPP_BRIDGE_URL=http://localhost:8080  # WhatsApp Go Bridge API URL
# WHATSAPP_API_TOKEN=             # Optional override for ~/.config/bridge/whatsapp_bridge_token
# WHATSAPP_GROUP_JID=             # Group JID for whatsapp_watcher inbound routing
# WHATSAPP_LEO_SENDER=            # Optional sender filter for whatsapp_watcher
# WHATSAPP_READ_WHITELIST=        # Comma-separated JIDs allowed for bridge_whatsapp_read
# WHATSAPP_SEND_WHITELIST=        # Comma-separated JIDs allowed for bridge_whatsapp_send
# WHATSAPP_APPROVAL_WHITELIST=    # Comma-separated JIDs that bypass approval
# WHATSAPP_WEBHOOK_ACTIVE=0       # 1 if Go bridge webhook already handles text messages
# WHATSAPP_WATCHER_STATE_FILE=    # Optional override for isolated watcher smoke tests
# WHATSAPP_WATCHER_LOCK_FILE=     # Optional override for isolated watcher smoke tests

# ---------------------------------------------------------------------------
# Telegram Integration (optional — only needed if Telegram bot bridge is set up)
# ---------------------------------------------------------------------------
# TELEGRAM_CONFIG_PATH=~/.config/bridge/telegram_config.json
# TELEGRAM_BOT_TOKEN=             # Optional override for ~/.config/bridge/telegram_bot_token
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# TELEGRAM_READ_WHITELIST=        # Comma-separated chat IDs/usernames allowed for bridge_telegram_read
# TELEGRAM_SEND_WHITELIST=        # Comma-separated chat IDs/usernames allowed for bridge_telegram_send
# TELEGRAM_APPROVAL_WHITELIST=    # Comma-separated chat IDs/usernames that bypass approval
# TELEGRAM_WATCH_CHATS=           # Comma-separated chat IDs polled by telegram_watcher
# TELEGRAM_DEFAULT_ROUTE=ordo     # Default Bridge route for inbound messages without @mentions
# TELEGRAM_UPDATES_STORE_PATH=    # Optional override for telegram watcher/read JSONL store
# TELEGRAM_WATCHER_STATE_FILE=    # Optional override for isolated watcher smoke tests
# TELEGRAM_WATCHER_LOCK_FILE=     # Optional override for isolated watcher smoke tests

# ---------------------------------------------------------------------------
# Telephony — Twilio (optional — only needed for outbound calls/SMS)
# ---------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=              # Twilio Account SID (starts with AC...)
# TWILIO_AUTH_TOKEN=               # Twilio Auth Token
# TWILIO_PHONE_NUMBER=             # Outbound phone number (E.164, e.g. +1234567890)

# ---------------------------------------------------------------------------
# Voice — ElevenLabs (optional — only needed for text-to-speech)
# ---------------------------------------------------------------------------
# ELEVENLABS_API_KEY=              # ElevenLabs API key
# ELEVENLABS_VOICE_ID=             # Voice ID (default: Carla Blum)

# ---------------------------------------------------------------------------
# Agent Configuration
# ---------------------------------------------------------------------------
# BRIDGE_HEARTBEAT_INTERVAL=30    # Heartbeat interval in seconds
# BRIDGE_DISCONNECT_TIMEOUT=60    # Seconds until agent is marked disconnected
# BRIDGE_CLEANUP_TTL=300          # Seconds until disconnected agent is cleaned up
# BRIDGE_MAX_IDLE=600             # Max idle time in seconds

# ---------------------------------------------------------------------------
# Message Limits
# ---------------------------------------------------------------------------
# BRIDGE_MAX_MESSAGE_SIZE=500000  # Max message size in bytes (500 KB)
# BRIDGE_MAX_BODY_SIZE=1048576    # Max HTTP body size in bytes (1 MB)
# BRIDGE_MAX_SENDER_LENGTH=128    # Max sender name length
# BRIDGE_MAX_MESSAGES_IN_MEMORY=50000  # Max messages kept in memory
# BRIDGE_MESSAGES_TRIM_TO=25000   # Trim target when max is reached
# BRIDGE_DEFAULT_HISTORY_LIMIT=50 # Default history query limit

# ---------------------------------------------------------------------------
# Approval Gate
# ---------------------------------------------------------------------------
# BRIDGE_APPROVAL_TIMEOUT=300     # Approval timeout in seconds (5 min)
# BRIDGE_APPROVAL_EXPIRE_CHECK=30 # Check interval for expired approvals

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# BRIDGE_VAULT_PASSPHRASE=        # Credential vault encryption passphrase
# BRIDGE_USER_TOKEN=              # User authentication token

# ---------------------------------------------------------------------------
# Context Warning
# ---------------------------------------------------------------------------
# BRIDGE_CONTEXT_WARNING_THRESHOLD=95  # Warn at this context usage percent

# ---------------------------------------------------------------------------
# Feature Flags (true/false)
# ---------------------------------------------------------------------------
# BRIDGE_ENABLE_SOUL_ENGINE=true       # Agent personality engine
# BRIDGE_ENABLE_APPROVAL_GATE=true     # Approval workflow for sensitive ops
# BRIDGE_ENABLE_CREDENTIAL_VAULT=true  # Encrypted credential storage
# BRIDGE_ENABLE_AUTO_CLEANUP=true      # Auto-cleanup of stale agents
# BRIDGE_ENABLE_WATCHER=true           # WebSocket-to-tmux message router
