#!/usr/bin/env python3
"""
output_forwarder.py — Stream Manager Terminal Output → Bridge

Hybrid approach:
  - tmux pipe-pane → FIFO as event trigger (detects new output)
  - tmux capture-pane for actual content (clean, rendered screen)
  - Debounce buffer: wait for silence before capturing

This gives event-based triggering (no blind polling) with clean
rendered output from capture-pane.

Option A: Two message types:
  - meta.type="prose"  → real agent text (shown as chat bubble)
  - meta.type="status" → spinner/thinking indicator (shown as typing dot)

Usage:
    python3 output_forwarder.py
    FORWARDER_SESSION=acw_manager python3 output_forwarder.py
"""

from __future__ import annotations

import json
import os
import re
import select
import signal
import stat
import subprocess
import sys
import time
import urllib.request

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

TMUX_SESSION = os.environ.get("FORWARDER_SESSION", "acw_manager")
BRIDGE_URL = os.environ.get("BRIDGE_URL", "http://127.0.0.1:9111")
STATUS_COOLDOWN = float(os.environ.get("STATUS_COOLDOWN", "10.0"))
FLUSH_DELAY = float(os.environ.get("FLUSH_DELAY", "2.5"))
MIN_PROSE_LEN = int(os.environ.get("MIN_PROSE_LEN", "10"))

_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PID_DIR = os.path.join(_SCRIPT_DIR, "pids")
PID_FILE = os.path.join(PID_DIR, "output_forwarder.pid")
FIFO_PATH = os.environ.get("FORWARDER_FIFO", f"/tmp/bridge_forwarder_{TMUX_SESSION}.fifo")

# ---------------------------------------------------------------------------
# ANSI / terminal escape stripping
# ---------------------------------------------------------------------------

_ANSI_RE = re.compile(
    r"\x1b\[[0-9;]*[a-zA-Z]"   # CSI sequences
    r"|\x1b\].*?\x07"           # OSC sequences
    r"|\x1b[()][AB012]"         # charset switching
    r"|\x1b\[[\?]?\d*[hl]"     # mode set/reset
    r"|\r"                       # carriage returns
)


def _strip_ansi(text: str) -> str:
    return _ANSI_RE.sub("", text)


# ---------------------------------------------------------------------------
# Spinner words (Claude Code thinking/processing status)
# ---------------------------------------------------------------------------

_SPINNER_WORDS = {
    "Fermenting", "Brewing", "Actualizing", "Thinking", "Reasoning",
    "Orbiting", "Pondering", "Computing", "Leavening", "Wandering",
    "Brewed", "Crunched", "Forming", "Whirring",
}

_SPINNER_RE = re.compile(
    r"^(?:" + "|".join(_SPINNER_WORDS) + r")"
)

_SPINNER_DURATION_RE = re.compile(
    r"(?:" + "|".join(_SPINNER_WORDS) + r") for \d"
)


# ---------------------------------------------------------------------------
# Line classification
# ---------------------------------------------------------------------------

# Tool call: ● <server> - <tool> (MCP)(...) or ● <ToolName> (...)
_TOOL_CALL_RE = re.compile(
    r"^●\s+.+\((?:MCP|Bash|Read|Write|Edit|Glob|Grep|Task|Skill|"
    r"NotebookEdit|WebFetch|WebSearch|EnterPlanMode|ExitPlanMode|"
    r"AskUserQuestion|EnterWorktree|TeamCreate|SendMessage)\)"
)
_TOOL_SEARCH_RE = re.compile(
    r"^●\s+(?:Searched for|Found \d+|Read \(|Wrote \(|Edited \()"
)


def _is_tool_call(stripped: str) -> bool:
    """True if line is a Claude Code tool invocation header."""
    if not stripped.startswith("●"):
        return False
    if _TOOL_CALL_RE.search(stripped):
        return True
    if _TOOL_SEARCH_RE.search(stripped):
        return True
    # Generic: ● word - word (SomeProvider)
    if re.match(r"^●\s+\w+\s+-\s+\w+\s+\(", stripped):
        return True
    return False


def _is_spinner(stripped: str) -> bool:
    """True if line is a Claude Code spinner/thinking status."""
    if not stripped:
        return False
    # Special spinner prefix chars: ✻ ✽ ✦ ✶
    if stripped[0] in ("✻", "✽", "✦", "✶"):
        return True
    # Regular asterisk: "* Orbiting…", "* Brewing…"
    if stripped.startswith("*") and not stripped.startswith("**"):
        rest = stripped.lstrip("* ").rstrip("…. ")
        if rest and rest.split()[0] in _SPINNER_WORDS:
            return True
    # Bare spinner word at start: "Brewing for 3s", "Orbiting…"
    if _SPINNER_RE.match(stripped):
        return True
    if _SPINNER_DURATION_RE.search(stripped):
        return True
    # "(thought for Xs)" pattern
    if re.search(r"\(thought for \d+s?\)", stripped):
        return True
    # "(thinking)" bare
    if stripped == "(thinking)":
        return True
    # Token counter: "(39s · ↑ 552 tokens)" — always chrome
    if re.search(r"\d+s\s*·\s*↑\s*[\d,]+ tokens", stripped):
        return True
    # Generic catch-all: Line is ONLY a capitalized word (possibly hyphenated) + …
    # Must be the entire line to avoid false positives on German prose
    if re.match(r"^[A-Z][a-z]+(?:-[A-Za-z]+)*…\.{0,3}$", stripped):
        return True
    return False


def _is_chrome(stripped: str) -> bool:
    """True if line is terminal UI chrome (not agent content).
    NOTE: Spinners are handled separately by _is_spinner()."""
    if not stripped:
        return True
    if stripped.startswith("❯"):
        return True
    if stripped.startswith("────"):
        return True
    if stripped.startswith("⏵"):
        return True
    if "bypass permissions" in stripped:
        return True
    if "esc to interrupt" in stripped:
        return True
    if "ctrl+o to expand" in stripped:
        return True
    if "shift+tab to cycle" in stripped:
        return True
    if re.match(r"^\s*[…\.]{1,3}\s*\+\d+ lines", stripped):
        return True
    # Raw JSON fragments (e.g. leaked curl / tool output)
    if re.match(r'^\s*[\{\}"\[]', stripped):
        return True
    if re.search(r'"timestamp"\s*:', stripped):
        return True
    if re.search(r'"result"\s*:', stripped):
        return True
    if re.search(r'"ok"\s*:', stripped):
        return True
    if re.search(r'"message"\s*:', stripped):
        return True
    # Bare tool call text without ● prefix: "Bash(...)", "Read(...)", etc.
    if re.match(
        r"^(?:Bash|Read|Write|Edit|Glob|Grep|Task|Skill|WebFetch|WebSearch)\s*\(",
        stripped,
    ):
        return True
    # Numbered source code lines from Read tool output (e.g. "311→  except...")
    # Require 2+ digits followed by → or tab to avoid false positives like "3 Agents"
    if re.match(r"^\d{2,}[→\t]", stripped):
        return True
    # Lines starting with +/- (diff output — with or without trailing space)
    if re.match(r"^[+\-]{1,3}[a-zA-Z|#]", stripped):
        return True
    if re.match(r"^[+\-]{1,3}\s", stripped):
        return True
    # Table rows from tool output (e.g. "| Column | Value |")
    if re.match(r"^\|.*\|", stripped):
        return True
    # Markdown headers leaked from tool output context
    if re.match(r"^#{1,6}\s", stripped):
        return True
    # Token counter line: "↑ N tokens" or "(Xs · ↑ N tokens)"
    if re.search(r"↑\s*[\d,]+\s*tokens", stripped):
        return True
    # Context/statusline messages: "Context left until auto-compact: N%"
    if re.search(r"Context left until auto-compact", stripped):
        return True
    # MCP tool call lines without ● prefix: "bridge - bridge_send (MCP)"
    if re.match(r"^\w+\s+-\s+\w+\s+\(MCP\)", stripped):
        return True
    # MCP tool call with args: "bridge - bridge_send (MCP)(to: ...)"
    if re.search(r"\(MCP\)\s*\(", stripped):
        return True
    # Truncated tool call output: "…+N lines (ctrl+o to expand)"
    if re.search(r"ctrl\+o to expand", stripped):
        return True
    return False


def _is_tool_result_continuation(line: str, stripped: str) -> bool:
    """True if line is indented continuation of a tool result block."""
    leading = len(line) - len(line.lstrip())
    # Box-drawing lines (table output from tools) — any indent level
    if re.search(r"[│├┌└┬┼┤┐┘]{1}", stripped):
        return True
    # Numbered source code lines from Read tool (e.g. "  311→  except...")
    if re.match(r"^\d+[→\t]\s*", stripped):
        return True
    if leading < 2:
        return False
    # Looks like JSON or quoted result text
    if stripped.startswith(("{", "}", '"', "'", "…")):
        return True
    if re.match(r'^"?\w+"?\s*:', stripped):
        return True
    # Escaped JSON strings (leaked curl output)
    if re.search(r'\\u[0-9a-fA-F]{4}', stripped):
        return True
    if re.search(r'\\"[a-z_]+\\"', stripped):
        return True
    # Indented text that looks like tool output (file paths, commands)
    if leading >= 3 and re.match(r"^/\w|^[a-z_]+\.[a-z]+", stripped):
        return True
    # Table rows (any indent) — "| Col | Val |"
    if re.match(r"^\|.*\|", stripped):
        return True
    # Diff additions/removals in tool output context
    if re.match(r"^[+\-]{1,3}[a-zA-Z|#]", stripped):
        return True
    return False


# ---------------------------------------------------------------------------
# Text extraction (state machine)
# ---------------------------------------------------------------------------

def extract_agent_text(lines: list[str]) -> tuple[str, bool]:
    """Extract agent prose from raw terminal lines.

    Returns (prose_text, has_spinner).
    - prose_text: The actual agent prose (filtered)
    - has_spinner: True if any spinner/thinking lines were detected

    Uses a simple state machine:
      TEXT       — collecting agent output
      TOOL_BLOCK — inside a tool call / result block, skipping
    """
    output: list[str] = []
    in_tool_block = False
    has_spinner = False

    for raw_line in lines:
        line = _strip_ansi(raw_line)
        stripped = line.strip()

        # ----- skip very short lines (terminal render artifacts) -----
        if stripped and len(stripped) <= 3:
            continue

        # ----- detect spinner (don't add to output) -----
        if _is_spinner(stripped):
            has_spinner = True
            continue

        # ----- skip UI chrome always -----
        if _is_chrome(stripped):
            continue

        # ----- tool result start (⎿) -----
        if stripped.startswith("⎿"):
            in_tool_block = True
            continue

        # ----- tool call start (●) -----
        if stripped.startswith("●"):
            if _is_tool_call(stripped):
                in_tool_block = True
                continue
            else:
                # Agent text paragraph starting with ●
                in_tool_block = False
                # Remove the ● marker for cleaner text
                text = re.sub(r"^●\s*", "", stripped)
                if text:
                    output.append(text)
                continue

        # ----- inside tool block: skip continuations -----
        if in_tool_block:
            if _is_tool_result_continuation(line, stripped):
                continue
            if not stripped:
                continue
            # Non-indented, non-empty → end of tool block
            in_tool_block = False

        # ----- regular text -----
        if stripped:
            output.append(line.rstrip())

    # Clean up trailing/leading empties
    while output and not output[0].strip():
        output.pop(0)
    while output and not output[-1].strip():
        output.pop()

    return "\n".join(output).strip(), has_spinner


# ---------------------------------------------------------------------------
# tmux capture-pane — gets clean rendered screen content
# ---------------------------------------------------------------------------

def capture_pane() -> list[str]:
    """Capture full scrollback from the manager tmux pane."""
    try:
        result = subprocess.run(
            ["tmux", "capture-pane", "-t", TMUX_SESSION, "-p", "-S", "-"],
            capture_output=True,
            text=True,
            timeout=5,
        )
        if result.returncode != 0:
            return []
        return (result.stdout or "").splitlines()
    except Exception:
        return []


# ---------------------------------------------------------------------------
# Delta detection
# ---------------------------------------------------------------------------

def find_delta(
    prev_lines: list[str],
    prev_count: int,
    curr_lines: list[str],
) -> list[str]:
    """Find new lines appended since the last capture.

    Strategy:
    1. If curr has more lines than prev → take lines[prev_count:]
       but verify via tail fingerprint to handle scrollback wrap.
    2. If same count → compare last lines for changes.
    3. If fewer → screen cleared / reset, skip this cycle.
    """
    curr_count = len(curr_lines)

    if curr_count <= prev_count:
        if curr_count == prev_count and curr_lines == prev_lines:
            return []
        return []

    # More lines than before — common case
    # Verify with tail fingerprint (last 5 non-empty lines of prev)
    fingerprint = [l for l in prev_lines[-5:] if l.strip()]
    fp_len = len(fingerprint)

    if fingerprint and fp_len > 0:
        search_start = max(0, prev_count - fp_len - 5)
        search_end = min(curr_count, prev_count + 5)
        best_match = -1

        for i in range(search_start, search_end):
            if i + fp_len <= curr_count:
                candidate = [l for l in curr_lines[i : i + fp_len] if l.strip()]
                if len(candidate) == fp_len and candidate == fingerprint:
                    best_match = i + fp_len
                    break

        if best_match >= 0:
            return curr_lines[best_match:]

    # Fallback: trust line count
    return curr_lines[prev_count:]


# ---------------------------------------------------------------------------
# FIFO management (for pipe-pane event trigger)
# ---------------------------------------------------------------------------

def _create_fifo() -> None:
    """Create named pipe (FIFO) if it doesn't exist."""
    if os.path.exists(FIFO_PATH):
        if stat.S_ISFIFO(os.stat(FIFO_PATH).st_mode):
            return
        os.remove(FIFO_PATH)
    os.mkfifo(FIFO_PATH)
    _log(f"Created FIFO: {FIFO_PATH}")


def _remove_fifo() -> None:
    """Remove the FIFO."""
    try:
        os.remove(FIFO_PATH)
    except OSError:
        pass


def _start_pipe_pane() -> None:
    """Attach tmux pipe-pane to stream output to our FIFO."""
    subprocess.run(
        ["tmux", "pipe-pane", "-t", TMUX_SESSION],
        capture_output=True, timeout=5,
    )
    result = subprocess.run(
        ["tmux", "pipe-pane", "-t", TMUX_SESSION, "-o",
         f"cat >> {FIFO_PATH}"],
        capture_output=True, text=True, timeout=5,
    )
    if result.returncode != 0:
        _log(f"pipe-pane failed: {result.stderr}")
        sys.exit(1)
    _log(f"pipe-pane attached to {TMUX_SESSION} → {FIFO_PATH}")


def _stop_pipe_pane() -> None:
    """Detach tmux pipe-pane."""
    try:
        subprocess.run(
            ["tmux", "pipe-pane", "-t", TMUX_SESSION],
            capture_output=True, timeout=5,
        )
    except Exception:
        pass


# ---------------------------------------------------------------------------
# Bridge HTTP sender
# ---------------------------------------------------------------------------

def send_to_bridge(content: str, msg_type: str = "prose") -> bool:
    """Send message via Bridge HTTP API.

    msg_type: "prose" for real agent text, "status" for spinner/thinking.
    """
    payload = json.dumps(
        {
            "from": "manager",
            "to": "user",
            "content": content,
            "meta": {
                "source": "output_forwarder",
                "auto_capture": True,
                "type": msg_type,
            },
        },
        ensure_ascii=False,
    ).encode("utf-8")

    req = urllib.request.Request(
        f"{BRIDGE_URL}/send",
        data=payload,
        headers={"Content-Type": "application/json; charset=utf-8"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            return resp.status in (200, 201)
    except Exception as exc:
        _log(f"send failed: {exc}")
        return False


# ---------------------------------------------------------------------------
# PID management
# ---------------------------------------------------------------------------

def _write_pid() -> None:
    os.makedirs(PID_DIR, exist_ok=True)
    with open(PID_FILE, "w") as fh:
        fh.write(str(os.getpid()))


def _cleanup(*_args: object) -> None:
    _log("Shutting down...")
    _stop_pipe_pane()
    _remove_fifo()
    try:
        os.remove(PID_FILE)
    except OSError:
        pass
    sys.exit(0)


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def _log(msg: str) -> None:
    ts = time.strftime("%H:%M:%S")
    print(f"[forwarder {ts}] {msg}", flush=True)


# ---------------------------------------------------------------------------
# Main loop — hybrid: pipe-pane trigger + capture-pane content
# ---------------------------------------------------------------------------

def main() -> None:
    _write_pid()
    signal.signal(signal.SIGTERM, _cleanup)
    signal.signal(signal.SIGINT, _cleanup)

    _log(f"Started PID={os.getpid()} session={TMUX_SESSION}")

    # Setup FIFO and pipe-pane
    _create_fifo()
    _start_pipe_pane()

    # Initial capture-pane baseline
    prev_lines = capture_pane()
    prev_count = len(prev_lines)
    _log(f"Baseline: {prev_count} lines")

    last_status_sent: float = 0.0
    activity_detected: bool = False
    last_activity_time: float = 0.0

    _log(f"Hybrid mode: pipe-pane trigger + capture-pane content (debounce={FLUSH_DELAY}s)")

    while True:
        try:
            with open(FIFO_PATH, "r") as fifo:
                while True:
                    # Wait for pipe-pane data or debounce timeout
                    if activity_detected:
                        # Activity was detected — wait for silence
                        elapsed = time.time() - last_activity_time
                        remaining = max(0.0, FLUSH_DELAY - elapsed)
                        if remaining <= 0:
                            # Debounce expired — capture and process
                            curr_lines = capture_pane()
                            if curr_lines:
                                curr_count = len(curr_lines)
                                delta = find_delta(prev_lines, prev_count, curr_lines)
                                prev_lines = curr_lines
                                prev_count = curr_count

                                if delta:
                                    prose, has_spinner = extract_agent_text(delta)

                                    if has_spinner:
                                        now = time.time()
                                        if now - last_status_sent >= STATUS_COOLDOWN:
                                            send_to_bridge("typing", msg_type="status")
                                            last_status_sent = now
                                            _log("Sent status: typing")

                                    if prose and len(prose) >= MIN_PROSE_LEN:
                                        send_to_bridge(prose, msg_type="prose")
                                        _log(f"Sent prose: {len(prose)} chars")

                            activity_detected = False
                            continue

                        timeout = remaining
                    else:
                        # No activity — block until pipe-pane sends data
                        timeout = None

                    ready, _, _ = select.select([fifo], [], [], timeout)

                    if ready:
                        # Read and discard pipe-pane data (we only care about
                        # the event, not the content — capture-pane gives us
                        # clean rendered output)
                        data = fifo.read(4096)
                        if not data:
                            # EOF — writer disconnected
                            if activity_detected:
                                # Flush pending activity
                                curr_lines = capture_pane()
                                if curr_lines:
                                    curr_count = len(curr_lines)
                                    delta = find_delta(prev_lines, prev_count, curr_lines)
                                    prev_lines = curr_lines
                                    prev_count = curr_count

                                    if delta:
                                        prose, has_spinner = extract_agent_text(delta)
                                        if has_spinner:
                                            now = time.time()
                                            if now - last_status_sent >= STATUS_COOLDOWN:
                                                send_to_bridge("typing", msg_type="status")
                                                last_status_sent = now
                                                _log("Sent status: typing")
                                        if prose and len(prose) >= MIN_PROSE_LEN:
                                            send_to_bridge(prose, msg_type="prose")
                                            _log(f"Sent prose: {len(prose)} chars")

                                activity_detected = False
                            break

                        activity_detected = True
                        last_activity_time = time.time()

            # FIFO EOF — writer disconnected, wait briefly and reopen
            _log("FIFO EOF — writer disconnected, reopening...")
            time.sleep(1.0)

        except OSError as exc:
            _log(f"FIFO read error: {exc}, retrying in 2s...")
            time.sleep(2.0)
            _create_fifo()
            _start_pipe_pane()
            # Re-establish baseline after error
            prev_lines = capture_pane()
            prev_count = len(prev_lines)


if __name__ == "__main__":
    main()
