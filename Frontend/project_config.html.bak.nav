<!doctype html>
<html lang="de" data-theme="warm">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bridge – Projekt Konfigurator</title>
  <style>
    /* ─── Themes (identisch mit chat.html) ─── */
    html[data-theme="warm"]{
      --bg:#fbf8f1; --bgFlat:#fbf8f1;
      --sidebar:#c8bfa8; --sbThumb:#b8af98; --sbDark:#8a7f6a;
    }
    html[data-theme="light"]{
      --bg:#ffffff; --bgFlat:#ffffff;
      --sidebar:#d6e8f7; --sbThumb:#b8d4ed; --sbDark:#5a9ac7;
    }
    html[data-theme="rose"]{
      --bg:#fdf2f4; --bgFlat:#fdf2f4;
      --sidebar:#e8c4cc; --sbThumb:#d9adb7; --sbDark:#a3707e;
    }
    html[data-theme="dark"]{
      --bg:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);
      --bgFlat:#161e3a;
      --sidebar:#1e2a42; --sbThumb:#2d3f5e; --sbDark:#8aa4c8;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      background:var(--bg);
      font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
      color:#3d3d3a;
      overflow-y:auto;
    }
    html[data-theme="dark"] body{ color:#e7edf5; }

    /* ─── Top Bar ─── */
    .topBar{
      position:sticky; top:0; z-index:10;
      display:flex; align-items:center; justify-content:space-between;
      padding:12px 24px;
      background:color-mix(in srgb, var(--sidebar) 18%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      backdrop-filter:blur(12px);
    }
    .topBar__left{
      display:flex; align-items:center; gap:8px;
    }
    .topBar__logo{ height:28px; width:auto; }
    .topBar__leftText{ display:flex; flex-direction:column; gap:2px; }
    .topBar__back{
      background:none; border:none; cursor:pointer; color:var(--sbDark);
      padding:4px; border-radius:6px; display:flex; align-items:center;
    }
    .topBar__back:hover{ background:color-mix(in srgb, var(--sidebar) 30%, transparent); }
    .topBar__title{
      font-size:11px; font-weight:700; text-transform:uppercase;
      letter-spacing:.6px; color:var(--sbDark);
    }
    .topBar__sub{
      font-size:10px; color:#8f8f8f;
    }
    html[data-theme="dark"] .topBar__sub{ color:#6b7a8f; }
    .topBar__right{
      display:flex; align-items:center; gap:8px;
    }

    /* ─── Status Dots ─── */
    .statusDots{
      display:flex; align-items:center; gap:6px;
    }
    .statusDot{
      width:8px; height:8px; border-radius:50%;
      background:#ef4444;
    }
    .statusDot--live{ background:#22c55e; }
    .statusDot--connecting{ background:#f59e0b; }
    .statusDot--disconnected{ background:#ef4444; }
    .statusLabel{
      font-size:10px; font-weight:500; color:#8f8f8f;
    }
    html[data-theme="dark"] .statusLabel{ color:#6b7a8f; }

    /* ─── Layout: Single Column ─── */
    .configLayout{
      max-width:780px;
      margin:0 auto;
      padding:20px 24px;
      min-height:calc(100vh - 49px);
    }

    /* ─── Shared Form Styles ─── */
    .section{
      font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:#8f8f8f;
      padding:16px 0 6px; display:flex; align-items:center; gap:6px;
    }
    html[data-theme="dark"] .section{ color:#6b7a8f; }
    .section:first-child{ padding-top:0; }

    .fieldLabel{
      font-size:10px; font-weight:600; color:var(--sbDark);
      margin-bottom:3px; display:block;
    }
    .fieldGroup{ margin-bottom:10px; }

    /* Field Icons (inline with label) */
    .fieldIcon{
      width:12px; height:12px; display:inline-block; vertical-align:-1px;
      fill:none; stroke:var(--sbDark); stroke-width:2;
      stroke-linecap:round; stroke-linejoin:round; margin-right:3px;
    }

    /* Button Icons */
    .btnIcon{
      width:14px; height:14px; display:inline-block; vertical-align:-2px;
      fill:none; stroke:currentColor; stroke-width:2;
      stroke-linecap:round; stroke-linejoin:round; margin-right:4px;
    }

    /* Scan Results */
    .scanResults{ display:none; }
    .scanResults.visible{ display:block; }
    .scanItem{
      display:flex; align-items:center; gap:8px;
      padding:7px 10px; font-size:11px;
      border-radius:6px; margin-bottom:2px;
    }
    .scanItemIcon{
      width:14px; height:14px; flex-shrink:0;
      fill:none; stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round;
    }
    .scanItem--found .scanItemIcon{ stroke:#22c55e; }
    .scanItem--missing .scanItemIcon{ stroke:#ef4444; }
    .scanItemText{
      flex:1; font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
      color:#3d3d3a;
    }
    html[data-theme="dark"] .scanItemText{ color:#e7edf5; }
    .scanItemStatus{
      font-size:9px; font-weight:600; text-transform:uppercase;
      letter-spacing:.3px; color:#8f8f8f;
    }
    html[data-theme="dark"] .scanItemStatus{ color:#6b7a8f; }
    .scanItem--found .scanItemStatus{ color:#22c55e; }
    .scanItem--missing .scanItemStatus{ color:#ef4444; }

    /* Advanced Toggle */
    .advancedToggle{
      display:flex; align-items:center; gap:4px;
      background:none; border:none; cursor:pointer;
      font-size:11px; font-weight:600; color:#8f8f8f;
      font-family:inherit; padding:4px 0;
      transition:color .15s ease;
    }
    html[data-theme="dark"] .advancedToggle{ color:#6b7a8f; }
    .advancedToggle:hover{ color:var(--sbDark); }
    .advancedArrow{
      width:12px; height:12px;
      fill:none; stroke:currentColor; stroke-width:2;
      stroke-linecap:round; stroke-linejoin:round;
      transition:transform .2s ease;
    }
    .advancedToggle.open .advancedArrow{ transform:rotate(90deg); }
    .advancedPanel{
      display:none; padding-top:8px;
    }
    .advancedPanel.open{ display:block; }

    /* ─── Collapsible Card (Team Leader, Agent) ─── */
    .cardToggle{
      display:flex; align-items:center; gap:8px;
      width:100%; background:none; border:none; cursor:pointer;
      font-family:inherit; padding:10px 12px;
      border-radius:10px;
      transition:background .12s ease;
    }
    .cardToggle:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .cardToggle:hover{ background:rgba(255,255,255,.04); }
    .cardToggle__arrow{
      width:14px; height:14px; flex-shrink:0;
      fill:none; stroke:#8f8f8f; stroke-width:2;
      stroke-linecap:round; stroke-linejoin:round;
      transition:transform .2s ease;
    }
    html[data-theme="dark"] .cardToggle__arrow{ stroke:#6b7a8f; }
    .cardToggle.open .cardToggle__arrow{ transform:rotate(90deg); }
    .cardToggle__icon{
      width:18px; height:18px; flex-shrink:0;
      fill:none; stroke:var(--sbDark); stroke-width:1.8;
      stroke-linecap:round; stroke-linejoin:round;
    }
    .cardToggle__name{
      font-size:14px; font-weight:700; color:#3d3d3a; flex:1; text-align:left;
    }
    html[data-theme="dark"] .cardToggle__name{ color:#e7edf5; }
    .cardToggle__badge{
      font-size:9px; font-weight:600; text-transform:uppercase;
      letter-spacing:.3px; padding:2px 8px; border-radius:4px;
    }
    .cardToggle__badge--leader{
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      color:var(--sbDark);
    }
    .cardToggle__badge--active{
      background:rgba(34,197,94,.12); color:#16a34a;
      border:1px solid rgba(34,197,94,.25);
    }
    .cardBody{
      display:none;
      padding:4px 12px 12px 34px;
    }
    .cardBody.open{ display:block; }
    .fieldRow{
      display:flex; gap:10px;
    }
    .fieldRow > .fieldGroup{ flex:1; }

    input[type="text"],
    input[type="number"],
    textarea,
    select{
      width:100%;
      padding:8px 10px;
      border-radius:8px;
      border:1px solid rgba(0,0,0,.08);
      background:rgba(255,255,255,.7);
      font-size:12px; font-family:inherit;
      color:#3d3d3a;
      outline:none;
      transition:border-color .15s ease, box-shadow .15s ease;
    }
    html[data-theme="dark"] input[type="text"],
    html[data-theme="dark"] input[type="number"],
    html[data-theme="dark"] textarea,
    html[data-theme="dark"] select{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.08);
      color:#e7edf5;
    }
    input:focus, textarea:focus, select:focus{
      border-color:color-mix(in srgb, var(--sidebar) 60%, transparent);
      box-shadow:0 0 0 3px color-mix(in srgb, var(--sidebar) 12%, transparent);
    }
    textarea{ resize:vertical; min-height:60px; line-height:1.5; }
    select{ cursor:pointer; appearance:auto; }

    ::placeholder{ color:#8f8f8f; }
    html[data-theme="dark"] ::placeholder{ color:#6b7a8f; }

    /* ─── Buttons ─── */
    .btnRow{
      display:flex; gap:8px; margin-top:12px;
    }
    .btn{
      flex:1; padding:9px 16px; border-radius:8px;
      font-size:12px; font-weight:600; font-family:inherit;
      cursor:pointer; text-align:center;
      transition:all .15s ease;
    }
    .btn--secondary{
      background:transparent;
      border:1px solid color-mix(in srgb, var(--sidebar) 40%, transparent);
      color:var(--sbDark);
    }
    .btn--secondary:hover{
      background:color-mix(in srgb, var(--sidebar) 12%, transparent);
    }
    .btn--primary{
      background:var(--sbDark); color:#fff;
      border:1px solid var(--sbDark);
    }
    html[data-theme="dark"] .btn--primary{ color:#0f172a; }
    .btn--primary:hover{ filter:brightness(.9); }

    /* ─── Divider ─── */
    .divider{
      height:1px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      margin:14px 0;
    }


    /* Tools Checkbox Row */
    .toolsRow{
      display:flex; flex-wrap:wrap; gap:4px; margin-top:3px;
    }
    .toolChip{
      display:flex; align-items:center; gap:3px;
      padding:3px 8px; border-radius:5px;
      font-size:10px; font-weight:500;
      border:1px solid rgba(0,0,0,.08);
      background:transparent; color:#3d3d3a;
      cursor:pointer; user-select:none;
      transition:all .12s ease;
      font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
    }
    html[data-theme="dark"] .toolChip{
      border-color:rgba(255,255,255,.08);
      color:#e7edf5;
    }
    .toolChip.on{
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      border-color:color-mix(in srgb, var(--sidebar) 50%, transparent);
      color:var(--sbDark); font-weight:600;
    }

    /* ─── Add Agent Button ─── */
    .addAgent{
      display:flex; align-items:center; justify-content:center; gap:6px;
      padding:10px; border-radius:10px;
      border:1px dashed color-mix(in srgb, var(--sidebar) 35%, transparent);
      background:transparent; color:var(--sbDark);
      font-size:12px; font-weight:600; font-family:inherit;
      cursor:pointer; width:100%;
      transition:all .15s ease;
      margin-bottom:12px;
    }
    .addAgent:hover{
      background:color-mix(in srgb, var(--sidebar) 8%, transparent);
      border-color:color-mix(in srgb, var(--sidebar) 55%, transparent);
    }
    .addAgent svg{
      width:16px; height:16px;
      stroke:var(--sbDark); fill:none; stroke-width:2; stroke-linecap:round;
    }

    /* ─── Checkbox (Plan Approval) ─── */
    .checkRow{
      display:flex; align-items:center; gap:6px;
      margin-top:6px;
    }
    .checkRow input[type="checkbox"]{
      width:14px; height:14px; accent-color:var(--sbDark); cursor:pointer;
    }
    .checkRow label{
      font-size:11px; color:#3d3d3a; cursor:pointer;
    }
    html[data-theme="dark"] .checkRow label{ color:#e7edf5; }

    /* ─── Inline field pairs ─── */
    .fieldTriple{
      display:flex; gap:10px;
    }
    .fieldTriple > .fieldGroup:first-child{ flex:0 0 38%; }
    .fieldTriple > .fieldGroup:nth-child(2){ flex:1; }
    .fieldTriple > .fieldGroup:last-child{ flex:0 0 25%; }

    /* ─── Column sub-headers ─── */
    .colHeader{
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:14px;
    }
    .colHeader__title{
      font-size:14px; font-weight:700; color:#3d3d3a;
    }
    html[data-theme="dark"] .colHeader__title{ color:#e7edf5; }

    /* ─── Loading & Feedback ─── */
    .btn[disabled]{
      opacity:.55; cursor:not-allowed; pointer-events:none;
    }
    .feedback{
      font-size:11px; font-weight:600; padding:6px 12px;
      border-radius:6px; margin-top:8px; text-align:center;
    }
    .feedback--ok{
      background:rgba(34,197,94,.10); color:#16a34a;
      border:1px solid rgba(34,197,94,.25);
    }
    .feedback--error{
      background:rgba(239,68,68,.10); color:#dc2626;
      border:1px solid rgba(239,68,68,.20);
    }
    html[data-theme="warm"] .feedback--error{ color:#b91c1c; }
    html[data-theme="rose"] .feedback--error{ color:#be123c; }
    html[data-theme="dark"] .feedback--ok{ background:rgba(34,197,94,.15); color:#4ade80; border-color:rgba(34,197,94,.3); }
    html[data-theme="dark"] .feedback--error{ background:rgba(239,68,68,.15); color:#fca5a5; border-color:rgba(239,68,68,.3); }

    /* ─── Status dot pulse ─── */
    @keyframes pulse{ 0%,100%{ opacity:1; } 50%{ opacity:.4; } }
    .statusDot--connecting{ animation:pulse 1.5s ease infinite; }

    /* ─── Accessibility: Focus + Skip-Link ─── */
    *:focus-visible{
      outline:2px solid #3b82f6;
      outline-offset:2px;
    }
    .skipLink{
      position:fixed;
      top:-100%;
      left:16px;
      z-index:10000;
      padding:8px 16px;
      background:var(--bgFlat);
      color:var(--sbDark);
      border:2px solid #3b82f6;
      border-radius:8px;
      font-size:14px;
      text-decoration:none;
      transition:top .2s;
    }
    .skipLink:focus{
      top:8px;
    }

    /* ─── Responsive: Mobile (<768px) ─── */
    @media (max-width:767px){
      .configLayout{
        padding:16px 12px;
      }
      .topBar{
        padding:10px 12px;
      }
      .topBar__sub{
        display:none;
      }
      .fieldRow{
        flex-direction:column;
        gap:10px;
      }
      .fieldTriple{
        flex-direction:column;
        gap:10px;
      }
      .fieldTriple > .fieldGroup{
        flex:1 1 auto !important;
      }
      .cardBody{
        padding-left:12px;
      }
      .cardToggle__name{
        font-size:12px;
      }
      input[type="text"],
      input[type="number"],
      textarea,
      select{
        font-size:16px; /* prevent iOS zoom */
      }
    }
  </style>
</head>
<body>
  <a class="skipLink" href="#configLayout">Skip to content</a>

  <!-- ─── Top Bar ─── -->
  <header class="topBar" role="banner">
    <div class="topBar__left">
      <img class="topBar__logo" src="ace_logo.svg" alt="ACE Logo">
      <button class="topBar__back" aria-label="Back" onclick="if(history.length>1)history.back();else window.location.href='chat.html';">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
      <div class="topBar__leftText">
        <div class="topBar__title">Team Up</div>
        <div class="topBar__sub">Step 1: Define project · Step 2: Build team</div>
      </div>
    </div>
    <div class="topBar__right">
      <div class="statusDots" id="statusDots" aria-label="Connection status" aria-live="polite">
        <span class="statusDot statusDot--disconnected" id="statusDot"></span>
        <span class="statusLabel" id="statusLabel">Offline</span>
      </div>
    </div>
  </header>

  <main class="configLayout" id="configLayout">

    <!-- ═══ LINKE SPALTE: PROJEKT ═══ -->
    <div class="colLeft">
      <div class="colHeader">
        <div class="colHeader__title">Project</div>
      </div>

      <!-- Name -->
      <div class="fieldGroup">
        <label class="fieldLabel">
          <svg class="fieldIcon" viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/></svg>
          Project Name
        </label>
        <input type="text" id="projName" value="bridge-ide-demo" />
      </div>

      <!-- Path -->
      <div class="fieldGroup">
        <label class="fieldLabel">
          <svg class="fieldIcon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          Project Path
        </label>
        <input type="text" id="projPath" value="/home/leo/Desktop/CC" placeholder="/path/to/project" />
      </div>

      <!-- Buttons -->
      <div class="btnRow">
        <button class="btn btn--secondary" id="scanBtn" aria-label="Scan project path">
          <svg class="btnIcon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          Scan
        </button>
        <button class="btn btn--primary" id="createBtn" aria-label="Create project">
          <svg class="btnIcon" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
          Create
        </button>
      </div>

      <!-- Scan Results (hidden until scan) -->
      <div class="scanResults" id="scanResults" aria-live="polite" aria-label="Scan results">
        <div class="divider"></div>
        <div class="section">Scan Results</div>
        <div class="scanItem scanItem--found">
          <svg class="scanItemIcon" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="scanItemText">PROJECT.md</span>
          <span class="scanItemStatus">created</span>
        </div>
        <div class="scanItem scanItem--found">
          <svg class="scanItemIcon" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="scanItemText">Git repository</span>
          <span class="scanItemStatus">detected</span>
        </div>
        <div class="scanItem scanItem--found">
          <svg class="scanItemIcon" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="scanItemText">package.json</span>
          <span class="scanItemStatus">detected</span>
        </div>
        <div class="scanItem scanItem--missing">
          <svg class="scanItemIcon" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
          <span class="scanItemText">.claude/settings.json</span>
          <span class="scanItemStatus">not found</span>
        </div>
      </div>

      <!-- Advanced (collapsed) -->
      <div class="divider"></div>
      <button class="advancedToggle" id="advancedToggle" aria-expanded="false" aria-controls="advancedPanel">
        <svg class="advancedArrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        Advanced
      </button>
      <div class="advancedPanel" id="advancedPanel" role="region" aria-label="Advanced settings">
        <div class="fieldGroup">
          <label class="fieldLabel">Tags</label>
          <input type="text" placeholder="e.g. trading, ace, infra" />
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Notes</label>
          <textarea rows="3" placeholder="Goals, constraints, scope..."></textarea>
        </div>
      </div>

    </div>

    <!-- ═══ TEAM ═══ -->
    <div class="divider" style="margin-top:20px"></div>
    <div class="colHeader" style="margin-top:12px">
      <div class="colHeader__title">Team</div>
    </div>

    <!-- Team Leader (collapsible) -->
    <button class="cardToggle open" data-target="leaderBody" aria-expanded="true" aria-controls="leaderBody" aria-label="Toggle Team Leader settings">
      <svg class="cardToggle__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      <svg class="cardToggle__icon" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 12 0v1"/><path d="M16 3l2 2 4-4"/></svg>
      <span class="cardToggle__name">Team Leader</span>
      <span class="cardToggle__badge cardToggle__badge--leader">leader</span>
    </button>
    <div class="cardBody open" id="leaderBody" role="region" aria-label="Team Leader configuration">
      <div class="fieldRow">
        <div class="fieldGroup">
          <label class="fieldLabel">Model</label>
          <select data-field="model">
            <option value="opus">Opus 4.6</option>
            <option value="sonnet" selected>Sonnet 4.6</option>
            <option value="haiku">Haiku 4.5</option>
            <option value="opusplan">OpusPlan</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Name</label>
          <input type="text" data-field="name" value="teamlead" />
        </div>
      </div>
      <div class="fieldGroup">
        <label class="fieldLabel">Prompt</label>
        <textarea data-field="prompt" rows="3">Du koordinierst Agents, priorisierst Aufgaben, meldest STOP nur direkt an Leo. Keine Rundenbegrenzung.</textarea>
      </div>
      <div class="fieldRow">
        <div class="fieldGroup">
          <label class="fieldLabel">Permission</label>
          <select data-field="permission">
            <option value="default" selected>default</option>
            <option value="acceptEdits">acceptEdits</option>
            <option value="dontAsk">dontAsk</option>
            <option value="bypassPermissions">bypassPermissions</option>
            <option value="plan">plan (read-only)</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">MaxTurns</label>
          <input type="number" data-field="maxTurns" placeholder="unlimited" />
        </div>
      </div>
      <div class="checkRow">
        <input type="checkbox" id="planApproval" data-field="planApproval" checked />
        <label for="planApproval">Plan-Approval required</label>
      </div>
    </div>

    <!-- Agent A (collapsible) -->
    <button class="cardToggle" data-target="agentABody" aria-expanded="false" aria-controls="agentABody" aria-label="Toggle Agent A settings">
      <svg class="cardToggle__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      <svg class="cardToggle__icon" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 12 0v1"/></svg>
      <span class="cardToggle__name">Agent A</span>
      <span class="cardToggle__badge cardToggle__badge--active">active</span>
    </button>
    <div class="cardBody" id="agentABody" role="region" aria-label="Agent A configuration">
      <div class="fieldTriple">
        <div class="fieldGroup">
          <label class="fieldLabel">Model</label>
          <select data-field="model">
            <option value="opus">Opus 4.6</option>
            <option value="sonnet" selected>Sonnet 4.6</option>
            <option value="haiku">Haiku 4.5</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Position</label>
          <input type="text" data-field="position" value="Implementer" />
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Slot/ID</label>
          <input type="text" data-field="slot" value="agent_a" />
        </div>
      </div>
      <div class="fieldGroup">
        <label class="fieldLabel">Prompt</label>
        <textarea data-field="prompt" rows="2">Implementiere präzise. Keine UI-Entscheidungen ohne Spec. Liefere Diffs.</textarea>
      </div>
      <div class="fieldGroup">
        <label class="fieldLabel">Tools</label>
        <div class="toolsRow">
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Read</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Write</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Edit</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Glob</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Grep</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Bash</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebFetch</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebSearch</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Task</button>
        </div>
      </div>
      <div class="fieldRow">
        <div class="fieldGroup">
          <label class="fieldLabel">Permission</label>
          <select data-field="permission">
            <option value="default">default</option>
            <option value="acceptEdits" selected>acceptEdits</option>
            <option value="dontAsk">dontAsk</option>
            <option value="bypassPermissions">bypassPermissions</option>
            <option value="plan">plan</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Isolation</label>
          <select data-field="isolation">
            <option value="none" selected>none</option>
            <option value="worktree">worktree</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">MaxTurns</label>
          <input type="number" data-field="maxTurns" value="50" />
        </div>
      </div>
    </div>

    <!-- Agent B (collapsible) -->
    <button class="cardToggle" data-target="agentBBody" aria-expanded="false" aria-controls="agentBBody" aria-label="Toggle Agent B settings">
      <svg class="cardToggle__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      <svg class="cardToggle__icon" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 12 0v1"/></svg>
      <span class="cardToggle__name">Agent B</span>
      <span class="cardToggle__badge cardToggle__badge--active">active</span>
    </button>
    <div class="cardBody" id="agentBBody" role="region" aria-label="Agent B configuration">
      <div class="fieldTriple">
        <div class="fieldGroup">
          <label class="fieldLabel">Model</label>
          <select data-field="model">
            <option value="opus">Opus 4.6</option>
            <option value="sonnet" selected>Sonnet 4.6</option>
            <option value="haiku">Haiku 4.5</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Position</label>
          <input type="text" data-field="position" value="Reviewer" />
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Slot/ID</label>
          <input type="text" data-field="slot" value="agent_b" />
        </div>
      </div>
      <div class="fieldGroup">
        <label class="fieldLabel">Prompt</label>
        <textarea data-field="prompt" rows="2">Review. Finde Widersprüche. Gib konkrete Fixes. Keine Prosa.</textarea>
      </div>
      <div class="fieldGroup">
        <label class="fieldLabel">Tools</label>
        <div class="toolsRow">
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Read</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Write</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Edit</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Glob</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Grep</button>
          <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Bash</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebFetch</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebSearch</button>
          <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Task</button>
        </div>
      </div>
      <div class="fieldRow">
        <div class="fieldGroup">
          <label class="fieldLabel">Permission</label>
          <select data-field="permission">
            <option value="default" selected>default</option>
            <option value="acceptEdits">acceptEdits</option>
            <option value="dontAsk">dontAsk</option>
            <option value="bypassPermissions">bypassPermissions</option>
            <option value="plan">plan</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Isolation</label>
          <select data-field="isolation">
            <option value="none" selected>none</option>
            <option value="worktree">worktree</option>
          </select>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">MaxTurns</label>
          <input type="number" data-field="maxTurns" value="50" />
        </div>
      </div>
    </div>

    <!-- Add Agent -->
    <button class="addAgent" id="addAgentBtn" aria-label="Add new agent">
      <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
      Add Agent
    </button>

    <div class="btnRow" style="margin-top:8px">
      <button class="btn btn--secondary" id="exportBtn" aria-label="Export configuration">Export</button>
      <button class="btn btn--primary" id="startTeamBtn" aria-label="Start team">Start Team</button>
    </div>

  </main><!-- /configLayout -->

  <script>
    const root = document.documentElement;
    const API_BASE = 'http://127.0.0.1:9111';
    const API_SERVER = 'http://127.0.0.1:9222';

    /* ─── Theme (aus localStorage, gesetzt in chat.html) ─── */
    const stored = localStorage.getItem('bridge_theme');
    if(stored) root.setAttribute('data-theme', stored);

    /* ─── Refs ─── */
    const scanBtn = document.getElementById('scanBtn');
    const createBtn = document.getElementById('createBtn');
    const startTeamBtn = document.getElementById('startTeamBtn');
    const exportBtn = document.getElementById('exportBtn');
    const scanResultsEl = document.getElementById('scanResults');
    const statusDot = document.getElementById('statusDot');
    const statusLabel = document.getElementById('statusLabel');

    /* ─── Feedback helper ─── */
    function showFeedback(afterEl, type, text){
      const prev = afterEl.parentNode.querySelector('.feedback');
      if(prev) prev.remove();
      const div = document.createElement('div');
      div.className = 'feedback feedback--' + type;
      div.textContent = text;
      afterEl.parentNode.insertBefore(div, afterEl.nextSibling);
      setTimeout(() => div.remove(), 5000);
    }

    /* ─── SVG icon helpers ─── */
    const scanIconSvg = '<svg class="btnIcon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>';
    const createIconSvg = '<svg class="btnIcon" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>';

    /* ═══════════════════════════════════════════
       Task 2: Scan Button → GET /context
    ═══════════════════════════════════════════ */
    scanBtn.addEventListener('click', async () => {
      const path = document.getElementById('projPath').value.trim();
      if(!path) return;
      scanBtn.disabled = true;
      scanBtn.textContent = 'Scanning\u2026';
      try {
        const res = await fetch(API_SERVER + '/api/context/scan?project_path=' + encodeURIComponent(path));
        const data = await res.json();
        renderScanResults(data);
      } catch(e){
        console.error('Scan failed:', e);
        scanResultsEl.innerHTML = '<div class="divider"></div><div class="section">Scan Results</div>'
          + '<div class="scanItem scanItem--missing">'
          + '<svg class="scanItemIcon" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>'
          + '<span class="scanItemText">Server nicht erreichbar</span>'
          + '<span class="scanItemStatus">error</span></div>';
        scanResultsEl.classList.add('visible');
      } finally {
        scanBtn.disabled = false;
        scanBtn.innerHTML = scanIconSvg + ' Scan';
      }
    });

    function renderScanResults(data){
      const items = [];
      for(const engine of ['claude','codex']){
        if(!data[engine]) continue;
        for(const arr of Object.values(data[engine])){
          if(Array.isArray(arr)) arr.forEach(item => items.push(item));
        }
      }
      let html = '<div class="divider"></div><div class="section">Scan Results</div>';
      items.forEach(item => {
        const found = item.exists;
        const cls = found ? 'scanItem--found' : 'scanItem--missing';
        const icon = found
          ? '<polyline points="20 6 9 17 4 12"/>'
          : '<path d="M18 6L6 18M6 6l12 12"/>';
        const status = found ? (item.is_dir ? 'found (dir)' : 'found') : 'not found';
        const name = item.source || item.path.split('/').pop();
        html += '<div class="scanItem ' + cls + '">'
          + '<svg class="scanItemIcon" viewBox="0 0 24 24">' + icon + '</svg>'
          + '<span class="scanItemText">' + escHtml(name) + '</span>'
          + '<span class="scanItemStatus">' + status + '</span></div>';
      });
      scanResultsEl.innerHTML = html;
      scanResultsEl.classList.add('visible');
    }

    function escHtml(s){
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    /* ═══════════════════════════════════════════
       Task 3: Create Button → POST /projects/create
    ═══════════════════════════════════════════ */
    createBtn.addEventListener('click', async () => {
      const name = document.getElementById('projName').value.trim();
      const path = document.getElementById('projPath').value.trim();
      if(!name || !path) return;
      createBtn.disabled = true;
      createBtn.textContent = 'Creating\u2026';
      try {
        const res = await fetch(API_SERVER + '/api/projects/create', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ project_name: name, base_dir: path })
        });
        const data = await res.json();
        if(data.ok){
          showFeedback(createBtn.parentNode, 'ok',
            'Projekt erstellt: ' + data.project_path + ' (' + data.created.length + ' Dateien)');
        } else {
          showFeedback(createBtn.parentNode, 'error', data.error || 'Unbekannter Fehler');
        }
      } catch(e){
        console.error('Create failed:', e);
        showFeedback(createBtn.parentNode, 'error', 'Server nicht erreichbar');
      } finally {
        createBtn.disabled = false;
        createBtn.innerHTML = createIconSvg + ' Create';
      }
    });

    /* ═══════════════════════════════════════════
       Task 4: Start Team → POST /runtime/configure
    ═══════════════════════════════════════════ */
    function extractCardData(cardBody){
      const f = (sel) => { const el = cardBody.querySelector(sel); return el ? el.value : ''; };
      const model = f('[data-field="model"]');
      const position = f('[data-field="position"]');
      const slot = f('[data-field="slot"]');
      const name = f('[data-field="name"]');
      const prompt = f('[data-field="prompt"]');
      const permission = f('[data-field="permission"]');
      const isolation = f('[data-field="isolation"]');
      const maxTurns = f('[data-field="maxTurns"]');
      const planApproval = cardBody.querySelector('[data-field="planApproval"]');
      const tools = [];
      cardBody.querySelectorAll('.toolChip.on').forEach(chip => tools.push(chip.textContent.trim()));
      return {
        model, position, slot, name, prompt, permission, isolation, tools,
        maxTurns: maxTurns ? parseInt(maxTurns,10) || 0 : 0,
        planApproval: planApproval ? planApproval.checked : false
      };
    }

    function modelToEngine(model){
      if(['opus','sonnet','haiku','opusplan'].includes(model)) return 'claude';
      if(model === 'codex') return 'codex';
      if(model === 'gemini') return 'gemini';
      if(model === 'qwen') return 'qwen';
      return 'claude';
    }

    function collectTeamConfig(){
      const projectPath = document.getElementById('projPath').value.trim();
      const projectName = document.getElementById('projName').value.trim();

      const leader = extractCardData(document.getElementById('leaderBody'));
      const agents = [];
      document.querySelectorAll('.cardBody').forEach(body => {
        if(body.id === 'leaderBody') return;
        agents.push(extractCardData(body));
      });

      const config = {
        project_path: projectPath,
        project_name: projectName,
        team_lead_engine: modelToEngine(leader.model),
        team_lead_enabled: true,
        leader: leader,
        agents: agents
      };
      if(agents[0]){
        config.agent_a_engine = modelToEngine(agents[0].model);
        config.agent_a_position = agents[0].position;
      }
      if(agents[1]){
        config.agent_b_engine = modelToEngine(agents[1].model);
        config.agent_b_position = agents[1].position;
      }
      return config;
    }

    startTeamBtn.addEventListener('click', async () => {
      const config = collectTeamConfig();
      if(!config.project_path){
        showFeedback(startTeamBtn.parentNode, 'error', 'Project Path fehlt');
        return;
      }
      startTeamBtn.disabled = true;
      startTeamBtn.textContent = 'Starting\u2026';
      try {
        const res = await fetch(API_SERVER + '/api/runtime/configure', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify(config)
        });
        const data = await res.json();
        if(data.ok){
          const count = (data.started || []).length;
          showFeedback(startTeamBtn.parentNode, 'ok',
            'Team gestartet \u2014 ' + count + ' Agent' + (count !== 1 ? 's' : '') + ' aktiv');
        } else {
          showFeedback(startTeamBtn.parentNode, 'error', data.error || 'Konfiguration fehlgeschlagen');
        }
      } catch(e){
        console.error('Start team failed:', e);
        showFeedback(startTeamBtn.parentNode, 'error', 'Server nicht erreichbar');
      } finally {
        startTeamBtn.disabled = false;
        startTeamBtn.textContent = 'Start Team';
      }
    });

    /* ─── Export (JSON download) ─── */
    exportBtn.addEventListener('click', () => {
      const config = collectTeamConfig();
      const blob = new Blob([JSON.stringify(config, null, 2)], {type:'application/json'});
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = (config.project_name || 'team-config') + '.json';
      a.click();
      URL.revokeObjectURL(a.href);
    });

    /* ═══════════════════════════════════════════
       Task 5: Status Dots → GET /agents Polling
    ═══════════════════════════════════════════ */
    async function pollPlatformStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        const agents = (data.agents || []).filter(a => a.status !== 'disconnected');
        statusDot.className = 'statusDot';
        if(agents.length > 0){
          statusDot.classList.add('statusDot--live');
          statusLabel.textContent = agents.length + ' Agent' + (agents.length !== 1 ? 's' : '') + ' online';
        } else {
          statusDot.classList.add('statusDot--connecting');
          statusLabel.textContent = 'Keine Agents';
        }
      } catch(e){
        statusDot.className = 'statusDot statusDot--disconnected';
        statusLabel.textContent = 'Offline';
      }
    }

    pollPlatformStatus();
    setInterval(pollPlatformStatus, 10000);

    /* ─── Advanced Toggle ─── */
    document.getElementById('advancedToggle').addEventListener('click', () => {
      const tog = document.getElementById('advancedToggle');
      tog.classList.toggle('open');
      document.getElementById('advancedPanel').classList.toggle('open');
      tog.setAttribute('aria-expanded', tog.classList.contains('open'));
    });

    /* ─── Card Toggle (collapsible) ─── */
    document.querySelectorAll('.cardToggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = document.getElementById(btn.dataset.target);
        btn.classList.toggle('open');
        target.classList.toggle('open');
        btn.setAttribute('aria-expanded', btn.classList.contains('open'));
      });
    });

    /* ─── Agent hinzufügen ─── */
    let agentCount = 2;
    document.getElementById('addAgentBtn').addEventListener('click', () => {
      agentCount++;
      const letter = String.fromCharCode(64 + agentCount);
      const id = 'agent_' + letter.toLowerCase();
      const bodyId = id + 'Body';

      const toggle = document.createElement('button');
      toggle.className = 'cardToggle';
      toggle.dataset.target = bodyId;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-controls', bodyId);
      toggle.innerHTML = `
        <svg class="cardToggle__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        <svg class="cardToggle__icon" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 12 0v1"/></svg>
        <span class="cardToggle__name">Agent ${letter}</span>
        <span class="cardToggle__badge cardToggle__badge--active">active</span>
      `;
      toggle.addEventListener('click', () => {
        const target = document.getElementById(toggle.dataset.target);
        toggle.classList.toggle('open');
        target.classList.toggle('open');
        toggle.setAttribute('aria-expanded', toggle.classList.contains('open'));
      });

      const body = document.createElement('div');
      body.className = 'cardBody';
      body.id = bodyId;
      body.setAttribute('role', 'region');
      body.setAttribute('aria-label', `Agent ${letter} configuration`);
      body.innerHTML = `
        <div class="fieldTriple">
          <div class="fieldGroup">
            <label class="fieldLabel">Model</label>
            <select data-field="model">
              <option value="opus">Opus 4.6</option>
              <option value="sonnet" selected>Sonnet 4.6</option>
              <option value="haiku">Haiku 4.5</option>
            </select>
          </div>
          <div class="fieldGroup">
            <label class="fieldLabel">Position</label>
            <input type="text" data-field="position" placeholder="e.g. Tester" />
          </div>
          <div class="fieldGroup">
            <label class="fieldLabel">Slot/ID</label>
            <input type="text" data-field="slot" value="${id}" />
          </div>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Prompt</label>
          <textarea data-field="prompt" rows="2" placeholder="Agent instructions..."></textarea>
        </div>
        <div class="fieldGroup">
          <label class="fieldLabel">Tools</label>
          <div class="toolsRow">
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Read</button>
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Write</button>
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Edit</button>
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Glob</button>
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Grep</button>
            <button class="toolChip on" aria-pressed="true" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Bash</button>
            <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebFetch</button>
            <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">WebSearch</button>
            <button class="toolChip" aria-pressed="false" onclick="this.classList.toggle('on');this.setAttribute('aria-pressed',this.classList.contains('on'))">Task</button>
          </div>
        </div>
        <div class="fieldRow">
          <div class="fieldGroup">
            <label class="fieldLabel">Permission</label>
            <select data-field="permission">
              <option value="default" selected>default</option>
              <option value="acceptEdits">acceptEdits</option>
              <option value="dontAsk">dontAsk</option>
              <option value="bypassPermissions">bypassPermissions</option>
              <option value="plan">plan</option>
            </select>
          </div>
          <div class="fieldGroup">
            <label class="fieldLabel">Isolation</label>
            <select data-field="isolation">
              <option value="none" selected>none</option>
              <option value="worktree">worktree</option>
            </select>
          </div>
          <div class="fieldGroup">
            <label class="fieldLabel">MaxTurns</label>
            <input type="number" data-field="maxTurns" value="50" />
          </div>
        </div>
      `;

      const addBtn = document.getElementById('addAgentBtn');
      addBtn.parentNode.insertBefore(toggle, addBtn);
      addBtn.parentNode.insertBefore(body, addBtn);
    });
  </script>
</body>
</html>
