        { type:'tool', agent:'Agent A', data:['Read', 'src/routes/v1/users.ts'] },
        { type:'message', agent:'Leader', to:'Agent B', text:'Review UserController after Agent A finishes', detail:'Check error handling + response format consistency' },
        { type:'typing', agent:'Agent B', dur:1200 },
