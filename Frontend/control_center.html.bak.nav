        { type:'message', agent:'Leader', to:'Agent A', text:'Approved. Move on to /v1/projects next', detail:'Same pattern — extract to ProjectController' },
      ],
      [
        { type:'task', agent:'Leader', data:['Database migration plan', false] },
        { type:'message', agent:'Leader', to:'Agent A', text:'Create migration for sessions table', detail:'Add columns: refresh_token, device_fingerprint, last_active' },
        { type:'message', agent:'Leader', to:'Agent B', text:'Update ORM models after migration runs', detail:'Sync Session model with new schema' },
        { type:'typing', agent:'Agent A', dur:1800 },
        { type:'message', agent:'Agent A', to:'Leader', text:'Creating migration file', detail:'Using knex migrate:make add_session_fields' },
        { type:'tool', agent:'Agent A', data:['Bash', 'npx knex migrate:make add_session_fields'] },
        { type:'tool', agent:'Agent A', data:['Write', 'migrations/20260222_add_session_fields.ts'] },
        { type:'tool', agent:'Agent A', data:['Bash', 'npx knex migrate:latest --env test'] },
        { type:'task', agent:'Agent A', data:['Sessions table migration', true] },
        { type:'message', agent:'Agent A', to:'Agent B', text:'Migration applied successfully', detail:'3 columns added, index on refresh_token created' },
        { type:'typing', agent:'Agent B', dur:1500 },
        { type:'tool', agent:'Agent B', data:['Read', 'src/models/Session.ts'] },
        { type:'tool', agent:'Agent B', data:['Edit', 'src/models/Session.ts — added new fields + types'] },
        { type:'tool', agent:'Agent B', data:['Bash', 'npm run typecheck'] },
        { type:'message', agent:'Agent B', to:'Leader', text:'Session model updated, types clean', detail:'Added refresh_token: string, device_fingerprint: string, last_active: Date' },
        { type:'task', agent:'Agent B', data:['Update Session ORM model', true] },
        { type:'message', agent:'Leader', to:'Agent A', text:'Write seed data for testing sessions', detail:'10 mock sessions with varied devices' },
        { type:'tool', agent:'Agent A', data:['Write', 'seeds/sessions.ts — 10 mock records'] },
        { type:'tool', agent:'Agent A', data:['Bash', 'npx knex seed:run --specific=sessions.ts'] },
        { type:'task', agent:'Agent A', data:['Seed test session data', true] },
        { type:'message', agent:'Agent A', to:'Leader', text:'Seeds planted, test DB ready', detail:'10 sessions across 4 devices' },
        { type:'message', agent:'Leader', to:'Agent A', text:'Excellent. Migration phase complete.', detail:'Moving to integration tests next' },
        { type:'task', agent:'Leader', data:['Database migration complete', true] },
      ],
    ];

    let dashScenarioIdx = 0;
    let dashEventIdx = 0;

    function dashProcessEvent(evt){
      switch(evt.type){
        case 'status': dashHandleStatus(evt.agent, evt.data); break;
        case 'typing': dashHandleTyping(evt.agent, evt.dur); break;
        case 'message': dashHandleMessage(evt.agent, evt.to, evt.text, evt.detail); break;
        case 'tool': dashHandleTool(evt.agent, evt.data[0], evt.data[1]); break;
        case 'task': dashHandleTask(evt.agent, evt.data[0], evt.data[1]); break;
      }
    }

    function dashScheduleNext(){
      const scenario = dashScenarios[dashScenarioIdx];
      if(dashEventIdx >= scenario.length){
        dashScenarioIdx = (dashScenarioIdx + 1) % dashScenarios.length;
        dashEventIdx = 0;
        setTimeout(dashScheduleNext, 4000);
        return;
      }
      const evt = scenario[dashEventIdx];
      dashProcessEvent(evt);
      dashEventIdx++;
      const base = evt.type === 'typing' ? 800 : 1500;
      const jitter = Math.random() * 2500;
      setTimeout(dashScheduleNext, base + jitter);
    }

