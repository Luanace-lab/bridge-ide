    let taskSelectedTeam = 'perf-opt';
    let taskActiveFilter = 'all';
    let taskExpandedId = null;

    /* Task Helpers */
    function taskEscHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function taskFormatUptime(startMs){
      if(!startMs) return '\u2014';
      const diff = Math.floor((Date.now() - startMs) / 1000);
      const h = Math.floor(diff / 3600);
      const m = Math.floor((diff % 3600) / 60);
      if(h > 0) return h + 'h ' + m + 'm';
      return m + 'm';
    }

    function taskFormatTimestamp(ms){
      if(!ms) return '\u2014';
      const d = new Date(ms);
      return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
    }

    function getTeamStats(teamKey){
      const t = taskTeams[teamKey];
      const total = t.tasks.length;
      const completed = t.tasks.filter(tk => tk.status === 'completed').length;
      const active = t.tasks.filter(tk => tk.status === 'in_progress' || tk.status === 'active').length;
      return { total, completed, active, pct: total > 0 ? Math.round(completed / total * 100) : 0 };
    }

    function getAllTaskStats(){
      let total=0, completed=0, active=0, continuous=0;
      Object.keys(taskTeams).forEach(k => {
        const t = taskTeams[k];
        total += t.tasks.length;
        completed += t.tasks.filter(tk => tk.status === 'completed').length;
        active += t.tasks.filter(tk => tk.status === 'in_progress' || tk.status === 'active').length;
        continuous += t.tasks.filter(tk => tk.type === 'continuous' && tk.status === 'active').length;
      });
      return { total, completed, active, continuous, teams:Object.keys(taskTeams).length };
    }

    /* Render: Team Panel */
    function renderTeamPanel(){
      const container = document.getElementById('teamList');
      let html = '';
      Object.keys(taskTeams).forEach(key => {
        const t = taskTeams[key];
        const stats = getTeamStats(key);
        const isSelected = key === taskSelectedTeam;
        const isOpen = isSelected;
        html += '<div class="teamCard' + (isSelected ? ' selected' : '') + '" data-team="' + key + '">';
        html += '<button class="teamCard__toggle' + (isOpen ? ' open' : '') + '" data-team="' + key + '">';
        html += '<svg class="teamCard__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>';
        html += '<span class="teamCard__colorDot" style="background:' + t.color + '"></span>';
        html += '<span class="teamCard__name">' + taskEscHtml(t.name) + '</span>';
        html += '<span class="teamCard__count">' + stats.completed + '/' + stats.total + '</span>';
        html += '</button>';
        html += '<div class="teamCard__info">';
        html += '<span>' + t.agents.length + ' agents</span>';
        html += '<span>' + stats.completed + '/' + stats.total + ' tasks</span>';
        html += '<div class="teamCard__progress"><div class="teamCard__progressFill" style="width:' + stats.pct + '%;background:' + t.color + '"></div></div>';
        html += '</div>';
        html += '<div class="teamCard__body' + (isOpen ? ' open' : '') + '">';
        t.agents.forEach(a => {
          const sColor = a.status === 'active' ? '#22c55e' : a.status === 'idle' ? '#f59e0b' : '#ef4444';
          html += '<div class="teamAgent">';
          html += '<span class="teamAgent__dot" style="background:' + a.color + '"></span>';
          html += '<span class="teamAgent__name">' + taskEscHtml(a.name) + '</span>';
          html += '<span class="teamAgent__task">' + taskEscHtml(a.task) + '</span>';
          html += '<span class="teamAgent__status" style="background:' + sColor + '"></span>';
          html += '</div>';
        });
        html += '</div>';
        html += '</div>';
      });
      html += '<button class="addTeam" onclick="window.location.href=\'project_config.html\'"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>New Team</button>';
      container.innerHTML = html;
      container.querySelectorAll('.teamCard__toggle').forEach(btn => {
        btn.addEventListener('click', () => { selectTeam(btn.dataset.team); });
      });
    }

    function selectTeam(teamKey){
      taskSelectedTeam = teamKey;
      taskExpandedId = null;
      renderTeamPanel();
      renderTaskBoard();
    }

    /* Render: Task Board */
    function renderTaskBoard(){
      const t = taskTeams[taskSelectedTeam];
      document.getElementById('boardTeamName').textContent = t.name;
      document.getElementById('boardAgentCount').textContent = t.agents.length + ' agents';

      let filtered = t.tasks;
      if(taskActiveFilter === 'pending'){
        filtered = filtered.filter(tk => tk.status === 'pending');
      } else if(taskActiveFilter === 'active'){
        filtered = filtered.filter(tk => tk.status === 'in_progress' || tk.status === 'active');
      } else if(taskActiveFilter === 'completed'){
        filtered = filtered.filter(tk => tk.status === 'completed' || tk.status === 'stopped');
      }

      const container = document.getElementById('taskList');
      let html = '';

      filtered.forEach((task, idx) => {
        const isCompleted = task.status === 'completed';
        const isExpanded = taskExpandedId === (taskSelectedTeam + '-' + task.id);

        html += '<div class="taskRow' + (isCompleted ? ' completed' : '') + '" style="animation-delay:' + (idx * 0.05) + 's">';
        html += '<div class="taskRow__main" data-taskid="' + task.id + '" role="button" tabindex="0" aria-expanded="' + isExpanded + '" aria-label="Task #' + task.id + ': ' + taskEscHtml(task.subject) + '">';
        html += '<span class="taskRow__priorityDot" style="background:' + PRIORITY_COLORS[task.priority] + '" title="' + task.priority + '"></span>';
        html += '<span class="taskRow__id">#' + task.id + '</span>';
        html += '<span class="taskRow__subject">' + taskEscHtml(task.subject) + '</span>';

        const typeClass = task.type === 'one-shot' ? 'typeBadge--oneshot' : 'typeBadge--continuous';
        const typeLabel = task.type === 'one-shot' ? 'ONE-SHOT' : 'CONTINUOUS';
        html += '<span class="typeBadge ' + typeClass + '">' + typeLabel + '</span>';

        const statusClass = 'statusBadge--' + task.status.replace('-','_');
        html += '<span class="statusBadge ' + statusClass + '">';
        if(task.status === 'active') html += '<span class="statusBadge__pulse"></span>';
        html += task.status.replace('_',' ');
        html += '</span>';

        if(task.type === 'continuous' && task.uptime && task.status === 'active'){
          html += '<span class="uptimeCounter">' + taskFormatUptime(task.uptime) + '</span>';
        }

        if(task.owner){
          const ownerColor = AGENT_COLORS[task.owner] || '#8f8f8f';
          html += '<span class="ownerChip"><span class="ownerChip__dot" style="background:' + ownerColor + '"></span>' + taskEscHtml(task.owner) + '</span>';
        }

        if(task.blockedBy.length > 0){
          html += '<span class="depInfo">blocked by #' + task.blockedBy.join(', #') + '</span>';
        } else if(task.blocks.length > 0){
          html += '<span class="depInfo">blocks #' + task.blocks.join(', #') + '</span>';
        }

        html += '</div>'; // /main

        // Detail accordion
        html += '<div class="taskRow__detail' + (isExpanded ? ' open' : '') + '">';
        html += '<div class="detailSection"><div class="detailSection__label">Description</div><div class="detailSection__text">' + taskEscHtml(task.description) + '</div></div>';

        if(task.blockedBy.length > 0 || task.blocks.length > 0){
          html += '<div class="detailSection"><div class="detailSection__label">Dependencies</div><div class="depGraph">';
          task.blockedBy.forEach(bid => {
            html += '<span class="depGraph__item"><span class="depGraph__id depGraph__id--blocker">#' + bid + '</span><span class="depGraph__arrow"> &rarr; </span><span class="depGraph__id">#' + task.id + '</span></span>';
          });
          task.blocks.forEach(bid => {
            html += '<span class="depGraph__item"><span class="depGraph__id">#' + task.id + '</span><span class="depGraph__arrow"> &rarr; </span><span class="depGraph__id depGraph__id--dependent">#' + bid + '</span></span>';
          });
          html += '</div></div>';
        }

        if(task.tags.length > 0){
          html += '<div class="detailSection"><div class="detailSection__label">Tags</div><div class="tagChips">';
          task.tags.forEach(tag => { html += '<span class="tagChip">' + taskEscHtml(tag) + '</span>'; });
          html += '</div></div>';
        }

        html += '<div class="detailSection"><div class="detailSection__label">Timeline</div><div class="timestamps">';
        html += '<span>Created: <b>' + taskFormatTimestamp(task.createdAt) + '</b></span>';
        if(task.status === 'in_progress' || task.status === 'active'){
          html += '<span>Started: <b>' + taskFormatTimestamp(task.createdAt + 300000) + '</b></span>';
        }
        if(task.completedAt) html += '<span>Completed: <b>' + taskFormatTimestamp(task.completedAt) + '</b></span>';
        html += '</div></div>';

        if(task.type === 'continuous'){
          html += '<div class="detailSection">';
          if(task.uptime && task.status === 'active') html += '<div class="detailSection__label">Uptime: ' + taskFormatUptime(task.uptime) + '</div>';
          html += '<div class="continuousControls">';
          if(task.status === 'active'){
            html += '<button class="ctrlBtn ctrlBtn--pause">Pause</button>';
            html += '<button class="ctrlBtn ctrlBtn--stop">Stop</button>';
          } else if(task.status === 'paused'){
            html += '<button class="ctrlBtn ctrlBtn--resume">Resume</button>';
            html += '<button class="ctrlBtn ctrlBtn--stop">Stop</button>';
          } else if(task.status === 'stopped'){
            html += '<button class="ctrlBtn ctrlBtn--resume">Restart</button>';
          }
          html += '</div></div>';
        }

        html += '</div>'; // /detail
        html += '</div>'; // /taskRow
      });

      container.innerHTML = html;

      container.querySelectorAll('.taskRow__main').forEach(main => {
        function toggleTask(){
          const tid = taskSelectedTeam + '-' + main.dataset.taskid;
          taskExpandedId = (taskExpandedId === tid) ? null : tid;
          renderTaskBoard();
        }
        main.addEventListener('click', toggleTask);
        main.addEventListener('keydown', (e) => {
          if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); toggleTask(); }
        });
      });
    }

    /* Combined Metrics Update */
    function updateAllMetrics(){
      const s = getAllTaskStats();
      document.getElementById('metricTasksCompleted').textContent = s.completed;
      document.getElementById('metricTasksOf').textContent = '/' + s.total;
      document.getElementById('metricTasksProgress').style.width = (s.total > 0 ? Math.round(s.completed / s.total * 100) : 0) + '%';
      document.getElementById('metricContinuous').textContent = s.continuous;
      document.getElementById('metricAgents').textContent = Object.values(taskTeams).reduce((sum, t) => sum + t.agents.length, 0);
      // Top bar stats
      document.getElementById('topTotal').textContent = s.total;
      document.getElementById('topActive').textContent = s.active;
      document.getElementById('topCompleted').textContent = s.completed;
    }

    /* Filter Chips */
    document.getElementById('filterChips').addEventListener('click', (e) => {
      const chip = e.target.closest('.filterChip');
      if(!chip) return;
      taskActiveFilter = chip.dataset.filter;
      document.querySelectorAll('.filterChip').forEach(c => {
        const isActive = c.dataset.filter === taskActiveFilter;
        c.classList.toggle('active', isActive);
        c.setAttribute('aria-pressed', isActive);
      });
      renderTaskBoard();
    });

    /* Task DemoEngine (transitions) */
    const taskTransitions = [
      { team:'perf-opt', taskId:'1', field:'status', from:'in_progress', to:'completed' },
      { team:'perf-opt', taskId:'3', field:'status', from:'pending', to:'in_progress' },
      { team:'perf-opt', taskId:'3', field:'blockedBy', from:['1'], to:[] },
      { team:'perf-opt', taskId:'8', field:'owner', from:null, to:'Agent B' },
      { team:'perf-opt', taskId:'8', field:'status', from:'pending', to:'in_progress' },
      { team:'perf-opt', taskId:'5', field:'status', from:'paused', to:'active' },
      { team:'perf-opt', taskId:'5', field:'uptime', from:null, to:Date.now() },
      { team:'perf-opt', taskId:'6', field:'status', from:'in_progress', to:'completed' },
      { team:'e2e-live', taskId:'1', field:'status', from:'in_progress', to:'completed' },
      { team:'e2e-live', taskId:'3', field:'status', from:'pending', to:'in_progress' },
      { team:'e2e-live', taskId:'3', field:'blockedBy', from:['1'], to:[] },
      { team:'e2e-live', taskId:'6', field:'status', from:'stopped', to:'active' },
      { team:'e2e-live', taskId:'6', field:'uptime', from:null, to:Date.now() },
      { team:'api-build', taskId:'3', field:'status', from:'in_progress', to:'completed' },
      { team:'api-build', taskId:'5', field:'owner', from:null, to:'Agent A' },
      { team:'api-build', taskId:'5', field:'status', from:'pending', to:'in_progress' },
    ];

    let taskTransitionIdx = 0;
    let taskOriginalData = null;

    function taskCaptureOriginal(){
      taskOriginalData = JSON.parse(JSON.stringify(taskTeams));
    }
    function taskResetDemoData(){
      const restored = JSON.parse(JSON.stringify(taskOriginalData));
      Object.keys(restored).forEach(k => {
        taskTeams[k].tasks = restored[k].tasks;
        taskTeams[k].agents = restored[k].agents;
      });
    }

    function taskApplyTransition(){
      if(taskTransitionIdx >= taskTransitions.length){
        taskTransitionIdx = 0;
        taskResetDemoData();
        renderTeamPanel();
        renderTaskBoard();
        updateAllMetrics();
        return;
      }
      const tr = taskTransitions[taskTransitionIdx];
      const team = taskTeams[tr.team];
      if(!team){ taskTransitionIdx++; return; }
      const task = team.tasks.find(t => t.id === tr.taskId);
      if(!task){ taskTransitionIdx++; return; }
      const current = task[tr.field];
      if(JSON.stringify(current) === JSON.stringify(tr.from)){
        task[tr.field] = tr.to;
        if(tr.field === 'status' && tr.to === 'completed') task.completedAt = Date.now();
      }
      taskTransitionIdx++;
      renderTeamPanel();
      renderTaskBoard();
      updateAllMetrics();
    }

    /* ═══════════════════════════════════════════
       LIVE BACKEND — WebSocket + Polling
    ═══════════════════════════════════════════ */
    let historyRenderedIds = new Set();

    function connectWebSocket(){
      try {
        ws = new WebSocket(WS_URL);
      } catch(e){ return; }
      ws.onopen = () => {
        wsRetry = 1000;
        console.log('[CC] WebSocket connected');
      };
      ws.onmessage = (e) => {
        try {
          const data = JSON.parse(e.data);
          if(data.type === 'message' && data.message){
            handleLiveMessage(data.message);
          } else if(data.type === 'agent_status'){
            pollAgentStatus();
          } else if(data.type === 'activity' && data.activity){
            const a = data.activity;
            dashAddFeedEntry('tool', agentDisplayName(a.agent_id),
              a.action + (a.target ? ' ' + a.target : ''), a.description || '');
          }
        } catch(err){ console.error('[CC] WS parse error:', err); }
      };
      ws.onclose = () => {
        setTimeout(connectWebSocket, wsRetry);
        wsRetry = Math.min(wsRetry * 2, 30000);
      };
      ws.onerror = () => {};
    }

    function handleLiveMessage(msg){
      if(msg.id && historyRenderedIds.has(msg.id)) return;
      if(msg.id) historyRenderedIds.add(msg.id);
      const from = agentDisplayName(msg.from);
      const to = agentDisplayName(msg.to);
      const text = (msg.content || '').substring(0, 120);
      const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
      dashAddFeedEntry('message', from, text, detail);

      const pathMap = {
        'Leader-Agent A':'pathLA', 'Agent A-Leader':'pathLA',
        'Leader-Agent B':'pathLB', 'Agent B-Leader':'pathLB',
        'Agent A-Agent B':'pathAB', 'Agent B-Agent A':'pathAB',
      };
      const pathId = pathMap[from + '-' + to];
      if(pathId) dashSendPacket(pathId, dashAgentColor(from));

      if(dashSparkData[from]){
        const d = dashSparkData[from];
        if(d.length > 0) d[d.length - 1] += 2;
      }

      if(dashAgentStats[from]){
        dashAgentStats[from].msgs++;
        dashUpdateAgentStats(from);
      }
    }

    async function pollAgentStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        const agents = data.agents || [];
        const active = agents.filter(a => a.status !== 'disconnected');

        document.getElementById('metricAgents').textContent = active.length;

        const dotMap = { teamlead:'dashStatusL', lead:'dashStatusL',
          claude_a:'dashStatusA', agent_a:'dashStatusA',
          claude_b:'dashStatusB', agent_b:'dashStatusB' };
        agents.forEach(a => {
          const dotId = dotMap[a.agent_id];
          if(!dotId) return;
          const color = a.status === 'live' ? '#22c55e' : a.status === 'connecting' ? '#f59e0b' : '#ef4444';
          const el = document.getElementById(dotId);
          if(el) el.setAttribute('fill', color);
        });

        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          const dot = topBarDots[0];
          const label = document.querySelector('.topBar .statusLabel');
          dot.className = 'statusDot';
          if(active.length > 0){
            dot.classList.add('statusDot--live');
            if(label) label.textContent = active.length + ' online';
          } else {
            dot.classList.add('statusDot--connecting');
            if(label) label.textContent = 'Keine Agents';
          }
        }
      } catch(e){
        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          topBarDots[0].className = 'statusDot statusDot--disconnected';
          const label = document.querySelector('.topBar .statusLabel');
          if(label) label.textContent = 'Offline';
        }
      }
    }

    async function loadHistory(){
      try {
        const res = await fetch(API_BASE + '/history?limit=50');
        const data = await res.json();
        const msgs = data.messages || [];
        msgs.forEach(msg => {
          if(msg.id) historyRenderedIds.add(msg.id);
          const from = agentDisplayName(msg.from);
          const to = agentDisplayName(msg.to);
          const text = (msg.content || '').substring(0, 120);
          const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
          dashAddFeedEntry('message', from, text, detail);
        });
        return true;
      } catch(e){
        return false;
      }
    }

    async function tryLiveMode(){
      try {
        const res = await fetch(API_BASE + '/agents', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return false;
        liveMode = true;
        await loadHistory();
        connectWebSocket();
        pollAgentStatus();
        setInterval(pollAgentStatus, 5000);
        console.log('[CC] Live mode active');
        return true;
      } catch(e){
        return false;
      }
    }

    /* ═══════════════════════════════════════════
       INIT — Start Both Engines
    ═══════════════════════════════════════════ */
    taskCaptureOriginal();
    renderTeamPanel();
    renderTaskBoard();
    updateAllMetrics();

    // Try live backend; fall back to demo if offline
    tryLiveMode().then(live => {
      if(!live){
        console.log('[CC] Backend offline — using demo scenarios');
        setTimeout(dashScheduleNext, 1200);
      }
    });

    // Task DemoEngine — transitions every 5-8s (always runs, independent of live mode)
    function taskScheduleTransition(){
      const delay = 5000 + Math.random() * 3000;
      setTimeout(() => {
        taskApplyTransition();
        taskScheduleTransition();
      }, delay);
    }
    setTimeout(taskScheduleTransition, 3000);

    // Uptime refresh for continuous tasks every 30s
    setInterval(() => { renderTaskBoard(); }, 30000);

  </script>
</body>
</html>
