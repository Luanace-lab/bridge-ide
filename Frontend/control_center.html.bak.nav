      ],
      [
        { type:'task', agent:'Leader', data:['API endpoint refactor', false] },
        { type:'message', agent:'Leader', to:'Agent A', text:'Refactor /v1/users to controller pattern', detail:'Extract handler logic from routes into UserController' },
        { type:'typing', agent:'Agent A', dur:1500 },
