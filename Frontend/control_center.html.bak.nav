        { type:'tool', agent:'Agent A', data:['Bash', 'npm test'] },
        { type:'message', agent:'Agent A', to:'Agent B', text:'Fixed — zod schema added for all mutations', detail:'Revalidated with npm test: 12/12 passing' },
