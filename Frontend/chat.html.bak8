<!doctype html>
<html lang="de" data-theme="warm">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bridge – Chat Layout</title>

  <style>
    /* Warm — Original Creme */
    html[data-theme="warm"]{
      --bg:#fbf8f1; --bgFlat:#fbf8f1;
      --sidebar: #c8bfa8;
      --sbThumb: #b8af98;
      --sbDark: #8a7f6a;
    }

    /* Light — ACE Weiss + Babyblau Sidebar */
    html[data-theme="light"]{
      --bg:#ffffff; --bgFlat:#ffffff;
      --sidebar:#d6e8f7;
      --sbThumb:#b8d4ed;
      --sbDark: #5a9ac7;
    }

    /* Rose — Sanftes Rosa */
    html[data-theme="rose"]{
      --bg:#fdf2f4; --bgFlat:#fdf2f4;
      --sidebar:#e8c4cc;
      --sbThumb:#d9adb7;
      --sbDark: #a3707e;
    }

    /* Dark — ACE gradient-universe + dunkle Sidebar */
    html[data-theme="dark"]{
      --bg: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
      --bgFlat:#161e3a;
      --sidebar:#1e2a42;
      --sbThumb:#2d3f5e;
      --sbDark: #8aa4c8;
    }

    :root{ --sw:14%; --dp:57%; }

    *{ margin:0; padding:0; box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      background:var(--bg);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    /* Theme-Switcher oben rechts */
    /* Settings Popup (oeffnet sich ueber Zahnrad) */
    .settingsPopup{
      position:absolute;
      bottom:calc(100% + 8px);
      right:0;
      min-width:140px;
      background:rgba(255,255,255,.85);
      backdrop-filter:blur(10px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:10px;
      padding:6px;
      display:none;
      box-shadow:0 4px 16px rgba(0,0,0,.1);
      z-index:10;
    }
    html[data-theme="dark"] .settingsPopup{
      background:rgba(30,42,66,.9);
      border-color:rgba(255,255,255,.1);
    }
    .settingsPopup.open{ display:block; }
    .settingsPopup__label{
      font-size:10px;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.5px;
      color:#73726C;
      padding:4px 8px 2px;
    }
    html[data-theme="dark"] .settingsPopup__label{ color:#999590; }
    .settingsPopup__option{
      display:flex;
      align-items:center;
      gap:8px;
      width:100%;
      padding:6px 8px;
      border:none;
      border-radius:6px;
      font-size:12px;
      font-family:inherit;
      cursor:pointer;
      text-align:left;
      background:transparent;
      color:#3d3d3a;
      transition:background .12s ease;
    }
    html[data-theme="dark"] .settingsPopup__option{ color:#e7edf5; }
    .settingsPopup__option:hover{ background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .settingsPopup__option:hover{ background:rgba(255,255,255,.08); }
    .settingsPopup__option.active{ font-weight:600; }
    .settingsPopup__dot{
      width:10px;
      height:10px;
      border-radius:50%;
      border:1px solid rgba(0,0,0,.15);
      flex-shrink:0;
    }

    .themeOption[data-theme="warm"]{
      background:#fbf8f1;
      color:#151a22;
    }
    .themeOption[data-theme="light"]{
      background:#ffffff;
      color:#111827;
    }
    .themeOption[data-theme="rose"]{
      background:#fdf2f4;
      color:#3d2b30;
    }
    .themeOption[data-theme="dark"]{
      background:#1e1b4b;
      color:#e7edf5;
    }

    /* Sidebar */
    .sidebar{
      position:fixed;
      top:0;
      left:0;
      width:var(--sw);
      height:100%;
      background: linear-gradient(to right, transparent 0%, color-mix(in srgb, var(--sidebar) 25%, transparent) 90%, color-mix(in srgb, var(--sidebar) 25%, transparent) 100%);
      pointer-events:none;
      z-index:0;
    }



    /* Scrollbar — innerhalb der Sidebar, vor der Kante */
    .scrollTrack{
      position:fixed;
      top:0;
      right:0;
      width:6px;
      height:100%;
      z-index:2;
    }
    .sidebarWrap{
      position:fixed;
      top:0;
      left:0;
      width:var(--sw);
      height:100%;
      z-index:1;
      overflow-y:scroll;
      pointer-events:auto;
    }
    .sidebarInner{
      min-height:calc(100% + 1px);
      padding-top:116px;
      padding-bottom:80px;
      padding-left:12px;
      padding-right:12px;
    }

    /* Sidebar Search */
    .sbSearch{
      display:flex;align-items:center;gap:6px;
      padding:7px 10px;border-radius:8px;
      background:rgba(255,255,255,.7);
      border:1px solid rgba(0,0,0,.06);
      color:#8f8f8f;font-size:11px;margin-bottom:8px;
    }
    html[data-theme="dark"] .sbSearch{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.06);
      color:#6b7a8f;
    }
    .sbSearch svg{width:13px;height:13px;stroke:#8f8f8f;fill:none;stroke-width:2;stroke-linecap:round;flex-shrink:0;}
    html[data-theme="dark"] .sbSearch svg{stroke:#6b7a8f;}

    /* Sidebar New Project Button */
    .sbNewBtn{
      display:flex;align-items:center;justify-content:center;gap:6px;
      padding:8px 10px;border-radius:8px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      border:1px solid color-mix(in srgb, var(--sidebar) 40%, transparent);
      color:var(--sbDark);font-size:11px;font-weight:600;
      cursor:pointer;margin-bottom:12px;transition:all .15s ease;
    }
    .sbNewBtn:hover{filter:brightness(.95);}
    html[data-theme="dark"] .sbNewBtn:hover{filter:brightness(1.1);}
    .sbNewBtn svg{width:14px;height:14px;stroke:var(--sbDark);fill:none;stroke-width:2;stroke-linecap:round;}

    /* Sidebar Section Headers */
    .sbSection{
      font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;
      color:#8f8f8f;padding:8px 4px 4px;display:flex;align-items:center;gap:4px;
    }
    html[data-theme="dark"] .sbSection{color:#6b7a8f;}
    .sbSection svg{width:10px;height:10px;stroke:var(--sbDark);fill:color-mix(in srgb, var(--sidebar) 20%, transparent);stroke-width:2;stroke-linecap:round;}

    /* Sidebar Items */
    .sbItem{
      display:flex;align-items:center;gap:6px;padding:6px 8px;
      border-radius:7px;cursor:pointer;transition:background .12s ease;
      color:#3d3d3a;
    }
    html[data-theme="dark"] .sbItem{color:#e7edf5;}
    .sbItem:hover{background:rgba(0,0,0,.05);}
    html[data-theme="dark"] .sbItem:hover{background:rgba(255,255,255,.05);}
    .sbItem.active{background:rgba(255,255,255,.7);box-shadow:0 1px 3px rgba(0,0,0,.05);}
    html[data-theme="dark"] .sbItem.active{background:rgba(255,255,255,.06);}
    .sbDot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
    .sbName{flex:1;font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .sbMeta{font-size:9px;color:#8f8f8f;flex-shrink:0;}
    html[data-theme="dark"] .sbMeta{color:#6b7a8f;}
    .sbAgents{display:flex;gap:2px;flex-shrink:0;}
    .sbAgentDot{width:5px;height:5px;border-radius:50%;}

    /* Sidebar Divider */
    .sbDivider{height:1px;background:rgba(0,0,0,.06);margin:4px 0;}
    html[data-theme="dark"] .sbDivider{background:rgba(255,255,255,.06);}

    /* FE14/FE28: Expandierbare Projekte + Teams in Sidebar */
    .sbItem--project{ cursor:pointer; }
    .sbItem--project.sbItem--selected{
      background:color-mix(in srgb, var(--sidebar) 30%, transparent);
      font-weight:600;
    }
    html[data-theme="dark"] .sbItem--project.sbItem--selected{
      background:rgba(255,255,255,.1);
    }
    .sbTeams{ padding-left:16px; overflow:hidden; }
    .sbTeams.collapsed{ display:none; }
    .sbTeamItem{
      display:flex; align-items:center; gap:5px; padding:3px 6px; border-radius:5px;
      font-size:10px; color:#3d3d3a; cursor:pointer; transition:background .12s;
    }
    html[data-theme="dark"] .sbTeamItem{ color:#c0cfe0; }
    .sbTeamItem:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .sbTeamItem:hover{ background:rgba(255,255,255,.05); }
    .sbTeamItem--active{ font-weight:600; background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .sbTeamItem--active{ background:rgba(255,255,255,.08); }
    .sbTeamItem__count{ font-size:8px; opacity:.6; }
    .sbExpandIcon{
      width:8px; height:8px; flex-shrink:0; transition:transform .15s;
      stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round;
    }
    .sbExpandIcon--open{ transform:rotate(90deg); }

    /* Sidebar Activity Feed */
    .sbActivity{
      display:flex;align-items:flex-start;gap:6px;padding:4px 8px;
      font-size:10px;color:#8f8f8f;line-height:1.3;
    }
    html[data-theme="dark"] .sbActivity{color:#6b7a8f;}
    .sbActivity svg{width:10px;height:10px;stroke:var(--sbDark);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:1px;}

    /* Sidebar Action Icons (fixed, zwischen Logo und Scroll-Content) */
    .sidebarIcons{
      position:fixed;
      z-index:3;
      top:72px;
      left:12px;
      width:calc(var(--sw) - 24px);
      display:flex;
      gap:4px;
      transition:all .3s ease;
    }
    .sidebarIcon{
      width:36px;
      height:36px;
      border:none;
      background:transparent;
      box-shadow:none;
      cursor:pointer;
      padding:0;
      border-radius:8px;
      transition:background .15s ease;
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .sidebarIcon:hover{
      background:rgba(0,0,0,.07);
    }
    html[data-theme="dark"] .sidebarIcon:hover{
      background:rgba(255,255,255,.1);
    }
    .sidebarIcon .tooltip{
      position:absolute;
      left:50%;
      top:calc(100% + 6px);
      transform:translateX(-50%);
      background:rgba(20,20,19,.85);
      color:#faf9f5;
      font-size:11px;
      padding:3px 8px;
      border-radius:5px;
      white-space:nowrap;
      pointer-events:none;
      opacity:0;
      transition:opacity .15s ease;
    }
    .sidebarIcon:hover .tooltip{
      opacity:1;
    }
    .sidebarIcon svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:var(--sbDark);
      stroke-width:1.8;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    /* Sidebar Toggle */
    .sidebarToggle{
      position:fixed;
      z-index:4;
      top:16px;
      left:calc(var(--sw) - 44px);
      width:32px;
      height:32px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:8px;
      display:flex;
      align-items:center;
      justify-content:center;
      transition:background .15s ease, left .3s ease;
    }
    .sidebarToggle:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarToggle svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:1.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    /* Light + Rose: Utility-Icons neutral muted */
    html[data-theme="light"] .sidebarToggle svg,
    html[data-theme="light"] .sidebarSettings svg,
    html[data-theme="rose"] .sidebarToggle svg,
    html[data-theme="rose"] .sidebarSettings svg{
      stroke:#73726C;
    }

    /* Transitions fuer Collapse */
    .sidebar,
    .sidebarWrap,
    .sidebarInner,
    .sidebarIcons,
    .sidebarLogo,
    .sidebarBottom,
    .mainDivider,
    .chatInput--left,
    .chatInput--right{
      transition:all .3s ease;
    }

    /* Collapsed: Content, Icons und Logo verstecken */
    html.collapsed .sidebarInner,
    html.collapsed .sidebarIcons,
    html.collapsed .sidebarLogo{
      opacity:0;
      pointer-events:none;
    }

    /* Sidebar Bottom (User-Profil + Settings) */
    .sidebarBottom{
      position:fixed;
      z-index:3;
      bottom:24px;
      left:24px;
      width:calc(var(--sw) - 32px);
      display:flex;
      align-items:center;
      gap:8px;
      transition:all .3s ease;
    }
    .sidebarUser{
      display:flex;
      align-items:center;
      gap:8px;
      flex:1;
      min-width:0;
      cursor:pointer;
      padding:6px 8px;
      border-radius:8px;
      transition:background .15s ease;
    }
    .sidebarUser:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarAvatar{
      width:32px;
      height:32px;
      border-radius:50%;
      background:#3d3d3a;
      color:#faf9f5;
      font-size:13px;
      font-weight:600;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
    }
    .sidebarUserName{
      font-size:13px;
      color:#3d3d3a;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    html[data-theme="dark"] .sidebarUserName{ color:#faf9f5; }
    .sidebarSettings{
      width:32px;
      height:32px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:8px;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
      transition:background .15s ease;
      position:relative;
    }
    .sidebarSettings:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarSettings svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:1.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }
    .sidebarSettings .tooltip{
      position:absolute;
      left:calc(100% + 8px);
      top:50%;
      transform:translateY(-50%);
      background:rgba(20,20,19,.85);
      color:#faf9f5;
      font-size:12px;
      padding:4px 10px;
      border-radius:6px;
      white-space:nowrap;
      pointer-events:none;
      opacity:0;
      transition:opacity .15s ease;
    }
    .sidebarSettings:hover .tooltip{
      opacity:1;
    }
    html.collapsed .sidebarUserName{
      opacity:0;
      width:0;
    }
    html.collapsed .sidebarUser{
      padding:6px 4px;
    }

    /* Scrollbars — ChatGPT-Stil: schwebende Kapsel, weich, schmal */
    .chatMessages,
    .sidebarWrap{
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 20%, var(--bgFlat)) transparent;
    }
    .chatMessages::-webkit-scrollbar,
    .sidebarWrap::-webkit-scrollbar{
      width:6px;
    }
    .chatMessages::-webkit-scrollbar-track,
    .sidebarWrap::-webkit-scrollbar-track{
      background:transparent;
    }
    .chatMessages::-webkit-scrollbar-thumb,
    .sidebarWrap::-webkit-scrollbar-thumb{
      background:color-mix(in srgb, var(--sbDark) 22%, var(--bgFlat));
      border-radius:999px;
      border:1px solid transparent;
      background-clip:padding-box;
    }
    .chatMessages::-webkit-scrollbar-thumb:hover,
    .sidebarWrap::-webkit-scrollbar-thumb:hover{
      background:color-mix(in srgb, var(--sbDark) 40%, var(--bgFlat));
      border:1px solid transparent;
      background-clip:padding-box;
    }

    /* Chat-Nachrichten */
    .chatMessages{
      position:fixed;
      top:0;
      bottom:80px;
      overflow-y:scroll;
      z-index:0;
      pointer-events:auto;
    }
    .chatMessagesInner{
      min-height:calc(100% + 1px);
      display:flex;
      flex-direction:column;
      gap:12px;
      padding:24px;
    }
    .chatMessages--left{
      left:calc(var(--sw) + 4px);
      right:calc(100% - var(--dp) + 4px);
      top:48px;
    }
    .chatMsg{
      max-width:80%;
      padding:10px 16px;
      border-radius:16px;
      font-size:14px;
      line-height:20px;
      word-wrap:break-word;
    }
    .chatMsg--user{
      align-self:flex-end;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      color:#3d3d3a;
      border-bottom-right-radius:4px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 1px 4px rgba(0,0,0,.04);
    }
    html[data-theme="dark"] .chatMsg--user{
      color:#e7edf5;
      border-color:rgba(255,255,255,.08);
      box-shadow:0 1px 4px rgba(0,0,0,.15);
    }
    .chatMsg--agent{
      align-self:flex-start;
      background:rgba(255,255,255,.7);
      color:#3d3d3a;
      border-bottom-left-radius:4px;
    }
    html[data-theme="dark"] .chatMsg--agent{
      background:rgba(255,255,255,.08);
      color:#e7edf5;
    }
    /* Management Board: Agent = User-Layout gespiegelt, Farben wie Team Board */
    .chatMessages--left .chatMsg--agent{
      background:rgba(255,255,255,.7);
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 1px 4px rgba(0,0,0,.04);
    }
    html[data-theme="dark"] .chatMessages--left .chatMsg--user{
      background:color-mix(in srgb, var(--sidebar) 70%, transparent);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 1px 4px rgba(0,0,0,.15);
    }
    html[data-theme="dark"] .chatMessages--left .chatMsg--agent{
      background:color-mix(in srgb, var(--sidebar) 15%, transparent);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 1px 4px rgba(0,0,0,.15);
    }
    .chatMsg--error{
      align-self:center;
      background:rgba(239,68,68,.10);
      color:#dc2626;
      border:1px solid rgba(239,68,68,.20);
      font-size:12px;
      padding:6px 14px;
      border-radius:8px;
      max-width:90%;
    }
    html[data-theme="warm"] .chatMsg--error{
      background:rgba(239,68,68,.08);
      color:#b91c1c;
    }
    html[data-theme="rose"] .chatMsg--error{
      background:rgba(239,68,68,.10);
      color:#be123c;
      border-color:rgba(239,68,68,.18);
    }
    html[data-theme="dark"] .chatMsg--error{
      background:rgba(239,68,68,.15);
      color:#fca5a5;
      border-color:rgba(239,68,68,.3);
    }
    .wsBanner{
      display:none;
      position:fixed;
      top:0;left:0;right:0;
      z-index:100;
      background:rgba(239,68,68,.12);
      color:#dc2626;
      text-align:center;
      font-size:11px;
      font-weight:600;
      padding:5px 0;
      letter-spacing:.3px;
      border-bottom:1px solid rgba(239,68,68,.25);
    }
    html[data-theme="warm"] .wsBanner{
      background:rgba(239,68,68,.10);
      color:#b91c1c;
    }
    html[data-theme="rose"] .wsBanner{
      background:rgba(239,68,68,.10);
      color:#be123c;
    }
    html[data-theme="dark"] .wsBanner{
      background:rgba(239,68,68,.18);
      color:#fca5a5;
      border-color:rgba(239,68,68,.3);
    }
    .wsBanner--visible{ display:block; }
    .agentBar__error{
      color:#dc2626;
      font-weight:600;
      font-size:11px;
    }
    html[data-theme="warm"] .agentBar__error{ color:#b91c1c; }
    html[data-theme="rose"] .agentBar__error{ color:#be123c; }
    html[data-theme="dark"] .agentBar__error{ color:#fca5a5; }
    .chatMsg--subagent{
      align-self:flex-start;
      background:rgba(255,255,255,.45);
      color:#3d3d3a;
      border-bottom-left-radius:4px;
    }
    html[data-theme="dark"] .chatMsg--subagent{
      background:rgba(255,255,255,.12);
      color:#e7edf5;
    }
    /* Output-forwarder: dezent, kleine stille Präsenz-Anzeige */
    .chatMsg--forwarder{
      padding:4px 12px;
      font-size:11px;
      line-height:16px;
      opacity:.55;
      border-radius:8px;
      max-width:60%;
    }
    .chatMsg--forwarder .agentLabel{
      font-size:9px;
    }
    .chatMsg--forwarder .msgTime{
      font-size:8px;
    }
    /* Message Row + Action Buttons */
    .msgRow{
      display:flex;
      align-items:flex-end;
      gap:4px;
      max-width:80%;
      position:relative;
    }
    .msgRow--user{ align-self:flex-end; }
    .msgRow--agent{ align-self:flex-start; flex-direction:row-reverse; gap:0; }
    .msgRow .chatMsg{ max-width:100%; align-self:auto; }
    .msgActions{
      display:flex;
      flex-direction:column;
      gap:2px;
      flex-shrink:0;
      align-self:flex-end;
      margin-bottom:-12px;
    }
    .copyBtn,.replyBtn{
      flex-shrink:0;
      width:16px;
      height:16px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:3px;
      display:flex;
      align-items:center;
      justify-content:center;
      opacity:.2;
      transition:opacity .15s ease, background .12s ease;
      padding:0;
    }
    .copyBtn:hover,.replyBtn:hover{opacity:.6;}
    .replyBtn:hover{background:color-mix(in srgb, var(--sidebar) 15%, transparent);border-radius:4px;}
    .copyBtn svg{
      width:10px;height:10px;fill:none;stroke:#3d3d3a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;
    }
    .replyBtn svg{
      width:11px;height:11px;fill:none;stroke:#3d3d3a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;
    }
    html[data-theme="dark"] .copyBtn svg,
    html[data-theme="dark"] .replyBtn svg{stroke:#e7edf5;}
    .copyBtn--done svg{stroke:#22c55e;}
    .copyBtn--done{opacity:.7;}
    .chatMsg--forwarder .copyBtn,.chatMsg--forwarder .replyBtn{display:none;}
    .typingIndicator .copyBtn,.typingIndicator .replyBtn{display:none;}

    /* Reply Popup — fixed positioning to avoid scroll clipping */
    .replyPopup{
      position:fixed;
      z-index:200;
      width:280px;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(12px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:10px;
      box-shadow:0 6px 24px rgba(0,0,0,.10), 0 2px 6px rgba(0,0,0,.05);
      overflow:hidden;
      animation:replyIn .12s ease;
    }
    html[data-theme="dark"] .replyPopup{
      background:rgba(30,42,66,.92);
      border-color:rgba(255,255,255,.1);
      box-shadow:0 6px 24px rgba(0,0,0,.3);
    }
    @keyframes replyIn{
      from{opacity:0;transform:translateY(3px);}
      to{opacity:1;transform:translateY(0);}
    }
    .replyPopup__header{
      display:flex;align-items:center;justify-content:space-between;
      padding:7px 10px;border-bottom:1px solid rgba(0,0,0,.06);
      font-size:11px;font-weight:600;color:#3d3d3a;
    }
    html[data-theme="dark"] .replyPopup__header{border-color:rgba(255,255,255,.06);color:#e7edf5;}
    .replyPopup__recipient{display:flex;align-items:center;gap:5px;}
    .replyPopup__dot{width:6px;height:6px;border-radius:50%;background:#22c55e;}
    .replyPopup__close{
      width:18px;height:18px;border:none;background:transparent;cursor:pointer;
      border-radius:4px;display:flex;align-items:center;justify-content:center;
      opacity:.4;transition:opacity .12s ease;
    }
    .replyPopup__close:hover{opacity:.8;}
    .replyPopup__close svg{width:11px;height:11px;stroke:#3d3d3a;fill:none;stroke-width:2;stroke-linecap:round;}
    html[data-theme="dark"] .replyPopup__close svg{stroke:#e7edf5;}
    .replyPopup__quote{
      padding:6px 10px;font-size:10px;line-height:14px;color:#8f8f8f;
      border-left:2px solid color-mix(in srgb, var(--sidebar) 50%, transparent);
      margin:6px 10px 0;max-height:36px;overflow:hidden;
    }
    html[data-theme="dark"] .replyPopup__quote{color:#6b7a8f;}
    .replyPopup__inputWrap{
      padding:6px 10px 8px;display:flex;align-items:flex-end;gap:5px;
    }
    .replyPopup__input{
      flex:1;resize:none;border:1px solid rgba(0,0,0,.1);border-radius:7px;
      padding:6px 8px;font-size:12px;font-family:inherit;line-height:16px;
      min-height:30px;max-height:64px;background:rgba(255,255,255,.6);
      color:#3d3d3a;outline:none;transition:border-color .15s ease;
    }
    .replyPopup__input:focus{border-color:color-mix(in srgb, var(--sbDark) 50%, transparent);}
    html[data-theme="dark"] .replyPopup__input{
      background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:#e7edf5;
    }
    html[data-theme="dark"] .replyPopup__input:focus{border-color:rgba(138,164,200,.4);}
    .replyPopup__send{
      width:28px;height:30px;border:none;flex-shrink:0;
      background:color-mix(in srgb, var(--sbDark) 80%, transparent);
      border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;
      transition:filter .12s ease;
    }
    .replyPopup__send:hover{filter:brightness(.9);}
    html[data-theme="dark"] .replyPopup__send:hover{filter:brightness(1.15);}
    .replyPopup__send svg{width:12px;height:12px;fill:none;stroke:#faf9f5;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

    /* Typing Indicator — ephemere Präsenz-Anzeige */
    .typingIndicator{
      display:flex;
      align-items:center;
      gap:6px;
      padding:6px 12px;
      font-size:11px;
      color:#8f8f8f;
      opacity:.6;
    }
    html[data-theme="dark"] .typingIndicator{ color:#6b7a8f; }
    .typingIndicator__dots{
      display:flex;
      gap:3px;
    }
    .typingIndicator__dot{
      width:5px;
      height:5px;
      border-radius:50%;
      background:#8f8f8f;
      animation:typingPulse 1.4s infinite ease-in-out;
    }
    html[data-theme="dark"] .typingIndicator__dot{ background:#6b7a8f; }
    .typingIndicator__dot:nth-child(2){ animation-delay:.2s; }
    .typingIndicator__dot:nth-child(3){ animation-delay:.4s; }
    @keyframes typingPulse{
      0%,80%,100%{ opacity:.3; transform:scale(.8); }
      40%{ opacity:1; transform:scale(1); }
    }


    .chatMessages--right{
      left:calc(var(--dp) + 4px);
      right:4px;
      top:48px;
    }
    .chatMsg .agentLabel{
      display:block;
      font-size:10px;
      font-weight:600;
      margin-bottom:2px;
      opacity:.7;
    }
    .chatMsg .msgTime{
      display:block;
      font-size:9px;
      opacity:.45;
      margin-top:3px;
      text-align:right;
    }

    /* Team Board: jede Nachricht als volle-Breite Box */
    .chatMessages--right .chatMsg{
      max-width:100%;
      width:100%;
      align-self:stretch;
      border:1px solid rgba(0,0,0,.06);
      border-radius:12px;
      box-shadow:0 1px 4px rgba(0,0,0,.04);
    }
    html[data-theme="dark"] .chatMessages--right .chatMsg{
      border-color:rgba(255,255,255,.08);
      box-shadow:0 1px 4px rgba(0,0,0,.15);
    }

    /* Board Headers (getrennte Labels oben) */
    .boardHeader{
      position:fixed;
      top:8px;
      z-index:6;
      height:32px;
      display:flex;
      align-items:center;
      padding:0 14px;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      backdrop-filter:blur(8px);
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px;
      transition:all .3s ease;
      text-decoration:none;
    }
    html[data-theme="light"] .boardHeader{
      border-color:transparent;
    }
    html[data-theme="dark"] .boardHeader{
      background:color-mix(in srgb, var(--sidebar) 40%, transparent);
      border-color:color-mix(in srgb, var(--sidebar) 30%, transparent);
    }
    .boardHeader--left{
      left:calc(var(--sw) + 12px);
      right:calc(100% - var(--dp) + 12px);
      flex-wrap:wrap;
    }
    .boardHeader--right{
      left:calc(var(--dp) + 12px);
      right:12px;
      flex-wrap:wrap;
    }
    .boardHeader__title{
      font-size:11px;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.5px;
      color:#3d3d3a;
      opacity:.5;
      white-space:nowrap;
      flex-shrink:0;
    }
    html[data-theme="dark"] .boardHeader__title{
      color:#e7edf5;
    }
    .boardHeader__agents{
      display:flex;
      gap:8px;
      justify-content:center;
      overflow:hidden;
      flex:1 1 0;
      min-width:0;
    }
    .agentBar__item{
      display:flex;
      align-items:center;
      gap:4px;
      font-size:10px;
      font-weight:400;
      color:#3d3d3a;
      opacity:.55;
      white-space:nowrap;
      min-width:18px;
      flex:0 1 auto;
      overflow:hidden;
      cursor:default;
    }
    html[data-theme="dark"] .agentBar__item{ color:#e7edf5; }
    .agentBar__dot{
      width:6px;
      height:6px;
      border-radius:50%;
      flex-shrink:0;
    }
    .agentBar__dot--active{ background:#22c55e; }
    .agentBar__dot--idle{ background:#f59e0b; }
    .agentBar__dot--dead{ background:#ef4444; }
    .agentBar__name{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      flex-shrink:1;
    }
    .agentBar__role{
      font-size:9px;
      font-weight:400;
      opacity:.7;
      margin-left:-1px;
      overflow:hidden;
      text-overflow:clip;
      white-space:nowrap;
      flex-shrink:100;
      min-width:0;
    }

    /* FE30: Team-Tabs im rechten Header */
    .teamTabs{
      display:flex; gap:2px; overflow:hidden; flex:1 1 0; min-width:0;
    }
    .teamTab{
      display:flex; align-items:center; gap:4px; padding:2px 8px; border-radius:5px; cursor:pointer;
      font-size:10px; font-weight:500; color:#3d3d3a; opacity:.65; white-space:nowrap;
      background:transparent; border:1px solid transparent; transition:all .15s;
    }
    .teamTab:hover{ opacity:.85; background:color-mix(in srgb, var(--sidebar) 15%, transparent); }
    .teamTab--active{
      opacity:1; font-weight:600;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      border-color:color-mix(in srgb, var(--sidebar) 35%, transparent);
    }
    .teamTab__count{
      font-size:8px; font-weight:600; opacity:.6;
    }
    html[data-theme="dark"] .teamTab{ color:#e7edf5; }
    html[data-theme="dark"] .teamTab:hover{ background:rgba(255,255,255,.08); }
    html[data-theme="dark"] .teamTab--active{
      background:rgba(255,255,255,.12); border-color:rgba(255,255,255,.18);
    }

    /* FE30: Collapsible Team-Members Panel */
    /* Member Bar — zweite Zeile im Header, Sidebar-Designsprache */
    .memberBar{
      display:none; width:100%;
      gap:8px; padding-top:3px; flex-wrap:wrap;
    }
    .boardHeader--expanded{ height:auto; padding-bottom:6px; }
    .boardHeader--expanded .memberBar{ display:flex; }
    .memberChip{
      display:inline-flex; align-items:center; gap:4px;
      padding:0; cursor:pointer;
      font-size:10px; color:#3d3d3a; white-space:nowrap;
      background:none; border:none;
      opacity:.75; transition:opacity .12s;
    }
    .memberChip:hover{ opacity:1; }
    .memberChip--selected{ opacity:1; font-weight:600; }
    html[data-theme="dark"] .memberChip{ color:#c8d6e5; }
    .memberChip__dot{
      width:5px; height:5px; border-radius:50%; flex-shrink:0;
    }
    .memberChip__name{ font-weight:600; font-size:10px; }
    .memberChip__role{
      font-size:8px; opacity:.55;
    }

    .projectBadge{
      display:inline-flex;
      gap:4px;
      margin-left:8px;
      flex-shrink:1;
      min-width:0;
      overflow:hidden;
    }
    .projectBadge__item{
      font-size:9px;
      font-weight:500;
      padding:2px 6px;
      border-radius:4px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      color:var(--sbDark);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:120px;
    }
    html[data-theme="dark"] .projectBadge__item{
      background:rgba(255,255,255,.08);
      color:#8aa4c8;
    }

    /* Chat-Panels (Hauptflaeche links + rechts) */
    .chatPanel{
      position:fixed;
      top:0;
      height:100%;
      background:rgba(255,255,255,.04);
      z-index:0;
    }
    .chatPanel--left{
      left:var(--sw);
      right:calc(100% - var(--dp));
    }
    .chatPanel--right{
      left:var(--dp);
      right:0;
    }
    html[data-theme="warm"] .chatPanel{ background:#ffffff; }
    html[data-theme="light"] .chatPanel{ background:transparent; }
    html[data-theme="rose"] .chatPanel{ background:#ffffff; }
    html[data-theme="dark"] .chatPanel{ background:rgba(0,0,0,.25); }

    /* Vertikale Trennlinie Hauptbereich */
    .mainDivider{
      position:fixed;
      top:0;
      left:var(--dp);
      width:6px;
      margin-left:-3px;
      height:100%;
      background:linear-gradient(to right, transparent, rgba(0,0,0,.08) 50%, transparent);
      z-index:5;
      cursor:col-resize;
    }
    html[data-theme="dark"] .mainDivider{
      background:linear-gradient(to right, transparent, var(--sidebar) 50%, transparent);
    }

    /* Nachrichtenboxen */
    .chatInput{
      position:fixed;
      bottom:24px;
      z-index:2;
      display:flex;
      align-items:flex-end;
      gap:8px;
    }
    .chatInput--left{
      left:calc(var(--sw) + 24px);
      right:calc(100% - var(--dp) + 24px);
    }
    .chatInput--right{
      left:calc(var(--dp) + 24px);
      right:24px;
    }
    .chatInput .inputWrap{
      flex:1;
      position:relative;
      display:flex;
      align-items:flex-end;
    }
    .chatAttach{
      position:absolute;
      left:10px;
      bottom:8px;
      width:28px;
      height:28px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:50%;
      background:transparent;
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      transition:background .15s ease;
      flex-shrink:0;
    }
    .chatAttach:hover{
      background:rgba(0,0,0,.05);
    }
    .chatAttach svg{
      width:16px;
      height:16px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:2;
      stroke-linecap:round;
    }
    .chatInput textarea{
      width:100%;
      resize:none;
      border:1px solid rgba(0,0,0,.12);
      border-radius:16px;
      padding:12px 16px 12px 46px;
      font-size:14px;
      font-family:inherit;
      line-height:20px;
      background:rgba(255,255,255,.7);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.035);
      outline:none;
      min-height:44px;
      max-height:120px;
      overflow-y:auto;
    }
    .chatInput textarea:focus{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .chatInput textarea::placeholder{
      color:#8f8f8f;
    }
    .chatSend{
      width:36px;
      height:36px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:50%;
      background:rgba(255,255,255,.7);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.035);
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
      margin-bottom:4px;
      transition:background .15s ease;
    }
    .chatSend:hover{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .chatSend svg{
      width:18px;
      height:18px;
      fill:none;
      stroke:var(--sbDark);
      stroke-width:2.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }
    html[data-theme="dark"] .chatSend svg{
      stroke:#1a1a1a;
    }
    /* Custom Agent Dropdown */
    .customSelect{
      position:relative;
      min-width:90px;
      margin-bottom:4px;
      user-select:none;
    }
    .customSelect__trigger{
      height:36px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:18px;
      background:rgba(255,255,255,.7);
      font-size:12px;
      font-family:inherit;
      padding:0 28px 0 12px;
      cursor:pointer;
      color:#3d3d3a;
      display:flex;
      align-items:center;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      transition:border-color .15s ease, box-shadow .15s ease;
    }
    .customSelect__trigger::after{
      content:'';
      position:absolute;
      right:10px;
      top:50%;
      transform:translateY(-50%);
      border-left:4px solid transparent;
      border-right:4px solid transparent;
      border-top:5px solid #8f8f8f;
      pointer-events:none;
    }
    .customSelect.open .customSelect__trigger{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .customSelect__dropdown{
      display:none;
      position:absolute;
      bottom:calc(100% + 4px);
      left:0;
      min-width:100%;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(12px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:14px;
      padding:4px;
      box-shadow:0 4px 16px rgba(0,0,0,.1);
      z-index:20;
      max-height:200px;
      overflow-y:auto;
      scrollbar-width:thin;
    }
    .customSelect.open .customSelect__dropdown{
      display:block;
    }
    .customSelect__option{
      padding:6px 10px;
      border-radius:10px;
      font-size:12px;
      font-family:inherit;
      cursor:pointer;
      color:#3d3d3a;
      transition:background .12s ease, font-weight .12s ease;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .customSelect__option:hover{
      background:rgba(0,0,0,.06);
      font-weight:700;
    }
    .customSelect__option.selected{
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
    }
    html[data-theme="dark"] .customSelect__trigger{
      background:rgba(255,255,255,.08);
      border-color:rgba(255,255,255,.12);
      color:#e7edf5;
    }
    html[data-theme="dark"] .customSelect__trigger::after{
      border-top-color:#6b7a8f;
    }
    html[data-theme="dark"] .customSelect.open .customSelect__trigger{
      border-color:rgba(255,255,255,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.15);
    }
    html[data-theme="dark"] .customSelect__dropdown{
      background:rgba(30,42,66,.92);
      border-color:rgba(255,255,255,.1);
      box-shadow:0 4px 16px rgba(0,0,0,.25);
    }
    html[data-theme="dark"] .customSelect__option{
      color:#e7edf5;
    }
    html[data-theme="dark"] .customSelect__option:hover{
      background:rgba(255,255,255,.08);
    }
    html[data-theme="dark"] .customSelect__option.selected{
      background:rgba(255,255,255,.06);
    }

    /* Sidebar Resize Handle */
    .sidebarEdge{
      position:fixed;
      top:0;
      left:calc(var(--sw) - 3px);
      width:6px;
      height:100%;
      cursor:col-resize;
      z-index:5;
      transition:left .3s ease;
    }
    .sidebarEdge:hover,
    .sidebarEdge.active{
      background:color-mix(in srgb, var(--sidebar) 40%, transparent);
    }
    .mainDivider:hover,
    .mainDivider.active{
      background:linear-gradient(to right, transparent, rgba(0,0,0,.18) 50%, transparent);
    }
    html[data-theme="dark"] .mainDivider:hover,
    html[data-theme="dark"] .mainDivider.active{
      background:linear-gradient(to right, transparent, color-mix(in srgb, var(--sidebar) 80%, white) 50%, transparent);
    }
    /* Waehrend Drag: kein Text-Select, Cursor global */
    html.dragging{ cursor:col-resize !important; }
    html.dragging *{ cursor:col-resize !important; user-select:none !important; }
    /* Waehrend Drag: Transitions deaktivieren fuer flüssiges Resizing */
    html.dragging .sidebar,
    html.dragging .sidebarWrap,
    html.dragging .sidebarInner,
    html.dragging .sidebarIcons,
    html.dragging .sidebarLogo,
    html.dragging .sidebarBottom,
    html.dragging .sidebarEdge,
    html.dragging .sidebarToggle,
    html.dragging .mainDivider,
    html.dragging .chatPanel,
    html.dragging .chatMessages,
    html.dragging .boardHeader,
    html.dragging .chatInput--left,
    html.dragging .chatInput--right{
      transition:none !important;
    }

    .themeOption:hover{
      filter:brightness(.95);
    }
    .themeOption[data-theme="dark"]:hover{
      filter:brightness(1.2);
    }

    /* ─── Accessibility: Focus + Skip-Link ─── */
    *:focus-visible{
      outline:2px solid #3b82f6;
      outline-offset:2px;
    }
    .skipLink{
      position:fixed;
      top:-100%;
      left:16px;
      z-index:10000;
      padding:8px 16px;
      background:var(--bgFlat);
      color:var(--sbDark);
      border:2px solid #3b82f6;
      border-radius:8px;
      font-size:14px;
      text-decoration:none;
      transition:top .2s;
    }
    .skipLink:focus{
      top:8px;
    }

    /* ─── Responsive: Mobile (<768px) ─── */
    @media (max-width:767px){
      /* Hide sidebar completely */
      .sidebar,
      .sidebarWrap,
      .sidebarInner,
      .sidebarIcons,
      .sidebarLogo,
      .sidebarBottom,
      .sidebarEdge,
      .sidebarToggle,
      .scrollTrack{
        display:none !important;
      }

      /* Left panel = full width (override inline --sw/--dp) */
      .chatPanel--left{
        left:0 !important; right:0 !important;
      }
      .chatMessages--left{
        left:4px !important; right:4px !important;
      }
      .boardHeader--left{
        left:12px !important; right:12px !important;
      }
      .chatInput--left{
        left:12px !important; right:12px !important;
      }

      /* Hide right panel + divider */
      .chatPanel--right,
      .chatMessages--right,
      .boardHeader--right,
      .chatInput--right,
      .mainDivider{
        display:none !important;
      }

      /* Input adjustments */
      .chatInput{
        bottom:8px !important;
      }
      .chatInput textarea{
        padding-left:42px;
        font-size:16px; /* prevent iOS zoom */
      }
    }

    /* ─── Responsive: Tablet (768–1024px) ─── */
    @media (min-width:768px) and (max-width:1024px){
      /* Hide sidebar */
      .sidebar,
      .sidebarWrap,
      .sidebarInner,
      .sidebarIcons,
      .sidebarLogo,
      .sidebarBottom,
      .sidebarEdge,
      .sidebarToggle,
      .scrollTrack{
        display:none !important;
      }

      /* Panels start from left edge */
      .chatPanel--left{
        left:0 !important;
      }
      .chatMessages--left{
        left:4px !important;
      }
      .boardHeader--left{
        left:12px !important;
      }
      .chatInput--left{
        left:12px !important;
      }
    }
  </style>
</head>

<body>
  <a class="skipLink" href="#chatMessagesLeft">Skip to content</a>
  <div class="sidebar"></div>
  <img class="sidebarLogo" src="ace_logo.svg" alt="ACE Logo" style="position:fixed;z-index:3;width:80px;top:12px;left:8px;">

  <div class="sidebarIcons">
    <button class="sidebarIcon" title="New Project">
      <svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M12 11v4M10 13h4"/></svg>
      <span class="tooltip">New Project</span>
    </button>
    <button class="sidebarIcon" title="Team">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="4" r="2"/><path d="M12 6v4"/><circle cx="12" cy="12" r="2"/><path d="M10.5 13.5L6.5 17.5"/><path d="M13.5 13.5L17.5 17.5"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18.5" cy="18.5" r="2"/></svg>
      <span class="tooltip">Team</span>
    </button>
    <button class="sidebarIcon" title="Control Center">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="tooltip">Control Center</span>
    </button>
  </div>

  <nav class="sidebarWrap" aria-label="Project navigation">
    <div class="sidebarInner">
      <div class="sbSearch" role="button" tabindex="0" aria-label="Search projects"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>Search projects...</div>
      <div class="sbNewBtn" role="button" tabindex="0" aria-label="New Project"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>New Project</div>
      <div class="sbSection"><svg viewBox="0 0 24 24"><polygon points="12,2 15,8.5 22,9.3 17,14 18,21 12,17.8 6,21 7,14 2,9.3 9,8.5"/></svg>Starred</div>
      <div id="sbStarredList"></div>
      <div class="sbSection">Projects</div>
      <div id="sbProjectList"></div>
      <div class="sbDivider"></div>
      <div class="sbSection"><svg viewBox="0 0 24 24"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>Activity</div>
      <div id="sbActivityList"></div>
    </div>
  </nav>

  <!-- Sidebar Bottom: User-Profil + Settings -->
  <div class="sidebarBottom">
    <div class="sidebarUser">
      <div class="sidebarAvatar" role="img" aria-label="User avatar: Leo">L</div>
      <span class="sidebarUserName">Leo</span>
    </div>
    <button class="sidebarSettings" id="settingsBtn" title="Settings" aria-label="Settings" aria-expanded="false" aria-controls="settingsPopup">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      <span class="tooltip">Settings</span>
    </button>
    <div class="settingsPopup" id="settingsPopup" role="dialog" aria-label="Theme Settings">
      <div class="settingsPopup__label" id="settingsPopupLabel">Theme</div>
      <button class="settingsPopup__option" data-theme="warm" aria-label="Theme: Warm"><span class="settingsPopup__dot" style="background:#c8bfa8"></span>Warm</button>
      <button class="settingsPopup__option" data-theme="light" aria-label="Theme: Light"><span class="settingsPopup__dot" style="background:#d6e8f7"></span>Light</button>
      <button class="settingsPopup__option" data-theme="rose" aria-label="Theme: Rose"><span class="settingsPopup__dot" style="background:#e8c4cc"></span>Rose</button>
      <button class="settingsPopup__option" data-theme="dark" aria-label="Theme: Dark"><span class="settingsPopup__dot" style="background:#1e2a42"></span>Dark</button>
    </div>
  </div>

  <!-- Sidebar Toggle -->
  <button class="sidebarToggle" id="sidebarToggle" title="Toggle Sidebar" aria-label="Toggle Sidebar" aria-expanded="true">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
  </button>

  <div class="sidebarEdge" id="sidebarEdge"></div>
  <div class="chatPanel chatPanel--left"></div>
  <div class="chatPanel chatPanel--right"></div>
  <div class="mainDivider" id="mainDivider"></div>

  <!-- Board Headers -->
  <header class="boardHeader boardHeader--left" id="boardHeaderLeft" role="banner" aria-label="Management Board">
    <span class="boardHeader__title">Management Board</span>
    <div class="memberBar" id="mgmtMemberBar" aria-label="Management-Team"></div>
  </header>
  <header class="boardHeader boardHeader--right" id="boardHeaderRight" role="banner" aria-label="Team Board">
    <span class="boardHeader__title">Team Board</span>
    <div class="teamTabs" id="teamTabs" aria-label="Team-Auswahl"></div>
    <div class="memberBar" id="memberBar" aria-label="Team-Mitglieder"></div>
  </header>

  <!-- Chat-Nachrichten links (User ↔ Manager Agent) -->
  <main class="chatMessages chatMessages--left" id="chatMessagesLeft" role="log" aria-label="Management chat">
    <div class="chatMessagesInner">
      <div class="chatMsg chatMsg--user">I need you to build the ACE API Gateway. REST endpoints, auth middleware, rate limiting. Target: 2 weeks.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Understood. I'll break this down into sub-tasks and delegate to the team. I'll assign a Team Lead and two engineers.</div>
      <div class="chatMsg chatMsg--user">Good. Make sure they coordinate on the auth layer — it needs to be consistent across all endpoints.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Noted. I've briefed the Team Lead. Agent A will handle endpoint scaffolding + routing, Agent B takes auth middleware + rate limiting. They're syncing now.</div>
      <div class="chatMsg chatMsg--user">Keep me posted on progress.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Will do. Team is active in the right panel — you can follow along there. I'll flag blockers directly to you.</div>
    </div>
  </main>

  <!-- Nachrichtenbox links -->
  <div class="chatInput chatInput--left" role="form" aria-label="Management message input">
    <div class="customSelect" id="leftTargetWrap" aria-label="Message recipient" data-value="ordo">
      <div class="customSelect__trigger" id="leftTargetTrigger">Ordo</div>
      <div class="customSelect__dropdown" id="leftTargetDropdown">
        <div class="customSelect__option" data-value="all_managers">Alle Manager</div>
        <div class="customSelect__option selected" data-value="ordo">Ordo</div>
      </div>
    </div>
    <div class="inputWrap">
      <button class="chatAttach" title="Attach" aria-label="Attach file"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
      <textarea rows="1" placeholder="Message to Agent..." aria-label="Message to Agent"></textarea>
    </div>
    <button class="chatSend" aria-label="Send message">
      <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  </div>

  <!-- Chat-Nachrichten rechts (Manager → Team Lead → Agent A + B) -->
  <section class="chatMessages chatMessages--right" id="chatMessagesRight" role="log" aria-label="Team chat">
    <div class="chatMessagesInner">
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>New project: ACE API Gateway. REST endpoints, auth middleware, rate limiting. Deadline: 2 weeks. You're leading this. Assign Agent A and Agent B.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Got it. I'll split the work. Agent A — you take endpoint scaffolding and routing. Agent B — auth middleware and rate limiting. Questions?</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>Clear. I'll set up the Express router with versioned routes. /v1/users, /v1/projects, /v1/tasks. Should I use controller pattern or inline handlers?</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Controller pattern. Keep it clean and testable.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent B</span>For auth — JWT or session-based? And rate limiting: per-user or per-endpoint?</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>JWT with refresh tokens. Rate limiting per-user, 100 req/min default. Use middleware chain so Agent A can plug it into routes easily.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>@Agent B — I'll export a registerRoutes(app, middleware) function. You pass me the auth + rate limiter as middleware array. Deal?</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent B</span>Deal. I'll expose authMiddleware() and rateLimiter(config). You just wire them in. I'll have the interfaces ready in 2 hours.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>Perfect. I'll scaffold the routes in parallel and integrate once you push.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Good coordination. I'll review the integration point once both are ready. Keep commits atomic.</div>
    </div>
  </section>

  <!-- Nachrichtenbox rechts -->
  <div class="chatInput chatInput--right" role="form" aria-label="Team message input">
    <div class="customSelect" id="rightTargetWrap" aria-label="Team message recipient">
      <div class="customSelect__trigger" id="rightTargetTrigger">Alle</div>
      <div class="customSelect__dropdown" id="rightTargetDropdown">
        <div class="customSelect__option selected" data-value="all">Alle</div>
      </div>
    </div>
    <div class="inputWrap">
      <button class="chatAttach" title="Attach" aria-label="Attach file"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
      <textarea rows="1" placeholder="Message to Team..." aria-label="Message to Team"></textarea>
    </div>
    <button class="chatSend" aria-label="Send message">
      <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  </div>


  <script>
    const root = document.documentElement;
    const settingsBtn = document.getElementById('settingsBtn');
    const settingsPopup = document.getElementById('settingsPopup');
    const themeOptions = settingsPopup.querySelectorAll('.settingsPopup__option');

    function setTheme(theme){
      root.setAttribute('data-theme', theme);
      localStorage.setItem('bridge_theme', theme);
      themeOptions.forEach(o => {
        const isActive = o.dataset.theme === theme;
        o.classList.toggle('active', isActive);
        o.setAttribute('aria-pressed', isActive);
      });
      settingsPopup.classList.remove('open');
      settingsBtn.setAttribute('aria-expanded', 'false');
    }

    const stored = localStorage.getItem('bridge_theme');
    if(stored) setTheme(stored);
    else { themeOptions[0].classList.add('active'); themeOptions[0].setAttribute('aria-pressed', 'true'); }

    settingsBtn.addEventListener('click', e => {
      e.stopPropagation();
      settingsPopup.classList.toggle('open');
      settingsBtn.setAttribute('aria-expanded', settingsPopup.classList.contains('open'));
    });

    themeOptions.forEach(o => o.addEventListener('click', e => {
      e.stopPropagation();
      setTheme(o.dataset.theme);
    }));

    document.addEventListener('click', e => {
      if(!settingsBtn.contains(e.target) && !settingsPopup.contains(e.target)){
        settingsPopup.classList.remove('open');
        settingsBtn.setAttribute('aria-expanded', 'false');
      }
    });

    // ========== Custom Select Dropdown Logic ==========
    function initCustomSelect(wrapId, triggerId, dropdownId){
      const wrap = document.getElementById(wrapId);
      const trigger = document.getElementById(triggerId);
      const dropdown = document.getElementById(dropdownId);
      if(!wrap || !trigger || !dropdown) return;

      trigger.addEventListener('click', e => {
        e.stopPropagation();
        // Close all other custom selects
        document.querySelectorAll('.customSelect.open').forEach(cs => {
          if(cs !== wrap) cs.classList.remove('open');
        });
        wrap.classList.toggle('open');
      });

      dropdown.addEventListener('click', e => {
        const opt = e.target.closest('.customSelect__option');
        if(!opt) return;
        e.stopPropagation();
        dropdown.querySelectorAll('.customSelect__option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        trigger.textContent = opt.textContent;
        wrap.dataset.value = opt.dataset.value;
        wrap.classList.remove('open');
        // Fire change event for listeners
        wrap.dispatchEvent(new Event('change'));
      });
    }

    // Helper: get value of custom select
    function getCustomSelectValue(wrapId, fallback){
      const el = document.getElementById(wrapId);
      return el ? (el.dataset.value || fallback) : fallback;
    }

    initCustomSelect('leftTargetWrap', 'leftTargetTrigger', 'leftTargetDropdown');
    initCustomSelect('rightTargetWrap', 'rightTargetTrigger', 'rightTargetDropdown');

    // Close custom selects on outside click
    document.addEventListener('click', e => {
      document.querySelectorAll('.customSelect.open').forEach(cs => {
        if(!cs.contains(e.target)) cs.classList.remove('open');
      });
    });

    // Navigation: Sidebar icons + New Project button → project_config.html
    document.querySelector('.sidebarIcon[title="New Project"]').addEventListener('click', () => {
      window.location.href = 'project_config.html';
    });
    document.querySelector('.sidebarIcon[title="Team"]').addEventListener('click', () => {
      window.location.href = 'project_config.html';
    });
    document.querySelector('.sidebarIcon[title="Control Center"]').addEventListener('click', () => {
      window.location.href = 'control_center.html';
    });
    document.querySelector('.sbNewBtn').addEventListener('click', () => {
      window.location.href = 'project_config.html';
    });

    // Search Projects → native OS directory picker
    document.querySelector('.sbSearch').addEventListener('click', async () => {
      const sbSearch = document.querySelector('.sbSearch');
      const origText = sbSearch.textContent;
      sbSearch.textContent = 'Opening file picker...';
      sbSearch.style.pointerEvents = 'none';
      sbSearch.style.opacity = '0.6';
      try {
        const res = await fetch('http://127.0.0.1:9111/pick-directory');
        const data = await res.json();
        if (data.ok && data.path) {
          window.location.href = 'project_config.html?path=' + encodeURIComponent(data.path);
        }
      } catch(e) {
        console.error('pick-directory failed:', e);
      } finally {
        sbSearch.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>Search projects...';
        sbSearch.style.pointerEvents = '';
        sbSearch.style.opacity = '';
      }
    });

    // Attach File [+] → hidden file input + upload to /projects/upload
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.multiple = true;
    fileInput.accept = '*/*';
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);

    let attachPanel = 'left'; // tracks which panel triggered the attach

    document.querySelectorAll('.chatAttach').forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        attachPanel = idx === 0 ? 'left' : 'right';
        fileInput.click();
      });
    });

    fileInput.addEventListener('change', async () => {
      if (!fileInput.files || fileInput.files.length === 0) return;
      const files = Array.from(fileInput.files);
      // Get current project_path from runtime
      let projectPath = '';
      try {
        const rtRes = await fetch('http://127.0.0.1:9111/runtime');
        const rtData = await rtRes.json();
        projectPath = rtData.project_path || '';
      } catch(e) {}
      if (!projectPath) {
        projectPath = '/home/leo/Desktop/CC';
      }
      // Upload via multipart
      const form = new FormData();
      form.append('project_path', projectPath);
      files.forEach(f => form.append('files', f, f.name));
      try {
        const res = await fetch('http://127.0.0.1:9111/projects/upload', { method: 'POST', body: form });
        const data = await res.json();
        if (data.ok && data.uploaded && data.uploaded.length > 0) {
          // Inject file references as chat messages
          const names = data.uploaded.map(u => u.filename).join(', ');
          const panel = attachPanel;
          const to = panel === 'left' ? getCustomSelectValue('leftTargetWrap', 'ordo') : getCustomSelectValue('rightTargetWrap', 'all');
          const content = '[Attached: ' + names + ']';
          // Use sendMessage (defined later) via deferred call
          setTimeout(() => {
            if (typeof sendMessage === 'function') {
              sendMessage('user', to, content, panel);
            }
          }, 0);
        }
      } catch(e) {
        console.error('File upload failed:', e);
      }
      fileInput.value = '';
    });

    // ========== Phase 1: Config + Rendering ==========
    const BRIDGE_CONFIG = {
      apiBase: 'http://127.0.0.1:9111',
      wsUrl: 'ws://127.0.0.1:9112',
      historyLimit: 200,
      pollInterval: 10000
    };
    const API_BASE = BRIDGE_CONFIG.apiBase;
    const WS_URL = BRIDGE_CONFIG.wsUrl;

    const AGENT_LABELS = { user: 'Leo' };
    function agentLabel(id){ return AGENT_LABELS[id] || id.charAt(0).toUpperCase() + id.slice(1); }

    // FE29: Management-Agents — fest definiert, immer linkes Panel
    const MANAGEMENT_AGENTS = new Set(['ordo', 'lucy', 'viktor', 'nova']);
    const AGENT_COLORS = {
      'ordo':'#6366f1', 'viktor':'#8b5cf6', 'nova':'#ec4899',
      'lucy':'#f59e0b', 'codex':'#06b6d4', 'frontend':'#22c55e',
      'backend':'#f97316', 'mobile':'#14b8a6',
      'qwen1':'#a855f7', 'qwen2':'#a855f7', 'qwen3':'#a855f7'
    };
    function getAgentColor(id){ return AGENT_COLORS[id] || '#8f8f8f'; }
    function isManagementAgent(id){ return MANAGEMENT_AGENTS.has(id); }

    const leftInner = document.querySelector('#chatMessagesLeft .chatMessagesInner');
    const rightInner = document.querySelector('#chatMessagesRight .chatMessagesInner');
    const leftBox = document.getElementById('chatMessagesLeft');
    const rightBox = document.getElementById('chatMessagesRight');

    // Track rendered message IDs to avoid duplicates
    const renderedIds = new Set();
    // Cache all messages for re-rendering on dropdown change
    const messageCache = [];

    // Track per-agent which panel the user last used to talk to them (persisted)
    let agentPanel = JSON.parse(localStorage.getItem('bridge_agentPanel') || '{}');
    function setAgentPanel(agentId, panel){
      agentPanel[agentId] = panel;
      localStorage.setItem('bridge_agentPanel', JSON.stringify(agentPanel));
    }

    function isLeftPanel(msg){
      // Persistent panel from API meta (survives history/poll)
      if(msg.meta && msg.meta.panel === 'left') return true;
      if(msg.meta && msg.meta.panel === 'right') return false;
      // Client-side panel tag from send functions (immediate render, before WS echo)
      if(msg._panel === 'left') return true;
      if(msg._panel === 'right') return false;
      // FE29: Deterministic routing via MANAGEMENT_AGENTS config
      // Broadcasts to 'all' or 'all_managers' go to their respective panels
      if(msg.to === 'all' || msg.to === 'broadcast') return false;
      if(msg.to === 'all_managers') return true;
      // Conversation context: check agentPanel for the other party
      const other = msg.from === 'user' ? msg.to : (msg.to === 'user' ? msg.from : null);
      if(other && agentPanel[other]) return agentPanel[other] === 'left';
      // Fallback: management agents default to left
      if(msg.from === 'user') return isManagementAgent(msg.to);
      if(msg.to === 'user') return isManagementAgent(msg.from);
      // Agent-to-agent: if BOTH are management agents → left (management discussion)
      if(isManagementAgent(msg.from) && isManagementAgent(msg.to)) return true;
      // Agent-to-agent involving at least one non-management → right
      return false;
    }

    // Typing indicators — ephemeral per agent
    const typingEls = {}; // agentId → DOM element
    function showTyping(agentId){
      removeTyping(agentId);
      const isLeft = isManagementAgent(agentId);
      const container = isLeft ? leftInner : rightInner;
      const scrollEl = isLeft ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);
      const div = document.createElement('div');
      div.className = 'typingIndicator';
      div.innerHTML = '<span class="typingIndicator__dots">' +
        '<span class="typingIndicator__dot"></span>' +
        '<span class="typingIndicator__dot"></span>' +
        '<span class="typingIndicator__dot"></span></span>' +
        agentLabel(agentId) + ' tippt\u2026';
      container.appendChild(div);
      typingEls[agentId] = div;
      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }
    function removeTyping(agentId){
      if(typingEls[agentId]){
        typingEls[agentId].remove();
        delete typingEls[agentId];
      }
    }

    function isNearBottom(el){ return el.scrollHeight - el.scrollTop - el.clientHeight < 60; }

    const timeFmt = new Intl.DateTimeFormat('de-DE', {hour:'2-digit', minute:'2-digit'});
    function formatTime(ts){
      if(!ts) return '';
      const d = new Date(ts);
      if(isNaN(d)) return '';
      const diff = (Date.now() - d.getTime()) / 1000;
      if(diff < 60) return 'gerade eben';
      if(diff < 3600) return 'vor ' + Math.floor(diff/60) + ' Min';
      if(diff < 86400) return timeFmt.format(d);
      return d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit'}) + ' ' + timeFmt.format(d);
    }

    const MAX_CACHE = 500;

    function renderMessage(msg, skipCache){
      // Output_forwarder: ONLY allow type="status" (typing indicator). Everything else is suppressed.
      if(msg.meta && msg.meta.source === 'output_forwarder'){
        if(msg.meta.type === 'status'){
          showTyping(msg.from);
        }
        return; // Never render forwarder messages as chat bubbles
      }
      // Prose or any real message from agent → remove their typing indicator
      if(msg.from && msg.from !== 'user') removeTyping(msg.from);

      if(!skipCache){
        // Prevent duplicates in cache (race: WebSocket echo vs HTTP response)
        const existing = msg.id ? messageCache.find(m => m.id === msg.id) : null;
        if(existing){
          // Merge _panel tag from later arrival
          if(msg._panel && !existing._panel) existing._panel = msg._panel;
        } else {
          messageCache.push(msg);
          // Evict oldest entries to prevent memory leak
          while(messageCache.length > MAX_CACHE){
            const removed = messageCache.shift();
            if(removed.id) renderedIds.delete(removed.id);
          }
        }
      }
      if(msg.id && renderedIds.has(msg.id)) return;
      if(msg.id) renderedIds.add(msg.id);

      const isLeft = isLeftPanel(msg);

      // FE14/FE28: Sidebar-Projekt-Filter — beide Panels
      if(sidebarProjectFilter && boardProjectsCache){
        const projMembers = new Set();
        boardProjectsCache.forEach(p => {
          if(p.name === sidebarProjectFilter){
            (p.teams || []).forEach(t => (t.members || []).forEach(m => projMembers.add(m.id || m)));
          }
        });
        projMembers.add('user'); // User-Nachrichten immer zeigen
        if(!projMembers.has(msg.from) && !projMembers.has(msg.to)) return;
      }

      const container = isLeft ? leftInner : rightInner;
      const scrollEl = isLeft ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);

      const div = document.createElement('div');
      const isForwarder = msg.meta && (msg.meta.source === 'output_forwarder' || msg.meta.auto_capture === true) && msg.meta.type !== 'prose';
      if(msg.from === 'user'){
        div.className = 'chatMsg chatMsg--user';
        // FE29: Always show direction label in left panel (multiple managers)
        const uLabel = document.createElement('span');
        uLabel.className = 'agentLabel';
        uLabel.textContent = agentLabel('user') + ' → ' + agentLabel(msg.to);
        div.appendChild(uLabel);
      } else {
        div.className = 'chatMsg chatMsg--agent';
        const label = document.createElement('span');
        label.className = 'agentLabel';
        // FE29: Show direction for both panels (multi-conversation context)
        label.textContent = agentLabel(msg.from) + (msg.to && msg.to !== 'user' ? ' → ' + agentLabel(msg.to) : '');
        div.appendChild(label);
      }
      if(isForwarder) div.classList.add('chatMsg--forwarder');

      const text = document.createTextNode(msg.content);
      div.appendChild(text);
      const ts = formatTime(msg.timestamp);
      if(ts){
        const timeEl = document.createElement('span');
        timeEl.className = 'msgTime';
        timeEl.textContent = ts;
        div.appendChild(timeEl);
      }
      // Action buttons — outside the message box in a wrapper row
      if(!isForwarder){
        const row = document.createElement('div');
        row.className = 'msgRow ' + (msg.from === 'user' ? 'msgRow--user' : 'msgRow--agent');

        const actions = document.createElement('div');
        actions.className = 'msgActions';

        // Reply button — only on agent messages, not on user's own
        if(msg.from !== 'user'){
          const replyTarget = msg.from;
          const replyBtn = document.createElement('button');
          replyBtn.className = 'replyBtn';
          replyBtn.title = 'Antworten';
          replyBtn.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>';
          replyBtn.addEventListener('click', e => {
            e.stopPropagation();
            openReplyPopup(row, replyTarget, msg.content, isLeft);
          });
          actions.appendChild(replyBtn);
        }

        // Copy button
        const copyBtn = document.createElement('button');
        copyBtn.className = 'copyBtn';
        copyBtn.title = 'Kopieren';
        copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        copyBtn.addEventListener('click', e => {
          e.stopPropagation();
          navigator.clipboard.writeText(msg.content).then(() => {
            copyBtn.classList.add('copyBtn--done');
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(() => {
              copyBtn.classList.remove('copyBtn--done');
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
            }, 1500);
          });
        });

        actions.appendChild(copyBtn);
        row.appendChild(div);
        row.appendChild(actions);
        container.appendChild(row);
      } else {
        container.appendChild(div);
      }

      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }

    // ========== Reply Popup Logic ==========
    let activeReplyPopup = null;

    function openReplyPopup(row, target, quote, isLeft){
      closeReplyPopup();
      const shortQuote = quote.length > 80 ? quote.substring(0, 80) + '\u2026' : quote;
      const popup = document.createElement('div');
      popup.className = 'replyPopup';
      popup.innerHTML =
        '<div class="replyPopup__header">' +
          '<div class="replyPopup__recipient">' +
            '<span class="replyPopup__dot"></span>' +
            '<span>Antwort an <strong>' + agentLabel(target) + '</strong></span>' +
          '</div>' +
          '<button class="replyPopup__close" title="Schliessen">' +
            '<svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>' +
          '</button>' +
        '</div>' +
        '<div class="replyPopup__quote">' + shortQuote + '</div>' +
        '<div class="replyPopup__inputWrap">' +
          '<textarea class="replyPopup__input" rows="1" placeholder="Nachricht an ' + agentLabel(target) + '..."></textarea>' +
          '<button class="replyPopup__send" title="Senden">' +
            '<svg viewBox="0 0 24 24"><path d="M22 2L11 13"/><polygon points="22 2 15 22 11 13 2 9"/></svg>' +
          '</button>' +
        '</div>';

      document.body.appendChild(popup);
      activeReplyPopup = popup;

      // Position popup next to the reply button
      const btn = row.querySelector('.replyBtn');
      const rect = btn.getBoundingClientRect();
      const popupW = 280;
      const isUserMsg = row.classList.contains('msgRow--user');
      let left, top;
      if(isUserMsg){
        left = rect.left - popupW - 8;
      } else {
        left = rect.right + 8;
      }
      top = rect.top;
      // Keep within viewport
      if(left < 8) left = 8;
      if(left + popupW > window.innerWidth - 8) left = window.innerWidth - popupW - 8;
      if(top + 160 > window.innerHeight) top = window.innerHeight - 168;
      if(top < 8) top = 8;
      popup.style.left = left + 'px';
      popup.style.top = top + 'px';

      const input = popup.querySelector('.replyPopup__input');
      setTimeout(() => input.focus(), 30);

      input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 64) + 'px';
      });
      input.addEventListener('keydown', e => {
        if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); submitReply(target, input, isLeft); }
        if(e.key === 'Escape') closeReplyPopup();
      });
      popup.querySelector('.replyPopup__close').addEventListener('click', e => {
        e.stopPropagation(); closeReplyPopup();
      });
      popup.querySelector('.replyPopup__send').addEventListener('click', e => {
        e.stopPropagation(); submitReply(target, input, isLeft);
      });
    }

    function submitReply(target, input, isLeft){
      const text = input.value.trim();
      if(!text) return;
      const panel = isLeft ? 'left' : 'right';
      setAgentPanel(target, panel);
      sendMessage('user', target, text, panel);
      closeReplyPopup();
    }

    function closeReplyPopup(){
      if(activeReplyPopup){ activeReplyPopup.remove(); activeReplyPopup = null; }
    }

    document.addEventListener('click', e => {
      if(activeReplyPopup && !activeReplyPopup.contains(e.target) && !e.target.closest('.replyBtn')){
        closeReplyPopup();
      }
    });

    function clearStaticMessages(){
      leftInner.innerHTML = '';
      rightInner.innerHTML = '';
    }

    // ========== Error Helpers ==========
    function showError(panel, text){
      const container = panel === 'left' ? leftInner : rightInner;
      const scrollEl = panel === 'left' ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);
      const div = document.createElement('div');
      div.className = 'chatMsg chatMsg--error';
      div.textContent = text;
      container.appendChild(div);
      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }

    // WS Disconnect Banner (fixed position, overlays full page top)
    const wsBanner = document.createElement('div');
    wsBanner.className = 'wsBanner';
    wsBanner.setAttribute('role', 'alert');
    wsBanner.setAttribute('aria-live', 'assertive');
    wsBanner.setAttribute('aria-atomic', 'true');
    wsBanner.textContent = 'Verbindung unterbrochen — Nachrichten werden nicht live aktualisiert';
    document.body.appendChild(wsBanner);

    function setWsBanner(visible){
      wsBanner.classList.toggle('wsBanner--visible', visible);
    }

    // ========== Phase 2: Backend-Anbindung ==========
    async function sendMessage(from, to, content, panel){
      try {
        const res = await fetch(API_BASE + '/send', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({from, to, content, meta: panel ? {panel} : undefined})
        });
        const data = await res.json();
        if(data.ok && data.message){
          if(panel) data.message._panel = panel;
          renderMessage(data.message);
        } else {
          showError(panel || 'left', 'Senden fehlgeschlagen: ' + (data.error || 'Unbekannter Fehler'));
        }
      } catch(e){
        console.error('Send failed:', e);
        showError(panel || 'left', 'Senden fehlgeschlagen — Server nicht erreichbar');
      }
    }

    async function loadHistory(){
      try {
        const res = await fetch(API_BASE + '/history?limit=' + BRIDGE_CONFIG.historyLimit);
        const data = await res.json();
        if(data.messages){
          data.messages.forEach(m => renderMessage(m));
        }
      } catch(e){ console.error('History load failed:', e); }
    }

    // Left panel send (Management Board: user → assi)
    const leftInput = document.querySelector('.chatInput--left textarea');
    const leftSend = document.querySelector('.chatInput--left .chatSend');

    function sendLeftMsg(){
      const text = leftInput.value.trim();
      if(!text) return;
      const to = getCustomSelectValue('leftTargetWrap', 'ordo');
      if(to === 'all_managers'){
        MANAGEMENT_AGENTS.forEach(agentId => {
          setAgentPanel(agentId, 'left');
          sendMessage('user', agentId, text, 'left');
        });
      } else {
        setAgentPanel(to, 'left');
        sendMessage('user', to, text, 'left');
      }
      leftInput.value = '';
      leftInput.style.height = 'auto';
    }

    leftSend.addEventListener('click', sendLeftMsg);
    leftInput.addEventListener('keydown', e => {
      if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendLeftMsg(); }
    });

    // Right panel send (Team Board: user → selected target)
    const rightInput = document.querySelector('.chatInput--right textarea');
    const rightSend = document.querySelector('.chatInput--right .chatSend');

    function sendRightMsg(){
      const text = rightInput.value.trim();
      if(!text) return;
      const to = getCustomSelectValue('rightTargetWrap', 'all');
      if(to === 'all_team'){
        // FE30: Broadcast to selected team members
        const members = getSelectedTeamMembers();
        if(members){
          members.forEach(m => {
            setAgentPanel(m, 'right');
            sendMessage('user', m, text, 'right');
          });
        }
      } else if(to === 'all'){
        Object.keys(agentPanel).forEach(k => setAgentPanel(k, 'right'));
        sendMessage('user', to, text, 'right');
      } else {
        setAgentPanel(to, 'right');
        sendMessage('user', to, text, 'right');
      }
      rightInput.value = '';
      rightInput.style.height = 'auto';
    }

    rightSend.addEventListener('click', sendRightMsg);
    rightInput.addEventListener('keydown', e => {
      if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendRightMsg(); }
    });

    // ========== Phase 3: WebSocket Live-Updates ==========
    let ws = null;
    let wsRetry = 1000;

    function connectWebSocket(){
      ws = new WebSocket(WS_URL);
      ws.onopen = () => {
        wsRetry = 1000;
        updateConnectionDot(true);
        setWsBanner(false);
      };
      ws.onmessage = ev => {
        try {
          const data = JSON.parse(ev.data);
          if(data.type === 'message' && data.message) renderMessage(data.message);
          if(data.type === 'agent_status') pollAgentStatus();
          if(data.type === 'agent_registered') pollAgentStatus();
        } catch(e){}
      };
      ws.onclose = () => {
        updateConnectionDot(false);
        setWsBanner(true);
        setTimeout(connectWebSocket, wsRetry);
        wsRetry = Math.min(wsRetry * 2, 30000);
      };
      ws.onerror = () => ws.close();
    }

    // ========== Phase 4: Agent-Status + FE30 Team-Tabs ==========
    let agentStatusCache = []; // all agents from /agents
    let selectedTeam = null; // {project, team} or null

    function getAgentStatus(agentId){
      const a = agentStatusCache.find(x => x.agent_id === agentId);
      if(!a) return 'dead';
      if(a.status === 'running') return 'active';
      if(a.status === 'waiting') return 'idle';
      return 'dead';
    }

    let chatActivityCache = {}; // agentId → {action, description}

    async function fetchChatActivities(){
      try {
        const res = await fetch(API_BASE + '/activity', {signal: AbortSignal.timeout(3000)});
        if(!res.ok) return;
        const data = await res.json();
        if(data.activities && Array.isArray(data.activities)){
          const map = {};
          data.activities.forEach(a => { map[a.agent_id] = {action: a.action || '', description: a.description || ''}; });
          chatActivityCache = map;
        }
      } catch(e){ /* keep cache */ }
    }

    function renderMgmtMemberBar(mgmtTeams){
      const header = document.getElementById('boardHeaderLeft');
      const bar = document.getElementById('mgmtMemberBar');
      if(!header || !bar) return;
      // Collect unique management members
      const seen = new Set();
      const members = [];
      mgmtTeams.forEach(t => t.members.forEach(m => { if(!seen.has(m)){ seen.add(m); members.push(m); } }));
      if(members.length === 0){ header.classList.remove('boardHeader--expanded'); bar.innerHTML = ''; return; }
      bar.innerHTML = members.map(m => {
        const st = getAgentStatus(m);
        const dotColor = st === 'active' ? '#22c55e' : st === 'idle' ? '#f59e0b' : '#ef4444';
        const agentInfo = agentStatusCache.find(a => a.agent_id === m);
        const role = agentInfo && agentInfo.role ? agentInfo.role.split(' ')[0] : '';
        return '<span class="memberChip" data-agent="' + m + '">' +
          '<span class="memberChip__dot" style="background:' + dotColor + '"></span>' +
          '<span class="memberChip__name">' + agentLabel(m) + '</span>' +
          (role ? '<span class="memberChip__role">' + role + '</span>' : '') +
          '</span>';
      }).join('');
      header.classList.add('boardHeader--expanded');
      // Click on chip → select in left dropdown
      bar.querySelectorAll('.memberChip').forEach(chip => {
        chip.addEventListener('click', () => {
          const agentId = chip.dataset.agent;
          const wrap = document.getElementById('leftTargetWrap');
          if(wrap) {
            wrap.dataset.value = agentId;
            document.getElementById('leftTargetTrigger').textContent = agentLabel(agentId);
            wrap.querySelectorAll('.customSelect__option').forEach(o => {
              o.classList.toggle('selected', o.dataset.value === agentId);
            });
          }
        });
      });
      // Adjust left chat top
      const chatLeft = document.querySelector('.chatMessages--left');
      if(chatLeft) requestAnimationFrame(() => { chatLeft.style.top = (header.offsetHeight + 12) + 'px'; });
    }

    function renderTeamTabs(){
      const container = document.getElementById('teamTabs');
      if(!container) return;

      // Build teams from boardProjectsCache — filter out management teams (belong LEFT)
      const allTeams = [];
      const mgmtTeams = [];
      if(boardProjectsCache){
        boardProjectsCache.forEach(p => {
          (p.teams || []).forEach(t => {
            const members = (t.members || []).map(m => m.id || m);
            const isMgmt = members.length > 0 && members.every(m => MANAGEMENT_AGENTS.has(m));
            if(isMgmt) { mgmtTeams.push({project: p.name, team: t.name, members}); }
            else { allTeams.push({project: p.name, team: t.name, members}); }
          });
        });
      }
      const teams = allTeams;

      // Render management agents in LEFT header
      renderMgmtMemberBar(mgmtTeams);

      if(teams.length === 0){
        container.innerHTML = '';
        return;
      }

      // Render team tabs
      let html = '';
      teams.forEach(t => {
        const isActive = selectedTeam && selectedTeam.project === t.project && selectedTeam.team === t.team;
        const online = t.members.filter(m => getAgentStatus(m) === 'active').length;
        html += '<span class="teamTab' + (isActive ? ' teamTab--active' : '') +
          '" data-project="' + t.project + '" data-team="' + t.team + '">' +
          t.team + ' <span class="teamTab__count">' + online + '/' + t.members.length + '</span></span>';
      });
      container.innerHTML = html;

      // Click handlers
      container.querySelectorAll('.teamTab').forEach(tab => {
        tab.addEventListener('click', () => {
          const proj = tab.dataset.project;
          const team = tab.dataset.team;
          if(selectedTeam && selectedTeam.project === proj && selectedTeam.team === team){
            selectedTeam = null; // Deselect → collapse
          } else {
            selectedTeam = {project: proj, team: team};
          }
          renderTeamTabs();
          updateRightDropdownForTeam();
        });
      });

      // Member Bar — inline im Header, keine Overlay-Panel
      const header = document.getElementById('boardHeaderRight');
      const bar = document.getElementById('memberBar');
      if(header && bar){
        if(!selectedTeam){
          header.classList.remove('boardHeader--expanded');
          bar.innerHTML = '';
        } else {
          const t = teams.find(x => x.project === selectedTeam.project && x.team === selectedTeam.team);
          if(t){
            const currentTarget = getCustomSelectValue('rightTargetWrap', '');
            bar.innerHTML = t.members.map(m => {
              const st = getAgentStatus(m);
              const dotColor = st === 'active' ? '#22c55e' : st === 'idle' ? '#f59e0b' : '#ef4444';
              const agentInfo = agentStatusCache.find(a => a.agent_id === m);
              const role = agentInfo && agentInfo.role ? agentInfo.role : '';
              const shortRole = role ? role.split(' ')[0] : '';
              const isSelected = currentTarget === m;
              return '<span class="memberChip' + (isSelected ? ' memberChip--selected' : '') + '" data-agent="' + m + '">' +
                '<span class="memberChip__dot" style="background:' + dotColor + '"></span>' +
                '<span class="memberChip__name">' + agentLabel(m) + '</span>' +
                (shortRole ? '<span class="memberChip__role">' + shortRole + '</span>' : '') +
                '</span>';
            }).join('');
            header.classList.add('boardHeader--expanded');
            // Click on chip → select agent in dropdown
            bar.querySelectorAll('.memberChip').forEach(chip => {
              chip.addEventListener('click', () => {
                const agentId = chip.dataset.agent;
                const wrap = document.getElementById('rightTargetWrap');
                if(wrap) {
                  wrap.dataset.value = agentId;
                  document.getElementById('rightTargetTrigger').textContent = agentLabel(agentId);
                  wrap.querySelectorAll('.customSelect__option').forEach(o => {
                    o.classList.toggle('selected', o.dataset.value === agentId);
                  });
                }
                bar.querySelectorAll('.memberChip').forEach(c => c.classList.remove('memberChip--selected'));
                chip.classList.add('memberChip--selected');
              });
            });
          } else {
            header.classList.remove('boardHeader--expanded');
            bar.innerHTML = '';
          }
        }
        // Adjust chat top to match header height
        const chatRight = document.querySelector('.chatMessages--right');
        if(chatRight){
          requestAnimationFrame(() => {
            chatRight.style.top = (header.offsetHeight + 12) + 'px';
          });
        }
      }
    }

    function getSelectedTeamMembers(){
      if(!selectedTeam || !boardProjectsCache) return null;
      for(const p of boardProjectsCache){
        if(p.name === selectedTeam.project){
          for(const t of (p.teams || [])){
            if(t.name === selectedTeam.team){
              return (t.members || []).map(m => m.id || m);
            }
          }
        }
      }
      return null;
    }

    function updateRightDropdownForTeam(){
      const members = getSelectedTeamMembers();
      const activeAgents = agentStatusCache.filter(a => a.status !== 'disconnected');

      if(!members){
        // No team selected — show all agents
        const rightOpts = [{value:'all', label:'Alle'}].concat(
          activeAgents.map(a => ({value:a.agent_id, label:agentLabel(a.agent_id)}))
        );
        populateRightDropdown(rightOpts, 'all');
      } else {
        // Team selected — show team members + "Alle (Teamname)"
        const label = 'Alle (' + selectedTeam.team + ')';
        const rightOpts = [{value:'all_team', label: label}].concat(
          members.map(m => ({value:m, label:agentLabel(m)}))
        );
        populateRightDropdown(rightOpts, 'all_team');
      }
    }

    function populateRightDropdown(options, defaultVal){
      const wrap = document.getElementById('rightTargetWrap');
      const trigger = document.getElementById('rightTargetTrigger');
      const dropdown = document.getElementById('rightTargetDropdown');
      if(!wrap || !trigger || !dropdown) return;
      const current = wrap.dataset.value || defaultVal;
      dropdown.innerHTML = '';
      const vals = options.map(o => o.value);
      options.forEach(o => {
        const div = document.createElement('div');
        div.className = 'customSelect__option';
        div.dataset.value = o.value;
        div.textContent = o.label;
        dropdown.appendChild(div);
      });
      let resolved = vals.includes(current) ? current : defaultVal;
      if(!vals.includes(resolved) && options.length) resolved = options[0].value;
      wrap.dataset.value = resolved;
      const selectedOpt = options.find(o => o.value === resolved);
      trigger.textContent = selectedOpt ? selectedOpt.label : resolved;
      dropdown.querySelectorAll('.customSelect__option').forEach(d => {
        d.classList.toggle('selected', d.dataset.value === resolved);
      });
    }

    async function pollAgentStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        if(!data.agents) return;

        // Populate AGENT_LABELS dynamically from response
        data.agents.forEach(a => {
          if(a.agent_id && a.agent_id !== 'user' && !AGENT_LABELS[a.agent_id]){
            AGENT_LABELS[a.agent_id] = a.role ? a.agent_id.charAt(0).toUpperCase() + a.agent_id.slice(1) : a.agent_id;
          }
        });

        agentStatusCache = data.agents;
        const activeAgents = data.agents.filter(a => a.status !== 'disconnected');

        // FE30: Render team tabs instead of flat agent bar
        renderTeamTabs();

        // Update target dropdowns
        updateTargetDropdown(activeAgents, data.agents);
      } catch(e){
        console.error('Agent status failed:', e);
        const container = document.getElementById('teamTabs');
        if(container) container.innerHTML = '<span class="teamTab" style="color:#ef4444;cursor:default">Verbindung verloren</span>';
      }
    }

    // ========== Projekt-Badge (Task B) ==========
    let boardProjectsCache = null;

    async function fetchBoardProjects(){
      try {
        const res = await fetch(API_BASE + '/board/projects');
        const data = await res.json();
        if(data.projects && data.projects.length > 0){
          boardProjectsCache = data.projects;
          renderTeamTabs();
        }
      } catch(e){ /* keep cache */ }
    }

    function getAgentProjects(agentId){
      if(!boardProjectsCache || !agentId) return [];
      const projects = [];
      boardProjectsCache.forEach(p => {
        const found = (p.teams || []).some(t => (t.members || []).some(m => m.id === agentId));
        if(found) projects.push(p.name);
      });
      return projects;
    }

    function updateProjectBadge(){
      const badge = document.getElementById('leftProjectBadge');
      if(!badge) return;
      // FE14/FE28: Show sidebar-selected project, fallback to agent's projects
      if(sidebarProjectFilter){
        badge.innerHTML = '<span class="projectBadge__item">' + sidebarProjectFilter + '</span>';
        return;
      }
      const agentId = getCustomSelectValue('leftTargetWrap', '');
      const projects = getAgentProjects(agentId);
      if(projects.length === 0){
        badge.innerHTML = '';
        return;
      }
      badge.innerHTML = projects.map(n => '<span class="projectBadge__item">' + n + '</span>').join('');
    }

    function updateTargetDropdown(agents, allAgents){
      if(!allAgents) allAgents = agents;
      // Helper: populate a custom select dropdown
      function populateCustomSelect(wrapId, triggerId, dropdownId, options, currentVal, defaultVal){
        const wrap = document.getElementById(wrapId);
        const trigger = document.getElementById(triggerId);
        const dropdown = document.getElementById(dropdownId);
        if(!wrap || !trigger || !dropdown) return currentVal;
        const current = wrap.dataset.value || currentVal;
        dropdown.innerHTML = '';
        options.forEach(o => {
          const div = document.createElement('div');
          div.className = 'customSelect__option' + (o.value === current ? ' selected' : '');
          div.dataset.value = o.value;
          div.textContent = o.label;
          dropdown.appendChild(div);
        });
        // Resolve value: keep current if still in list, else fallback
        const vals = options.map(o => o.value);
        let resolved = vals.includes(current) ? current : defaultVal;
        if(!vals.includes(resolved) && options.length) resolved = options[0].value;
        wrap.dataset.value = resolved;
        const selectedOpt = options.find(o => o.value === resolved);
        trigger.textContent = selectedOpt ? selectedOpt.label : resolved;
        // Mark selected
        dropdown.querySelectorAll('.customSelect__option').forEach(d => {
          d.classList.toggle('selected', d.dataset.value === resolved);
        });
        return resolved;
      }

      // FE29: Split agents — management from ALL agents (incl. offline), team from active only
      const mgmtAgents = allAgents.filter(a => isManagementAgent(a.agent_id));

      // FE30: Right panel now managed by updateRightDropdownForTeam()
      updateRightDropdownForTeam();

      // Left panel: "Alle Manager" + management agents only
      const leftOpts = [{value:'all_managers', label:'Alle Manager'}].concat(
        mgmtAgents.map(a => ({value:a.agent_id, label:agentLabel(a.agent_id)}))
      );
      const prevLeft = getCustomSelectValue('leftTargetWrap', 'ordo');
      const newLeft = populateCustomSelect('leftTargetWrap', 'leftTargetTrigger', 'leftTargetDropdown', leftOpts, prevLeft, 'ordo');
      if(newLeft !== prevLeft) rerenderAll();
      updateProjectBadge();
    }

    // ========== Phase 5: Connection Indicator ==========
    let connDot = null;

    function createConnectionDot(){
      // Connection indicator in right header (not left — member chips show status there)
      const header = document.querySelector('.boardHeader--right');
      if(!header) return;
      connDot = document.createElement('span');
      connDot.className = 'agentBar__dot';
      connDot.style.marginLeft = '4px';
      connDot.title = 'Disconnected';
      updateConnectionDot(false);
      const title = header.querySelector('.boardHeader__title');
      if(title) title.after(connDot);
    }

    function updateConnectionDot(connected){
      if(!connDot) return;
      connDot.className = 'agentBar__dot ' + (connected ? 'agentBar__dot--active' : 'agentBar__dot--dead');
      connDot.title = connected ? 'Connected' : 'Disconnected';
    }

    // ========== Rerender on dropdown change ==========
    function rerenderAll(){
      leftInner.innerHTML = '';
      rightInner.innerHTML = '';
      renderedIds.clear();
      messageCache.forEach(m => renderMessage(m, true));
    }

    // Change listener on leftTarget — rerenders all messages when user switches agent
    document.getElementById('leftTargetWrap').addEventListener('change', rerenderAll);

    // ========== Phase 6: Dynamic Sidebar ==========
    const SB_COLORS = ['#C15F3C','#2B7FD4','#6B9F5B','#D4A14E','#9B6BC1','#E07B53','#4A90D9','#7CB342'];
    const sbStarredList = document.getElementById('sbStarredList');
    const sbProjectList = document.getElementById('sbProjectList');
    const sbActivityList = document.getElementById('sbActivityList');

    function relativeTime(ts) {
      if (!ts) return '';
      const diff = (Date.now() - new Date(ts).getTime()) / 1000;
      if (diff < 60) return 'now';
      if (diff < 3600) return Math.floor(diff/60) + 'm';
      if (diff < 86400) return Math.floor(diff/3600) + 'h';
      if (diff < 604800) return Math.floor(diff/86400) + 'd';
      return Math.floor(diff/604800) + 'w';
    }

    function renderSbItem(name, color, agentDots, meta, isActive) {
      const div = document.createElement('div');
      div.className = 'sbItem' + (isActive ? ' active' : '');
      div.setAttribute('role', 'button');
      div.setAttribute('tabindex', '0');
      div.setAttribute('aria-label', name);
      div.innerHTML =
        '<span class="sbDot" style="background:' + color + '"></span>' +
        '<span class="sbName">' + name + '</span>' +
        (agentDots ? '<span class="sbAgents">' + agentDots + '</span>' : '') +
        (meta ? '<span class="sbMeta">' + meta + '</span>' : '');
      return div;
    }

    // FE14/FE28: Sidebar-Filter — Projekt/Team-Auswahl filtert BEIDE Panels
    let sidebarProjectFilter = null; // project name or null
    let expandedSidebarProjects = new Set(); // which projects are expanded

    function selectSidebarProject(projectName){
      if(sidebarProjectFilter === projectName) {
        sidebarProjectFilter = null; // Deselect
      } else {
        sidebarProjectFilter = projectName;
        expandedSidebarProjects.add(projectName);
      }
      // Update Team Board: auto-select first team of project
      if(sidebarProjectFilter && boardProjectsCache){
        const proj = boardProjectsCache.find(p => p.name === sidebarProjectFilter);
        if(proj && proj.teams && proj.teams.length > 0){
          selectedTeam = {project: proj.name, team: proj.teams[0].name};
        }
      } else {
        selectedTeam = null;
      }
      renderTeamTabs();
      updateRightDropdownForTeam();
      updateProjectBadge();
      renderSidebarProjects();
      rerenderAll();
    }

    function selectSidebarTeam(projectName, teamName){
      sidebarProjectFilter = projectName;
      selectedTeam = {project: projectName, team: teamName};
      renderTeamTabs();
      updateRightDropdownForTeam();
      renderSidebarProjects();
      rerenderAll();
    }

    function renderSidebarProjects(){
      // Starred: show selected project (or first project)
      sbStarredList.innerHTML = '';
      if(boardProjectsCache && boardProjectsCache.length > 0){
        const starred = sidebarProjectFilter
          ? boardProjectsCache.find(p => p.name === sidebarProjectFilter) || boardProjectsCache[0]
          : boardProjectsCache[0];
        const totalMembers = (starred.teams || []).reduce((n, t) => n + (t.members || []).length, 0);
        const onlineCount = (starred.teams || []).reduce((n, t) =>
          n + (t.members || []).filter(m => getAgentStatus(m.id || m) === 'active').length, 0);
        const item = renderSbItem(starred.name, SB_COLORS[0], '', onlineCount + '/' + totalMembers, !!sidebarProjectFilter);
        item.addEventListener('click', () => selectSidebarProject(starred.name));
        sbStarredList.appendChild(item);
      }

      // Projects: all from boardProjectsCache with expandable teams
      sbProjectList.innerHTML = '';
      if(boardProjectsCache){
        boardProjectsCache.forEach((p, i) => {
          const color = SB_COLORS[(i + 1) % SB_COLORS.length];
          const isSelected = sidebarProjectFilter === p.name;
          const isExpanded = expandedSidebarProjects.has(p.name);

          // Project row
          const item = document.createElement('div');
          item.className = 'sbItem sbItem--project' + (isSelected ? ' sbItem--selected' : '');
          item.setAttribute('role', 'button');
          item.setAttribute('tabindex', '0');
          const expandSvg = '<svg class="sbExpandIcon' + (isExpanded ? ' sbExpandIcon--open' : '') +
            '" viewBox="0 0 24 24"><polyline points="9,6 15,12 9,18"/></svg>';
          item.innerHTML = expandSvg +
            '<span class="sbDot" style="background:' + color + '"></span>' +
            '<span class="sbName">' + p.name + '</span>' +
            '<span class="sbMeta">' + (p.teams || []).length + ' Teams</span>';
          item.addEventListener('click', () => selectSidebarProject(p.name));
          sbProjectList.appendChild(item);

          // Teams (expandable)
          if(isExpanded && p.teams){
            const teamsDiv = document.createElement('div');
            teamsDiv.className = 'sbTeams';
            p.teams.forEach(t => {
              const members = (t.members || []).map(m => m.id || m);
              const online = members.filter(m => getAgentStatus(m) === 'active').length;
              const isTeamActive = selectedTeam && selectedTeam.project === p.name && selectedTeam.team === t.name;
              const teamEl = document.createElement('div');
              teamEl.className = 'sbTeamItem' + (isTeamActive ? ' sbTeamItem--active' : '');
              teamEl.innerHTML = t.name + ' <span class="sbTeamItem__count">' + online + '/' + members.length + '</span>';
              teamEl.addEventListener('click', (e) => {
                e.stopPropagation();
                selectSidebarTeam(p.name, t.name);
              });
              teamsDiv.appendChild(teamEl);
            });
            sbProjectList.appendChild(teamsDiv);
          }
        });
      }
    }

    async function loadSidebarProjects() {
      try {
        // Ensure boardProjectsCache is fresh
        await fetchBoardProjects();
        renderSidebarProjects();

        // Activity: show agent activities
        sbActivityList.innerHTML = '';
        try {
          const actRes = await fetch(API_BASE + '/activity');
          const actData = await actRes.json();
          if (actData.activities && actData.activities.length > 0) {
            actData.activities.slice(0, 5).forEach(act => {
              const div = document.createElement('div');
              div.className = 'sbActivity';
              div.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="9,18 15,12 9,6"/></svg>' +
                agentLabel(act.agent_id || '') + ': ' + (act.action || '') + (act.description ? ' — ' + act.description : '');
              sbActivityList.appendChild(div);
            });
          } else {
            sbActivityList.innerHTML = '<div class="sbActivity" style="opacity:0.5">No recent activity</div>';
          }
        } catch(e) {
          sbActivityList.innerHTML = '<div class="sbActivity" style="opacity:0.5">No recent activity</div>';
        }
      } catch(e) {
        console.error('Sidebar load failed:', e);
        sbStarredList.innerHTML = '<div class="sbActivity" style="opacity:0.5">Could not load projects</div>';
      }
    }

    // ========== Init ==========
    clearStaticMessages();
    createConnectionDot();
    // Load agents first so dropdown is populated, then load history
    fetchChatActivities();
    pollAgentStatus().then(() => loadHistory());
    connectWebSocket();
    loadSidebarProjects();
    fetchBoardProjects().then(updateProjectBadge);
    setInterval(pollAgentStatus, BRIDGE_CONFIG.pollInterval);
    setInterval(fetchChatActivities, BRIDGE_CONFIG.pollInterval);
    setInterval(loadSidebarProjects, 30000);
    setInterval(fetchBoardProjects, 30000);

    // Update badge when left dropdown changes
    document.getElementById('leftTargetWrap').addEventListener('change', updateProjectBadge);

    // --- Resize Logik ---
    const sidebarEdge = document.getElementById('sidebarEdge');
    const mainDivider = document.getElementById('mainDivider');
    const sidebarToggle = document.getElementById('sidebarToggle');

    let sw = 14;  // Sidebar-Breite in %
    let dp = 57;  // Divider-Position in %
    let sidebarCollapsed = false;

    function setVars(){
      root.style.setProperty('--sw', sw + '%');
      root.style.setProperty('--dp', dp + '%');
    }

    // Clamp helper
    function clamp(val, min, max){ return Math.min(Math.max(val, min), max); }

    // Generischer Drag-Handler
    function makeDraggable(handle, onDrag, activeClass){
      handle.addEventListener('mousedown', e => {
        e.preventDefault();
        handle.classList.add('active');
        root.classList.add('dragging');
        const onMove = ev => onDrag(ev.clientX / window.innerWidth * 100);
        const onUp = () => {
          handle.classList.remove('active');
          root.classList.remove('dragging');
          window.removeEventListener('mousemove', onMove);
          window.removeEventListener('mouseup', onUp);
        };
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
      });
    }

    // Sidebar-Edge: Sidebar-Breite aendern
    makeDraggable(sidebarEdge, pct => {
      sw = clamp(pct, 4, 30);
      // dp muss rechts von sw bleiben, mindestens sw+10
      dp = clamp(dp, sw + 10, 95);
      sidebarCollapsed = sw <= 5;
      root.classList.toggle('collapsed', sidebarCollapsed);
      setVars();
    });

    // Main-Divider: Divider-Position aendern
    makeDraggable(mainDivider, pct => {
      dp = clamp(pct, sw + 10, 95);
      setVars();
    });

    // Sidebar Collapse Toggle
    sidebarToggle.addEventListener('click', () => {
      sidebarCollapsed = !sidebarCollapsed;
      if(sidebarCollapsed){
        sw = 4;
        dp = clamp(dp, 14, 95);
      } else {
        sw = 14;
        dp = clamp(dp, 24, 95);
      }
      root.classList.toggle('collapsed', sidebarCollapsed);
      sidebarToggle.setAttribute('aria-expanded', !sidebarCollapsed);
      setVars();
    });
  </script>
</body>
</html>
