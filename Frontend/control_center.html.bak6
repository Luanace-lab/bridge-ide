    let dashScenarioIdx = 0;
    let dashEventIdx = 0;

    function dashProcessEvent(evt){
      switch(evt.type){
        case 'status': dashHandleStatus(evt.agent, evt.data); break;
        case 'typing': dashHandleTyping(evt.agent, evt.dur); break;
        case 'message': dashHandleMessage(evt.agent, evt.to, evt.text, evt.detail); break;
        case 'tool': dashHandleTool(evt.agent, evt.data[0], evt.data[1]); break;
        case 'task': dashHandleTask(evt.agent, evt.data[0], evt.data[1]); break;
      }
    }

    function dashScheduleNext(){
      const scenario = dashScenarios[dashScenarioIdx];
      if(dashEventIdx >= scenario.length){
        dashScenarioIdx = (dashScenarioIdx + 1) % dashScenarios.length;
        dashEventIdx = 0;
        setTimeout(dashScheduleNext, 4000);
        return;
      }
      const evt = scenario[dashEventIdx];
      dashProcessEvent(evt);
      dashEventIdx++;
      const base = evt.type === 'typing' ? 800 : 1500;
      const jitter = Math.random() * 2500;
      setTimeout(dashScheduleNext, base + jitter);
    }

    /* ═══════════════════════════════════════════
       TEAM BOARD ENGINE
