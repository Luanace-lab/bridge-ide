<!doctype html>
<html lang="de" data-theme="warm">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bridge – Control Center</title>
  <style>
    /* ─── Themes (shared, single source) ─── */
    html[data-theme="warm"]{
      --bg:#fbf8f1; --bgFlat:#fbf8f1;
      --sidebar:#c8bfa8; --sbThumb:#b8af98; --sbDark:#8a7f6a;
    }
    html[data-theme="light"]{
      --bg:#ffffff; --bgFlat:#ffffff;
      --sidebar:#d6e8f7; --sbThumb:#b8d4ed; --sbDark:#5a9ac7;
    }
    html[data-theme="rose"]{
      --bg:#fdf2f4; --bgFlat:#fdf2f4;
      --sidebar:#e8c4cc; --sbThumb:#d9adb7; --sbDark:#a3707e;
    }
    html[data-theme="dark"]{
      --bg:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);
      --bgFlat:#161e3a;
      --sidebar:#1e2a42; --sbThumb:#2d3f5e; --sbDark:#8aa4c8;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    html,body{ height:100%; overflow:hidden; }
    body{
      background:var(--bg);
      font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
      color:#3d3d3a;
      display:flex; flex-direction:column;
    }
    html[data-theme="dark"] body{ color:#e7edf5; }

    /* ─── Top Bar ─── */
    .topBar{
      flex-shrink:0;
      display:flex; align-items:center; justify-content:space-between;
      padding:8px 24px;
      background:color-mix(in srgb, var(--sidebar) 18%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      backdrop-filter:blur(12px);
      z-index:10;
    }
    .topBar__left{ display:flex; align-items:center; gap:10px; }
    .topBar__logo{ height:28px; width:auto; }
    .topBar__title{
      font-size:11px; font-weight:700; text-transform:uppercase;
      letter-spacing:.6px; color:var(--sbDark);
    }
    .topBar__liveDot{
      width:7px; height:7px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }
    @keyframes livePulse{
      0%,100%{ opacity:1; transform:scale(1); }
      50%{ opacity:.5; transform:scale(1.3); }
    }
    .topBar__stats{
      display:flex; align-items:center; gap:14px;
      font-size:10px; font-weight:500; color:#8f8f8f;
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .topBar__stats{ color:#6b7a8f; }
    .topBar__stats b{ color:#3d3d3a; font-weight:700; }
    html[data-theme="dark"] .topBar__stats b{ color:#e7edf5; }
    .topBar__right{ display:flex; align-items:center; gap:12px; }
    .statusDots{ display:flex; align-items:center; gap:6px; }
    .statusDot{ width:8px; height:8px; border-radius:50%; }
    .statusDot--live{ background:#22c55e; }
    .statusDot--connecting{ background:#f59e0b; }
    .statusDot--disconnected{ background:#ef4444; }
    .statusLabel{ font-size:10px; font-weight:500; color:#8f8f8f; }
    html[data-theme="dark"] .statusLabel{ color:#6b7a8f; }
    .themeSwitcher{ display:flex; gap:4px; }
    .themeBtn{
      width:16px; height:16px; border-radius:50%;
      border:2px solid transparent; cursor:pointer;
      transition:border-color .15s ease, transform .15s ease;
    }
    .themeBtn:hover{ transform:scale(1.15); }
    .themeBtn.active{ border-color:var(--sbDark); }
    .themeBtn[data-theme="warm"]{ background:#c8bfa8; }
    .themeBtn[data-theme="light"]{ background:#d6e8f7; }
    .themeBtn[data-theme="rose"]{ background:#e8c4cc; }
    .themeBtn[data-theme="dark"]{ background:#1e2a42; }

    /* ─── Page Navigation ─── */
    .topBar__nav{ display:flex; gap:2px; background:color-mix(in srgb, var(--sidebar) 15%, transparent); border-radius:6px; padding:2px; margin-left:16px; }
    .topBar__navLink{
      font-size:10px; font-weight:500; text-decoration:none;
      padding:4px 10px; border-radius:4px; color:#8f8f8f;
      transition:background .15s, color .15s;
    }
    .topBar__navLink:hover{ background:color-mix(in srgb, var(--sidebar) 25%, transparent); color:#3d3d3a; }
    .topBar__navLink--active{ background:color-mix(in srgb, var(--sidebar) 30%, transparent); color:var(--sbDark); font-weight:600; }
    html[data-theme="dark"] .topBar__navLink{ color:#6b7a8f; }
    html[data-theme="dark"] .topBar__navLink:hover{ color:#e7edf5; }
    html[data-theme="dark"] .topBar__navLink--active{ color:#8aa4c8; }

    /* ─── Combined Layout ─── */
    .combined{
      flex:1; display:flex; flex-direction:column;
      overflow:hidden; min-height:0;
    }

    /* ─── Section Label Bars ─── */
    .sectionLabel{
      flex-shrink:0;
      display:flex; align-items:center; gap:6px;
      padding:5px 16px;
      font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:#8f8f8f;
      background:color-mix(in srgb, var(--sidebar) 10%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
    }
    html[data-theme="dark"] .sectionLabel{
      color:#6b7a8f;
      background:rgba(255,255,255,.02);
      border-color:rgba(255,255,255,.04);
    }
    .sectionLabel__dot{
      width:5px; height:5px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }

    /* ─── Shared: Scrollbar ─── */
    .scrollable{
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 20%, var(--bgFlat)) transparent;
    }
    .scrollable::-webkit-scrollbar{ width:5px; }
    .scrollable::-webkit-scrollbar-track{ background:transparent; }
    .scrollable::-webkit-scrollbar-thumb{
      background:color-mix(in srgb, var(--sbDark) 22%, var(--bgFlat));
      border-radius:999px;
    }

    /* ─── Shared: Animations ─── */
    @keyframes sectionIn{
      from{ opacity:0; transform:translateY(12px); }
      to{ opacity:1; transform:translateY(0); }
    }
    @keyframes feedIn{
      from{ opacity:0; transform:translateX(-8px); }
      to{ opacity:1; transform:translateX(0); }
    }

    /* ═══════════════════════════════════════════
       DASHBOARD SECTION (top)
    ═══════════════════════════════════════════ */
    .dashSection{
      flex:4; display:flex; flex-direction:column;
      overflow:hidden; min-height:0;
      animation:sectionIn .5s ease both;
    }
    .dashContent{
      flex:1; display:flex; flex-direction:column;
      padding:8px 16px 4px; gap:6px;
      overflow:hidden; min-height:0;
    }

    /* Network Graph (compact) */
    .networkGraph{
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px;
      padding:4px 8px;
      flex-shrink:0;
      height:120px;
    }
    html[data-theme="dark"] .networkGraph{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .networkGraph svg{ width:100%; height:100%; display:block; }
    .nodeLabel{
      font-size:9px; font-weight:600; text-transform:uppercase;
      letter-spacing:.3px;
    }
    .nodeInitial{ font-size:11px; font-weight:700; }
    .nodeStatus{ font-size:7px; }

    /* Status Cards Row (compact) */
    .cardsRow{
      display:flex; gap:6px; flex-shrink:0;
    }
    .statusCard{
      flex:1;
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:8px;
      padding:6px 10px;
      position:relative;
      overflow:hidden;
    }
    html[data-theme="dark"] .statusCard{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .statusCard__accent{
      position:absolute; left:0; top:0; bottom:0; width:3px;
    }
    .statusCard__header{
      display:flex; align-items:center; gap:5px; margin-bottom:2px;
    }
    .statusCard__dot{
      width:6px; height:6px; border-radius:50%; flex-shrink:0;
    }
    .statusCard__name{ font-size:10px; font-weight:700; }
    .statusCard__badge{
      font-size:7px; font-weight:600; text-transform:uppercase;
      letter-spacing:.3px; padding:1px 4px; border-radius:3px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      color:var(--sbDark); margin-left:auto;
    }
    .statusCard__task{
      font-size:9px; color:#8f8f8f; margin-bottom:3px;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    html[data-theme="dark"] .statusCard__task{ color:#6b7a8f; }
    .statusCard__sparkline{
      width:100%; height:18px; display:block;
    }
    .statusCard__stats{
      display:flex; gap:10px; margin-top:2px;
    }
    .statusCard__stat{
      font-size:8px; color:#8f8f8f;
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .statusCard__stat{ color:#6b7a8f; }
    .statusCard__stat b{ color:#3d3d3a; font-weight:600; }
    html[data-theme="dark"] .statusCard__stat b{ color:#e7edf5; }

    /* Activity Feed (compact) */
    .feedSection{
      flex:1; display:flex; flex-direction:column;
      min-height:0; position:relative;
    }
    .feedSection__header{
      display:flex; align-items:center; gap:5px;
      font-size:8px; font-weight:700; text-transform:uppercase;
      letter-spacing:.4px; color:#8f8f8f; margin-bottom:3px;
    }
    html[data-theme="dark"] .feedSection__header{ color:#6b7a8f; }
    .feedSection__headerDot{
      width:5px; height:5px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }
    .activityFeed{
      flex:1; overflow-y:auto; display:flex; flex-direction:column;
      gap:2px; padding-right:4px; min-height:0;
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 20%, var(--bgFlat)) transparent;
    }
    .activityFeed::-webkit-scrollbar{ width:5px; }
    .activityFeed::-webkit-scrollbar-track{ background:transparent; }
    .activityFeed::-webkit-scrollbar-thumb{
      background:color-mix(in srgb, var(--sbDark) 22%, var(--bgFlat));
      border-radius:999px;
    }
    .feedEntry{
      display:flex; align-items:flex-start; gap:6px;
      padding:3px 8px; border-radius:6px;
      animation:feedIn .3s ease both;
      font-size:10px; line-height:1.3;
      transition:background .12s ease;
    }
    .feedEntry:hover{
      background:color-mix(in srgb, var(--sidebar) 10%, transparent);
    }
    html[data-theme="dark"] .feedEntry:hover{
      background:rgba(255,255,255,.03);
    }
    .feedEntry__time{
      font-size:8px; color:#8f8f8f; flex-shrink:0; width:38px;
      font-variant-numeric:tabular-nums; padding-top:1px;
    }
    html[data-theme="dark"] .feedEntry__time{ color:#6b7a8f; }
    .feedEntry__icon{
      width:14px; height:14px; flex-shrink:0; border-radius:3px;
      display:flex; align-items:center; justify-content:center;
    }
    .feedEntry__icon svg{
      width:9px; height:9px; fill:none; stroke:#fff;
      stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round;
    }
    .feedEntry__icon--message{ background:#6366f1; }
    .feedEntry__icon--tool{ background:#06b6d4; }
    .feedEntry__icon--status{ background:#22c55e; }
    .feedEntry__icon--task{ background:#f59e0b; }
    .feedEntry__icon--error{ background:#ef4444; }
    .feedEntry__content{ flex:1; }
    .feedEntry__agent{ font-weight:700; margin-right:3px; }
    .feedEntry__detail{
      color:#8f8f8f; font-size:9px; margin-top:1px;
    }
    html[data-theme="dark"] .feedEntry__detail{ color:#6b7a8f; }

    /* Typing Indicator */
    .typingIndicator{
      display:none; align-items:center; gap:6px;
      padding:3px 8px; font-size:10px; color:#8f8f8f;
    }
    .typingIndicator.visible{ display:flex; }
    html[data-theme="dark"] .typingIndicator{ color:#6b7a8f; }
    .typingDots{ display:flex; gap:3px; }
    .typingDot{
      width:3px; height:3px; border-radius:50%;
      background:#8f8f8f; animation:bounce .6s ease-in-out infinite;
    }
    html[data-theme="dark"] .typingDot{ background:#6b7a8f; }
    .typingDot:nth-child(2){ animation-delay:.1s; }
    .typingDot:nth-child(3){ animation-delay:.2s; }
    @keyframes bounce{
      0%,100%{ transform:translateY(0); }
      50%{ transform:translateY(-3px); }
    }

    /* New Activity Pill */
    .newActivityPill{
      position:absolute; bottom:4px; left:50%; transform:translateX(-50%);
      background:var(--sbDark); color:#fff; font-size:9px; font-weight:600;
      padding:3px 10px; border-radius:10px; cursor:pointer;
      display:none; z-index:5;
      box-shadow:0 2px 8px rgba(0,0,0,.15);
      transition:opacity .2s ease;
    }
    html[data-theme="dark"] .newActivityPill{ color:#0f172a; }
    .newActivityPill.visible{ display:block; }

    /* SVG Path Animations */
    @keyframes flowIdle{
      to{ stroke-dashoffset:-14; }
    }
    @keyframes flowActive{
      to{ stroke-dashoffset:-14; }
    }
    .pathIdle{
      stroke-dasharray:4 3;
      animation:flowIdle 4s linear infinite;
    }
    .pathActive{
      stroke-dasharray:6 2;
      animation:flowActive 1.5s linear infinite;
    }

    /* ═══════════════════════════════════════════
       TEAM BOARD SECTION (bottom)
    ═══════════════════════════════════════════ */
    .teamBoardSection{
      flex:6; display:flex;
      overflow:hidden; min-height:0;
      animation:sectionIn .5s ease both;
      animation-delay:.15s;
    }

    /* ─── Project Sidebar (left, 240px) ─── */
    .projectSidebar{
      width:240px; flex-shrink:0;
      display:flex; flex-direction:column;
      border-right:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      background:color-mix(in srgb, var(--sidebar) 6%, var(--bgFlat));
      overflow:hidden;
    }
    html[data-theme="dark"] .projectSidebar{
      background:rgba(255,255,255,.02);
      border-color:rgba(255,255,255,.06);
    }
    .projectSidebar__header{ padding:8px 10px 0; }
    .projectSidebar__headerLabel{
      display:flex; align-items:center; gap:5px;
      font-size:8px; font-weight:700; text-transform:uppercase;
      letter-spacing:.4px; color:#8f8f8f; margin-bottom:4px;
    }
    html[data-theme="dark"] .projectSidebar__headerLabel{ color:#6b7a8f; }
    .projectSidebar__headerDot{
      width:5px; height:5px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }
    .projectSidebar__list{
      flex:1; overflow-y:auto; padding:4px 8px;
    }

    /* Project Card */
    .projectCard{
      border-radius:7px;
      margin-bottom:4px;
      border:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      transition:all .15s ease;
      overflow:hidden;
    }
    html[data-theme="dark"] .projectCard{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .projectCard.selected{
      border-left:3px solid var(--sbDark);
      background:color-mix(in srgb, var(--sidebar) 16%, var(--bgFlat));
    }
    html[data-theme="dark"] .projectCard.selected{
      background:rgba(255,255,255,.06);
    }
    .projectCard__toggle{
      display:flex; align-items:center; gap:6px;
      width:100%; background:none; border:none; cursor:pointer;
      font-family:inherit; padding:6px 8px;
      transition:background .12s ease;
    }
    .projectCard__toggle:hover{ background:rgba(0,0,0,.03); }
    html[data-theme="dark"] .projectCard__toggle:hover{ background:rgba(255,255,255,.03); }
    .projectCard__arrow{
      width:11px; height:11px; flex-shrink:0;
      fill:none; stroke:#8f8f8f; stroke-width:2.5;
      stroke-linecap:round; stroke-linejoin:round;
      transition:transform .2s ease;
    }
    html[data-theme="dark"] .projectCard__arrow{ stroke:#6b7a8f; }
    .projectCard__toggle.open .projectCard__arrow{ transform:rotate(90deg); }
    .projectCard__name{
      font-size:10px; font-weight:700; color:#3d3d3a; flex:1; text-align:left;
    }
    html[data-theme="dark"] .projectCard__name{ color:#e7edf5; }
    .projectCard__info{
      padding:0 8px 4px 25px;
      font-size:9px; color:#8f8f8f;
    }
    html[data-theme="dark"] .projectCard__info{ color:#6b7a8f; }
    .projectCard__created{
      padding:0 8px 4px 25px;
      font-size:8px; color:#a0a0a0;
    }
    html[data-theme="dark"] .projectCard__created{ color:#5a6a7f; }
    .projectCard__teams{
      display:none; padding:2px 8px 6px 25px;
    }
    .projectCard__teams.open{ display:block; }
    .projectCard__teamItem{
      display:flex; align-items:center; gap:5px;
      padding:2px 0; font-size:9px;
    }
    .projectCard__teamName{ font-weight:600; color:#3d3d3a; }
    html[data-theme="dark"] .projectCard__teamName{ color:#e7edf5; }
    .projectCard__teamCount{
      color:#8f8f8f; font-size:8px; margin-left:auto;
    }
    html[data-theme="dark"] .projectCard__teamCount{ color:#6b7a8f; }

    /* Ampel Dot */
    .ampelDot{
      width:7px; height:7px; border-radius:50%; flex-shrink:0;
      display:inline-block;
    }
    .ampelDot--green{ background:#22c55e; }
    .ampelDot--yellow{ background:#f59e0b; }
    .ampelDot--red{ background:#ef4444; }
    .ampelDot--standby{ background:#8f8f8f; }
    .ampelDot--sm{ width:5px; height:5px; }

    /* ─── Team Board Main (right) ─── */
    .teamBoardMain{
      flex:1; display:flex; flex-direction:column;
      min-width:0; overflow:hidden;
    }
    .boardHeader{
      flex-shrink:0;
      display:flex; align-items:center; gap:8px;
      padding:8px 14px 4px;
    }
    .boardHeader__projectName{
      font-size:12px; font-weight:700; color:#3d3d3a;
    }
    html[data-theme="dark"] .boardHeader__projectName{ color:#e7edf5; }
    .boardHeader__badge{
      font-size:7px; font-weight:600; text-transform:uppercase;
      letter-spacing:.3px; padding:2px 6px; border-radius:3px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      color:var(--sbDark);
    }
    .boardHeader__spacer{ flex:1; }

    /* ─── Search Field ─── */
    .teamBoardSearch{
      width:220px;
      padding:5px 10px;
      font-size:10px;
      border:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      border-radius:6px;
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      color:#3d3d3a;
      outline:none;
      transition:border-color .15s ease, box-shadow .15s ease;
    }
    .teamBoardSearch::placeholder{ color:#8f8f8f; }
    .teamBoardSearch:focus{
      border-color:var(--sbDark);
      box-shadow:0 0 0 2px color-mix(in srgb, var(--sbDark) 15%, transparent);
    }
    html[data-theme="dark"] .teamBoardSearch{
      background:rgba(255,255,255,.03);
      color:#e7edf5;
      border-color:rgba(255,255,255,.08);
    }
    html[data-theme="dark"] .teamBoardSearch::placeholder{ color:#6b7a8f; }
    html[data-theme="dark"] .teamBoardSearch:focus{
      border-color:#8aa4c8;
      box-shadow:0 0 0 2px rgba(138,164,200,.15);
    }

    /* View Toggle */
    .viewToggle{
      display:flex; gap:2px;
      background:color-mix(in srgb, var(--sidebar) 15%, transparent);
      border-radius:6px; padding:2px;
    }
    .viewToggle__btn{
      font-size:9px; font-weight:500;
      padding:3px 10px; border-radius:4px; color:#8f8f8f;
      transition:background .15s, color .15s;
      border:none; background:none; cursor:pointer; font-family:inherit;
    }
    .viewToggle__btn:hover{ background:color-mix(in srgb, var(--sidebar) 25%, transparent); color:#3d3d3a; }
    .viewToggle__btn.active{ background:color-mix(in srgb, var(--sidebar) 30%, transparent); color:var(--sbDark); font-weight:600; }
    html[data-theme="dark"] .viewToggle__btn{ color:#6b7a8f; }
    html[data-theme="dark"] .viewToggle__btn:hover{ color:#e7edf5; }
    html[data-theme="dark"] .viewToggle__btn.active{ color:#8aa4c8; }

    /* Team Board Content */
    .teamBoardContent{
      flex:1; overflow-y:auto; padding:8px 14px;
      display:flex; flex-direction:column; gap:8px;
    }

    /* ─── Project View: Team Group Card ─── */
    .teamGroupCard{
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px;
      overflow:hidden;
      animation:feedIn .3s ease both;
    }
    html[data-theme="dark"] .teamGroupCard{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .teamGroupCard__header{
      display:flex; align-items:center; gap:8px;
      padding:8px 12px;
    }
    .teamGroupCard__name{
      font-size:11px; font-weight:700; color:#3d3d3a;
    }
    html[data-theme="dark"] .teamGroupCard__name{ color:#e7edf5; }
    .teamGroupCard__meta{
      font-size:8px; color:#8f8f8f; margin-left:auto;
    }
    html[data-theme="dark"] .teamGroupCard__meta{ color:#6b7a8f; }
    .teamGroupCard__body{
      padding:0 12px 8px;
      display:flex; flex-direction:column; gap:2px;
    }

    /* Agent Row */
    .agentRow{
      display:flex; align-items:center; gap:8px;
      padding:5px 8px;
      border-radius:6px;
      transition:background .12s ease;
    }
    .agentRow:hover{
      background:color-mix(in srgb, var(--sidebar) 10%, transparent);
    }
    html[data-theme="dark"] .agentRow:hover{
      background:rgba(255,255,255,.03);
    }
    .agentRow__name{
      font-size:10px; font-weight:700; min-width:80px;
    }
    .agentRow__role{
      font-size:9px; color:#8f8f8f; flex:1;
    }
    html[data-theme="dark"] .agentRow__role{ color:#6b7a8f; }
    .agentRow__time{
      font-size:8px; color:#a0a0a0; margin-left:auto; white-space:nowrap; flex-shrink:0;
    }
    html[data-theme="dark"] .agentRow__time{ color:#5a6a7f; }
    .agentRow__activity{
      font-size:8px; color:#888; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    }
    html[data-theme="dark"] .agentRow__activity{ color:#5a6a7f; }
    .agentRow__contextWarn{
      font-size:7px; font-weight:600; padding:1px 5px; border-radius:3px;
      background:rgba(245,158,11,.12); color:#d97706; border:1px solid rgba(245,158,11,.2);
    }
    .agentRow__contextWarn--critical{
      background:rgba(239,68,68,.12); color:#dc2626; border-color:rgba(239,68,68,.2);
    }
    html[data-theme="dark"] .agentRow__contextWarn{
      background:rgba(245,158,11,.15); color:#f59e0b; border-color:rgba(245,158,11,.25);
    }
    html[data-theme="dark"] .agentRow__contextWarn--critical{
      background:rgba(239,68,68,.15); color:#ef4444; border-color:rgba(239,68,68,.25);
    }
    .agentRow__alsoIn{
      display:flex; gap:3px; flex-wrap:wrap;
    }
    .alsoInBadge{
      font-size:7px; font-weight:600; padding:1px 5px; border-radius:3px;
      background:rgba(99,102,241,.1); color:#6366f1;
      border:1px solid rgba(99,102,241,.15);
    }
    html[data-theme="dark"] .alsoInBadge{
      background:rgba(99,102,241,.15);
      border-color:rgba(99,102,241,.25);
    }

    /* Drag & Drop States */
    .agentRow[draggable="true"]{ cursor:grab; }
    .agentRow.dragging{ opacity:.4; }
    .teamGroupCard.dragOver{
      outline:2px dashed var(--sbDark);
      outline-offset:-2px;
      background:color-mix(in srgb, var(--sidebar) 12%, transparent);
    }
    html[data-theme="dark"] .teamGroupCard.dragOver{
      outline-color:#8aa4c8;
      background:rgba(255,255,255,.05);
    }

    /* ─── Project Group (Expand/Collapse) ─── */
    .projectGroup{ margin-bottom:4px; }
    .projectGroup__header{
      display:flex; align-items:center; gap:8px;
      padding:7px 12px; cursor:pointer;
      border-radius:8px;
      background:color-mix(in srgb, var(--sidebar) 10%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
      transition:background .15s ease;
      user-select:none;
    }
    .projectGroup__header:hover{
      background:color-mix(in srgb, var(--sidebar) 18%, transparent);
    }
    html[data-theme="dark"] .projectGroup__header{
      background:rgba(255,255,255,.04);
      border-color:rgba(255,255,255,.07);
    }
    html[data-theme="dark"] .projectGroup__header:hover{
      background:rgba(255,255,255,.07);
    }
    .projectGroup__arrow{
      width:12px; height:12px; flex-shrink:0;
      fill:none; stroke:#8f8f8f; stroke-width:2.5;
      stroke-linecap:round; stroke-linejoin:round;
      transition:transform .2s ease;
    }
    html[data-theme="dark"] .projectGroup__arrow{ stroke:#6b7a8f; }
    .projectGroup__header.open .projectGroup__arrow{ transform:rotate(90deg); }
    .projectGroup__name{
      font-size:11px; font-weight:700; color:#3d3d3a;
    }
    html[data-theme="dark"] .projectGroup__name{ color:#e7edf5; }
    .projectGroup__meta{
      font-size:8px; color:#8f8f8f; margin-left:auto;
    }
    html[data-theme="dark"] .projectGroup__meta{ color:#6b7a8f; }
    .projectGroup__body{
      display:flex; flex-direction:column; gap:8px;
      padding-top:6px;
      overflow:hidden;
      transition:max-height .25s ease, opacity .2s ease, padding .2s ease;
    }
    .projectGroup__body.collapsed{
      display:none;
    }

    /* ─── Agent View: Agent Card ─── */
    .agentViewCard{
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px;
      padding:10px 14px;
      animation:feedIn .3s ease both;
      display:flex; align-items:flex-start; gap:10px;
    }
    html[data-theme="dark"] .agentViewCard{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .agentViewCard__info{ flex:1; }
    .agentViewCard__name{
      font-size:11px; font-weight:700;
      display:flex; align-items:center; gap:6px;
    }
    .agentViewCard__role{
      font-size:9px; color:#8f8f8f; margin-top:2px;
    }
    html[data-theme="dark"] .agentViewCard__role{ color:#6b7a8f; }
    .agentViewCard__time{
      font-size:8px; color:#a0a0a0; margin-top:1px;
    }
    html[data-theme="dark"] .agentViewCard__time{ color:#5a6a7f; }
    .agentViewCard__activity{
      font-size:8px; color:#888; margin-top:1px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    }
    html[data-theme="dark"] .agentViewCard__activity{ color:#5a6a7f; }
    .agentViewCard__contextWarn{
      font-size:7px; font-weight:600; padding:1px 5px; border-radius:3px; display:inline-block; margin-top:2px;
      background:rgba(245,158,11,.12); color:#d97706; border:1px solid rgba(245,158,11,.2);
    }
    .agentViewCard__contextWarn--critical{
      background:rgba(239,68,68,.12); color:#dc2626; border-color:rgba(239,68,68,.2);
    }
    html[data-theme="dark"] .agentViewCard__contextWarn{
      background:rgba(245,158,11,.15); color:#f59e0b; border-color:rgba(245,158,11,.25);
    }
    html[data-theme="dark"] .agentViewCard__contextWarn--critical{
      background:rgba(239,68,68,.15); color:#ef4444; border-color:rgba(239,68,68,.25);
    }
    .agentViewCard__projects{
      margin-top:6px;
      display:flex; flex-direction:column; gap:3px;
    }
    .agentViewCard__projectItem{
      display:flex; align-items:center; gap:6px;
      font-size:9px; color:#3d3d3a;
      padding:3px 8px;
      border-radius:4px;
      background:color-mix(in srgb, var(--sidebar) 8%, transparent);
    }
    html[data-theme="dark"] .agentViewCard__projectItem{
      color:#e7edf5;
      background:rgba(255,255,255,.03);
    }
    .agentViewCard__projectName{ font-weight:600; }
    .agentViewCard__teams{
      font-size:8px; color:#8f8f8f; margin-left:auto;
    }
    html[data-theme="dark"] .agentViewCard__teams{ color:#6b7a8f; }

    /* ─── Metrics Bar (combined) ─── */
    .metricsBar{
      flex-shrink:0;
      display:flex; align-items:center; justify-content:space-around;
      padding:7px 24px;
      background:color-mix(in srgb, var(--sidebar) 12%, var(--bgFlat));
      border-top:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .metricsBar{
      background:rgba(0,0,0,.2);
      border-color:rgba(255,255,255,.06);
    }
    .metric{
      display:flex; flex-direction:column; align-items:center; gap:1px;
    }
    .metric__value{
      font-size:15px; font-weight:700; color:#3d3d3a;
      font-variant-numeric:tabular-nums;
      display:flex; align-items:center; gap:3px;
    }
    html[data-theme="dark"] .metric__value{ color:#e7edf5; }
    .metric__label{
      font-size:8px; font-weight:600; text-transform:uppercase;
      letter-spacing:.4px; color:#8f8f8f;
    }
    html[data-theme="dark"] .metric__label{ color:#6b7a8f; }
    .metric__progress{
      width:50px; height:3px; border-radius:2px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      overflow:hidden;
    }
    .metric__progressFill{
      height:100%; border-radius:2px;
      background:var(--sbDark);
      transition:width .5s ease;
    }
    .metric__pulse{
      width:5px; height:5px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }

    /* ─── Accessibility: Focus + Skip-Link ─── */
    *:focus-visible{
      outline:2px solid #3b82f6;
      outline-offset:2px;
    }
    .skipLink{
      position:fixed;
      top:-100%;
      left:16px;
      z-index:10000;
      padding:8px 16px;
      background:var(--bgFlat);
      color:var(--sbDark);
      border:2px solid #3b82f6;
      border-radius:8px;
      font-size:14px;
      text-decoration:none;
      transition:top .2s;
    }
    .skipLink:focus{
      top:8px;
    }

    /* ─── Responsive: Mobile (<768px) ─── */
    @media (max-width:767px){
      /* Top Bar: compact */
      .topBar{
        padding:6px 12px;
        flex-wrap:wrap;
        gap:4px;
      }
      .topBar__stats{
        display:none;
      }

      /* Allow body scroll on mobile */
      html,body{
        overflow:auto;
      }
      body{
        min-height:100vh;
        height:auto;
      }

      /* Stack dashboard + task vertically, allow scroll */
      .combined{
        flex:none;
        overflow:visible;
      }
      .dashSection{
        flex:none;
        overflow:visible;
        min-height:auto;
      }
      .dashContent{
        overflow:visible;
      }

      /* Network graph smaller */
      .networkGraph{
        height:90px;
      }

      /* Cards: stack vertically */
      .cardsRow{
        flex-direction:column;
      }

      /* Activity feed: fixed height with scroll */
      .feedSection{
        min-height:150px;
        max-height:200px;
      }

      /* Team Board section: stack vertically */
      .teamBoardSection{
        flex:none;
        flex-direction:column;
        overflow:visible;
        min-height:auto;
      }

      /* Project sidebar: horizontal strip */
      .projectSidebar{
        width:100%;
        max-height:140px;
        border-right:none;
        border-bottom:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      }
      .projectSidebar__list{
        display:flex;
        flex-direction:row;
        gap:4px;
        overflow-x:auto;
        overflow-y:hidden;
        flex-wrap:nowrap;
      }
      .projectCard{
        min-width:140px;
        flex-shrink:0;
      }

      /* Team board main: full width, scrollable */
      .teamBoardMain{
        overflow:visible;
        min-height:300px;
      }
      .teamBoardContent{
        overflow:visible;
        max-height:none;
      }

      /* Metrics bar: wrap */
      .metricsBar{
        flex-wrap:wrap;
        gap:8px 16px;
        padding:8px 12px;
      }
    }

    /* ─── Responsive: Tablet (768–1024px) ─── */
    @media (min-width:768px) and (max-width:1024px){
      .topBar{
        padding:6px 16px;
      }
      .networkGraph{
        height:100px;
      }
      .projectSidebar{
        width:160px;
      }
      /* Reset mobile stacking for tablet */
      .cardsRow{
        flex-direction:row;
      }
      .feedSection{
        min-height:0;
        max-height:none;
      }
      html,body{
        overflow:hidden;
      }
      body{
        height:100vh;
        min-height:auto;
      }
    }

    /* ═══════════════════════════════════════════
       TAB SYSTEM
    ═══════════════════════════════════════════ */
    .ccTabBar{
      flex-shrink:0;
      display:flex; gap:0;
      padding:0 16px;
      background:color-mix(in srgb, var(--sidebar) 10%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
    }
    html[data-theme="dark"] .ccTabBar{
      background:rgba(255,255,255,.02);
      border-color:rgba(255,255,255,.04);
    }
    .ccTab{
      padding:8px 16px;
      font-size:10px; font-weight:600; text-transform:uppercase;
      letter-spacing:.5px; color:#8f8f8f;
      background:none; border:none;
      border-bottom:2px solid transparent;
      cursor:pointer; transition:color .15s, border-color .15s;
    }
    .ccTab:hover{ color:var(--sbDark); }
    .ccTab.active{ color:var(--sbDark); border-bottom-color:var(--sbDark); }
    html[data-theme="dark"] .ccTab{ color:#6b7a8f; }
    html[data-theme="dark"] .ccTab:hover{ color:#e7edf5; }
    html[data-theme="dark"] .ccTab.active{ color:#8aa4c8; border-bottom-color:#8aa4c8; }
    .ccTabPanel{
      display:none; flex:1;
      flex-direction:column; overflow:hidden; min-height:0;
    }
    .ccTabPanel.active{ display:flex; }

    /* ═══════════════════════════════════════════
       LIVEBOARD PANEL
    ═══════════════════════════════════════════ */
    .lbGrid{
      flex:1; display:grid;
      grid-template-columns:280px 1fr;
      grid-template-rows:auto 1fr auto;
      gap:8px; padding:8px 16px;
      min-height:0; overflow:hidden;
    }
    .lbTeamPanel{ grid-row:1/3; }
    .lbScopePanel{ grid-column:1/-1; max-height:160px; }

    .lbPanel{
      display:flex; flex-direction:column;
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px; overflow:hidden; min-height:0;
    }
    html[data-theme="dark"] .lbPanel{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    .lbPanel__header{
      flex-shrink:0; display:flex; align-items:center; gap:6px;
      padding:8px 12px;
      font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:#8f8f8f;
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
    }
    html[data-theme="dark"] .lbPanel__header{
      color:#6b7a8f; border-color:rgba(255,255,255,.04);
    }
    .lbPanel__headerDot{
      width:5px; height:5px; border-radius:50%;
      background:#22c55e; animation:livePulse 2s ease-in-out infinite;
    }
    .lbPanel__body{
      flex:1; overflow-y:auto; padding:8px; min-height:0;
    }

    /* Empty States */
    .lbEmpty{
      display:flex; align-items:center; justify-content:center;
      height:100%; min-height:60px;
      font-size:11px; color:#8f8f8f; font-style:italic;
    }
    html[data-theme="dark"] .lbEmpty{ color:#6b7a8f; }
    .lbEmpty--ok{ color:#22c55e; font-style:normal; }
    .lbEmpty--error{ color:#ef4444; font-style:normal; }

    /* Loading */
    .lbLoading{
      display:flex; align-items:center; justify-content:center;
      height:100%; min-height:60px; gap:6px;
    }
    .lbLoadingDot{
      width:6px; height:6px; border-radius:50%;
      background:var(--sbDark); opacity:.3;
      animation:lbPulse 1.2s ease-in-out infinite;
    }
    .lbLoadingDot:nth-child(2){ animation-delay:.2s; }
    .lbLoadingDot:nth-child(3){ animation-delay:.4s; }
    @keyframes lbPulse{
      0%,80%,100%{ opacity:.3; transform:scale(1); }
      40%{ opacity:1; transform:scale(1.3); }
    }

    /* Team-Status Entries */
    .lbAgent{
      display:flex; align-items:flex-start; gap:8px;
      padding:8px; border-radius:6px; transition:background .15s;
    }
    .lbAgent:hover{ background:color-mix(in srgb, var(--sidebar) 12%, transparent); }
    html[data-theme="dark"] .lbAgent:hover{ background:rgba(255,255,255,.04); }
    .lbAgent__dot{
      width:8px; height:8px; border-radius:50%;
      flex-shrink:0; margin-top:3px;
    }
    .lbAgent__dot--online{ background:#22c55e; }
    .lbAgent__dot--paused{ background:#8f8f8f; }
    .lbAgent__dot--problem{ background:#ef4444; }
    .lbAgent__info{ flex:1; min-width:0; }
    .lbAgent__name{ font-size:12px; font-weight:600; }
    .lbAgent__task{
      font-size:10px; color:#8f8f8f;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    html[data-theme="dark"] .lbAgent__task{ color:#6b7a8f; }
    .lbAgent__scope{ font-size:9px; color:#8f8f8f; margin-top:2px; }
    html[data-theme="dark"] .lbAgent__scope{ color:#6b7a8f; }
    .lbAgent__blocker{ font-size:9px; color:#f59e0b; margin-top:2px; }
    .lbAgent__time{ font-size:9px; color:#8f8f8f; flex-shrink:0; }
    html[data-theme="dark"] .lbAgent__time{ color:#6b7a8f; }

    /* Alert Entries */
    .lbAlert{
      padding:8px 10px; border-radius:6px; margin-bottom:4px;
      font-size:11px; display:flex; align-items:flex-start; gap:8px;
    }
    .lbAlert--critical{
      background:rgba(239,68,68,.1); border-left:3px solid #ef4444; color:#ef4444;
    }
    html[data-theme="dark"] .lbAlert--critical{ background:rgba(239,68,68,.15); }
    .lbAlert--warning{
      background:rgba(245,158,11,.1); border-left:3px solid #f59e0b; color:#92400e;
    }
    html[data-theme="dark"] .lbAlert--warning{ background:rgba(245,158,11,.1); color:#f59e0b; }
    .lbAlert--info{
      background:rgba(34,197,94,.08); border-left:3px solid #22c55e; color:#166534;
    }
    html[data-theme="dark"] .lbAlert--info{ background:rgba(34,197,94,.1); color:#22c55e; }
    .lbAlert__content{ flex:1; }
    .lbAlert__agent{ font-weight:600; }
    .lbAlert__time{ font-size:9px; color:#8f8f8f; flex-shrink:0; }

    /* Timeline Entries */
    .lbTimeEntry{
      display:flex; align-items:flex-start; gap:8px;
      padding:6px 8px; font-size:11px;
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 10%, transparent);
    }
    html[data-theme="dark"] .lbTimeEntry{ border-color:rgba(255,255,255,.03); }
    .lbTimeEntry__time{
      font-size:10px; color:#8f8f8f; font-weight:500;
      flex-shrink:0; min-width:40px; font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .lbTimeEntry__time{ color:#6b7a8f; }
    .lbTimeEntry__icon{ flex-shrink:0; font-size:12px; }
    .lbTimeEntry__content{ flex:1; min-width:0; }
    .lbTimeEntry__agent{ font-weight:600; }

    /* Scope Lock Entries */
    .lbScope{
      display:flex; align-items:center; gap:10px;
      padding:6px 10px; font-size:11px;
    }
    .lbScope__label{ flex:1; font-weight:600; }
    .lbScope__agent{ display:flex; align-items:center; gap:4px; }
    .lbScope__dot{ width:6px; height:6px; border-radius:50%; }
    .lbScope__time{ font-size:9px; color:#8f8f8f; }
    html[data-theme="dark"] .lbScope__time{ color:#6b7a8f; }
    .lbScope__overlap{ font-size:9px; color:#f59e0b; font-weight:600; }

    /* Stufe-3 Eskalations-Dialog */
    .lbEscalation{
      position:fixed; inset:0;
      background:rgba(0,0,0,.6); z-index:10000;
      display:flex; align-items:center; justify-content:center;
    }
    .lbEscalation__inner{
      background:var(--bgFlat); border-radius:12px;
      padding:24px; max-width:440px; width:90%;
      box-shadow:0 8px 32px rgba(0,0,0,.3);
      border:2px solid #ef4444;
    }
    .lbEscalation__title{
      font-size:14px; font-weight:700; color:#ef4444;
      margin-bottom:8px; display:flex; align-items:center; gap:8px;
    }
    .lbEscalation__msg{
      font-size:12px; color:#8f8f8f; margin-bottom:16px; line-height:1.5;
    }
    html[data-theme="dark"] .lbEscalation__msg{ color:#6b7a8f; }
    .lbEscalation__actions{
      display:flex; gap:8px; flex-wrap:wrap;
    }
    .lbEscBtn{
      padding:8px 16px; border:none; border-radius:6px;
      font-size:11px; font-weight:600; cursor:pointer;
      transition:opacity .15s;
    }
    .lbEscBtn:hover{ opacity:.85; }
    .lbEscBtn--extend{ background:#22c55e; color:#fff; }
    .lbEscBtn--reassign{ background:#3b82f6; color:#fff; }
    .lbEscBtn--cancel{ background:#ef4444; color:#fff; }
    .lbEscBtn:disabled{ opacity:.4; cursor:not-allowed; }
    .lbEscSelect{
      padding:6px 10px; border:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      border-radius:6px; font-size:11px; background:var(--bgFlat);
      color:var(--sbDark); outline:none;
    }

    /* WS Reconnect Banner */
    .lbReconnect{
      padding:6px 12px; text-align:center;
      font-size:10px; font-weight:600;
      background:rgba(245,158,11,.15); color:#92400e;
      border-bottom:1px solid rgba(245,158,11,.3);
    }
    html[data-theme="dark"] .lbReconnect{ color:#f59e0b; }

    /* Responsive: Liveboard mobile */
    @media (max-width:767px){
      .lbGrid{
        grid-template-columns:1fr;
        grid-template-rows:auto;
        overflow:auto;
      }
      .lbTeamPanel{ grid-row:auto; }
      .lbScopePanel{ grid-column:auto; max-height:none; }
    }
    @media (min-width:768px) and (max-width:1024px){
      .lbGrid{ grid-template-columns:220px 1fr; }
    }
  </style>
</head>
<body>
  <a class="skipLink" href="#activityFeed">Skip to content</a>

  <!-- ─── Top Bar ─── -->
  <header class="topBar" role="banner">
    <div class="topBar__left">
      <img class="topBar__logo" src="ace_logo.svg" alt="ACE Logo">
      <div class="topBar__liveDot" role="status" aria-label="Live indicator"></div>
      <div class="topBar__title">Control Center</div>
      <nav class="topBar__nav" aria-label="Page navigation">
        <a class="topBar__navLink" href="chat.html">Chat</a>
        <a class="topBar__navLink topBar__navLink--active" href="control_center.html">Control Center</a>
        <a class="topBar__navLink" href="project_config.html">Neues Projekt</a>
      </nav>
    </div>
    <div class="topBar__stats" id="topStats" aria-label="Project statistics">
      <span><b id="topProjects">0</b> Projekte</span>
      <span><b id="topTeams">0</b> Teams</span>
      <span><b id="topAgents">0</b> Agenten</span>
    </div>
    <div class="topBar__right">
      <div class="statusDots" aria-label="System status">
        <span class="statusDot statusDot--live"></span>
        <span class="statusDot statusDot--connecting"></span>
        <span class="statusDot statusDot--disconnected"></span>
        <span class="statusLabel">System</span>
      </div>
      <div class="themeSwitcher" role="group" aria-label="Theme selection">
        <button class="themeBtn" data-theme="warm" title="Warm" aria-label="Theme: Warm"></button>
        <button class="themeBtn" data-theme="light" title="Light" aria-label="Theme: Light"></button>
        <button class="themeBtn" data-theme="rose" title="Rose" aria-label="Theme: Rose"></button>
        <button class="themeBtn" data-theme="dark" title="Dark" aria-label="Theme: Dark"></button>
      </div>
    </div>
  </header>

  <!-- ─── Combined Content ─── -->
  <main class="combined">

    <!-- Tab Bar -->
    <div class="ccTabBar" role="tablist" aria-label="Control Center Ansichten">
      <button class="ccTab active" data-tab="dashboard" role="tab" aria-selected="true" aria-controls="tabDashboard">Dashboard</button>
      <button class="ccTab" data-tab="liveboard" role="tab" aria-selected="false" aria-controls="tabLiveboard">Live-Board</button>
    </div>

    <!-- ═══ DASHBOARD TAB ═══ -->
    <div class="ccTabPanel active" id="tabDashboard" data-panel="dashboard" role="tabpanel">

    <!-- ═══ LIVE DASHBOARD (top) ═══ -->
    <div class="sectionLabel">
      <span class="sectionLabel__dot"></span>
      Live Dashboard
    </div>
    <section class="dashSection" aria-label="Live Dashboard">
      <div class="dashContent">
        <!-- Network Graph -->
        <div class="networkGraph" role="img" aria-label="Agent network topology">
          <svg viewBox="0 0 400 170" xmlns="http://www.w3.org/2000/svg">
            <path id="pathLA" d="M200,45 C160,90 100,100 70,135" fill="none" stroke="#6366f1" stroke-width="1.5" opacity=".3" class="pathIdle"/>
            <path id="pathLB" d="M200,45 C240,90 300,100 330,135" fill="none" stroke="#6366f1" stroke-width="1.5" opacity=".3" class="pathIdle"/>
            <path id="pathAB" d="M70,135 C130,155 270,155 330,135" fill="none" stroke="#06b6d4" stroke-width="1.5" opacity=".2" class="pathIdle"/>
            <!-- Leader Node -->
            <circle cx="200" cy="45" r="22" fill="none" stroke="#6366f1" stroke-width="1" opacity=".15">
              <animate attributeName="r" values="22;28;22" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values=".15;.05;.15" dur="3s" repeatCount="indefinite"/>
            </circle>
            <circle id="nodeRing0" cx="200" cy="45" r="18" fill="none" stroke="#6366f1" stroke-width="1.5" opacity=".4"/>
            <circle id="nodeFill0" cx="200" cy="45" r="16" fill="#6366f1" opacity=".12"/>
            <text id="nodeInitial0" x="200" y="49" text-anchor="middle" fill="#6366f1" class="nodeInitial">L</text>
            <circle id="dashStatusL" cx="214" cy="33" r="3.5" fill="#22c55e"/>
            <text id="nodeLabel0" x="200" y="72" text-anchor="middle" fill="#8f8f8f" class="nodeLabel">Leader</text>
            <!-- Agent A Node -->
            <circle cx="70" cy="135" r="22" fill="none" stroke="#06b6d4" stroke-width="1" opacity=".15">
              <animate attributeName="r" values="22;28;22" dur="3.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values=".15;.05;.15" dur="3.5s" repeatCount="indefinite"/>
            </circle>
            <circle id="nodeRing1" cx="70" cy="135" r="18" fill="none" stroke="#06b6d4" stroke-width="1.5" opacity=".4"/>
            <circle id="nodeFill1" cx="70" cy="135" r="16" fill="#06b6d4" opacity=".12"/>
            <text id="nodeInitial1" x="70" y="139" text-anchor="middle" fill="#06b6d4" class="nodeInitial">A</text>
            <circle id="dashStatusA" cx="84" cy="123" r="3.5" fill="#22c55e"/>
            <text id="nodeLabel1" x="70" y="162" text-anchor="middle" fill="#8f8f8f" class="nodeLabel">Agent A</text>
            <!-- Agent B Node -->
            <circle cx="330" cy="135" r="22" fill="none" stroke="#f59e0b" stroke-width="1" opacity=".15">
              <animate attributeName="r" values="22;28;22" dur="2.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values=".15;.05;.15" dur="2.8s" repeatCount="indefinite"/>
            </circle>
            <circle id="nodeRing2" cx="330" cy="135" r="18" fill="none" stroke="#f59e0b" stroke-width="1.5" opacity=".4"/>
            <circle id="nodeFill2" cx="330" cy="135" r="16" fill="#f59e0b" opacity=".12"/>
            <text id="nodeInitial2" x="330" y="139" text-anchor="middle" fill="#f59e0b" class="nodeInitial">B</text>
            <circle id="dashStatusB" cx="344" cy="123" r="3.5" fill="#f59e0b"/>
            <text id="nodeLabel2" x="330" y="162" text-anchor="middle" fill="#8f8f8f" class="nodeLabel">Agent B</text>
            <g id="packetLayer"></g>
          </svg>
        </div>

        <!-- Status Cards -->
        <div class="cardsRow">
          <div class="statusCard" id="cardLeader">
            <div class="statusCard__accent" style="background:#6366f1"></div>
            <div class="statusCard__header">
              <div class="statusCard__dot" style="background:#6366f1"></div>
              <span class="statusCard__name">Leader</span>
              <span class="statusCard__badge">Opus 4.6</span>
            </div>
            <div class="statusCard__task" id="dashTaskLeader">Koordiniert Team...</div>
            <svg class="statusCard__sparkline" id="sparkLeader" viewBox="0 0 120 18" preserveAspectRatio="none">
              <polyline id="sparkLineLeader" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points=""/>
            </svg>
            <div class="statusCard__stats">
              <span class="statusCard__stat">Nachr.: <b id="statLeaderMsgs">0</b></span>
              <span class="statusCard__stat">Aufgaben: <b id="statLeaderTasks">0</b></span>
            </div>
          </div>
          <div class="statusCard" id="cardAgentA">
            <div class="statusCard__accent" style="background:#06b6d4"></div>
            <div class="statusCard__header">
              <div class="statusCard__dot" style="background:#06b6d4"></div>
              <span class="statusCard__name">Agent A</span>
              <span class="statusCard__badge">Sonnet 4.6</span>
            </div>
            <div class="statusCard__task" id="dashTaskAgentA">Wartet auf Aufgabe...</div>
            <svg class="statusCard__sparkline" id="sparkAgentA" viewBox="0 0 120 18" preserveAspectRatio="none">
              <polyline id="sparkLineAgentA" fill="none" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points=""/>
            </svg>
            <div class="statusCard__stats">
              <span class="statusCard__stat">Nachr.: <b id="statAgentAMsgs">0</b></span>
              <span class="statusCard__stat">Werkzeuge: <b id="statAgentATools">0</b></span>
            </div>
          </div>
          <div class="statusCard" id="cardAgentB">
            <div class="statusCard__accent" style="background:#f59e0b"></div>
            <div class="statusCard__header">
              <div class="statusCard__dot" style="background:#f59e0b"></div>
              <span class="statusCard__name">Agent B</span>
              <span class="statusCard__badge">Sonnet 4.6</span>
            </div>
            <div class="statusCard__task" id="dashTaskAgentB">Wartet auf Aufgabe...</div>
            <svg class="statusCard__sparkline" id="sparkAgentB" viewBox="0 0 120 18" preserveAspectRatio="none">
              <polyline id="sparkLineAgentB" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points=""/>
            </svg>
            <div class="statusCard__stats">
              <span class="statusCard__stat">Nachr.: <b id="statAgentBMsgs">0</b></span>
              <span class="statusCard__stat">Werkzeuge: <b id="statAgentBTools">0</b></span>
            </div>
          </div>
        </div>

        <!-- Activity Feed -->
        <div class="feedSection">
          <div class="feedSection__header">
            <span class="feedSection__headerDot"></span>
            Aktivitaet
          </div>
          <div class="activityFeed scrollable" id="activityFeed" role="log" aria-label="Activity feed" aria-live="polite"></div>
          <div class="typingIndicator" id="typingIndicator">
            <div class="typingDots">
              <div class="typingDot"></div>
              <div class="typingDot"></div>
              <div class="typingDot"></div>
            </div>
            <span id="typingAgent">Leader tippt...</span>
          </div>
          <button class="newActivityPill" id="newActivityPill" aria-label="Zur neuen Aktivitaet scrollen">Neue Aktivitaet</button>
        </div>
      </div>
    </section>

    <!-- ═══ TEAM BOARD (bottom) ═══ -->
    <div class="sectionLabel">
      <span class="sectionLabel__dot"></span>
      Team Board
    </div>
    <section class="teamBoardSection" aria-label="Team Board">
      <aside class="projectSidebar" aria-label="Projects">
        <div class="projectSidebar__header">
          <div class="projectSidebar__headerLabel">
            <span class="projectSidebar__headerDot"></span>
            Projekte
          </div>
        </div>
        <div class="projectSidebar__list scrollable" id="projectList" role="list" aria-label="Project list"></div>
      </aside>
      <div class="teamBoardMain">
        <div class="boardHeader">
          <span class="ampelDot" id="boardProjectAmpel"></span>
          <span class="boardHeader__projectName" id="boardProjectName">Bridge IDE</span>
          <span class="boardHeader__badge" id="boardTeamCount">2 Teams</span>
          <span class="boardHeader__spacer"></span>
          <input type="text" id="teamBoardSearch" class="teamBoardSearch" placeholder="Suche (Agent, Team, Projekt)..." aria-label="Suche im Team Board">
          <button class="viewToggle__btn" id="newProjectBtn" style="margin-right:8px;background:rgba(34,197,94,.15);color:#16a34a;font-weight:600" title="Neues Projekt anlegen">+ Neues Projekt</button>
          <div class="viewToggle" id="viewToggle" role="group" aria-label="View mode">
            <button class="viewToggle__btn active" data-view="project">Projekt-Sicht</button>
            <button class="viewToggle__btn" data-view="agent">Agent-Sicht</button>
          </div>
        </div>
        <div class="teamBoardContent scrollable" id="teamBoardContent"></div>
      </div>
    </section>

    </div><!-- /tabDashboard -->

    <!-- ═══ LIVEBOARD TAB ═══ -->
    <div class="ccTabPanel" id="tabLiveboard" data-panel="liveboard" role="tabpanel">
      <div class="lbGrid">
        <!-- Team-Status Panel (links) -->
        <div class="lbPanel lbTeamPanel">
          <div class="lbPanel__header">
            <span class="lbPanel__headerDot"></span>
            Team-Status
          </div>
          <div class="lbPanel__body scrollable" id="lbTeamList">
            <div class="lbEmpty">Alle Team-Mitglieder sind gerade offline</div>
          </div>
        </div>

        <!-- Alerts Panel (rechts oben) -->
        <div class="lbPanel lbAlertsPanel">
          <div class="lbPanel__header">
            <span class="lbPanel__headerDot"></span>
            Benachrichtigungen
          </div>
          <div class="lbPanel__body scrollable" id="lbAlertsList">
            <div class="lbEmpty lbEmpty--ok">Alles laeuft</div>
          </div>
        </div>

        <!-- Timeline Panel (mitte) -->
        <div class="lbPanel lbTimelinePanel">
          <div class="lbPanel__header">
            <span class="lbPanel__headerDot"></span>
            Aktivitaeten
          </div>
          <div class="lbPanel__body scrollable" id="lbTimeline">
            <div class="lbEmpty">Noch keine Aktivitaet</div>
          </div>
        </div>

        <!-- Reservierte Bereiche Panel (unten) -->
        <div class="lbPanel lbScopePanel">
          <div class="lbPanel__header">
            <span class="lbPanel__headerDot"></span>
            Reservierte Bereiche
          </div>
          <div class="lbPanel__body scrollable" id="lbScopeLocks">
            <div class="lbEmpty">Keine reservierten Bereiche</div>
          </div>
        </div>
      </div>
    </div><!-- /tabLiveboard -->

  </main><!-- /combined -->

  <!-- Stufe-3 Eskalations-Dialog (hidden) -->
  <div class="lbEscalation" id="lbEscalationDialog" style="display:none" role="alertdialog" aria-modal="true" aria-labelledby="lbEscTitle">
    <div class="lbEscalation__inner">
      <div class="lbEscalation__title" id="lbEscTitle">⚠ Eskalation — Stufe 3</div>
      <div class="lbEscalation__msg" id="lbEscMsg"></div>
      <div class="lbEscalation__actions">
        <button class="lbEscBtn lbEscBtn--extend" id="lbEscExtend">Mehr Zeit geben</button>
        <select class="lbEscSelect" id="lbEscAgentSelect" style="display:none" aria-label="Agent auswaehlen"></select>
        <button class="lbEscBtn lbEscBtn--reassign" id="lbEscReassign">Uebergeben</button>
        <button class="lbEscBtn lbEscBtn--cancel" id="lbEscCancel">Aufgabe abbrechen</button>
      </div>
    </div>
  </div>

  <!-- ─── Metrics Bar (combined) ─── -->
  <footer class="metricsBar" role="contentinfo" aria-label="System metrics">
    <div class="metric">
      <span class="metric__value" id="metricMessages">0</span>
      <span class="metric__label">Nachrichten</span>
    </div>
    <div class="metric">
      <span class="metric__value" id="metricProjects">0</span>
      <span class="metric__label">Projekte</span>
    </div>
    <div class="metric">
      <span class="metric__value" id="metricTeams">0</span>
      <span class="metric__label">Teams</span>
    </div>
    <div class="metric">
      <span class="metric__value">
        <span id="metricAgents">0</span>
        <span class="metric__pulse"></span>
      </span>
      <span class="metric__label">Agenten</span>
    </div>
    <div class="metric">
      <span class="metric__value" id="metricUptime">00:00:00</span>
      <span class="metric__label">Laufzeit</span>
    </div>
  </footer>

  <!-- New Project Modal -->
  <div id="newProjectModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10000;align-items:center;justify-content:center" role="dialog" aria-modal="true" aria-labelledby="newProjectModalTitle">
    <div style="background:var(--bgFlat);border-radius:12px;padding:24px;max-width:400px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,.2)">
      <h2 id="newProjectModalTitle" style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--sbDark)">Neues Projekt anlegen</h2>
      <form id="newProjectForm">
        <label for="newProjectName" style="display:block;font-size:11px;font-weight:600;margin-bottom:6px;color:#8f8f8f">Projekt-Name<span style="color:#ef4444">*</span></label>
        <input type="text" id="newProjectName" name="name" required placeholder="z.B. Mein Neues Projekt" style="width:100%;padding:10px 12px;border:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);border-radius:6px;font-size:12px;background:var(--bgFlat);color:var(--sbDark);outline:none" />
        <p style="font-size:9px;color:#8f8f8f;margin:8px 0 16px">Die Projekt-ID wird automatisch generiert (aus Name: lowercase, Leerzeichen → Bindestrich).</p>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button type="button" id="newProjectCancel" style="padding:8px 16px;border:none;border-radius:6px;background:color-mix(in srgb, var(--sidebar) 20%, transparent);color:#8f8f8f;font-size:11px;font-weight:600;cursor:pointer">Abbrechen</button>
          <button type="submit" id="newProjectSubmit" style="padding:8px 16px;border:none;border-radius:6px;background:#16a34a;color:#fff;font-size:11px;font-weight:600;cursor:pointer">Projekt erstellen</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    /* ═══════════════════════════════════════════
       Theme System (single, shared)
    ═══════════════════════════════════════════ */
    const root = document.documentElement;
    const themeBtns = document.querySelectorAll('.themeBtn');

    function setTheme(theme){
      root.setAttribute('data-theme', theme);
      localStorage.setItem('bridge_theme', theme);
      themeBtns.forEach(b => b.classList.toggle('active', b.dataset.theme === theme));
    }

    const stored = localStorage.getItem('bridge_theme');
    if(stored) setTheme(stored);
    else setTheme('warm');
    themeBtns.forEach(b => b.addEventListener('click', () => setTheme(b.dataset.theme)));

    /* ═══════════════════════════════════════════
       BACKEND CONNECTION
    ═══════════════════════════════════════════ */
    const API_BASE = 'http://127.0.0.1:9111';
    const WS_URL = 'ws://127.0.0.1:9112';
    let liveMode = false;
    let ws = null;
    let wsRetry = 1000;

    function agentDisplayName(id){
      if(!id) return 'Unknown';
      if(id === 'user') return 'Leo';
      if(id === 'teamlead' || id === 'lead') return 'Leader';
      const m = id.match(/^(?:claude_|agent_)([a-z])$/);
      if(m) return 'Agent ' + m[1].toUpperCase();
      return id.charAt(0).toUpperCase() + id.slice(1);
    }

    /* ═══════════════════════════════════════════
       DASHBOARD ENGINE
    ═══════════════════════════════════════════ */

    /* DOM References (dashboard) */
    const dashFeed = document.getElementById('activityFeed');
    const dashTypingEl = document.getElementById('typingIndicator');
    const dashTypingAgent = document.getElementById('typingAgent');
    const dashNewPill = document.getElementById('newActivityPill');
    const dashPacketLayer = document.getElementById('packetLayer');

    const dashEls = {
      taskLeader: document.getElementById('dashTaskLeader'),
      taskAgentA: document.getElementById('dashTaskAgentA'),
      taskAgentB: document.getElementById('dashTaskAgentB'),
      statusL: document.getElementById('dashStatusL'),
      statusA: document.getElementById('dashStatusA'),
      statusB: document.getElementById('dashStatusB'),
      statLeaderMsgs: document.getElementById('statLeaderMsgs'),
      statLeaderTasks: document.getElementById('statLeaderTasks'),
      statAgentAMsgs: document.getElementById('statAgentAMsgs'),
      statAgentATools: document.getElementById('statAgentATools'),
      statAgentBMsgs: document.getElementById('statAgentBMsgs'),
      statAgentBTools: document.getElementById('statAgentBTools'),
    };

    /* Dashboard State */
    let dashTotalMessages = 0;
    let dashTotalTasks = 0;
    let dashAgentStats = {
      Leader: { msgs:0, tasks:0 },
      'Agent A': { msgs:0, tools:0 },
      'Agent B': { msgs:0, tools:0 },
    };
    let dashSparkData = { Leader:[], 'Agent A':[], 'Agent B':[] };
    let dashStartTime = Date.now();

    /* Uptime Counter */
    setInterval(() => {
      const diff = Math.floor((Date.now() - dashStartTime) / 1000);
      const h = String(Math.floor(diff / 3600)).padStart(2, '0');
      const m = String(Math.floor((diff % 3600) / 60)).padStart(2, '0');
      const s = String(diff % 60).padStart(2, '0');
      document.getElementById('metricUptime').textContent = h + ':' + m + ':' + s;
    }, 1000);

    /* Sparklines */
    const dashSparkEls = {
      Leader: document.getElementById('sparkLineLeader'),
      'Agent A': document.getElementById('sparkLineAgentA'),
      'Agent B': document.getElementById('sparkLineAgentB'),
    };

    function dashUpdateSparkline(agent){
      const data = dashSparkData[agent];
      if(data.length < 2) return;
      const max = Math.max(...data, 1);
      const step = 120 / (20 - 1);
      const pts = data.map((v, i) => {
        const x = i * step;
        const y = 16 - (v / max) * 14;
        return x.toFixed(1) + ',' + y.toFixed(1);
      }).join(' ');
      // Find sparkline by slot or by old name
      let el = dashSparkEls[agent];
      if(!el){
        const id = (agent || '').toLowerCase();
        const slotIdx = dashSlotAgents.indexOf(id);
        if(slotIdx >= 0){
          const polyIds = ['sparkLineLeader', 'sparkLineAgentA', 'sparkLineAgentB'];
          el = document.getElementById(polyIds[slotIdx]);
        }
      }
      if(el) el.setAttribute('points', pts);
    }

    setInterval(() => {
      Object.keys(dashSparkData).forEach(agent => {
        const data = dashSparkData[agent];
        const last = data.length > 0 ? data[data.length - 1] : 0;
        const next = Math.max(0, last + (Math.random() - 0.45) * 3);
        data.push(Math.round(next * 10) / 10);
        if(data.length > 20) data.shift();
        dashUpdateSparkline(agent);
      });
    }, 3000);

    /* Feed Helpers */
    const dashIcons = {
      message: '<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
      tool: '<svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
      status: '<svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
      task: '<svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>',
      error: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>',
    };

    function dashTimeNow(){
      const d = new Date();
      return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0') + ':' + String(d.getSeconds()).padStart(2,'0');
    }

    function dashEscHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    let dashSlotAgents = []; // agent_ids in each dashboard slot

    function dashAgentColor(agent){
      const id = (agent || '').toLowerCase();
      return AGENT_COLORS_MAP[id] || '#8f8f8f';
    }

    function dashAddFeedEntry(type, agent, text, detail){
      const el = document.createElement('div');
      el.className = 'feedEntry';
      const iconClass = 'feedEntry__icon feedEntry__icon--' + type;
      el.innerHTML =
        '<span class="feedEntry__time">' + dashTimeNow() + '</span>' +
        '<span class="' + iconClass + '">' + (dashIcons[type] || dashIcons.message) + '</span>' +
        '<span class="feedEntry__content">' +
          '<span class="feedEntry__agent" style="color:' + dashAgentColor(agent) + '">' + agent + '</span> ' + dashEscHtml(text) +
          (detail ? '<div class="feedEntry__detail">' + dashEscHtml(detail) + '</div>' : '') +
        '</span>';

      dashFeed.appendChild(el);
      dashTotalMessages++;
      document.getElementById('metricMessages').textContent = dashTotalMessages;

      const atBottom = dashFeed.scrollHeight - dashFeed.scrollTop - dashFeed.clientHeight < 60;
      if(atBottom){
        dashFeed.scrollTop = dashFeed.scrollHeight;
        dashNewPill.classList.remove('visible');
      } else {
        dashNewPill.classList.add('visible');
      }
    }

    dashNewPill.addEventListener('click', () => {
      dashFeed.scrollTop = dashFeed.scrollHeight;
      dashNewPill.classList.remove('visible');
    });

    /* Packet Animation */
    function dashSendPacket(pathId, color){
      const ns = 'http://www.w3.org/2000/svg';
      const circle = document.createElementNS(ns, 'circle');
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', color);
      circle.setAttribute('opacity', '0.9');

      const anim = document.createElementNS(ns, 'animateMotion');
      anim.setAttribute('dur', '1.2s');
      anim.setAttribute('fill', 'freeze');
      anim.setAttribute('repeatCount', '1');

      const mpath = document.createElementNS(ns, 'mpath');
      mpath.setAttributeNS('http://www.w3.org/1999/xlink', 'xlink:href', '#' + pathId);
      mpath.setAttribute('href', '#' + pathId);
      anim.appendChild(mpath);
      circle.appendChild(anim);
      dashPacketLayer.appendChild(circle);

      const path = document.getElementById(pathId);
      path.classList.remove('pathIdle');
      path.classList.add('pathActive');
      path.setAttribute('opacity', '.6');

      setTimeout(() => {
        path.classList.remove('pathActive');
        path.classList.add('pathIdle');
        path.setAttribute('opacity', '.3');
        if(circle.parentNode) circle.remove();
      }, 1300);
    }

    /* Dashboard Event Handlers */
    function dashHandleStatus(agent, status){
      const dotId = agent === 'Leader' ? 'dashStatusL' : agent === 'Agent A' ? 'dashStatusA' : 'dashStatusB';
      const color = status === 'active' ? '#22c55e' : status === 'idle' ? '#f59e0b' : '#ef4444';
      document.getElementById(dotId).setAttribute('fill', color);
      dashAddFeedEntry('status', agent, 'Status changed to ' + status);
    }

    function dashHandleTyping(agent, duration){
      dashTypingAgent.textContent = agent + ' tippt...';
      dashTypingEl.classList.add('visible');
      setTimeout(() => dashTypingEl.classList.remove('visible'), duration || 1500);
    }

    function dashHandleMessage(from, to, text, detail){
      dashAddFeedEntry('message', from, text, detail);
      dashAgentStats[from].msgs++;
      dashUpdateAgentStats(from);

      let pathId = null;
      if(from === 'Leader' && to === 'Agent A') pathId = 'pathLA';
      else if(from === 'Leader' && to === 'Agent B') pathId = 'pathLB';
      else if(from === 'Agent A' && to === 'Leader') pathId = 'pathLA';
      else if(from === 'Agent B' && to === 'Leader') pathId = 'pathLB';
      else if(from === 'Agent A' && to === 'Agent B') pathId = 'pathAB';
      else if(from === 'Agent B' && to === 'Agent A') pathId = 'pathAB';
      if(pathId) dashSendPacket(pathId, dashAgentColor(from));

      const data = dashSparkData[from];
      if(data.length > 0) data[data.length - 1] += 2;
    }

    function dashHandleTool(agent, tool, target){
      dashAddFeedEntry('tool', agent, 'Used ' + tool, target);
      if(agent !== 'Leader') dashAgentStats[agent].tools++;
      dashUpdateAgentStats(agent);

      const data = dashSparkData[agent];
      if(data.length > 0) data[data.length - 1] += 1.5;
    }

    function dashHandleTask(agent, task, completed){
      if(completed){
        dashTotalTasks++;
        dashAgentStats.Leader.tasks++;
        dashUpdateAgentStats('Leader');
        dashAddFeedEntry('task', agent, 'Completed: ' + task);
      } else {
        dashAddFeedEntry('task', agent, 'Started: ' + task);
      }
      if(agent === 'Leader') dashEls.taskLeader.textContent = task;
      else if(agent === 'Agent A') dashEls.taskAgentA.textContent = task;
      else if(agent === 'Agent B') dashEls.taskAgentB.textContent = task;
    }

    function dashUpdateAgentStats(agent){
      const msgEls = [dashEls.statLeaderMsgs, dashEls.statAgentAMsgs, dashEls.statAgentBMsgs];
      const secEls = [dashEls.statLeaderTasks, dashEls.statAgentATools, dashEls.statAgentBTools];
      const id = (agent || '').toLowerCase();
      const slotIdx = dashSlotAgents.indexOf(id);
      if(slotIdx >= 0 && dashAgentStats[agent]){
        const s = dashAgentStats[agent];
        if(msgEls[slotIdx]) msgEls[slotIdx].textContent = s.msgs;
        if(secEls[slotIdx]) secEls[slotIdx].textContent = s.tools || s.tasks || 0;
      }
    }

    async function populateDashboard(){
      try {
        const res = await fetch(API_BASE + '/board/agents');
        const data = await res.json();
        const agents = data.agents || [];
        if(agents.length === 0) return;

        const statusOrder = { green:0, yellow:1, red:2 };
        const sorted = [...agents].sort((a, b) => {
          const sa = statusOrder[a.status] ?? 2;
          const sb = statusOrder[b.status] ?? 2;
          if(sa !== sb) return sa - sb;
          return (a.name || '').localeCompare(b.name || '');
        });

        const top3 = sorted.slice(0, 3);
        dashSlotAgents = top3.map(a => a.id);

        const cards = [
          document.getElementById('cardLeader'),
          document.getElementById('cardAgentA'),
          document.getElementById('cardAgentB')
        ];
        const statusDots = ['dashStatusL', 'dashStatusA', 'dashStatusB'];

        top3.forEach((agent, i) => {
          const card = cards[i];
          if(!card) return;
          const name = agent.name || agent.id;
          const role = agent.role || '';
          const color = getAgentColor(agent.id);
          const ampel = agent.status === 'green' ? '#22c55e' : agent.status === 'yellow' ? '#f59e0b' : '#ef4444';

          // Card content
          const nameEl = card.querySelector('.statusCard__name');
          const badgeEl = card.querySelector('.statusCard__badge');
          const accentEl = card.querySelector('.statusCard__accent');
          const dotEl = card.querySelector('.statusCard__dot');
          if(nameEl) nameEl.textContent = name;
          if(badgeEl) badgeEl.textContent = role;
          if(accentEl) accentEl.style.background = color;
          if(dotEl) dotEl.style.background = ampel;

          // Sparkline color
          const sparkPoly = card.querySelector('.statusCard__sparkline polyline');
          if(sparkPoly) sparkPoly.setAttribute('stroke', color);

          // SVG node
          const initial = document.getElementById('nodeInitial' + i);
          const label = document.getElementById('nodeLabel' + i);
          const ring = document.getElementById('nodeRing' + i);
          const fill = document.getElementById('nodeFill' + i);
          const sDot = document.getElementById(statusDots[i]);
          if(initial){ initial.textContent = name.charAt(0).toUpperCase(); initial.setAttribute('fill', color); }
          if(label) label.textContent = name;
          if(ring) ring.setAttribute('stroke', color);
          if(fill) fill.setAttribute('fill', color);
          if(sDot) sDot.setAttribute('fill', ampel);

          // Init stats + sparkline tracking for real agents
          if(!dashAgentStats[name]) dashAgentStats[name] = { msgs:0, tools:0, tasks:0 };
          if(!dashSparkData[name]) dashSparkData[name] = [];
        });

        // Update path colors
        if(top3.length >= 2){
          const c0 = getAgentColor(top3[0].id);
          const c1 = getAgentColor(top3[1].id);
          document.getElementById('pathLA').setAttribute('stroke', c0);
          document.getElementById('pathLB').setAttribute('stroke', c0);
          document.getElementById('pathAB').setAttribute('stroke', c1);
        }
      } catch(e){ /* keep existing display */ }
    }

    /* Dashboard Demo Scenarios */
