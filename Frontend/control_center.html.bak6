    /* Derive agents data from projects (for Agent View) */
    function deriveAgentsData(){
      const agentMap = {};
      projectsData.projects.forEach(proj => {
        proj.teams.forEach(team => {
          team.members.forEach(member => {
            if(!agentMap[member.id]){
              agentMap[member.id] = {
                id: member.id, name: member.name, role: member.role,
                status: member.status, online_since: member.online_since || '',
                last_seen: member.last_seen || '', projects: []
              };
            }
            const existing = agentMap[member.id];
            if(member.status === 'red') existing.status = 'red';
            else if(member.status === 'yellow' && existing.status !== 'red') existing.status = 'yellow';
            const existingProj = existing.projects.find(p => p.id === proj.id);
            if(existingProj){
              if(!existingProj.teams.includes(team.name)) existingProj.teams.push(team.name);
            } else {
              existing.projects.push({ id: proj.id, name: proj.name, teams: [team.name] });
            }
          });
        });
      });
      return Object.values(agentMap);
    }

    /* State */
    let selectedProjectId = 'bridge-ide';
    let currentView = 'project';

    /* Project Expand/Collapse State (localStorage) */
    const TB_COLLAPSE_KEY = 'bridge_tb_collapsed';
    function tbGetCollapseState(){
      try { return JSON.parse(localStorage.getItem(TB_COLLAPSE_KEY)) || {}; } catch(e){ return {}; }
    }
    function tbSetCollapsed(projectId, collapsed){
      const state = tbGetCollapseState();
      state[projectId] = collapsed;
      localStorage.setItem(TB_COLLAPSE_KEY, JSON.stringify(state));
    }
    function tbIsCollapsed(projectId, index){
      const state = tbGetCollapseState();
      if(state.hasOwnProperty(projectId)) return state[projectId];
      // Default: first project expanded, rest collapsed
      return index > 0;
    }

    function tbEscHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function formatTimeAgo(isoStr){
      if(!isoStr) return '';
      const d = new Date(isoStr);
      if(isNaN(d.getTime())) return '';
      const now = Date.now();
      const diffMs = now - d.getTime();
      if(diffMs < 0) return 'gerade eben';
      const mins = Math.floor(diffMs / 60000);
      if(mins < 1) return 'gerade eben';
      if(mins < 60) return 'vor ' + mins + ' Min';
      const hrs = Math.floor(mins / 60);
      if(hrs < 24) return 'vor ' + hrs + ' Std';
      const days = Math.floor(hrs / 24);
      return 'vor ' + days + ' Tag' + (days > 1 ? 'en' : '');
    }

    function formatDate(isoStr){
      if(!isoStr) return '';
      const d = new Date(isoStr);
      if(isNaN(d.getTime())) return '';
      return d.toLocaleDateString('de-DE', { day:'2-digit', month:'2-digit', year:'numeric' });
    }

    /* Activity Cache — fetched from /activity endpoint */
    let activityCache = {};

    async function fetchActivities(){
      try {
        const res = await fetch(API_BASE + '/activity', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return;
        const data = await res.json();
        if(data.activities && Array.isArray(data.activities)){
          const map = {};
          data.activities.forEach(a => {
            map[a.agent_id] = { action: a.action || '', description: a.description || '', timestamp: a.timestamp || '' };
          });
          activityCache = map;
          renderMainContent();
        }
      } catch(e){ /* offline — keep last cache */ }
    }

    function getActivityDotClass(agentId, memberStatus){
      if(memberStatus === 'red') return 'ampelDot--red';
      const act = activityCache[agentId];
      if(act && act.action){
        if(act.action === 'standby' || act.action === 'waiting' || act.action === 'idle') return 'ampelDot--standby';
        return 'ampelDot--green';
      }
      return 'ampelDot--' + (memberStatus || 'green');
    }

    function getActivityHtml(agentId, prefix){
      const act = activityCache[agentId];
      if(!act || !act.action) return '';
      const isContextWarn = act.action === 'context_warning' || act.action === 'context_saving';
      const isContextStop = act.action === 'context_stop';
      if(isContextWarn){
        return '<span class="' + prefix + '__contextWarn">Context-Wechsel — Arbeit wird gesichert</span>';
      }
      if(isContextStop){
        return '<span class="' + prefix + '__contextWarn ' + prefix + '__contextWarn--critical">Context-Limit — Agent gestoppt</span>';
      }
      if(act.description){
        return '<span class="' + prefix + '__activity" title="' + tbEscHtml(act.description) + '">' + tbEscHtml(act.description) + '</span>';
      }
      return '';
    }

    /* Render: Project Sidebar */
    function renderProjectSidebar(){
      const container = document.getElementById('projectList');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;
      projectsData.projects.forEach(proj => {
        // Filter: match project name, team name, or member name/role
        let projMatches = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const projNameMatch = proj.name.toLowerCase().includes(term);
          const teamMatch = proj.teams.some(t => t.name.toLowerCase().includes(term) || t.members.some(m => m.name.toLowerCase().includes(term) || m.role.toLowerCase().includes(term)));
          projMatches = projNameMatch || teamMatch;
        }
        if(!projMatches) return;
        const isSelected = proj.id === selectedProjectId;
        const teamCount = proj.teams.length;
        const uniqueMembers = new Set();
        proj.teams.forEach(t => t.members.forEach(m => uniqueMembers.add(m.id)));
        html += '<div class="projectCard' + (isSelected ? ' selected' : '') + '">';
        html += '<button class="projectCard__toggle' + (isSelected ? ' open' : '') + '" data-project="' + proj.id + '">';
        html += '<svg class="projectCard__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>';
        html += '<span class="ampelDot ampelDot--' + proj.status + '"></span>';
        html += '<span class="projectCard__name">' + tbEscHtml(proj.name) + '</span>';
        html += '</button>';
        html += '<div class="projectCard__info">' + teamCount + ' Teams &middot; ' + uniqueMembers.size + ' Agenten</div>';
        if(proj.created_at){
          html += '<div class="projectCard__created">erstellt ' + formatDate(proj.created_at) + '</div>';
        }
        html += '<div class="projectCard__teams' + (isSelected ? ' open' : '') + '">';
        proj.teams.forEach(team => {
          const teamMatches = !hasSearch || team.name.toLowerCase().includes(searchTerm.toLowerCase()) || team.members.some(m => m.name.toLowerCase().includes(searchTerm.toLowerCase()) || m.role.toLowerCase().includes(searchTerm.toLowerCase()));
          if(hasSearch && !teamMatches) return;
          html += '<div class="projectCard__teamItem">';
          html += '<span class="ampelDot ampelDot--' + team.status + ' ampelDot--sm"></span>';
          html += '<span class="projectCard__teamName">' + tbEscHtml(team.name) + '</span>';
          html += '<span class="projectCard__teamCount">' + team.members.length + '</span>';
          html += '</div>';
        });
        html += '</div></div>';
      });
      container.innerHTML = html;
      container.querySelectorAll('.projectCard__toggle').forEach(btn => {
        btn.addEventListener('click', () => selectProject(btn.dataset.project));
      });
    }

    function selectProject(projectId){
      selectedProjectId = projectId;
      renderProjectSidebar();
      renderMainContent();
    }

    /* Render: Main Content */
    function renderMainContent(){
      if(currentView === 'project') renderProjectView();
      else renderAgentView();
      updateTeamBoardMetrics();
    }

    /* Render: Project View — all projects with expand/collapse */
    function renderProjectView(){
      const totalTeams = projectsData.projects.reduce((s, p) => s + p.teams.length, 0);
      document.getElementById('boardProjectName').textContent = 'Alle Projekte';
      document.getElementById('boardProjectAmpel').className = 'ampelDot';
      document.getElementById('boardTeamCount').textContent = totalTeams + ' Teams';
      const container = document.getElementById('teamBoardContent');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;

      projectsData.projects.forEach((proj, projIdx) => {
        // Filter: does this project match search?
        let projHasMatch = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const projNameMatch = proj.name.toLowerCase().includes(term);
          const teamMatch = proj.teams.some(t => t.name.toLowerCase().includes(term) || t.members.some(m => m.name.toLowerCase().includes(term) || m.role.toLowerCase().includes(term)));
          projHasMatch = projNameMatch || teamMatch;
        }
        if(!projHasMatch) return;

        const collapsed = hasSearch ? false : tbIsCollapsed(proj.id, projIdx);
        const uniqueMembers = new Set();
        proj.teams.forEach(t => t.members.forEach(m => uniqueMembers.add(m.id)));

        html += '<div class="projectGroup" data-project-id="' + proj.id + '">';
        html += '<div class="projectGroup__header' + (collapsed ? '' : ' open') + '" data-project="' + proj.id + '">';
        html += '<svg class="projectGroup__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>';
        html += '<span class="ampelDot ampelDot--' + proj.status + '"></span>';
        html += '<span class="projectGroup__name">' + tbEscHtml(proj.name) + '</span>';
        html += '<span class="projectGroup__meta">' + proj.teams.length + ' Teams &middot; ' + uniqueMembers.size + ' Agenten</span>';
        html += '</div>';
        html += '<div class="projectGroup__body' + (collapsed ? ' collapsed' : '') + '">';

        proj.teams.forEach((team, idx) => {
          let teamMatches = true;
          if(hasSearch){
            const term = searchTerm.toLowerCase();
            const teamNameMatch = team.name.toLowerCase().includes(term);
            const memberMatch = team.members.some(m => m.name.toLowerCase().includes(term) || m.role.toLowerCase().includes(term));
            teamMatches = teamNameMatch || memberMatch;
          }
          if(!teamMatches) return;
          html += '<div class="teamGroupCard" data-team-id="' + team.id + '" data-project-id="' + proj.id + '" style="animation-delay:' + (idx * 0.08) + 's">';
          html += '<div class="teamGroupCard__header">';
          html += '<span class="ampelDot ampelDot--' + team.status + '"></span>';
          html += '<span class="teamGroupCard__name">' + tbEscHtml(team.name) + '</span>';
          html += '<span class="teamGroupCard__meta">' + team.members.length + ' Agenten</span>';
          html += '</div>';
          html += '<div class="teamGroupCard__body">';
          team.members.forEach(member => {
            let memberMatches = true;
            if(hasSearch){
              const term = searchTerm.toLowerCase();
              memberMatches = member.name.toLowerCase().includes(term) || member.role.toLowerCase().includes(term);
            }
            if(!memberMatches) return;
            html += '<div class="agentRow" draggable="true" data-agent-id="' + member.id + '" data-from-team="' + team.id + '" data-from-project="' + proj.id + '">';
            html += '<span class="ampelDot ' + getActivityDotClass(member.id, member.status) + ' ampelDot--sm"></span>';
            html += '<span class="agentRow__name" style="color:' + getAgentColor(member.id) + '">' + tbEscHtml(member.name) + '</span>';
            html += '<span class="agentRow__role">' + tbEscHtml(member.role) + '</span>';
            var timeText = '';
            if(member.status === 'green' && member.online_since) timeText = 'online ' + formatTimeAgo(member.online_since);
            else if(member.last_seen) timeText = 'zuletzt ' + formatTimeAgo(member.last_seen);
            if(timeText) html += '<span class="agentRow__time">' + timeText + '</span>';
            html += getActivityHtml(member.id, 'agentRow');
            if(member.also_in && member.also_in.length > 0){
              html += '<span class="agentRow__alsoIn">';
              member.also_in.forEach(pn => {
                html += '<span class="alsoInBadge">auch in: ' + tbEscHtml(pn) + '</span>';
              });
              html += '</span>';
            }
            html += '</div>';
          });
          html += '</div></div>';
        });
        html += '</div></div>'; // close projectGroup__body + projectGroup
      });
      container.innerHTML = html;
      // Wire up expand/collapse click handlers
      container.querySelectorAll('.projectGroup__header').forEach(header => {
        header.addEventListener('click', () => {
          const pid = header.dataset.project;
          const body = header.nextElementSibling;
          const isOpen = header.classList.contains('open');
          header.classList.toggle('open', !isOpen);
          body.classList.toggle('collapsed', isOpen);
          tbSetCollapsed(pid, isOpen);
          // Also sync sidebar selection
          selectedProjectId = pid;
          renderProjectSidebar();
        });
      });
      initDragAndDrop(container);
    }

    /* Render: Agent View */
    function renderAgentView(){
      document.getElementById('boardProjectName').textContent = 'Alle Agenten';
      document.getElementById('boardProjectAmpel').className = 'ampelDot';
      const agents = deriveAgentsData();
      document.getElementById('boardTeamCount').textContent = agents.length + ' Agenten';
      const container = document.getElementById('teamBoardContent');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;
      agents.forEach((agent, idx) => {
        // Filter: match agent name, role, project name, team name
        let matches = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const nameMatch = agent.name.toLowerCase().includes(term);
          const roleMatch = agent.role.toLowerCase().includes(term);
          const projMatch = agent.projects.some(p => p.name.toLowerCase().includes(term) || p.teams.some(t => t.toLowerCase().includes(term)));
          matches = nameMatch || roleMatch || projMatch;
        }
        if(!matches) return;
        html += '<div class="agentViewCard" style="animation-delay:' + (idx * 0.06) + 's">';
        html += '<span class="ampelDot ' + getActivityDotClass(agent.id, agent.status) + '"></span>';
        html += '<div class="agentViewCard__info">';
        html += '<div class="agentViewCard__name" style="color:' + getAgentColor(agent.id) + '">' + tbEscHtml(agent.name) + '</div>';
        html += '<div class="agentViewCard__role">' + tbEscHtml(agent.role) + '</div>';
        var avTimeText = '';
        if(agent.status === 'green' && agent.online_since) avTimeText = 'online ' + formatTimeAgo(agent.online_since);
        else if(agent.last_seen) avTimeText = 'zuletzt ' + formatTimeAgo(agent.last_seen);
        if(avTimeText) html += '<div class="agentViewCard__time">' + avTimeText + '</div>';
        html += getActivityHtml(agent.id, 'agentViewCard');
        html += '<div class="agentViewCard__projects">';
        agent.projects.forEach(proj => {
          const projMatches = !hasSearch || proj.name.toLowerCase().includes(searchTerm.toLowerCase()) || proj.teams.some(t => t.toLowerCase().includes(searchTerm.toLowerCase()));
          if(hasSearch && !projMatches) return;
          html += '<div class="agentViewCard__projectItem">';
          html += '<span class="agentViewCard__projectName">' + tbEscHtml(proj.name) + '</span>';
          html += '<span class="agentViewCard__teams">' + proj.teams.join(', ') + '</span>';
          html += '</div>';
        });
        html += '</div></div></div>';
      });
      container.innerHTML = html;
    }

    /* ═══════════════════════════════════════════
       DRAG & DROP — Agents between Teams
    ═══════════════════════════════════════════ */
    let dragData = null;

    function initDragAndDrop(container){
      // Drag start on agent rows
      container.querySelectorAll('.agentRow[draggable]').forEach(row => {
        row.addEventListener('dragstart', (e) => {
          dragData = {
            agentId: row.dataset.agentId,
            fromTeam: row.dataset.fromTeam,
            fromProject: row.dataset.fromProject
          };
          row.classList.add('dragging');
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', row.dataset.agentId);
        });
        row.addEventListener('dragend', () => {
          row.classList.remove('dragging');
          container.querySelectorAll('.teamGroupCard.dragOver').forEach(c => c.classList.remove('dragOver'));
          dragData = null;
        });
      });

      // Drop targets on team cards
      container.querySelectorAll('.teamGroupCard').forEach(card => {
        card.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          if(dragData && card.dataset.teamId !== dragData.fromTeam){
            card.classList.add('dragOver');
          }
        });
        card.addEventListener('dragleave', (e) => {
          if(!card.contains(e.relatedTarget)){
            card.classList.remove('dragOver');
          }
        });
        card.addEventListener('drop', async (e) => {
          e.preventDefault();
          card.classList.remove('dragOver');
          if(!dragData) return;
          const dd = { ...dragData };
          const toTeam = card.dataset.teamId;
          const toProject = card.dataset.projectId;
          if(toTeam === dd.fromTeam && toProject === dd.fromProject) return;

          try {
            // Add to new team
            const addRes = await fetch(API_BASE + '/board/projects/' + toProject + '/teams/' + toTeam + '/members', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ agent_id: dd.agentId })
            });
            if(!addRes.ok) throw new Error('Add failed: ' + addRes.status);

            // Remove from old team
            const delRes = await fetch(API_BASE + '/board/projects/' + dd.fromProject + '/teams/' + dd.fromTeam + '/members/' + dd.agentId, {
              method: 'DELETE'
            });
            if(!delRes.ok) throw new Error('Remove failed: ' + delRes.status);

            // Refresh data
            await fetchProjects();
          } catch(err){
            console.error('Drag&Drop failed:', err);
          }
        });
      });
    }

    /* Search Filter */
    let currentSearchTerm = '';

    function getSearchTerm(){ return currentSearchTerm; }

    function filterBySearch(){
      currentSearchTerm = document.getElementById('teamBoardSearch').value || '';
      renderMainContent();
    }

    document.getElementById('teamBoardSearch').addEventListener('input', filterBySearch);

    /* View Toggle */
    document.getElementById('viewToggle').addEventListener('click', (e) => {
      const btn = e.target.closest('.viewToggle__btn');
      if(!btn) return;
      currentView = btn.dataset.view;
      document.querySelectorAll('.viewToggle__btn').forEach(b => {
        b.classList.toggle('active', b.dataset.view === currentView);
      });
      renderMainContent();
    });

    /* Metrics Update */
    function updateTeamBoardMetrics(){
      const totalProjects = projectsData.projects.length;
      const totalTeams = projectsData.projects.reduce((sum, p) => sum + p.teams.length, 0);
      const agents = deriveAgentsData();
      document.getElementById('metricProjects').textContent = totalProjects;
      document.getElementById('metricTeams').textContent = totalTeams;
      document.getElementById('metricAgents').textContent = agents.length;
      document.getElementById('topProjects').textContent = totalProjects;
      document.getElementById('topTeams').textContent = totalTeams;
      document.getElementById('topAgents').textContent = agents.length;
    }

    /* Fetch Projects from API (polling) */
    async function fetchProjects(){
      try {
        const res = await fetch(API_BASE + '/board/projects', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return false;
        const data = await res.json();
        if(data.projects && data.projects.length > 0){
          projectsData = data;
          renderProjectSidebar();
          renderMainContent();
        }
        return true;
      } catch(e){
        return false;
      }
    }

    /* ═══════════════════════════════════════════
       NEW PROJECT MODAL
    ═══════════════════════════════════════════ */
    const newProjectModal = document.getElementById('newProjectModal');
    const newProjectBtn = document.getElementById('newProjectBtn');
    const newProjectForm = document.getElementById('newProjectForm');
    const newProjectNameInput = document.getElementById('newProjectName');
    const newProjectCancel = document.getElementById('newProjectCancel');

    function generateProjectSlug(name){
      return name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-').replace(/^-|-$/g, '');
    }

    newProjectBtn.addEventListener('click', () => {
      newProjectModal.style.display = 'flex';
      newProjectNameInput.focus();
    });

    newProjectCancel.addEventListener('click', () => {
      newProjectModal.style.display = 'none';
      newProjectNameInput.value = '';
    });

    newProjectModal.addEventListener('click', (e) => {
      if(e.target === newProjectModal){
        newProjectModal.style.display = 'none';
        newProjectNameInput.value = '';
      }
    });

    document.addEventListener('keydown', (e) => {
      if(e.key === 'Escape' && newProjectModal.style.display === 'flex'){
        newProjectModal.style.display = 'none';
        newProjectNameInput.value = '';
      }
    });

    newProjectForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = newProjectNameInput.value.trim();
      if(!name) return;
      const slug = generateProjectSlug(name);
      const submitBtn = document.getElementById('newProjectSubmit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Erstelle...';
      try {
        const res = await fetch(API_BASE + '/board/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: slug, name: name })
        });
        const data = await res.json();
        if(data.ok || data.project){
          newProjectModal.style.display = 'none';
          newProjectNameInput.value = '';
          window.location = 'project_config.html?project=' + encodeURIComponent(slug);
        } else {
          alert('Fehler: ' + (data.error || 'Projekt konnte nicht erstellt werden'));
        }
      } catch(err){
        alert('Fehler beim Erstellen: ' + err.message);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Projekt erstellen';
      }
    });

    /* ═══════════════════════════════════════════
       LIVE BACKEND — WebSocket + Polling
    ═══════════════════════════════════════════ */
    let historyRenderedIds = new Set();

    function connectWebSocket(){
      try {
        ws = new WebSocket(WS_URL);
      } catch(e){ return; }
      ws.onopen = () => {
        wsRetry = 1000;
        console.log('[CC] WebSocket connected');
      };
      ws.onmessage = (e) => {
        try {
          const data = JSON.parse(e.data);
          if(data.type === 'message' && data.message){
            handleLiveMessage(data.message);
          } else if(data.type === 'agent_status'){
            pollAgentStatus();
          } else if(data.type === 'activity' && data.activity){
            const a = data.activity;
            dashAddFeedEntry('tool', agentDisplayName(a.agent_id),
              a.action + (a.target ? ' ' + a.target : ''), a.description || '');
            // Update activityCache + team board dots
            activityCache[a.agent_id] = { action: a.action || '', description: a.description || '', timestamp: a.timestamp || '' };
            renderMainContent();
            // Update liveboard team panel
            if(lbLoaded){
              const idx = lbActivitiesData.findIndex(x => x.agent_id === a.agent_id);
              if(idx >= 0) lbActivitiesData[idx] = a;
              else lbActivitiesData.push(a);
              renderLbTeamPanel();
            }
          } else if(data.type === 'whiteboard_updated' || data.type === 'whiteboard_alert'){
            lbHandleWhiteboardEvent(data);
          } else if(data.type === 'scope_locked' || data.type === 'scope_unlocked'){
            lbHandleScopeEvent(data);
          } else if(data.type === 'escalation_stage_3'){
            lbShowEscalationDialog(data);
          } else if(data.type === 'task_done' || data.type === 'task_failed' || data.type === 'task_claimed' || data.type === 'task_timeout'){
            lbHandleTaskEvent(data);
          }
        } catch(err){ console.error('[CC] WS parse error:', err); }
      };
      ws.onclose = () => {
        setTimeout(connectWebSocket, wsRetry);
        wsRetry = Math.min(wsRetry * 2, 30000);
      };
      ws.onerror = () => {};
    }

    function handleLiveMessage(msg){
      if(msg.id && historyRenderedIds.has(msg.id)) return;
      if(msg.id) historyRenderedIds.add(msg.id);
      const from = agentDisplayName(msg.from);
      const to = agentDisplayName(msg.to);
      const text = (msg.content || '').substring(0, 120);
      const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
      dashAddFeedEntry('message', from, text, detail);

      // Packet routing: slot-based for real agents
      const fromSlot = dashSlotAgents.indexOf(msg.from);
      const toSlot = dashSlotAgents.indexOf(msg.to);
      const slotPaths = { '0-1':'pathLA','1-0':'pathLA','0-2':'pathLB','2-0':'pathLB','1-2':'pathAB','2-1':'pathAB' };
      const pathId = slotPaths[fromSlot + '-' + toSlot];
      if(pathId) dashSendPacket(pathId, dashAgentColor(from));

      if(dashSparkData[from]){
        const d = dashSparkData[from];
        if(d.length > 0) d[d.length - 1] += 2;
      }

      if(dashAgentStats[from]){
        dashAgentStats[from].msgs++;
        dashUpdateAgentStats(from);
      }
    }

    async function pollAgentStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        const agents = data.agents || [];
        const active = agents.filter(a => a.status !== 'disconnected');

        // Online count in status dots area (don't overwrite team board metric)

        const dotMap = { teamlead:'dashStatusL', lead:'dashStatusL',
          claude_a:'dashStatusA', agent_a:'dashStatusA',
          claude_b:'dashStatusB', agent_b:'dashStatusB' };
        agents.forEach(a => {
          const dotId = dotMap[a.agent_id];
          if(!dotId) return;
          const color = a.status === 'live' ? '#22c55e' : a.status === 'connecting' ? '#f59e0b' : '#ef4444';
          const el = document.getElementById(dotId);
          if(el) el.setAttribute('fill', color);
        });

        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          const dot = topBarDots[0];
          const label = document.querySelector('.topBar .statusLabel');
          dot.className = 'statusDot';
          if(active.length > 0){
            dot.classList.add('statusDot--live');
            if(label) label.textContent = active.length + ' online';
          } else {
            dot.classList.add('statusDot--connecting');
            if(label) label.textContent = 'Keine Agenten';
          }
        }
      } catch(e){
        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          topBarDots[0].className = 'statusDot statusDot--disconnected';
          const label = document.querySelector('.topBar .statusLabel');
          if(label) label.textContent = 'Offline';
        }
      }
    }

    async function loadHistory(){
      try {
        const res = await fetch(API_BASE + '/history?limit=50');
        const data = await res.json();
        const msgs = data.messages || [];
        msgs.forEach(msg => {
          if(msg.id) historyRenderedIds.add(msg.id);
          const from = agentDisplayName(msg.from);
          const to = agentDisplayName(msg.to);
          const text = (msg.content || '').substring(0, 120);
          const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
          dashAddFeedEntry('message', from, text, detail);
        });
        return true;
      } catch(e){
        return false;
      }
    }

    async function tryLiveMode(){
      try {
        const res = await fetch(API_BASE + '/agents', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return false;
        liveMode = true;
        await populateDashboard();
        await loadHistory();
        connectWebSocket();
        pollAgentStatus();
        setInterval(pollAgentStatus, 5000);
        setInterval(populateDashboard, 10000);
        console.log('[CC] Live mode active');
        return true;
      } catch(e){
        return false;
      }
    }

    /* ═══════════════════════════════════════════
       TAB SYSTEM
    ═══════════════════════════════════════════ */
    const ccTabBtns = document.querySelectorAll('.ccTab');
    const ccTabPanels = document.querySelectorAll('.ccTabPanel');

    function switchTab(tabName){
      ccTabBtns.forEach(b => {
        const isActive = b.dataset.tab === tabName;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      ccTabPanels.forEach(p => p.classList.toggle('active', p.dataset.panel === tabName));
      if(tabName === 'liveboard') loadLiveboard();
    }

    ccTabBtns.forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));

    /* ═══════════════════════════════════════════
       LIVEBOARD ENGINE
    ═══════════════════════════════════════════ */
    const SCOPE_LABELS = {
      'BRIDGE/Frontend/': 'Frontend-Oberflaeche',
      'BRIDGE/Backend/server.py': 'Backend-System',
      'BRIDGE/Backend/bridge_mcp.py': 'Agent-Werkzeuge',
      'BRIDGE/Backend/bridge_watcher.py': 'Nachrichten-Router',
      'BRIDGE/Backend/tmux_manager.py': 'Session-Manager'
    };

    function resolveScopeLabel(path){
      if(!path) return '';
      for(const [prefix, label] of Object.entries(SCOPE_LABELS)){
        if(path.includes(prefix)) return label;
      }
      return path.split('/').pop();
    }

    function lbRelativeTime(isoStr){
      if(!isoStr) return '';
      const d = new Date(isoStr);
      if(isNaN(d.getTime())) return '';
      const diffMs = Date.now() - d.getTime();
      if(diffMs < 0) return 'gerade eben';
      const mins = Math.floor(diffMs / 60000);
      if(mins < 1) return 'gerade eben';
      if(mins < 60) return 'vor ' + mins + ' Min';
      const hrs = Math.floor(mins / 60);
      if(hrs < 24) return 'vor ' + hrs + ' Std';
      const days = Math.floor(hrs / 24);
      return 'vor ' + days + ' Tag' + (days > 1 ? 'en' : '');
    }

    function lbFormatTime(isoStr){
      if(!isoStr) return '';
      const d = new Date(isoStr);
      if(isNaN(d.getTime())) return '';
      return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
    }

    let lbLoaded = false;
    let lbAgentsData = [];
    let lbWhiteboardData = [];
    let lbScopeLocksData = [];
    let lbActivitiesData = [];
    let lbEscTaskId = null;

    async function loadLiveboard(){
      const panels = document.querySelectorAll('#tabLiveboard .lbPanel__body');
      if(!lbLoaded){
        panels.forEach(p => {
          p.innerHTML = '<div class="lbLoading"><div class="lbLoadingDot"></div><div class="lbLoadingDot"></div><div class="lbLoadingDot"></div></div>';
        });
      }
      try {
        const [agentsRes, activityRes, whiteboardRes, scopeRes] = await Promise.all([
          fetch(API_BASE + '/agents', { signal: AbortSignal.timeout(5000) }),
          fetch(API_BASE + '/activity', { signal: AbortSignal.timeout(5000) }),
          fetch(API_BASE + '/whiteboard?limit=50', { signal: AbortSignal.timeout(5000) }),
          fetch(API_BASE + '/scope/locks', { signal: AbortSignal.timeout(5000) }),
        ]);
        const agentsJson = await agentsRes.json();
        const activityJson = await activityRes.json();
        const whiteboardJson = await whiteboardRes.json();
        const scopeJson = await scopeRes.json();

        lbAgentsData = agentsJson.agents || [];
        lbActivitiesData = activityJson.activities || [];
        lbWhiteboardData = whiteboardJson.entries || whiteboardJson.whiteboard || [];
        lbScopeLocksData = scopeJson.locks || [];

        lbLoaded = true;
        renderLbTeamPanel();
        renderLbAlertsPanel();
        renderLbTimelinePanel();
        renderLbScopePanel();
      } catch(e){
        panels.forEach(p => {
          p.innerHTML = '<div class="lbEmpty lbEmpty--error">Verbindungsproblem — wird automatisch erneut versucht</div>';
        });
        setTimeout(() => { lbLoaded = false; loadLiveboard(); }, 5000);
      }
    }

    function renderLbTeamPanel(){
      const container = document.getElementById('lbTeamList');
      if(!lbAgentsData.length){
        container.innerHTML = '<div class="lbEmpty">Alle Team-Mitglieder sind gerade offline</div>';
        return;
      }
      let html = '';
      lbAgentsData.forEach(agent => {
        const agentId = agent.agent_id || agent.id || '';
        const hbAge = agent.last_heartbeat ? (Date.now() - new Date(agent.last_heartbeat).getTime()) / 1000 : 9999;
        let dotClass = 'lbAgent__dot--online';
        if(agent.active === false) dotClass = 'lbAgent__dot--paused';
        else if(hbAge > 120) dotClass = 'lbAgent__dot--problem';

        const name = agentDisplayName(agentId);
        const color = getAgentColor(agentId);

        const statusEntry = lbWhiteboardData.find(e => e.type === 'status' && e.agent_id === agentId);
        const actEntry = lbActivitiesData.find(a => a.agent_id === agentId);
        const actDesc = actEntry ? (actEntry.description || actEntry.action || '') : '';
        const scopeLabel = statusEntry && statusEntry.scope_label ? resolveScopeLabel(statusEntry.scope_label) : '';
        const blockerEntry = lbWhiteboardData.find(e => e.type === 'blocker' && e.agent_id === agentId);
        const timeStr = agent.registered_at ? lbRelativeTime(agent.registered_at) : '';

        html += '<div class="lbAgent">';
        html += '<div class="lbAgent__dot ' + dotClass + '"></div>';
        html += '<div class="lbAgent__info">';
        html += '<div class="lbAgent__name" style="color:' + color + '">' + tbEscHtml(name) + '</div>';
        if(actDesc) html += '<div class="lbAgent__task">' + tbEscHtml(actDesc) + '</div>';
        else if(statusEntry && statusEntry.content) html += '<div class="lbAgent__task">' + tbEscHtml(statusEntry.content) + '</div>';
        if(scopeLabel) html += '<div class="lbAgent__scope">Bereich: ' + tbEscHtml(scopeLabel) + '</div>';
        if(blockerEntry) html += '<div class="lbAgent__blocker">\u26a0 ' + tbEscHtml(blockerEntry.content || 'Blockiert') + '</div>';
        html += '</div>';
        if(timeStr) html += '<div class="lbAgent__time">seit ' + timeStr + '</div>';
        html += '</div>';
      });
      container.innerHTML = html;
    }

    function renderLbAlertsPanel(){
      const container = document.getElementById('lbAlertsList');
      const now = Date.now();
      const alerts = lbWhiteboardData.filter(e => {
        if(e.type !== 'alert') return false;
        if(e.severity === 'critical') return true;
        if(e.ttl && e.created_at){
          const created = new Date(e.created_at).getTime();
          if(now - created > e.ttl * 1000) return false;
        }
        return true;
      });

      const sevOrder = { critical:0, warning:1, info:2 };
      alerts.sort((a, b) => {
        const sa = sevOrder[a.severity] ?? 2;
        const sb = sevOrder[b.severity] ?? 2;
        if(sa !== sb) return sa - sb;
        return new Date(b.created_at || 0) - new Date(a.created_at || 0);
      });

      if(!alerts.length){
        container.innerHTML = '<div class="lbEmpty lbEmpty--ok">Alles laeuft</div>';
        return;
      }
      let html = '';
      alerts.forEach(alert => {
        const sev = alert.severity || 'info';
        const name = agentDisplayName(alert.agent_id);
        html += '<div class="lbAlert lbAlert--' + sev + '">';
        html += '<div class="lbAlert__content">';
        html += '<span class="lbAlert__agent">' + tbEscHtml(name) + ':</span> ';
        html += tbEscHtml(alert.content || '');
        html += '</div>';
        html += '<div class="lbAlert__time">' + lbRelativeTime(alert.created_at) + '</div>';
        html += '</div>';
      });
      container.innerHTML = html;
    }

    function renderLbTimelinePanel(){
      const container = document.getElementById('lbTimeline');
      if(!lbWhiteboardData.length){
        container.innerHTML = '<div class="lbEmpty">Noch keine Aktivitaet</div>';
        return;
      }
      const sorted = [...lbWhiteboardData].sort((a, b) =>
        new Date(b.created_at || 0) - new Date(a.created_at || 0)
      ).slice(0, 20);

      const typeIcons = { status:'', result:'\u2705', blocker:'\u26a0\ufe0f' };

      let html = '';
      sorted.forEach(entry => {
        let icon = typeIcons[entry.type] || '';
        if(entry.type === 'alert'){
          if(entry.severity === 'critical') icon = '\ud83d\udd34';
          else if(entry.severity === 'warning') icon = '\u26a0\ufe0f';
          else icon = '\u2705';
        }
        const name = agentDisplayName(entry.agent_id);
        const color = getAgentColor(entry.agent_id);
        const timeStr = lbRelativeTime(entry.created_at);

        html += '<div class="lbTimeEntry">';
        html += '<div class="lbTimeEntry__time">' + timeStr + '</div>';
        if(icon) html += '<div class="lbTimeEntry__icon">' + icon + '</div>';
        html += '<div class="lbTimeEntry__content">';
        html += '<span class="lbTimeEntry__agent" style="color:' + color + '">' + tbEscHtml(name) + '</span> ';
        html += tbEscHtml(entry.content || '');
        html += '</div>';
        html += '</div>';
      });
      container.innerHTML = html;
    }

    function renderLbScopePanel(){
      const container = document.getElementById('lbScopeLocks');
      if(!lbScopeLocksData.length){
        container.innerHTML = '<div class="lbEmpty">Keine reservierten Bereiche</div>';
        return;
      }
      const labelCounts = {};
      lbScopeLocksData.forEach(lock => {
        const label = resolveScopeLabel(lock.path || lock.scope || '');
        labelCounts[label] = (labelCounts[label] || 0) + 1;
      });

      let html = '';
      lbScopeLocksData.forEach(lock => {
        const label = resolveScopeLabel(lock.path || lock.scope || '');
        const agentId = lock.agent_id || '';
        const name = agentDisplayName(agentId);
        const color = getAgentColor(agentId);
        const hasOverlap = labelCounts[label] > 1;

        html += '<div class="lbScope">';
        html += '<div class="lbScope__label">' + tbEscHtml(label) + '</div>';
        html += '<div class="lbScope__agent">';
        html += '<div class="lbScope__dot" style="background:' + color + '"></div>';
        html += '<span style="color:' + color + '">' + tbEscHtml(name) + '</span>';
        html += '</div>';
        html += '<div class="lbScope__time">seit ' + lbRelativeTime(lock.locked_at || lock.created_at) + '</div>';
        if(hasOverlap) html += '<div class="lbScope__overlap">\u26a0 Ueberlappung</div>';
        html += '</div>';
      });
      container.innerHTML = html;
    }

    /* Liveboard: WebSocket Event Handlers */
    function lbHandleWhiteboardEvent(data){
      const entry = data.entry || data;
      if(!entry || !entry.type) return;
      // Update local data
      const idx = lbWhiteboardData.findIndex(e => e.id === entry.id);
      if(idx >= 0) lbWhiteboardData[idx] = entry;
      else lbWhiteboardData.unshift(entry);
      // Re-render affected panels
      if(entry.type === 'alert') renderLbAlertsPanel();
      if(entry.type === 'status' || entry.type === 'blocker') renderLbTeamPanel();
      renderLbTimelinePanel();
    }

    function lbHandleScopeEvent(data){
      if(data.type === 'scope_locked'){
        const lock = data.lock || { path: data.path, agent_id: data.agent_id, task_id: data.task_id, locked_at: data.locked_at || new Date().toISOString() };
        lbScopeLocksData.push(lock);
      } else if(data.type === 'scope_unlocked'){
        const taskId = data.task_id;
        const paths = data.paths || (data.path ? [data.path] : []);
        lbScopeLocksData = lbScopeLocksData.filter(l => {
          if(taskId && l.task_id === taskId){
            if(paths.length === 0) return false;
            return !paths.includes(l.path || l.scope);
          }
          return true;
        });
      }
      renderLbScopePanel();
    }

    function lbHandleTaskEvent(data){
      const entry = {
        type: data.type === 'task_done' ? 'result' : data.type === 'task_failed' ? 'alert' : 'status',
        agent_id: data.agent_id || '',
        content: data.title || data.result_summary || data.type,
        severity: data.type === 'task_failed' ? 'warning' : data.type === 'task_timeout' ? 'warning' : 'info',
        created_at: new Date().toISOString(),
        id: 'task_' + Date.now()
      };
      lbWhiteboardData.unshift(entry);
      renderLbTimelinePanel();
      if(entry.type === 'alert') renderLbAlertsPanel();
    }

    /* Stufe-3 Eskalations-Dialog */
    function lbShowEscalationDialog(data){
      const dialog = document.getElementById('lbEscalationDialog');
      const msgEl = document.getElementById('lbEscMsg');
      const titleEl = document.getElementById('lbEscTitle');
      const selectEl = document.getElementById('lbEscAgentSelect');

      lbEscTaskId = data.task_id;
      titleEl.textContent = '\u26a0 Eskalation — ' + (data.title || 'Stufe 3');
      msgEl.textContent = data.message || 'Eine Aufgabe hat das Zeitlimit ueberschritten.';

      // Populate agent dropdown (exclude current agent)
      const activeAgents = lbAgentsData.filter(a => a.active !== false && (a.agent_id || a.id) !== data.agent_id);
      selectEl.innerHTML = '';
      if(activeAgents.length === 0){
        document.getElementById('lbEscReassign').disabled = true;
        selectEl.style.display = 'none';
      } else {
        document.getElementById('lbEscReassign').disabled = false;
        activeAgents.forEach(a => {
          const opt = document.createElement('option');
          opt.value = a.agent_id || a.id;
          opt.textContent = agentDisplayName(a.agent_id || a.id);
          selectEl.appendChild(opt);
        });
      }
      dialog.style.display = 'flex';
    }

    function lbResolveEscalation(action){
      if(!lbEscTaskId) return;
      const body = { action: action };
      if(action === 'reassign'){
        const selectEl = document.getElementById('lbEscAgentSelect');
        selectEl.style.display = 'inline-block';
        if(!selectEl.value) return;
        body.reassign_to = selectEl.value;
      }
      fetch(API_BASE + '/escalation/' + lbEscTaskId + '/resolve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      }).then(() => {
        document.getElementById('lbEscalationDialog').style.display = 'none';
        lbEscTaskId = null;
      }).catch(e => console.error('[LB] Escalation resolve error:', e));
    }

    document.getElementById('lbEscExtend').addEventListener('click', () => lbResolveEscalation('extend'));
    document.getElementById('lbEscReassign').addEventListener('click', () => {
      const selectEl = document.getElementById('lbEscAgentSelect');
      if(selectEl.style.display === 'none' || selectEl.style.display === ''){
        selectEl.style.display = 'inline-block';
        return;
      }
      lbResolveEscalation('reassign');
    });
    document.getElementById('lbEscCancel').addEventListener('click', () => lbResolveEscalation('cancel'));

    /* Liveboard: Auto-refresh relative times every 30s */
    setInterval(() => {
      if(document.querySelector('.ccTab.active[data-tab="liveboard"]')){
        if(lbLoaded){
          renderLbTeamPanel();
          renderLbAlertsPanel();
          renderLbTimelinePanel();
          renderLbScopePanel();
        }
      }
    }, 30000);

    /* ═══════════════════════════════════════════
       INIT — Start Both Engines
    ═══════════════════════════════════════════ */
    renderProjectSidebar();
    renderMainContent();

    // URL-Parameter Tab-Routing (F3)
    const _urlTab = new URLSearchParams(window.location.search).get('tab');
    if(_urlTab === 'liveboard') switchTab('liveboard');

    // Try live backend; fall back to demo if offline
    tryLiveMode().then(live => {
      if(!live){
        console.log('[CC] Backend offline — using demo scenarios');
        setTimeout(dashScheduleNext, 1200);
      }
      // Try fetching live project data
      fetchProjects();
      fetchActivities();
    });

    // Poll projects every 10s, activities every 10s
    setInterval(fetchProjects, 10000);
    setInterval(fetchActivities, 10000);

  </script>
</body>
</html>
