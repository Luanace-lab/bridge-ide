<!doctype html>
<html lang="de" data-theme="warm">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bridge – Chat Layout</title>

  <style>
    /* Warm — Original Creme */
    html[data-theme="warm"]{
      --bg:#fbf8f1; --bgFlat:#fbf8f1;
      --sidebar: #c8bfa8;
      --sbThumb: #b8af98;
      --sbDark: #8a7f6a;
    }

    /* Light — ACE Weiss + Babyblau Sidebar */
    html[data-theme="light"]{
      --bg:#ffffff; --bgFlat:#ffffff;
      --sidebar:#d6e8f7;
      --sbThumb:#b8d4ed;
      --sbDark: #5a9ac7;
    }

    /* Rose — Sanftes Rosa */
    html[data-theme="rose"]{
      --bg:#fdf2f4; --bgFlat:#fdf2f4;
      --sidebar:#e8c4cc;
      --sbThumb:#d9adb7;
      --sbDark: #a3707e;
    }

    /* Dark — ACE gradient-universe + dunkle Sidebar */
    html[data-theme="dark"]{
      --bg: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
      --bgFlat:#161e3a;
      --sidebar:#1e2a42;
      --sbThumb:#2d3f5e;
      --sbDark: #8aa4c8;
    }

    :root{ --sw:14%; --dp:57%; }

    *{ margin:0; padding:0; box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      background:var(--bg);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    /* Theme-Switcher oben rechts */
    /* Settings Popup (oeffnet sich ueber Zahnrad) */
    .settingsPopup{
      position:absolute;
      bottom:calc(100% + 8px);
      right:0;
      min-width:140px;
      background:rgba(255,255,255,.85);
      backdrop-filter:blur(10px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:10px;
      padding:6px;
      display:none;
      box-shadow:0 4px 16px rgba(0,0,0,.1);
      z-index:10;
    }
    html[data-theme="dark"] .settingsPopup{
      background:rgba(30,42,66,.9);
      border-color:rgba(255,255,255,.1);
    }
    .settingsPopup.open{ display:block; }
    .settingsPopup__label{
      font-size:10px;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.5px;
      color:#73726C;
      padding:4px 8px 2px;
    }
    html[data-theme="dark"] .settingsPopup__label{ color:#999590; }
    .settingsPopup__option{
      display:flex;
      align-items:center;
      gap:8px;
      width:100%;
      padding:6px 8px;
      border:none;
      border-radius:6px;
      font-size:12px;
      font-family:inherit;
      cursor:pointer;
      text-align:left;
      background:transparent;
      color:#3d3d3a;
      transition:background .12s ease;
    }
    html[data-theme="dark"] .settingsPopup__option{ color:#e7edf5; }
    .settingsPopup__option:hover{ background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .settingsPopup__option:hover{ background:rgba(255,255,255,.08); }
    .settingsPopup__option.active{ font-weight:600; }
    .settingsPopup__dot{
      width:10px;
      height:10px;
      border-radius:50%;
      border:1px solid rgba(0,0,0,.15);
      flex-shrink:0;
    }

    .themeOption[data-theme="warm"]{
      background:#fbf8f1;
      color:#151a22;
    }
    .themeOption[data-theme="light"]{
      background:#ffffff;
      color:#111827;
    }
    .themeOption[data-theme="rose"]{
      background:#fdf2f4;
      color:#3d2b30;
    }
    .themeOption[data-theme="dark"]{
      background:#1e1b4b;
      color:#e7edf5;
    }

    /* Sidebar */
    .sidebar{
      position:fixed;
      top:0;
      left:0;
      width:var(--sw);
      height:100%;
      background:
        linear-gradient(180deg, rgba(255,255,255,.25) 0%, transparent 35%, rgba(0,0,0,.06) 100%),
        color-mix(in srgb, var(--sidebar) 35%, transparent);
      box-shadow:inset 0 2px 4px rgba(255,255,255,.6), inset 0 -4px 8px rgba(0,0,0,.07);
      pointer-events:none;
      z-index:0;
    }



    /* Scrollbar — innerhalb der Sidebar, vor der Kante */
    .scrollTrack{
      position:fixed;
      top:0;
      right:0;
      width:6px;
      height:100%;
      z-index:2;
    }
    .sidebarWrap{
      position:fixed;
      top:0;
      left:0;
      width:var(--sw);
      height:100%;
      z-index:1;
      overflow:hidden;
      pointer-events:auto;
    }
    .sidebarInner{
      display:flex;flex-direction:column;
      height:100%;
      padding-top:116px;
      padding-bottom:80px;
      padding-left:12px;
      padding-right:12px;
    }

    /* Sidebar Search */
    .sbSearch{
      display:flex;align-items:center;gap:6px;
      padding:7px 10px;border-radius:8px;
      background:rgba(255,255,255,.7);
      border:1px solid rgba(0,0,0,.06);
      color:#8f8f8f;font-size:11px;margin-bottom:8px;
    }
    html[data-theme="dark"] .sbSearch{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.06);
      color:#6b7a8f;
    }
    .sbSearch svg{width:13px;height:13px;stroke:#8f8f8f;fill:none;stroke-width:2;stroke-linecap:round;flex-shrink:0;}
    html[data-theme="dark"] .sbSearch svg{stroke:#6b7a8f;}

    /* Sidebar Neues Team Button */
    .sbNewBtn{
      display:flex;align-items:center;justify-content:center;gap:6px;
      padding:8px 10px;border-radius:8px;
      background:rgba(0,0,0,.04);
      border:1px solid rgba(0,0,0,.06);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.5);
      color:var(--sbDark);font-size:11px;font-weight:600;
      cursor:pointer;margin-bottom:12px;transition:all .15s ease;
    }
    html[data-theme="dark"] .sbNewBtn{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
    }
    .sbNewBtn:hover{filter:brightness(.95);}
    html[data-theme="dark"] .sbNewBtn:hover{filter:brightness(1.1);}
    .sbNewBtn svg{width:14px;height:14px;stroke:var(--sbDark);fill:none;stroke-width:2;stroke-linecap:round;}

    /* Sidebar Section Headers */
    .sbSection{
      font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;
      color:#8f8f8f;padding:8px 4px 4px;display:flex;align-items:center;gap:4px;
    }
    html[data-theme="dark"] .sbSection{color:#6b7a8f;}
    .sbSection svg{width:10px;height:10px;stroke:var(--sbDark);fill:color-mix(in srgb, var(--sidebar) 20%, transparent);stroke-width:2;stroke-linecap:round;}

    /* Sidebar Items */
    .sbItem{
      display:flex;align-items:center;gap:6px;padding:6px 8px;
      border-radius:7px;cursor:pointer;transition:background .12s ease;
      color:#3d3d3a;
    }
    html[data-theme="dark"] .sbItem{color:#e7edf5;}
    .sbItem:hover{background:rgba(0,0,0,.05);}
    html[data-theme="dark"] .sbItem:hover{background:rgba(255,255,255,.05);}
    .sbItem.active{background:rgba(255,255,255,.7);box-shadow:0 1px 3px rgba(0,0,0,.05);}
    html[data-theme="dark"] .sbItem.active{background:rgba(255,255,255,.06);}
    .sbDot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
    .sbName{flex:1;font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .sbMeta{font-size:9px;color:#8f8f8f;flex-shrink:0;}
    html[data-theme="dark"] .sbMeta{color:#6b7a8f;}
    .sbAgents{display:flex;gap:2px;flex-shrink:0;}
    .sbAgentDot{width:5px;height:5px;border-radius:50%;}

    /* Sidebar Divider */
    .sbDivider{height:1px;background:rgba(0,0,0,.06);margin:4px 0;}
    html[data-theme="dark"] .sbDivider{background:rgba(255,255,255,.06);}

    /* Sidebar Split Panes */
    .sbTopPane{
      flex:1;overflow-y:auto;min-height:60px;
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 15%, transparent) transparent;
    }
    .sbTopPane::-webkit-scrollbar{width:4px;}
    .sbTopPane::-webkit-scrollbar-track{background:transparent;}
    .sbTopPane::-webkit-scrollbar-thumb{background:color-mix(in srgb, var(--sbDark) 20%, transparent);border-radius:999px;}
    .sbBottomPane{
      overflow-y:auto;min-height:60px;
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 15%, transparent) transparent;
    }
    .sbBottomPane::-webkit-scrollbar{width:4px;}
    .sbBottomPane::-webkit-scrollbar-track{background:transparent;}
    .sbBottomPane::-webkit-scrollbar-thumb{background:color-mix(in srgb, var(--sbDark) 20%, transparent);border-radius:999px;}
    .sbResizeHandle{
      height:6px;flex-shrink:0;cursor:row-resize;position:relative;
      margin:2px 0;
    }
    .sbResizeHandle::before{
      content:'';position:absolute;left:25%;right:25%;top:50%;
      height:2px;border-radius:1px;transform:translateY(-50%);
      background:rgba(0,0,0,.1);transition:background .15s;
    }
    html[data-theme="dark"] .sbResizeHandle::before{background:rgba(255,255,255,.1);}
    .sbResizeHandle:hover::before,.sbResizeHandle.active::before{
      background:rgba(0,0,0,.25);
    }
    html[data-theme="dark"] .sbResizeHandle:hover::before,
    html[data-theme="dark"] .sbResizeHandle.active::before{
      background:rgba(255,255,255,.25);
    }

    /* FE14/FE28: Expandierbare Projekte + Teams in Sidebar */
    .sbItem--project{ cursor:pointer; }
    .sbItem--project.sbItem--selected{
      background:color-mix(in srgb, var(--sidebar) 30%, transparent);
      font-weight:600;
    }
    html[data-theme="dark"] .sbItem--project.sbItem--selected{
      background:rgba(255,255,255,.1);
    }
    .sbTeams{ padding-left:16px; overflow:hidden; }
    .sbTeams.collapsed{ display:none; }
    .sbTeamItem{
      display:flex; align-items:center; gap:5px; padding:3px 6px; border-radius:5px;
      font-size:10px; color:#3d3d3a; cursor:pointer; transition:background .12s;
    }
    html[data-theme="dark"] .sbTeamItem{ color:#c0cfe0; }
    .sbTeamItem:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .sbTeamItem:hover{ background:rgba(255,255,255,.05); }
    .sbTeamItem--active{ font-weight:600; background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .sbTeamItem--active{ background:rgba(255,255,255,.08); }
    .sbTeamItem__count{ font-size:8px; opacity:.6; }
    .sbExpandIcon{
      width:8px; height:8px; flex-shrink:0; transition:transform .15s;
      stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round;
    }
    .sbExpandIcon--open{ transform:rotate(90deg); }

    /* Sidebar Activity Feed */
    .sbActivity{
      display:flex;align-items:flex-start;gap:6px;padding:4px 8px;
      font-size:10px;color:#8f8f8f;line-height:1.3;
    }
    html[data-theme="dark"] .sbActivity{color:#6b7a8f;}
    .sbActivity svg{width:10px;height:10px;stroke:var(--sbDark);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:1px;}

    /* Sidebar Action Icons (fixed, zwischen Logo und Scroll-Content) */
    .sidebarIcons{
      position:fixed;
      z-index:3;
      top:72px;
      left:12px;
      width:calc(var(--sw) - 24px);
      display:flex;
      gap:4px;
      transition:all .3s ease;
    }
    .sidebarIcon{
      width:36px;
      height:36px;
      border:1px solid rgba(0,0,0,.06);
      background:rgba(0,0,0,.04);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.5), 0 1px 3px rgba(0,0,0,.1);
      cursor:pointer;
      padding:0;
      border-radius:8px;
      transition:all .15s ease;
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .sidebarIcon:hover{
      background:rgba(0,0,0,.08);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.5), 0 2px 6px rgba(0,0,0,.15);
    }
    html[data-theme="dark"] .sidebarIcon{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1), 0 1px 3px rgba(0,0,0,.2);
    }
    html[data-theme="dark"] .sidebarIcon:hover{
      background:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.15), 0 2px 6px rgba(0,0,0,.25);
    }
    .sidebarIcon .tooltip{
      position:absolute;
      left:50%;
      top:calc(100% + 6px);
      transform:translateX(-50%);
      background:rgba(20,20,19,.85);
      color:#faf9f5;
      font-size:11px;
      padding:3px 8px;
      border-radius:5px;
      white-space:nowrap;
      pointer-events:none;
      opacity:0;
      transition:opacity .15s ease;
    }
    .sidebarIcon:hover .tooltip{
      opacity:1;
    }
    .sidebarIcon svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:var(--sbDark);
      stroke-width:1.8;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    /* Sidebar Toggle */
    .sidebarToggle{
      position:fixed;
      z-index:4;
      top:16px;
      left:calc(var(--sw) - 44px);
      width:32px;
      height:32px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:8px;
      display:flex;
      align-items:center;
      justify-content:center;
      transition:background .15s ease, left .3s ease;
    }
    .sidebarToggle:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarToggle svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:1.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    /* Light + Rose: Utility-Icons neutral muted */
    html[data-theme="light"] .sidebarToggle svg,
    html[data-theme="light"] .sidebarSettings svg,
    html[data-theme="rose"] .sidebarToggle svg,
    html[data-theme="rose"] .sidebarSettings svg{
      stroke:#73726C;
    }

    /* Transitions fuer Collapse */
    .sidebar,
    .sidebarWrap,
    .sidebarInner,
    .sidebarIcons,
    .sidebarLogo,
    .sidebarBottom,
    .mainDivider,
    .chatInput--left,
    .chatInput--right{
      transition:all .3s ease;
    }

    /* Collapsed: Content, Icons und Logo verstecken */
    html.collapsed .sidebarInner,
    html.collapsed .sidebarIcons,
    html.collapsed .sidebarLogo{
      opacity:0;
      pointer-events:none;
    }

    /* Sidebar Bottom (User-Profil + Settings) */
    .sidebarBottom{
      position:fixed;
      z-index:3;
      bottom:24px;
      left:24px;
      width:calc(var(--sw) - 32px);
      display:flex;
      align-items:center;
      gap:8px;
      transition:all .3s ease;
    }
    .sidebarUser{
      display:flex;
      align-items:center;
      gap:8px;
      flex:1;
      min-width:0;
      cursor:pointer;
      padding:6px 8px;
      border-radius:8px;
      transition:background .15s ease;
      background:rgba(0,0,0,.04);
      border:1px solid rgba(0,0,0,.06);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.5);
    }
    .sidebarUser:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarAvatar{
      width:32px;
      height:32px;
      border-radius:50%;
      background:#3d3d3a;
      color:#faf9f5;
      font-size:13px;
      font-weight:600;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
    }
    .sidebarUserName{
      font-size:13px;
      color:#3d3d3a;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    html[data-theme="dark"] .sidebarUserName{ color:#faf9f5; }
    html[data-theme="dark"] .sidebarUser{ background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.1); box-shadow:inset 0 1px 0 rgba(255,255,255,.1); }
    .sidebarSettings{
      width:32px;
      height:32px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:8px;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
      transition:background .15s ease;
      position:relative;
    }
    .sidebarSettings:hover{
      background:rgba(0,0,0,.07);
    }
    .sidebarSettings svg{
      width:20px;
      height:20px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:1.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }
    .sidebarSettings .tooltip{
      position:absolute;
      left:calc(100% + 8px);
      top:50%;
      transform:translateY(-50%);
      background:rgba(20,20,19,.85);
      color:#faf9f5;
      font-size:12px;
      padding:4px 10px;
      border-radius:6px;
      white-space:nowrap;
      pointer-events:none;
      opacity:0;
      transition:opacity .15s ease;
    }
    .sidebarSettings:hover .tooltip{
      opacity:1;
    }
    html.collapsed .sidebarUserName{
      opacity:0;
      width:0;
    }
    html.collapsed .sidebarUser{
      padding:6px 4px;
    }

    /* Scrollbars — ChatGPT-Stil: schwebende Kapsel, weich, schmal */
    .chatMessages,
    .sidebarWrap{
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 20%, var(--bgFlat)) transparent;
    }
    .chatMessages::-webkit-scrollbar,
    .sidebarWrap::-webkit-scrollbar{
      width:6px;
    }
    .chatMessages::-webkit-scrollbar-track,
    .sidebarWrap::-webkit-scrollbar-track{
      background:transparent;
    }
    .chatMessages::-webkit-scrollbar-thumb,
    .sidebarWrap::-webkit-scrollbar-thumb{
      background:color-mix(in srgb, var(--sbDark) 22%, var(--bgFlat));
      border-radius:999px;
      border:1px solid transparent;
      background-clip:padding-box;
    }
    .chatMessages::-webkit-scrollbar-thumb:hover,
    .sidebarWrap::-webkit-scrollbar-thumb:hover{
      background:color-mix(in srgb, var(--sbDark) 40%, var(--bgFlat));
      border:1px solid transparent;
      background-clip:padding-box;
    }

    /* Chat-Nachrichten */
    .chatMessages{
      position:fixed;
      top:0;
      bottom:80px;
      overflow-y:scroll;
      z-index:0;
      pointer-events:auto;
    }
    .chatMessagesInner{
      min-height:calc(100% + 1px);
      display:flex;
      flex-direction:column;
      gap:12px;
      padding:24px;
    }
    .chatMessages--left{
      left:calc(var(--sw) + 4px);
      right:calc(100% - var(--dp) + 4px);
      top:48px;
    }
    .chatMsg{
      max-width:80%;
      padding:10px 16px;
      border-radius:16px;
      font-size:14px;
      line-height:20px;
      word-wrap:break-word;
    }
    .chatMsg--user{
      align-self:flex-end;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      color:#3d3d3a;
      border-bottom-right-radius:4px;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 1px 3px rgba(0,0,0,.06);
    }
    html[data-theme="dark"] .chatMsg--user{
      color:#e7edf5;
      border-color:rgba(255,255,255,.08);
      border-top:1px solid rgba(255,255,255,.12);
      box-shadow:inset 0 2px 4px rgba(255,255,255,.08), inset 0 -4px 8px rgba(0,0,0,.2), 0 1px 3px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.18);
    }
    .chatMsg--agent{
      align-self:flex-start;
      background:rgba(255,255,255,.7);
      color:#3d3d3a;
      border-bottom-left-radius:4px;
    }
    html[data-theme="dark"] .chatMsg--agent{
      background:rgba(255,255,255,.08);
      color:#e7edf5;
    }
    /* Management Board: Agent = User-Layout gespiegelt, Farben wie Team Board */
    .chatMessages--left .chatMsg--agent{
      background:rgba(255,255,255,.7);
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 1px 3px rgba(0,0,0,.06);
    }
    html[data-theme="dark"] .chatMessages--left .chatMsg--user{
      background:color-mix(in srgb, var(--sidebar) 70%, transparent);
      border:1px solid rgba(255,255,255,.08);
      border-top:1px solid rgba(255,255,255,.12);
      box-shadow:inset 0 2px 4px rgba(255,255,255,.08), inset 0 -4px 8px rgba(0,0,0,.2), 0 1px 3px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.18);
    }
    html[data-theme="dark"] .chatMessages--left .chatMsg--agent{
      background:color-mix(in srgb, var(--sidebar) 15%, transparent);
      border:1px solid rgba(255,255,255,.08);
      border-top:1px solid rgba(255,255,255,.12);
      box-shadow:inset 0 2px 4px rgba(255,255,255,.08), inset 0 -4px 8px rgba(0,0,0,.2), 0 1px 3px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.18);
    }
    .chatMsg--error{
      align-self:center;
      background:rgba(239,68,68,.10);
      color:#dc2626;
      border:1px solid rgba(239,68,68,.20);
      font-size:12px;
      padding:6px 14px;
      border-radius:8px;
      max-width:90%;
    }
    html[data-theme="warm"] .chatMsg--error{
      background:rgba(239,68,68,.08);
      color:#b91c1c;
    }
    html[data-theme="rose"] .chatMsg--error{
      background:rgba(239,68,68,.10);
      color:#be123c;
      border-color:rgba(239,68,68,.18);
    }
    html[data-theme="dark"] .chatMsg--error{
      background:rgba(239,68,68,.15);
      color:#fca5a5;
      border-color:rgba(239,68,68,.3);
    }
    .wsBanner{
      display:none;
      position:fixed;
      top:0;left:0;right:0;
      z-index:100;
      background:rgba(239,68,68,.12);
      color:#dc2626;
      text-align:center;
      font-size:11px;
      font-weight:600;
      padding:5px 0;
      letter-spacing:.3px;
      border-bottom:1px solid rgba(239,68,68,.25);
    }
    html[data-theme="warm"] .wsBanner{
      background:rgba(239,68,68,.10);
      color:#b91c1c;
    }
    html[data-theme="rose"] .wsBanner{
      background:rgba(239,68,68,.10);
      color:#be123c;
    }
    html[data-theme="dark"] .wsBanner{
      background:rgba(239,68,68,.18);
      color:#fca5a5;
      border-color:rgba(239,68,68,.3);
    }
    .wsBanner--visible{ display:block; }
    .agentBar__error{
      color:#dc2626;
      font-weight:600;
      font-size:11px;
    }
    html[data-theme="warm"] .agentBar__error{ color:#b91c1c; }
    html[data-theme="rose"] .agentBar__error{ color:#be123c; }
    html[data-theme="dark"] .agentBar__error{ color:#fca5a5; }
    .chatMsg--subagent{
      align-self:flex-start;
      background:rgba(255,255,255,.45);
      color:#3d3d3a;
      border-bottom-left-radius:4px;
    }
    html[data-theme="dark"] .chatMsg--subagent{
      background:rgba(255,255,255,.12);
      color:#e7edf5;
    }
    /* Output-forwarder: dezent, kleine stille Präsenz-Anzeige */
    .chatMsg--forwarder{
      padding:4px 12px;
      font-size:11px;
      line-height:16px;
      opacity:.55;
      border-radius:8px;
      max-width:60%;
    }
    .chatMsg--forwarder .agentLabel{
      font-size:9px;
    }
    .chatMsg--forwarder .msgTime{
      font-size:8px;
    }
    /* Message Row + Action Buttons */
    .msgRow{
      display:flex;
      align-items:flex-end;
      gap:4px;
      max-width:80%;
      position:relative;
    }
    .msgRow--user{ align-self:flex-end; }
    .msgRow--agent{ align-self:flex-start; flex-direction:row-reverse; gap:0; }
    .msgRow .chatMsg{ max-width:100%; align-self:auto; }
    .msgActions{
      display:flex;
      flex-direction:column;
      gap:2px;
      flex-shrink:0;
      align-self:flex-end;
      margin-bottom:-12px;
    }
    .copyBtn,.replyBtn{
      flex-shrink:0;
      width:16px;
      height:16px;
      border:none;
      background:transparent;
      cursor:pointer;
      border-radius:3px;
      display:flex;
      align-items:center;
      justify-content:center;
      opacity:.2;
      transition:opacity .15s ease, background .12s ease;
      padding:0;
    }
    .copyBtn:hover,.replyBtn:hover{opacity:.6;}
    .replyBtn:hover{background:color-mix(in srgb, var(--sidebar) 15%, transparent);border-radius:4px;}
    .copyBtn svg{
      width:10px;height:10px;fill:none;stroke:#3d3d3a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;
    }
    .replyBtn svg{
      width:11px;height:11px;fill:none;stroke:#3d3d3a;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;
    }
    html[data-theme="dark"] .copyBtn svg,
    html[data-theme="dark"] .replyBtn svg{stroke:#e7edf5;}
    .copyBtn--done svg{stroke:#22c55e;}
    .copyBtn--done{opacity:.7;}
    .chatMsg--forwarder .copyBtn,.chatMsg--forwarder .replyBtn{display:none;}
    .typingIndicator .copyBtn,.typingIndicator .replyBtn{display:none;}

    /* Reply indicator in messages */
    .msgReplyRef{
      display:flex;align-items:center;gap:4px;
      font-size:9px;color:#8f8f8f;margin-bottom:3px;
      text-transform:uppercase;letter-spacing:.3px;
    }
    .msgReplyRef svg{width:10px;height:10px;stroke:#8f8f8f;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    html[data-theme="dark"] .msgReplyRef{color:#999590;}
    html[data-theme="dark"] .msgReplyRef svg{stroke:#999590;}

    /* Reply Popup — fixed positioning to avoid scroll clipping */
    .replyPopup{
      position:fixed;
      z-index:200;
      width:280px;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(12px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:10px;
      box-shadow:0 6px 24px rgba(0,0,0,.10), 0 2px 6px rgba(0,0,0,.05);
      overflow:hidden;
      animation:replyIn .12s ease;
    }
    html[data-theme="dark"] .replyPopup{
      background:rgba(30,42,66,.92);
      border-color:rgba(255,255,255,.1);
      box-shadow:0 6px 24px rgba(0,0,0,.3);
    }
    @keyframes replyIn{
      from{opacity:0;transform:translateY(3px);}
      to{opacity:1;transform:translateY(0);}
    }
    .replyPopup__header{
      display:flex;align-items:center;justify-content:space-between;
      padding:7px 10px;border-bottom:1px solid rgba(0,0,0,.06);
      font-size:11px;font-weight:600;color:#3d3d3a;
    }
    html[data-theme="dark"] .replyPopup__header{border-color:rgba(255,255,255,.06);color:#e7edf5;}
    .replyPopup__recipient{display:flex;align-items:center;gap:5px;}
    .replyPopup__dot{width:6px;height:6px;border-radius:50%;background:#22c55e;}
    .replyPopup__close{
      width:18px;height:18px;border:none;background:transparent;cursor:pointer;
      border-radius:4px;display:flex;align-items:center;justify-content:center;
      opacity:.4;transition:opacity .12s ease;
    }
    .replyPopup__close:hover{opacity:.8;}
    .replyPopup__close svg{width:11px;height:11px;stroke:#3d3d3a;fill:none;stroke-width:2;stroke-linecap:round;}
    html[data-theme="dark"] .replyPopup__close svg{stroke:#e7edf5;}
    .replyPopup__quote{
      padding:6px 10px;font-size:10px;line-height:14px;color:#8f8f8f;
      border-left:2px solid color-mix(in srgb, var(--sidebar) 50%, transparent);
      margin:6px 10px 0;max-height:36px;overflow:hidden;
    }
    html[data-theme="dark"] .replyPopup__quote{color:#6b7a8f;}
    .replyPopup__inputWrap{
      padding:6px 10px 8px;display:flex;align-items:flex-end;gap:5px;
    }
    .replyPopup__input{
      flex:1;resize:none;border:1px solid rgba(0,0,0,.1);border-radius:7px;
      padding:6px 8px;font-size:12px;font-family:inherit;line-height:16px;
      min-height:30px;max-height:64px;background:rgba(255,255,255,.6);
      color:#3d3d3a;outline:none;transition:border-color .15s ease;
    }
    .replyPopup__input:focus{border-color:color-mix(in srgb, var(--sbDark) 50%, transparent);}
    html[data-theme="dark"] .replyPopup__input{
      background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:#e7edf5;
    }
    html[data-theme="dark"] .replyPopup__input:focus{border-color:rgba(138,164,200,.4);}
    .replyPopup__send{
      width:28px;height:30px;border:none;flex-shrink:0;
      background:color-mix(in srgb, var(--sbDark) 80%, transparent);
      border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;
      transition:filter .12s ease;
    }
    .replyPopup__send:hover{filter:brightness(.9);}
    html[data-theme="dark"] .replyPopup__send:hover{filter:brightness(1.15);}
    .replyPopup__send svg{width:12px;height:12px;fill:none;stroke:#faf9f5;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

    /* Typing Indicator — ephemere Präsenz-Anzeige */
    .typingIndicator{
      display:flex;
      align-items:center;
      gap:6px;
      padding:6px 12px;
      font-size:11px;
      color:#8f8f8f;
      opacity:.6;
    }
    html[data-theme="dark"] .typingIndicator{ color:#6b7a8f; }
    .typingIndicator__dots{
      display:flex;
      gap:3px;
    }
    .typingIndicator__dot{
      width:5px;
      height:5px;
      border-radius:50%;
      background:#8f8f8f;
      animation:typingPulse 1.4s infinite ease-in-out;
    }
    html[data-theme="dark"] .typingIndicator__dot{ background:#6b7a8f; }
    .typingIndicator__dot:nth-child(2){ animation-delay:.2s; }
    .typingIndicator__dot:nth-child(3){ animation-delay:.4s; }
    @keyframes typingPulse{
      0%,80%,100%{ opacity:.3; transform:scale(.8); }
      40%{ opacity:1; transform:scale(1); }
    }


    .chatMessages--right{
      left:calc(var(--dp) + 4px);
      right:4px;
      top:48px;
    }
    .chatMsg .agentLabel{
      display:block;
      font-size:10px;
      font-weight:600;
      margin-bottom:2px;
      opacity:.7;
    }
    .chatMsg .msgTime{
      display:block;
      font-size:9px;
      opacity:.45;
      margin-top:3px;
      text-align:right;
    }

    /* Team Board: jede Nachricht als volle-Breite Box */
    .chatMessages--right .chatMsg{
      max-width:100%;
      width:100%;
      align-self:stretch;
      border:1px solid rgba(0,0,0,.06);
      border-radius:12px;
      box-shadow:0 1px 3px rgba(0,0,0,.06);
    }
    html[data-theme="dark"] .chatMessages--right .chatMsg{
      border-color:rgba(255,255,255,.08);
      border-top:1px solid rgba(255,255,255,.12);
      box-shadow:inset 0 2px 4px rgba(255,255,255,.08), inset 0 -4px 8px rgba(0,0,0,.2), 0 1px 3px rgba(0,0,0,.12), 0 4px 16px rgba(0,0,0,.18);
    }

    /* Board Headers (getrennte Labels oben) */
    .boardHeader{
      position:fixed;
      top:8px;
      z-index:6;
      height:32px;
      display:flex;
      align-items:center;
      padding:0 14px;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      backdrop-filter:blur(8px);
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px;
      transition:all .3s ease;
      text-decoration:none;
    }
    html[data-theme="light"] .boardHeader{
      border-color:transparent;
    }
    html[data-theme="dark"] .boardHeader{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
    }
    .boardHeader--left{
      left:calc(var(--sw) + 12px);
      right:calc(100% - var(--dp) + 12px);
      flex-wrap:wrap;
    }
    .boardHeader--right{
      left:calc(var(--dp) + 12px);
      right:12px;
      flex-wrap:wrap;
    }
    .boardHeader__title{
      font-size:11px;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.5px;
      color:#3d3d3a;
      opacity:.5;
      white-space:nowrap;
      flex-shrink:0;
    }
    html[data-theme="dark"] .boardHeader__title{
      color:#e7edf5;
    }
    .boardHeader__agents{
      display:flex;
      gap:8px;
      justify-content:center;
      overflow:hidden;
      flex:1 1 0;
      min-width:0;
    }
    .agentBar__item{
      display:flex;
      align-items:center;
      gap:4px;
      font-size:10px;
      font-weight:400;
      color:#3d3d3a;
      opacity:.55;
      white-space:nowrap;
      min-width:18px;
      flex:0 1 auto;
      overflow:hidden;
      cursor:default;
    }
    html[data-theme="dark"] .agentBar__item{ color:#e7edf5; }
    .agentBar__dot{
      width:6px;
      height:6px;
      border-radius:50%;
      flex-shrink:0;
    }
    .agentBar__dot--active{ background:#22c55e; }
    .agentBar__dot--idle{ background:#f59e0b; }
    .agentBar__dot--dead{ background:#ef4444; }
    .agentBar__name{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      flex-shrink:1;
    }
    .agentBar__role{
      font-size:9px;
      font-weight:400;
      opacity:.7;
      margin-left:-1px;
      overflow:hidden;
      text-overflow:clip;
      white-space:nowrap;
      flex-shrink:100;
      min-width:0;
    }

    /* FE30: Team-Tabs im rechten Header */
    .teamTabs{
      display:flex; gap:2px; overflow:hidden; flex:1 1 0; min-width:0;
    }
    .teamTab{
      display:flex; align-items:center; gap:4px; padding:2px 8px; border-radius:5px; cursor:pointer;
      font-size:10px; font-weight:500; color:#3d3d3a; opacity:.65; white-space:nowrap;
      background:transparent; border:1px solid transparent; transition:all .15s;
    }
    .teamTab:hover{ opacity:.85; background:color-mix(in srgb, var(--sidebar) 15%, transparent); }
    .teamTab--active{
      opacity:1; font-weight:600;
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
      border-color:color-mix(in srgb, var(--sidebar) 35%, transparent);
    }
    .teamTab__count{
      font-size:8px; font-weight:600; opacity:.6;
    }
    html[data-theme="dark"] .teamTab{ color:#e7edf5; }
    html[data-theme="dark"] .teamTab:hover{ background:rgba(255,255,255,.08); }
    html[data-theme="dark"] .teamTab--active{
      background:rgba(255,255,255,.12); border-color:rgba(255,255,255,.18);
    }

    /* FE30: Collapsible Team-Members Panel */
    /* Member Bar — zweite Zeile im Header, Sidebar-Designsprache */
    .memberBar{
      display:none; width:100%;
      gap:8px; padding-top:3px; flex-wrap:wrap;
    }
    .boardHeader--expanded{ height:auto; padding-bottom:6px; }
    .boardHeader--expanded .memberBar{ display:flex; }
    .memberChip{
      display:inline-flex; align-items:center; gap:4px;
      padding:0; cursor:pointer;
      font-size:10px; color:#3d3d3a; white-space:nowrap;
      background:none; border:none;
      opacity:.75; transition:opacity .12s;
    }
    .memberChip:hover{ opacity:1; }
    .memberChip--selected{ opacity:1; font-weight:600; }
    html[data-theme="dark"] .memberChip{ color:#c8d6e5; }
    .memberChip__dot{
      width:5px; height:5px; border-radius:50%; flex-shrink:0;
    }
    /* Pulse feedback on active chip click */
    @keyframes chipPulse{ 0%{transform:scale(1)} 50%{transform:scale(2.2)} 100%{transform:scale(1)} }
    .memberChip__dot--pulse{ animation:chipPulse .4s ease-out; }
    /* Error state on chip after timeout */
    @keyframes chipErrorPulse{ 0%,100%{opacity:1} 50%{opacity:.4} }
    .memberChip__dot--error{
      background:#ef4444 !important;
      animation:chipErrorPulse 1.5s ease infinite;
    }
    /* Deactivated agent */
    .memberChip--deactivated{ opacity:.35 !important; cursor:default !important; pointer-events:none; }
    /* Progress tooltip under starting chip */
    .memberChip__progress{
      font-size:7px; color:var(--sbDark,#8a7f6a); opacity:.7;
      white-space:nowrap; margin-left:-4px;
    }
    /* Agent-Start Spinner on Chip */
    @keyframes chipSpin{ to{ transform:rotate(360deg); } }
    .memberChip__dot--starting{
      border:1.5px solid #f59e0b;
      border-top-color:transparent;
      background:none !important;
      animation:chipSpin .6s linear infinite;
    }
    .memberChip__hint{
      font-size:8px; opacity:.6; cursor:pointer;
      text-decoration:underline;
    }
    .memberChip__hint:hover{ opacity:1; }
    .memberChip__name{ font-weight:600; font-size:10px; }
    .memberChip__role{
      font-size:8px; opacity:.55;
    }

    .projectBadge{
      display:inline-flex;
      gap:4px;
      margin-left:8px;
      flex-shrink:1;
      min-width:0;
      overflow:hidden;
    }
    .projectBadge__item{
      font-size:9px;
      font-weight:500;
      padding:2px 6px;
      border-radius:4px;
      background:color-mix(in srgb, var(--sidebar) 20%, transparent);
      color:var(--sbDark);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:120px;
    }
    html[data-theme="dark"] .projectBadge__item{
      background:rgba(255,255,255,.08);
      color:#8aa4c8;
    }

    /* Chat-Panels (Hauptflaeche links + rechts) */
    .chatPanel{
      position:fixed;
      top:0;
      height:100%;
      background:rgba(255,255,255,.04);
      z-index:0;
    }
    .chatPanel--left{
      left:var(--sw);
      right:calc(100% - var(--dp));
    }
    .chatPanel--right{
      left:var(--dp);
      right:0;
    }
    html[data-theme="warm"] .chatPanel{ background:#fdfcfa; }
    html[data-theme="warm"] .sidebar{ background: linear-gradient(180deg, rgba(255,255,255,.35) 0%, transparent 35%, rgba(0,0,0,.03) 100%), color-mix(in srgb, var(--sidebar) 25%, transparent); }
    html[data-theme="warm"] .boardHeader{ background:color-mix(in srgb, var(--sidebar) 15%, transparent); border-color:color-mix(in srgb, var(--sidebar) 10%, transparent); }
    html[data-theme="warm"] .sbNewBtn{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="warm"] .sidebarIcon{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="warm"] .sidebarUser{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="warm"] .chatMsg--user{ background:color-mix(in srgb, var(--sidebar) 25%, white); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="warm"] .chatMsg--agent{ background:#ffffff; border:1px solid rgba(0,0,0,.06); border-top:1px solid rgba(255,255,255,.9); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); }
    html[data-theme="warm"] .chatMessages--left .chatMsg--agent{ background:#ffffff; box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.9); }
    html[data-theme="warm"] .chatMessages--right .chatMsg{ box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="light"] .chatPanel{ background:#ffffff; }
    html[data-theme="light"] .sidebar{ background: linear-gradient(180deg, rgba(255,255,255,.35) 0%, transparent 35%, rgba(0,0,0,.03) 100%), color-mix(in srgb, var(--sidebar) 25%, transparent); }
    html[data-theme="light"] .boardHeader{ background:color-mix(in srgb, var(--sidebar) 15%, transparent); border-color:color-mix(in srgb, var(--sidebar) 10%, transparent); }
    html[data-theme="light"] .sbNewBtn{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="light"] .sidebarIcon{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="light"] .sidebarUser{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="light"] .chatMsg--user{ background:color-mix(in srgb, var(--sidebar) 25%, white); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="light"] .chatMsg--agent{ background:#ffffff; border:1px solid rgba(0,0,0,.06); border-top:1px solid rgba(255,255,255,.9); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); }
    html[data-theme="light"] .chatMessages--left .chatMsg--agent{ background:#ffffff; box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.9); }
    html[data-theme="light"] .chatMessages--right .chatMsg{ box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="rose"] .chatPanel{ background:#ffffff; }
    html[data-theme="rose"] .sidebar{ background: linear-gradient(180deg, rgba(255,255,255,.35) 0%, transparent 35%, rgba(0,0,0,.03) 100%), color-mix(in srgb, var(--sidebar) 25%, transparent); }
    html[data-theme="rose"] .boardHeader{ background:color-mix(in srgb, var(--sidebar) 15%, transparent); border-color:color-mix(in srgb, var(--sidebar) 10%, transparent); }
    html[data-theme="rose"] .sbNewBtn{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="rose"] .sidebarIcon{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="rose"] .sidebarUser{ background:rgba(0,0,0,.02); border-color:rgba(0,0,0,.04); }
    html[data-theme="rose"] .chatMsg--user{ background:color-mix(in srgb, var(--sidebar) 25%, white); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="rose"] .chatMsg--agent{ background:#ffffff; border:1px solid rgba(0,0,0,.06); border-top:1px solid rgba(255,255,255,.9); box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); }
    html[data-theme="rose"] .chatMessages--left .chatMsg--agent{ background:#ffffff; box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.9); }
    html[data-theme="rose"] .chatMessages--right .chatMsg{ box-shadow:inset 0 2px 4px rgba(255,255,255,.9), inset 0 -4px 8px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.12); border-top:1px solid rgba(255,255,255,.7); }
    html[data-theme="dark"] .chatPanel{ background:rgba(0,0,0,.25); }

    /* Vertikale Trennlinie Hauptbereich */
    .mainDivider{
      position:fixed;
      top:0;
      left:var(--dp);
      width:6px;
      margin-left:-3px;
      height:100%;
      background:linear-gradient(to right, transparent, rgba(0,0,0,.08) 50%, transparent);
      z-index:5;
      cursor:col-resize;
    }
    html[data-theme="dark"] .mainDivider{
      background:linear-gradient(to right, transparent, var(--sidebar) 50%, transparent);
    }

    /* Nachrichtenboxen */
    .chatInput{
      position:fixed;
      bottom:24px;
      z-index:2;
      display:flex;
      align-items:flex-end;
      gap:8px;
    }
    .chatInput--left{
      left:calc(var(--sw) + 24px);
      right:calc(100% - var(--dp) + 24px);
    }
    .chatInput--right{
      left:calc(var(--dp) + 24px);
      right:24px;
    }
    .chatInput .inputWrap{
      flex:1;
      position:relative;
      display:flex;
      align-items:flex-end;
    }
    .chatAttach{
      position:absolute;
      left:10px;
      bottom:8px;
      width:28px;
      height:28px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:50%;
      background:transparent;
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      transition:background .15s ease;
      flex-shrink:0;
    }
    .chatAttach:hover{
      background:rgba(0,0,0,.05);
    }
    .chatAttach svg{
      width:16px;
      height:16px;
      fill:none;
      stroke:#8f8f8f;
      stroke-width:2;
      stroke-linecap:round;
    }
    .chatInput textarea{
      width:100%;
      resize:none;
      border:1px solid rgba(0,0,0,.12);
      border-radius:16px;
      padding:12px 16px 12px 46px;
      font-size:14px;
      font-family:inherit;
      line-height:20px;
      background:rgba(255,255,255,.7);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.035);
      outline:none;
      min-height:44px;
      max-height:120px;
      overflow-y:auto;
    }
    .chatInput textarea:focus{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .chatInput textarea::placeholder{
      color:#8f8f8f;
    }
    .chatSend{
      width:36px;
      height:36px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:50%;
      background:rgba(255,255,255,.7);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.035);
      cursor:pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      flex-shrink:0;
      margin-bottom:4px;
      transition:background .15s ease;
    }
    .chatSend:hover{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .chatSend svg{
      width:18px;
      height:18px;
      fill:none;
      stroke:var(--sbDark);
      stroke-width:2.5;
      stroke-linecap:round;
      stroke-linejoin:round;
    }
    html[data-theme="dark"] .chatSend svg{
      stroke:#e2e8f0;
    }
    html[data-theme="dark"] .chatInput textarea{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      color:#e2e8f0;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
      backdrop-filter:blur(8px);
    }
    html[data-theme="dark"] .chatInput textarea:focus{
      border-color:rgba(129,140,248,.4);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1), 0 0 0 2px rgba(129,140,248,.15);
    }
    html[data-theme="dark"] .chatInput textarea::placeholder{
      color:#64748b;
    }
    html[data-theme="dark"] .chatSend{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
    }
    html[data-theme="dark"] .chatSend:hover{
      background:rgba(255,255,255,.1);
      border-color:rgba(255,255,255,.15);
    }
    html[data-theme="dark"] .chatAttach{
      border-color:rgba(255,255,255,.1);
    }
    html[data-theme="dark"] .chatAttach:hover{
      background:rgba(255,255,255,.1);
    }
    html[data-theme="dark"] .chatAttach svg{
      stroke:#8aa4c8;
    }
    /* Custom Agent Dropdown */
    .customSelect{
      position:relative;
      min-width:90px;
      margin-bottom:4px;
      user-select:none;
    }
    .customSelect__trigger{
      height:36px;
      border:1px solid rgba(0,0,0,.12);
      border-radius:18px;
      background:rgba(255,255,255,.7);
      font-size:12px;
      font-family:inherit;
      padding:0 28px 0 12px;
      cursor:pointer;
      color:#3d3d3a;
      display:flex;
      align-items:center;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      transition:border-color .15s ease, box-shadow .15s ease;
    }
    .customSelect__trigger::after{
      content:'';
      position:absolute;
      right:10px;
      top:50%;
      transform:translateY(-50%);
      border-left:4px solid transparent;
      border-right:4px solid transparent;
      border-top:5px solid #8f8f8f;
      pointer-events:none;
    }
    .customSelect.open .customSelect__trigger{
      border-color:rgba(0,0,0,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.06);
    }
    .customSelect__dropdown{
      display:none;
      position:absolute;
      bottom:calc(100% + 4px);
      left:0;
      min-width:100%;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(12px);
      border:1px solid rgba(0,0,0,.1);
      border-radius:14px;
      padding:4px;
      box-shadow:0 4px 16px rgba(0,0,0,.1);
      z-index:20;
      max-height:200px;
      overflow-y:auto;
      scrollbar-width:thin;
    }
    .customSelect.open .customSelect__dropdown{
      display:block;
    }
    .customSelect__option{
      padding:6px 10px;
      border-radius:10px;
      font-size:12px;
      font-family:inherit;
      cursor:pointer;
      color:#3d3d3a;
      transition:background .12s ease, font-weight .12s ease;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .customSelect__option:hover{
      background:rgba(0,0,0,.06);
      font-weight:700;
    }
    .customSelect__option.selected{
      background:color-mix(in srgb, var(--sidebar) 25%, transparent);
    }
    html[data-theme="dark"] .customSelect__trigger{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      color:#e7edf5;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
    }
    html[data-theme="dark"] .customSelect__trigger::after{
      border-top-color:#6b7a8f;
    }
    html[data-theme="dark"] .customSelect.open .customSelect__trigger{
      border-color:rgba(255,255,255,.2);
      box-shadow:0 0.25rem 1.25rem rgba(0,0,0,.15);
    }
    html[data-theme="dark"] .customSelect__dropdown{
      background:rgba(255,255,255,.06);
      border-color:rgba(255,255,255,.1);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.1);
      backdrop-filter:blur(12px);
    }
    html[data-theme="dark"] .customSelect__option{
      color:#e7edf5;
    }
    html[data-theme="dark"] .customSelect__option:hover{
      background:rgba(255,255,255,.08);
    }
    html[data-theme="dark"] .customSelect__option.selected{
      background:rgba(255,255,255,.06);
    }

    /* Sidebar Resize Handle */
    .sidebarEdge{
      position:fixed;
      top:0;
      left:calc(var(--sw) - 3px);
      width:6px;
      height:100%;
      cursor:col-resize;
      z-index:5;
      transition:left .3s ease;
    }
    .sidebarEdge:hover,
    .sidebarEdge.active{
      background:color-mix(in srgb, var(--sidebar) 40%, transparent);
    }
    .mainDivider:hover,
    .mainDivider.active{
      background:linear-gradient(to right, transparent, rgba(0,0,0,.18) 50%, transparent);
    }
    html[data-theme="dark"] .mainDivider:hover,
    html[data-theme="dark"] .mainDivider.active{
      background:linear-gradient(to right, transparent, color-mix(in srgb, var(--sidebar) 80%, white) 50%, transparent);
    }
    /* Waehrend Drag: kein Text-Select, Cursor global */
    html.dragging{ cursor:col-resize !important; }
    html.dragging *{ cursor:col-resize !important; user-select:none !important; }
    html.dragging-row{ cursor:row-resize !important; }
    html.dragging-row *{ cursor:row-resize !important; user-select:none !important; }
    /* Waehrend Drag: Transitions deaktivieren fuer flüssiges Resizing */
    html.dragging .sidebar,
    html.dragging .sidebarWrap,
    html.dragging .sidebarInner,
    html.dragging .sidebarIcons,
    html.dragging .sidebarLogo,
    html.dragging .sidebarBottom,
    html.dragging .sidebarEdge,
    html.dragging .sidebarToggle,
    html.dragging .mainDivider,
    html.dragging .chatPanel,
    html.dragging .chatMessages,
    html.dragging .boardHeader,
    html.dragging .chatInput--left,
    html.dragging .chatInput--right{
      transition:none !important;
    }

    .themeOption:hover{
      filter:brightness(.95);
    }
    .themeOption[data-theme="dark"]:hover{
      filter:brightness(1.2);
    }

    /* ─── Accessibility: Focus + Skip-Link ─── */
    *:focus-visible{
      outline:2px solid #3b82f6;
      outline-offset:2px;
    }
    .skipLink{
      position:fixed;
      top:-100%;
      left:16px;
      z-index:10000;
      padding:8px 16px;
      background:var(--bgFlat);
      color:var(--sbDark);
      border:2px solid #3b82f6;
      border-radius:8px;
      font-size:14px;
      text-decoration:none;
      transition:top .2s;
    }
    .skipLink:focus{
      top:8px;
    }

    /* ─── Responsive: Mobile (<768px) ─── */
    @media (max-width:767px){
      /* Hide sidebar completely */
      .sidebar,
      .sidebarWrap,
      .sidebarInner,
      .sidebarIcons,
      .sidebarLogo,
      .sidebarBottom,
      .sidebarEdge,
      .sidebarToggle,
      .scrollTrack{
        display:none !important;
      }

      /* Left panel = full width (override inline --sw/--dp) */
      .chatPanel--left{
        left:0 !important; right:0 !important;
      }
      .chatMessages--left{
        left:4px !important; right:4px !important;
      }
      .boardHeader--left{
        left:12px !important; right:12px !important;
      }
      .chatInput--left{
        left:12px !important; right:12px !important;
      }

      /* Hide right panel + divider */
      .chatPanel--right,
      .chatMessages--right,
      .boardHeader--right,
      .chatInput--right,
      .mainDivider{
        display:none !important;
      }

      /* Input adjustments */
      .chatInput{
        bottom:8px !important;
      }
      .chatInput textarea{
        padding-left:42px;
        font-size:16px; /* prevent iOS zoom */
      }
    }

    /* ─── Responsive: Tablet (768–1024px) ─── */
    @media (min-width:768px) and (max-width:1024px){
      /* Hide sidebar */
      .sidebar,
      .sidebarWrap,
      .sidebarInner,
      .sidebarIcons,
      .sidebarLogo,
      .sidebarBottom,
      .sidebarEdge,
      .sidebarToggle,
      .scrollTrack{
        display:none !important;
      }

      /* Panels start from left edge */
      .chatPanel--left{
        left:0 !important;
      }
      .chatMessages--left{
        left:4px !important;
      }
      .boardHeader--left{
        left:12px !important;
      }
      .chatInput--left{
        left:12px !important;
      }
    }
    /* ═══ APPROVAL GATE ═══ */

    /* Badge */
    .approvalBadge{
      background:none; border:none; cursor:pointer; position:relative;
      font-size:18px; padding:4px 6px; line-height:1; color:var(--sbDark);
    }
    .approvalBadge:hover{ opacity:.8; }
    .approvalBadge__count{
      position:absolute; top:-2px; right:-4px; min-width:16px; height:16px;
      background:#ef4444; color:#fff; font-size:10px; font-weight:700;
      border-radius:50%; display:flex; align-items:center; justify-content:center;
      padding:0 4px; line-height:1;
    }
    .approvalBadge--pulse .approvalBadge__count{
      animation:badgePulse 1.5s ease infinite;
    }
    @keyframes badgePulse{
      0%,100%{ transform:scale(1); }
      50%{ transform:scale(1.3); }
    }

    /* Toast */
    .approvalToast{
      position:fixed; top:20px; right:20px; z-index:150;
      max-width:400px; min-width:300px;
      border-radius:10px; overflow:hidden;
      background:rgba(255,255,255,.92); backdrop-filter:blur(10px);
      box-shadow:0 4px 24px rgba(0,0,0,.18);
      display:flex; transform:translateX(440px);
      transition:transform .25s ease;
      font-size:13px;
    }
    .approvalToast--visible{ transform:translateX(0); }
    .approvalToast__risk{
      width:4px; flex-shrink:0;
    }
    .approvalToast--low .approvalToast__risk{ background:#00B050; }
    .approvalToast--medium .approvalToast__risk{ background:#FFA500; }
    .approvalToast--high .approvalToast__risk{ background:#FF4444; }
    .approvalToast__body{ padding:12px 14px; flex:1; }
    .approvalToast__header{ display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; }
    .approvalToast__title{ font-weight:600; font-size:13px; }
    .approvalToast__timer{ font-size:12px; color:#888; font-variant-numeric:tabular-nums; }
    .approvalToast__desc{ color:#555; margin-bottom:10px; font-size:12px; line-height:1.4; }
    .approvalToast__actions{ display:flex; gap:6px; }
    .approvalToast__btn{
      border:none; border-radius:6px; padding:5px 12px; font-size:12px; font-weight:600;
      cursor:pointer; transition:opacity .15s;
    }
    .approvalToast__btn:hover{ opacity:.85; }
    .approvalToast__btn--approve{ background:#00B050; color:#fff; }
    .approvalToast__btn--deny{ background:#FF4444; color:#fff; }
    .approvalToast__btn--details{ background:rgba(0,0,0,.08); color:inherit; }
    html[data-theme="dark"] .approvalToast{ background:rgba(30,42,66,.92); color:#e0e0e0; }
    html[data-theme="dark"] .approvalToast__desc{ color:#aaa; }
    html[data-theme="dark"] .approvalToast__btn--details{ background:rgba(255,255,255,.1); }
    html[data-theme="dark"] .approvalToast__timer{ color:#8aa4c8; }

    /* Panel */
    .approvalPanel{
      position:fixed; top:0; right:0; bottom:0; width:370px; z-index:50;
      background:var(--bgFlat, #fff); border-left:1px solid rgba(0,0,0,.06);
      transform:translateX(400px); transition:transform .3s ease;
      display:flex; flex-direction:column; overflow:hidden;
    }
    .approvalPanel--open{ transform:translateX(0); }
    html[data-theme="dark"] .approvalPanel{ background:#1a2236; border-color:rgba(255,255,255,.08); }
    .approvalPanel__header{
      display:flex; align-items:center; gap:8px; padding:16px 18px;
      border-bottom:1px solid rgba(0,0,0,.06); flex-shrink:0;
    }
    html[data-theme="dark"] .approvalPanel__header{ border-color:rgba(255,255,255,.08); }
    .approvalPanel__header h2{ margin:0; font-size:15px; font-weight:700; flex:1; }
    .approvalPanel__count{ font-size:12px; color:#888; }
    .approvalPanel__close{
      background:none; border:none; font-size:18px; cursor:pointer;
      color:inherit; opacity:.5; padding:2px 6px;
    }
    .approvalPanel__close:hover{ opacity:1; }
    .approvalPanel__list{ flex:1; overflow-y:auto; padding:12px; scrollbar-width:thin; }
    .approvalPanel__empty{
      text-align:center; color:#888; padding:40px 20px; font-size:13px;
    }

    /* Cards */
    .approvalCard{
      border-radius:10px; margin-bottom:10px; overflow:hidden;
      background:rgba(255,255,255,.85); border:1px solid rgba(0,0,0,.06);
      box-shadow:0 2px 8px rgba(0,0,0,.08);
    }
    html[data-theme="dark"] .approvalCard{
      background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08);
    }
    .approvalCard__risk{
      height:3px;
    }
    .approvalCard--low .approvalCard__risk{ background:#00B050; }
    .approvalCard--medium .approvalCard__risk{ background:#FFA500; }
    .approvalCard--high .approvalCard__risk{ background:#FF4444; }
    .approvalCard__header{
      display:flex; align-items:center; gap:6px; padding:10px 12px 4px;
    }
    .approvalCard__icon{ font-size:16px; }
    .approvalCard__action{ font-weight:600; font-size:13px; flex:1; }
    .approvalCard__timer{
      font-size:11px; color:#888; font-variant-numeric:tabular-nums;
    }
    .approvalCard__timer--urgent{ color:#FF4444; font-weight:600; }
    .approvalCard__body{ padding:4px 12px 8px; font-size:12px; line-height:1.4; color:#555; }
    html[data-theme="dark"] .approvalCard__body{ color:#aaa; }
    .approvalCard__who{ margin:0 0 2px; }
    .approvalCard__preview{
      background:rgba(0,0,0,.03); border-radius:6px; padding:8px 10px;
      margin-top:6px; font-size:11px; max-height:80px; overflow-y:auto;
      white-space:pre-wrap;
    }
    html[data-theme="dark"] .approvalCard__preview{ background:rgba(255,255,255,.04); }
    .approvalCard__buttons{
      display:flex; gap:8px; padding:8px 12px 12px;
    }
    .approvalCard__btn{
      border:none; border-radius:6px; padding:6px 16px; font-size:12px; font-weight:600;
      cursor:pointer; transition:opacity .15s;
    }
    .approvalCard__btn:hover{ opacity:.85; }
    .approvalCard__btn--approve{ background:#00B050; color:#fff; }
    .approvalCard__btn--approve.edited{ background:var(--accent,#6366f1); }
    .approvalCard__btn--deny{ background:#FF4444; color:#fff; }

    /* Editable fields */
    .approvalCard__label{
      display:block; font-size:11px; font-weight:600; color:var(--textMuted,#888);
      margin:6px 0 2px; text-transform:uppercase; letter-spacing:.5px;
    }
    .approvalCard__editField{
      width:100%; padding:6px 8px; border:1px solid rgba(0,0,0,.1); border-radius:4px;
      background:var(--bgFlat,#fff); color:var(--textMain,#333); font-family:inherit;
      font-size:13px; margin-bottom:4px; transition:border-color .2s; box-sizing:border-box;
    }
    .approvalCard__editField:focus{ border-color:var(--accent,#6366f1); outline:none; }
    .approvalCard__editField--body{ resize:vertical; min-height:80px; }
    html[data-theme="dark"] .approvalCard__editField{
      background:rgba(255,255,255,.06); color:#e7edf5; border-color:rgba(255,255,255,.12);
    }
    html[data-theme="dark"] .approvalCard__editField:focus{ border-color:var(--accent,#6366f1); }
    html[data-theme="dark"] .approvalCard__label{ color:#888; }

    /* History */
    .approvalPanel__history{
      border-top:1px solid rgba(0,0,0,.06); padding:12px; flex-shrink:0; max-height:180px; overflow-y:auto;
    }
    html[data-theme="dark"] .approvalPanel__history{ border-color:rgba(255,255,255,.08); }
    .approvalPanel__history h3{ margin:0 0 8px; font-size:11px; text-transform:uppercase; letter-spacing:.5px; color:#888; font-weight:600; }
    .approvalHistory__item{
      font-size:11px; color:#666; padding:3px 0; display:flex; gap:6px;
    }
    html[data-theme="dark"] .approvalHistory__item{ color:#888; }

    /* Feedback overlay */
    .approvalFeedback{
      position:fixed; top:80px; right:30px; z-index:160;
      padding:10px 20px; border-radius:8px; font-size:13px; font-weight:600;
      transform:translateX(300px); transition:transform .25s ease;
      box-shadow:0 4px 16px rgba(0,0,0,.15);
    }
    .approvalFeedback--visible{ transform:translateX(0); }
    .approvalFeedback--approved{ background:#00B050; color:#fff; }
    .approvalFeedback--denied{ background:#FF4444; color:#fff; }
    .approvalFeedback--expired{ background:#888; color:#fff; }
    .approvalFeedback--error{ background:#FFA500; color:#fff; }

    /* Organigramm Panel */
    .orgPanel{
      position:fixed; top:0; left:0; bottom:0; width:320px;
      background:var(--bgFlat,#fbf8f1);
      border-right:1px solid rgba(0,0,0,.08);
      z-index:55; transform:translateX(-340px);
      transition:transform .3s ease;
      display:flex; flex-direction:column;
      overflow:hidden;
    }
    .orgPanel--open{ transform:translateX(0); }
    html[data-theme="dark"] .orgPanel{ background:#161e3a; border-color:rgba(255,255,255,.08); }

    .orgPanel__header{
      display:flex; align-items:center; gap:8px;
      padding:14px 16px; border-bottom:1px solid rgba(0,0,0,.08);
      position:sticky; top:0; background:inherit; z-index:1;
    }
    .orgPanel__header h2{ font-size:14px; font-weight:700; margin:0; flex:1; color:var(--sbDark); }
    .orgPanel__count{ font-size:11px; color:#888; font-weight:600; }
    .orgPanel__close{
      width:28px; height:28px; border:none; background:none;
      cursor:pointer; font-size:18px; color:#888; border-radius:6px;
      display:flex; align-items:center; justify-content:center;
    }
    .orgPanel__close:hover{ background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .orgPanel__header{ border-color:rgba(255,255,255,.08); }
    html[data-theme="dark"] .orgPanel__close:hover{ background:rgba(255,255,255,.08); }

    .orgPanel__tree{
      flex:1; overflow-y:auto; padding:12px 8px;
      scrollbar-width:thin;
    }

    /* Tree Node */
    .orgNode{
      padding:6px 8px; border-radius:8px; margin-bottom:2px;
      display:flex; align-items:center; gap:8px;
      cursor:default; transition:background .15s;
    }
    .orgNode:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .orgNode:hover{ background:rgba(255,255,255,.04); }

    .orgNode__dot{
      width:8px; height:8px; border-radius:50%; flex-shrink:0;
    }
    .orgNode__dot--running{ background:#22c55e; box-shadow:0 0 4px rgba(34,197,94,.4); }
    .orgNode__dot--waiting{ background:#f59e0b; box-shadow:0 0 4px rgba(245,158,11,.4); }
    .orgNode__dot--disconnected{ background:#ef4444; }

    .orgNode__info{ flex:1; min-width:0; }
    .orgNode__name{
      font-size:13px; font-weight:600; color:var(--sbDark);
      display:flex; align-items:center; gap:6px;
    }
    .orgNode__role{
      font-size:10px; color:#888; font-weight:500;
      text-transform:uppercase; letter-spacing:.3px;
    }
    .orgNode__activity{
      font-size:11px; color:#999; margin-top:1px;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }

    .orgNode__toggle{
      width:18px; height:18px; border:none; background:none;
      cursor:pointer; font-size:10px; color:#888; border-radius:4px;
      display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .orgNode__toggle:hover{ background:rgba(0,0,0,.08); }

    /* Children container */
    .orgChildren{
      padding-left:20px;
      border-left:1px solid rgba(0,0,0,.06);
      margin-left:12px;
    }
    .orgChildren--collapsed{ display:none; }
    html[data-theme="dark"] .orgChildren{ border-color:rgba(255,255,255,.06); }

    /* Owner node special */
    .orgNode--owner .orgNode__name{ color:var(--sbDark); }

    /* Inactive agents dimmed */
    .orgNode--inactive{ opacity:.45; }

    /* ========== W6: Error-State Modals ========== */
    .teamModal__overlay{
      position:fixed; inset:0; z-index:200;
      background:rgba(0,0,0,.35); backdrop-filter:blur(3px);
      display:flex; align-items:center; justify-content:center;
      opacity:0; pointer-events:none; transition:opacity .2s;
    }
    .teamModal__overlay--open{ opacity:1; pointer-events:auto; }
    .teamModal{
      background:var(--bgFlat,#fff); border-radius:12px;
      box-shadow:0 8px 32px rgba(0,0,0,.18);
      padding:20px 24px; max-width:420px; width:90%;
      border:1px solid rgba(0,0,0,.08);
    }
    html[data-theme="dark"] .teamModal{ background:#1e2a42; border-color:rgba(255,255,255,.08); box-shadow:0 8px 32px rgba(0,0,0,.4); }
    .teamModal__icon{ font-size:20px; margin-bottom:8px; }
    .teamModal__title{ font-size:15px; font-weight:700; margin-bottom:6px; color:var(--sbDark,#3d3d3a); }
    html[data-theme="dark"] .teamModal__title{ color:#e2e8f0; }
    .teamModal__desc{ font-size:12px; color:#666; line-height:1.5; margin-bottom:4px; }
    html[data-theme="dark"] .teamModal__desc{ color:#94a3b8; }
    .teamModal__meta{ font-size:10px; color:#999; margin-bottom:14px; }
    .teamModal__actions{ display:flex; gap:8px; flex-wrap:wrap; }
    .teamModal__btn{
      padding:6px 14px; border:1px solid rgba(0,0,0,.1); border-radius:6px;
      background:var(--bgFlat,#f8f8f8); color:var(--sbDark,#3d3d3a);
      font-size:11px; font-weight:500; cursor:pointer; transition:background .15s;
    }
    .teamModal__btn:hover{ background:rgba(0,0,0,.05); }
    html[data-theme="dark"] .teamModal__btn{ background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.1); color:#c8d6e5; }
    html[data-theme="dark"] .teamModal__btn:hover{ background:rgba(255,255,255,.1); }
    .teamModal__btn--primary{ background:#6366f1; color:#fff; border-color:#6366f1; }
    .teamModal__btn--primary:hover{ background:#5558e6; }
    .teamModal__btn--danger{ background:#ef4444; color:#fff; border-color:#ef4444; }
    .teamModal__btn--danger:hover{ background:#dc2626; }

    /* ========== F1: Susi Team-Wizard Modal ========== */
    .twOverlay{
      position:fixed; inset:0; z-index:210;
      background:rgba(0,0,0,.35); backdrop-filter:blur(3px);
      display:flex; align-items:center; justify-content:center;
      opacity:0; pointer-events:none; transition:opacity .2s;
    }
    .twOverlay--open{ opacity:1; pointer-events:auto; }
    .twContainer{
      background:var(--bgFlat,#fff); border-radius:12px;
      box-shadow:0 8px 32px rgba(0,0,0,.18);
      padding:24px 28px; max-width:460px; width:92%;
      border:1px solid rgba(0,0,0,.08);
    }
    html[data-theme="dark"] .twContainer{
      background:#1e2a42; border-color:rgba(255,255,255,.08);
      box-shadow:0 8px 32px rgba(0,0,0,.4);
    }
    .twHeader{
      display:flex; align-items:center; justify-content:space-between;
      margin-bottom:16px;
    }
    .twTitle{
      font-size:15px; font-weight:700; color:var(--sbDark,#3d3d3a);
    }
    html[data-theme="dark"] .twTitle{ color:#e2e8f0; }
    .twClose{
      background:none; border:none; font-size:18px; cursor:pointer;
      color:#999; padding:0 2px; line-height:1;
    }
    .twClose:hover{ color:#666; }
    html[data-theme="dark"] .twClose{ color:#6b7a8f; }
    html[data-theme="dark"] .twClose:hover{ color:#c8d6e5; }
    .twSteps{
      display:flex; gap:8px; justify-content:center; margin-bottom:18px;
    }
    .twStepDot{
      width:8px; height:8px; border-radius:50%;
      background:rgba(0,0,0,.12); transition:background .2s;
    }
    html[data-theme="dark"] .twStepDot{ background:rgba(255,255,255,.12); }
    .twStepDot--active{ background:#6366f1; }
    .twStepLabel{
      font-size:10px; color:#999; text-align:center; margin-bottom:14px;
    }
    html[data-theme="dark"] .twStepLabel{ color:#6b7a8f; }
    .twStep{ display:none; }
    .twStep--active{ display:block; }
    .twLabel{
      font-size:11px; font-weight:600; color:var(--sbDark,#3d3d3a);
      margin-bottom:5px;
    }
    html[data-theme="dark"] .twLabel{ color:#c8d6e5; }
    .twInput{
      width:100%; padding:8px 10px; border:1px solid rgba(0,0,0,.1);
      border-radius:6px; font-size:12px; background:var(--bgFlat,#fff);
      color:var(--sbDark,#3d3d3a); margin-bottom:12px; box-sizing:border-box;
    }
    html[data-theme="dark"] .twInput{
      background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.1);
      color:#e2e8f0;
    }
    .twInput:focus{ outline:none; border-color:#6366f1; }
    .twTextarea{
      width:100%; padding:8px 10px; border:1px solid rgba(0,0,0,.1);
      border-radius:6px; font-size:12px; background:var(--bgFlat,#fff);
      color:var(--sbDark,#3d3d3a); margin-bottom:12px; box-sizing:border-box;
      resize:vertical; min-height:50px; font-family:inherit;
    }
    html[data-theme="dark"] .twTextarea{
      background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.1);
      color:#e2e8f0;
    }
    .twTextarea:focus{ outline:none; border-color:#6366f1; }
    .twSelectGroup{ margin-bottom:12px; }
    .twAgentList{
      display:flex; flex-direction:column; gap:4px;
      max-height:160px; overflow-y:auto; scrollbar-width:thin;
    }
    .twAgentItem{
      display:flex; align-items:center; gap:8px;
      padding:6px 8px; border-radius:6px; cursor:pointer;
      font-size:12px; color:var(--sbDark,#3d3d3a);
      transition:background .12s;
    }
    html[data-theme="dark"] .twAgentItem{ color:#c8d6e5; }
    .twAgentItem:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .twAgentItem:hover{ background:rgba(255,255,255,.06); }
    .twAgentItem--selected{
      background:rgba(99,102,241,.08);
      border:1px solid rgba(99,102,241,.2);
    }
    html[data-theme="dark"] .twAgentItem--selected{
      background:rgba(99,102,241,.15);
      border:1px solid rgba(99,102,241,.3);
    }
    .twAgentDot{
      width:6px; height:6px; border-radius:50%; flex-shrink:0;
    }
    .twAgentName{ font-weight:500; }
    .twAgentRole{ font-size:10px; color:#999; margin-left:auto; }
    html[data-theme="dark"] .twAgentRole{ color:#6b7a8f; }
    .twRadio{
      width:14px; height:14px; border:2px solid rgba(0,0,0,.15);
      border-radius:50%; flex-shrink:0; position:relative;
    }
    html[data-theme="dark"] .twRadio{ border-color:rgba(255,255,255,.2); }
    .twRadio--checked{ border-color:#6366f1; }
    .twRadio--checked::after{
      content:''; position:absolute; top:2px; left:2px;
      width:6px; height:6px; border-radius:50%; background:#6366f1;
    }
    .twCheck{
      width:14px; height:14px; border:2px solid rgba(0,0,0,.15);
      border-radius:3px; flex-shrink:0; position:relative;
    }
    html[data-theme="dark"] .twCheck{ border-color:rgba(255,255,255,.2); }
    .twCheck--checked{ border-color:#6366f1; background:#6366f1; }
    .twCheck--checked::after{
      content:''; position:absolute; top:1px; left:3px;
      width:4px; height:7px; border:solid #fff;
      border-width:0 2px 2px 0; transform:rotate(45deg);
    }
    .twActions{
      display:flex; gap:8px; justify-content:flex-end; margin-top:16px;
    }
    .twBtn{
      padding:7px 16px; border:1px solid rgba(0,0,0,.1); border-radius:6px;
      background:var(--bgFlat,#f8f8f8); color:var(--sbDark,#3d3d3a);
      font-size:11px; font-weight:500; cursor:pointer; transition:background .15s;
    }
    .twBtn:hover{ background:rgba(0,0,0,.05); }
    html[data-theme="dark"] .twBtn{
      background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.1);
      color:#c8d6e5;
    }
    html[data-theme="dark"] .twBtn:hover{ background:rgba(255,255,255,.1); }
    .twBtn--primary{ background:#6366f1; color:#fff; border-color:#6366f1; }
    .twBtn--primary:hover{ background:#5558e6; }
    .twBtn:disabled{ opacity:.5; cursor:not-allowed; }
    .twSummary{ margin-bottom:12px; }
    .twSummaryRow{
      display:flex; justify-content:space-between; align-items:baseline;
      font-size:12px; padding:4px 0;
      border-bottom:1px solid rgba(0,0,0,.05);
    }
    html[data-theme="dark"] .twSummaryRow{ border-color:rgba(255,255,255,.06); }
    .twSummaryKey{ color:#999; font-size:10px; text-transform:uppercase; letter-spacing:.3px; }
    html[data-theme="dark"] .twSummaryKey{ color:#6b7a8f; }
    .twSummaryVal{ color:var(--sbDark,#3d3d3a); font-weight:500; }
    html[data-theme="dark"] .twSummaryVal{ color:#e2e8f0; }
    .twError{
      font-size:11px; color:#ef4444; margin-top:4px; display:none;
    }

    /* ========== Task Notification Toast ========== */
    .taskToast{
      position:fixed; top:16px; right:16px; z-index:180;
      min-width:280px; max-width:380px;
      background:rgba(255,255,255,.92); backdrop-filter:blur(12px);
      border-radius:10px; border-left:4px solid #22c55e;
      box-shadow:0 4px 20px rgba(0,0,0,.12);
      padding:12px 16px; display:flex; gap:10px; align-items:flex-start;
      transform:translateX(420px); transition:transform .3s ease;
    }
    .taskToast--visible{ transform:translateX(0); }
    .taskToast--warning{ border-left-color:#f59e0b; }
    .taskToast--error{ border-left-color:#ef4444; }
    .taskToast--info{ border-left-color:#6366f1; }
    .taskToast--locked{ border-left-color:#94a3b8; }
    html[data-theme="dark"] .taskToast{ background:rgba(30,42,66,.92); box-shadow:0 4px 20px rgba(0,0,0,.3); }
    .taskToast__icon{ font-size:16px; flex-shrink:0; margin-top:1px; }
    .taskToast__body{ flex:1; }
    .taskToast__title{ font-size:12px; font-weight:600; color:var(--sbDark,#3d3d3a); margin-bottom:2px; }
    html[data-theme="dark"] .taskToast__title{ color:#e2e8f0; }
    .taskToast__desc{ font-size:11px; color:#666; line-height:1.4; }
    html[data-theme="dark"] .taskToast__desc{ color:#94a3b8; }
    .taskToast__close{
      background:none; border:none; cursor:pointer; color:#999;
      font-size:14px; padding:0 0 0 6px; line-height:1;
    }
    .taskToast__close:hover{ color:#333; }
    html[data-theme="dark"] .taskToast__close:hover{ color:#e2e8f0; }

    /* ========== W1-W3: Teams Panel ========== */
    .teamsPanel{
      position:fixed; top:0; right:0; bottom:0; width:400px; z-index:90;
      background:var(--bgFlat,#faf9f6); border-left:1px solid rgba(0,0,0,.08);
      transform:translateX(420px); transition:transform .25s ease;
      display:flex; flex-direction:column; overflow:hidden;
    }
    .teamsPanel--open{ transform:translateX(0); }
    html[data-theme="dark"] .teamsPanel{ background:#161e3a; border-color:rgba(255,255,255,.08); }

    .teamsPanel__header{
      display:flex; align-items:center; gap:8px;
      padding:14px 16px; border-bottom:1px solid rgba(0,0,0,.06);
    }
    .teamsPanel__header h2{ font-size:14px; font-weight:700; margin:0; flex:1; color:var(--sbDark); }
    html[data-theme="dark"] .teamsPanel__header{ border-color:rgba(255,255,255,.08); }
    .teamsPanel__back{
      background:none; border:none; cursor:pointer; font-size:16px; color:var(--sbDark);
      padding:2px 6px; border-radius:4px; display:none;
    }
    .teamsPanel__back:hover{ background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .teamsPanel__back{ color:#c8d6e5; }
    html[data-theme="dark"] .teamsPanel__back:hover{ background:rgba(255,255,255,.08); }
    .teamsPanel__addBtn{
      background:none; border:1px solid rgba(0,0,0,.1); border-radius:6px;
      padding:4px 10px; font-size:10px; font-weight:600; color:var(--sbDark);
      cursor:pointer; transition:background .15s;
    }
    .teamsPanel__addBtn:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .teamsPanel__addBtn{ border-color:rgba(255,255,255,.1); color:#c8d6e5; }
    html[data-theme="dark"] .teamsPanel__addBtn:hover{ background:rgba(255,255,255,.06); }
    .teamsPanel__close{
      background:none; border:none; cursor:pointer; font-size:18px; color:#999;
      padding:2px 6px; border-radius:4px;
    }
    .teamsPanel__close:hover{ background:rgba(0,0,0,.06); }
    html[data-theme="dark"] .teamsPanel__close:hover{ background:rgba(255,255,255,.08); }

    .teamsPanel__body{ flex:1; overflow-y:auto; padding:12px 16px; }

    /* Team Cards (W1) */
    .teamCard{
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:10px; padding:14px 16px; margin-bottom:10px;
      cursor:pointer; transition:border-color .15s, box-shadow .15s;
    }
    .teamCard:hover{ border-color:color-mix(in srgb, var(--sidebar) 40%, transparent); box-shadow:0 2px 8px rgba(0,0,0,.06); }
    html[data-theme="dark"] .teamCard{ background:rgba(255,255,255,.03); border-color:rgba(255,255,255,.06); }
    html[data-theme="dark"] .teamCard:hover{ border-color:rgba(255,255,255,.12); box-shadow:0 2px 8px rgba(0,0,0,.2); }
    .teamCard__top{ display:flex; align-items:center; gap:8px; margin-bottom:6px; }
    .teamCard__dot{ width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .teamCard__dot--green{ background:#22c55e; }
    .teamCard__dot--yellow{ background:#f59e0b; }
    .teamCard__dot--red{ background:#ef4444; }
    .teamCard__name{ font-size:13px; font-weight:700; color:var(--sbDark,#3d3d3a); flex:1; }
    html[data-theme="dark"] .teamCard__name{ color:#e2e8f0; }
    .teamCard__count{ font-size:10px; color:#888; font-weight:600; }
    .teamCard__lead{ font-size:11px; color:#888; margin-bottom:4px; }
    .teamCard__activity{ font-size:10px; color:#aaa; font-style:italic; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .teamCard__scope{ font-size:9px; color:#bbb; margin-top:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Team Detail (W2) */
    .teamDetail__section{ margin-bottom:16px; }
    .teamDetail__sectionTitle{
      font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:var(--sbDark,.5); margin-bottom:8px;
      opacity:.6;
    }
    .teamDetail__member{
      display:flex; align-items:flex-start; gap:8px;
      padding:8px 10px; border-radius:8px; margin-bottom:4px;
      background:color-mix(in srgb, var(--sidebar) 6%, var(--bgFlat));
    }
    html[data-theme="dark"] .teamDetail__member{ background:rgba(255,255,255,.03); }
    .teamDetail__memberDot{ width:8px; height:8px; border-radius:50%; flex-shrink:0; margin-top:4px; }
    .teamDetail__memberInfo{ flex:1; min-width:0; }
    .teamDetail__memberName{ font-size:12px; font-weight:600; color:var(--sbDark); }
    html[data-theme="dark"] .teamDetail__memberName{ color:#e2e8f0; }
    .teamDetail__memberRole{ font-size:10px; color:#999; }
    .teamDetail__memberActivity{ font-size:10px; color:#aaa; font-style:italic; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .teamDetail__badge{
      font-size:8px; font-weight:700; text-transform:uppercase;
      padding:2px 6px; border-radius:3px; background:#6366f1; color:#fff;
      flex-shrink:0; margin-top:3px;
    }
    .teamDetail__scopeTag{
      display:inline-block; font-size:10px; padding:3px 8px;
      background:color-mix(in srgb, var(--sidebar) 12%, var(--bgFlat));
      border-radius:4px; margin:0 4px 4px 0; color:#666;
    }
    html[data-theme="dark"] .teamDetail__scopeTag{ background:rgba(255,255,255,.06); color:#94a3b8; }

    /* ========== V2 W4: Team-Detail Tabs ========== */
    .tdTabs{
      display:flex; gap:0; margin-bottom:14px;
      border-bottom:1px solid rgba(0,0,0,.08);
    }
    html[data-theme="dark"] .tdTabs{ border-color:rgba(255,255,255,.08); }
    .tdTab{
      padding:8px 14px; font-size:11px; font-weight:600; color:#999;
      cursor:pointer; border-bottom:2px solid transparent;
      transition:color .15s, border-color .15s;
    }
    .tdTab:hover{ color:var(--sbDark,#3d3d3a); }
    html[data-theme="dark"] .tdTab:hover{ color:#e2e8f0; }
    .tdTab--active{
      color:var(--sbDark,#3d3d3a); border-bottom-color:#6366f1;
    }
    html[data-theme="dark"] .tdTab--active{ color:#e2e8f0; border-bottom-color:#818cf8; }

    /* ========== V2 W4: Task-Board (Kanban) ========== */
    .tkBoard{ display:flex; flex-direction:column; gap:14px; }

    .tkColumn{}
    .tkColumnHeader{
      display:flex; align-items:center; gap:6px;
      font-size:9px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px; color:var(--sbDark,.5); opacity:.6;
      margin-bottom:8px;
    }
    .tkColumnHeader__icon{ font-size:12px; opacity:.8; }
    .tkColumnHeader__count{
      font-size:9px; font-weight:600; background:rgba(0,0,0,.06);
      padding:1px 5px; border-radius:3px; margin-left:2px;
    }
    html[data-theme="dark"] .tkColumnHeader__count{ background:rgba(255,255,255,.08); }

    .tkCard{
      background:color-mix(in srgb, var(--sidebar) 6%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
      border-radius:8px; padding:10px 12px; margin-bottom:6px;
      border-left:3px solid #94a3b8;
      transition:border-color .15s, box-shadow .15s;
    }
    .tkCard:hover{ box-shadow:0 2px 8px rgba(0,0,0,.06); }
    html[data-theme="dark"] .tkCard{ background:rgba(255,255,255,.03); border-color:rgba(255,255,255,.06); }
    html[data-theme="dark"] .tkCard:hover{ box-shadow:0 2px 8px rgba(0,0,0,.2); }
    .tkCard--blue{ border-left-color:#3b82f6; }
    .tkCard--green{ border-left-color:#22c55e; }
    .tkCard--yellow{ border-left-color:#f59e0b; }
    .tkCard--red{ border-left-color:#ef4444; }
    .tkCard--gray{ border-left-color:#94a3b8; }

    .tkCard__title{ font-size:12px; font-weight:600; color:var(--sbDark); margin-bottom:4px; }
    html[data-theme="dark"] .tkCard__title{ color:#e2e8f0; }
    .tkCard__row{ display:flex; align-items:center; gap:6px; font-size:10px; color:#888; margin-top:2px; }
    .tkCard__dot{ width:6px; height:6px; border-radius:50%; flex-shrink:0; }
    .tkCard__agent{ font-weight:500; }
    .tkCard__time{ color:#aaa; }
    .tkCard__files{ font-size:9px; color:#bbb; margin-top:3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .tkCard__priority{
      font-size:8px; font-weight:700; text-transform:uppercase;
      padding:1px 5px; border-radius:3px; color:#fff; flex-shrink:0;
    }
    .tkCard__priority--high{ background:#f59e0b; }
    .tkCard__priority--critical{ background:#ef4444; }
    .tkCard__labels{ display:flex; flex-wrap:wrap; gap:3px; margin-top:4px; }
    .tkCard__label{
      font-size:8px; padding:1px 5px; border-radius:3px;
      background:color-mix(in srgb, var(--sidebar) 12%, var(--bgFlat)); color:#666;
    }
    html[data-theme="dark"] .tkCard__label{ background:rgba(255,255,255,.06); color:#94a3b8; }

    .tkEmpty{ text-align:center; padding:12px 8px; font-size:11px; color:#bbb; font-style:italic; }

    .tkAddBtn{
      display:flex; align-items:center; justify-content:center; gap:4px;
      padding:8px 0; font-size:11px; font-weight:600; color:#6366f1;
      cursor:pointer; border:1px dashed rgba(99,102,241,.3);
      border-radius:8px; margin-top:8px; transition:background .15s, border-color .15s;
    }
    .tkAddBtn:hover{ background:rgba(99,102,241,.04); border-color:rgba(99,102,241,.5); }
    html[data-theme="dark"] .tkAddBtn{ color:#818cf8; border-color:rgba(129,140,248,.3); }
    html[data-theme="dark"] .tkAddBtn:hover{ background:rgba(129,140,248,.06); border-color:rgba(129,140,248,.5); }

    /* ========== V2 W5: Task-Erstellen Modal ========== */
    .tcOverlay{
      position:fixed; inset:0; z-index:220;
      background:rgba(0,0,0,.35); backdrop-filter:blur(3px);
      display:flex; align-items:center; justify-content:center;
      opacity:0; pointer-events:none; transition:opacity .2s;
    }
    .tcOverlay--open{ opacity:1; pointer-events:auto; }
    .tcContainer{
      background:var(--bgFlat,#fff); border-radius:12px;
      box-shadow:0 8px 32px rgba(0,0,0,.18);
      padding:24px 28px; max-width:480px; width:92%;
      border:1px solid rgba(0,0,0,.08);
    }
    html[data-theme="dark"] .tcContainer{
      background:#1e2a42; border-color:rgba(255,255,255,.08);
      box-shadow:0 8px 32px rgba(0,0,0,.4);
    }
    .tcHeader{ display:flex; align-items:center; margin-bottom:18px; }
    .tcTitle{ font-size:14px; font-weight:700; color:var(--sbDark); flex:1; }
    html[data-theme="dark"] .tcTitle{ color:#e2e8f0; }
    .tcClose{
      background:none; border:none; font-size:20px; color:#999;
      cursor:pointer; padding:0 0 0 8px; line-height:1;
    }
    .tcClose:hover{ color:#333; }
    html[data-theme="dark"] .tcClose:hover{ color:#e2e8f0; }
    .tcLabel{ display:block; font-size:10px; font-weight:600; color:#888; margin-bottom:5px; text-transform:uppercase; letter-spacing:.3px; }
    .tcInput{
      width:100%; box-sizing:border-box; padding:8px 10px;
      font-size:12px; border:1px solid rgba(0,0,0,.12);
      border-radius:6px; background:transparent; color:var(--sbDark);
      margin-bottom:12px; outline:none;
    }
    .tcInput:focus{ border-color:#6366f1; box-shadow:0 0 0 2px rgba(99,102,241,.15); }
    html[data-theme="dark"] .tcInput{ border-color:rgba(255,255,255,.12); color:#e2e8f0; }
    html[data-theme="dark"] .tcInput:focus{ border-color:#818cf8; box-shadow:0 0 0 2px rgba(129,140,248,.15); }
    .tcTextarea{
      width:100%; box-sizing:border-box; padding:8px 10px;
      font-size:12px; border:1px solid rgba(0,0,0,.12);
      border-radius:6px; background:transparent; color:var(--sbDark);
      margin-bottom:12px; outline:none; resize:vertical; font-family:inherit;
    }
    .tcTextarea:focus{ border-color:#6366f1; box-shadow:0 0 0 2px rgba(99,102,241,.15); }
    html[data-theme="dark"] .tcTextarea{ border-color:rgba(255,255,255,.12); color:#e2e8f0; }
    html[data-theme="dark"] .tcTextarea:focus{ border-color:#818cf8; box-shadow:0 0 0 2px rgba(129,140,248,.15); }
    .tcSelect{
      width:100%; box-sizing:border-box; padding:8px 10px;
      font-size:12px; border:1px solid rgba(0,0,0,.12);
      border-radius:6px; background:transparent; color:var(--sbDark);
      margin-bottom:12px; outline:none; cursor:pointer;
    }
    html[data-theme="dark"] .tcSelect{ border-color:rgba(255,255,255,.12); color:#e2e8f0; background:#1e2a42; }
    .tcActions{ display:flex; justify-content:flex-end; gap:8px; margin-top:16px; }
    .tcBtn{
      padding:8px 16px; border-radius:6px; font-size:11px; font-weight:600;
      border:1px solid rgba(0,0,0,.1); background:transparent;
      color:var(--sbDark); cursor:pointer; transition:background .15s;
    }
    .tcBtn:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .tcBtn{ border-color:rgba(255,255,255,.1); color:#c8d6e5; }
    html[data-theme="dark"] .tcBtn:hover{ background:rgba(255,255,255,.06); }
    .tcBtn--primary{ background:#6366f1; color:#fff; border-color:#6366f1; }
    .tcBtn--primary:hover{ background:#5558e6; }
    html[data-theme="dark"] .tcBtn--primary{ background:#6366f1; border-color:#6366f1; color:#fff; }
    .tcError{
      display:none; font-size:11px; color:#ef4444;
      margin-top:8px; padding:6px 10px; border-radius:6px;
      background:rgba(239,68,68,.06);
    }

    /* ========== V2 AUFGABE 3: Agent Toggle-Switch ========== */
    .atToggleWrap{ display:flex; align-items:center; gap:6px; margin-left:auto; flex-shrink:0; }
    .atToggle{ position:relative; width:32px; height:18px; cursor:pointer; }
    .atToggle__track{
      position:absolute; inset:0; border-radius:9px;
      background:#22c55e; transition:background .2s;
    }
    .atToggle__thumb{
      position:absolute; top:2px; left:2px; width:14px; height:14px;
      border-radius:50%; background:#fff; transition:left .2s;
      box-shadow:0 1px 3px rgba(0,0,0,.15);
    }
    .atToggle--off .atToggle__track{ background:#94a3b8; }
    .atToggle--off .atToggle__thumb{ left:16px; }
    .atToggle__label{ font-size:10px; font-weight:600; color:#22c55e; white-space:nowrap; }
    .atToggle--off .atToggle__label{ color:#94a3b8; }
    html[data-theme="dark"] .atToggle__label{ color:#4ade80; }
    html[data-theme="dark"] .atToggle--off .atToggle__label{ color:#64748b; }
    .teamDetail__member--paused{ opacity:.5; }
    /* Confirmation Dialog */
    .atConfirmOverlay{
      position:fixed; inset:0; z-index:230;
      background:rgba(0,0,0,.45); display:flex;
      align-items:center; justify-content:center;
    }
    .atConfirmBox{
      background:var(--bgFlat,#fff); border-radius:12px;
      padding:20px 24px; max-width:360px; width:90%;
      box-shadow:0 8px 32px rgba(0,0,0,.18);
    }
    html[data-theme="dark"] .atConfirmBox{ background:#1e2a42; }
    .atConfirmMsg{ font-size:13px; color:var(--sbDark,#3d3d3a); margin-bottom:16px; line-height:1.5; }
    html[data-theme="dark"] .atConfirmMsg{ color:#e2e8f0; }
    .atConfirmActions{ display:flex; gap:8px; justify-content:flex-end; }
    .atConfirmBtn{
      padding:7px 16px; border-radius:8px; font-size:12px; font-weight:600;
      cursor:pointer; border:1px solid rgba(0,0,0,.1); background:transparent;
      color:var(--sbDark,#3d3d3a);
    }
    html[data-theme="dark"] .atConfirmBtn{ border-color:rgba(255,255,255,.1); color:#e2e8f0; }
    .atConfirmBtn:hover{ background:rgba(0,0,0,.04); }
    html[data-theme="dark"] .atConfirmBtn:hover{ background:rgba(255,255,255,.06); }
    .atConfirmBtn--danger{ background:#ef4444; color:#fff; border-color:#ef4444; }
    .atConfirmBtn--danger:hover{ background:#dc2626; }
    .atConfirmBtn--success{ background:#22c55e; color:#fff; border-color:#22c55e; }
    .atConfirmBtn--success:hover{ background:#16a34a; }

  </style>
</head>

<body>
  <a class="skipLink" href="#chatMessagesLeft">Skip to content</a>
  <div class="sidebar"></div>
  <img class="sidebarLogo" src="ace_logo.svg" alt="ACE Logo" style="position:fixed;z-index:3;width:80px;top:12px;left:8px;">

  <div class="sidebarIcons">
    <button class="sidebarIcon" title="Neues Projekt">
      <svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M12 11v4M10 13h4"/></svg>
      <span class="tooltip">Neues Projekt</span>
    </button>
    <button class="sidebarIcon" title="Organigramm">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="4" r="2.5"/><path d="M12 6.5V9"/><path d="M5 9h14"/><path d="M5 9v3M12 9v3M19 9v3"/><rect x="2" y="12" width="6" height="4" rx="1"/><rect x="9" y="12" width="6" height="4" rx="1"/><rect x="16" y="12" width="6" height="4" rx="1"/></svg>
      <span class="tooltip">Organigramm</span>
    </button>
    <button class="sidebarIcon" title="Aufgaben">
      <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      <span class="tooltip">Aufgaben</span>
    </button>
    <button class="sidebarIcon" title="Control Center">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="tooltip">Control Center</span>
    </button>
  </div>

  <nav class="sidebarWrap" aria-label="Projektnavigation">
    <div class="sidebarInner">
      <div class="sbSearch" role="button" tabindex="0" aria-label="Projekte durchsuchen"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>Projekte durchsuchen...</div>
      <div class="sbNewBtn" role="button" tabindex="0" aria-label="Neues Projekt"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>Neues Projekt</div>
      <div class="sbTopPane" id="sbTopPane">
        <div class="sbSection"><svg viewBox="0 0 24 24"><polygon points="12,2 15,8.5 22,9.3 17,14 18,21 12,17.8 6,21 7,14 2,9.3 9,8.5"/></svg>Favoriten</div>
        <div id="sbStarredList"></div>
        <div class="sbSection">Projekte</div>
        <div id="sbProjectList"></div>
      </div>
      <div class="sbResizeHandle" id="sbResizeHandle" title="Groesse anpassen" aria-label="Panel-Groesse anpassen"></div>
      <div class="sbBottomPane" id="sbBottomPane">
        <div class="sbSection"><svg viewBox="0 0 24 24"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>Aktivitaet</div>
        <div id="sbActivityList"></div>
      </div>
    </div>
  </nav>

  <!-- Sidebar Bottom: User-Profil + Settings -->
  <div class="sidebarBottom">
    <div class="sidebarUser">
      <div class="sidebarAvatar" role="img" aria-label="User avatar: Leo">L</div>
      <span class="sidebarUserName">Leo</span>
    </div>
    <button class="approvalBadge" id="approvalBadge" title="Genehmigungen" aria-label="Genehmigungen">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span class="approvalBadge__count" id="approvalCount" style="display:none">0</span>
    </button>
    <button class="sidebarSettings" id="settingsBtn" title="Einstellungen" aria-label="Einstellungen" aria-expanded="false" aria-controls="settingsPopup">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      <span class="tooltip">Einstellungen</span>
    </button>
    <div class="settingsPopup" id="settingsPopup" role="dialog" aria-label="Design-Einstellungen">
      <div class="settingsPopup__label" id="settingsPopupLabel">Design</div>
      <button class="settingsPopup__option" data-theme="warm" aria-label="Design: Warm"><span class="settingsPopup__dot" style="background:#c8bfa8"></span>Warm</button>
      <button class="settingsPopup__option" data-theme="light" aria-label="Design: Hell"><span class="settingsPopup__dot" style="background:#d6e8f7"></span>Hell</button>
      <button class="settingsPopup__option" data-theme="rose" aria-label="Design: Rosé"><span class="settingsPopup__dot" style="background:#e8c4cc"></span>Rosé</button>
      <button class="settingsPopup__option" data-theme="dark" aria-label="Design: Dunkel"><span class="settingsPopup__dot" style="background:#1e2a42"></span>Dunkel</button>
    </div>
  </div>

  <!-- Sidebar Toggle -->
  <button class="sidebarToggle" id="sidebarToggle" title="Seitenleiste ein/ausblenden" aria-label="Seitenleiste ein/ausblenden" aria-expanded="true">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
  </button>

  <div class="sidebarEdge" id="sidebarEdge"></div>
  <div class="chatPanel chatPanel--left"></div>
  <div class="chatPanel chatPanel--right"></div>
  <div class="mainDivider" id="mainDivider"></div>

  <!-- Board Headers -->
  <header class="boardHeader boardHeader--left" id="boardHeaderLeft" role="banner" aria-label="Management-Board">
    <span class="boardHeader__title">Management-Board</span>
    <div class="memberBar" id="mgmtMemberBar" aria-label="Management-Team"></div>
  </header>
  <header class="boardHeader boardHeader--right" id="boardHeaderRight" role="banner" aria-label="Team-Board">
    <span class="boardHeader__title">Team-Board</span>
    <div class="teamTabs" id="teamTabs" aria-label="Team-Auswahl"></div>
    <div class="memberBar" id="memberBar" aria-label="Team-Mitglieder"></div>
  </header>

  <!-- Chat-Nachrichten links (User ↔ Manager Agent) -->
  <main class="chatMessages chatMessages--left" id="chatMessagesLeft" role="log" aria-label="Management-Chat">
    <div class="chatMessagesInner">
      <div class="chatMsg chatMsg--user">I need you to build the ACE API Gateway. REST endpoints, auth middleware, rate limiting. Target: 2 weeks.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Understood. I'll break this down into sub-tasks and delegate to the team. I'll assign a Team Lead and two engineers.</div>
      <div class="chatMsg chatMsg--user">Good. Make sure they coordinate on the auth layer — it needs to be consistent across all endpoints.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Noted. I've briefed the Team Lead. Agent A will handle endpoint scaffolding + routing, Agent B takes auth middleware + rate limiting. They're syncing now.</div>
      <div class="chatMsg chatMsg--user">Keep me posted on progress.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>Will do. Team is active in the right panel — you can follow along there. I'll flag blockers directly to you.</div>
    </div>
  </main>

  <!-- Nachrichtenbox links -->
  <div class="chatInput chatInput--left" role="form" aria-label="Management-Nachrichteneingabe">
    <div class="customSelect" id="leftTargetWrap" aria-label="Nachrichtenempfaenger" data-value="ordo">
      <div class="customSelect__trigger" id="leftTargetTrigger">Ordo</div>
      <div class="customSelect__dropdown" id="leftTargetDropdown">
        <div class="customSelect__option" data-value="all_managers">Alle Manager</div>
        <div class="customSelect__option selected" data-value="ordo">Ordo</div>
      </div>
    </div>
    <div class="inputWrap">
      <button class="chatAttach" title="Anhaengen" aria-label="Datei anhaengen"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
      <textarea rows="1" placeholder="Nachricht an Agent..." aria-label="Nachricht an Agent"></textarea>
    </div>
    <button class="chatSend" aria-label="Nachricht senden">
      <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  </div>

  <!-- Chat-Nachrichten rechts (Manager → Team Lead → Agent A + B) -->
  <section class="chatMessages chatMessages--right" id="chatMessagesRight" role="log" aria-label="Team-Chat">
    <div class="chatMessagesInner">
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Manager Agent</span>New project: ACE API Gateway. REST endpoints, auth middleware, rate limiting. Deadline: 2 weeks. You're leading this. Assign Agent A and Agent B.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Got it. I'll split the work. Agent A — you take endpoint scaffolding and routing. Agent B — auth middleware and rate limiting. Questions?</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>Clear. I'll set up the Express router with versioned routes. /v1/users, /v1/projects, /v1/tasks. Should I use controller pattern or inline handlers?</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Controller pattern. Keep it clean and testable.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent B</span>For auth — JWT or session-based? And rate limiting: per-user or per-endpoint?</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>JWT with refresh tokens. Rate limiting per-user, 100 req/min default. Use middleware chain so Agent A can plug it into routes easily.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>@Agent B — I'll export a registerRoutes(app, middleware) function. You pass me the auth + rate limiter as middleware array. Deal?</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent B</span>Deal. I'll expose authMiddleware() and rateLimiter(config). You just wire them in. I'll have the interfaces ready in 2 hours.</div>
      <div class="chatMsg chatMsg--subagent"><span class="agentLabel">Agent A</span>Perfect. I'll scaffold the routes in parallel and integrate once you push.</div>
      <div class="chatMsg chatMsg--agent"><span class="agentLabel">Team Lead</span>Good coordination. I'll review the integration point once both are ready. Keep commits atomic.</div>
    </div>
  </section>

  <!-- Nachrichtenbox rechts -->
  <div class="chatInput chatInput--right" role="form" aria-label="Team-Nachrichteneingabe">
    <div class="customSelect" id="rightTargetWrap" aria-label="Team-Nachrichtenempfaenger">
      <div class="customSelect__trigger" id="rightTargetTrigger">Alle</div>
      <div class="customSelect__dropdown" id="rightTargetDropdown">
        <div class="customSelect__option selected" data-value="all">Alle</div>
      </div>
    </div>
    <div class="inputWrap">
      <button class="chatAttach" title="Anhaengen" aria-label="Datei anhaengen"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
      <textarea rows="1" placeholder="Nachricht ans Team..." aria-label="Nachricht ans Team"></textarea>
    </div>
    <button class="chatSend" aria-label="Nachricht senden">
      <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  </div>

  <!-- Approval Gate: Toast -->
  <div class="approvalToast" id="approvalToast">
    <div class="approvalToast__risk"></div>
    <div class="approvalToast__body">
      <div class="approvalToast__header">
        <span class="approvalToast__title" id="approvalToastTitle"></span>
        <span class="approvalToast__timer" id="approvalToastTimer"></span>
      </div>
      <div class="approvalToast__desc" id="approvalToastDesc"></div>
      <div class="approvalToast__actions">
        <button class="approvalToast__btn approvalToast__btn--approve" id="toastApprove">OK</button>
        <button class="approvalToast__btn approvalToast__btn--deny" id="toastDeny">Nein</button>
        <button class="approvalToast__btn approvalToast__btn--details" id="toastDetails">Details</button>
      </div>
    </div>
  </div>

  <!-- Approval Gate: Panel -->
  <div class="approvalPanel" id="approvalPanel">
    <header class="approvalPanel__header">
      <h2>Genehmigungen</h2>
      <span class="approvalPanel__count" id="panelCount">0 offen</span>
      <button class="approvalPanel__close" id="panelClose">&times;</button>
    </header>
    <div class="approvalPanel__list" id="approvalList">
      <div class="approvalPanel__empty">Keine offenen Genehmigungen</div>
    </div>
    <div class="approvalPanel__history">
      <h3>Vergangene Entscheidungen</h3>
      <div id="approvalHistory"></div>
    </div>
  </div>

  <!-- Approval Gate: Feedback -->
  <div class="approvalFeedback" id="approvalFeedback"></div>

  <!-- W1-W3: Teams Panel -->
  <div class="teamsPanel" id="teamsPanel">
    <header class="teamsPanel__header">
      <button class="teamsPanel__back" id="teamsPanelBack">&larr;</button>
      <h2 id="teamsPanelTitle">Meine Teams</h2>
      <button class="teamsPanel__addBtn" id="teamsPanelAdd">+ Neues Team</button>
      <button class="teamsPanel__close" id="teamsPanelClose">&times;</button>
    </header>
    <div class="teamsPanel__body" id="teamsPanelBody"></div>
  </div>

  <!-- F1: Susi Team-Wizard Modal -->
  <div class="twOverlay" id="twOverlay">
    <div class="twContainer">
      <div class="twHeader">
        <span class="twTitle" id="twTitle">Neues Team erstellen</span>
        <button class="twClose" id="twClose">&times;</button>
      </div>
      <div class="twSteps" id="twSteps">
        <span class="twStepDot twStepDot--active" data-step="0"></span>
        <span class="twStepDot" data-step="1"></span>
        <span class="twStepDot" data-step="2"></span>
      </div>
      <div class="twStepLabel" id="twStepLabel">Schritt 1 von 3</div>

      <!-- Step 1: Name + Beschreibung -->
      <div class="twStep twStep--active" id="twStep0">
        <label class="twLabel" for="twName">Teamname</label>
        <input class="twInput" type="text" id="twName" placeholder="z.B. Marketing, Entwicklung..." maxlength="60" autocomplete="off">
        <label class="twLabel" for="twDesc">Beschreibung (optional)</label>
        <textarea class="twTextarea" id="twDesc" placeholder="Was macht dieses Team?" maxlength="200" rows="2"></textarea>
      </div>

      <!-- Step 2: Leitung + Mitglieder -->
      <div class="twStep" id="twStep1">
        <div class="twSelectGroup">
          <div class="twLabel">Teamleitung</div>
          <div class="twAgentList" id="twLeadList"></div>
        </div>
        <div class="twSelectGroup">
          <div class="twLabel">Mitglieder</div>
          <div class="twAgentList" id="twMemberList"></div>
        </div>
      </div>

      <!-- Step 3: Zusammenfassung -->
      <div class="twStep" id="twStep2">
        <div class="twSummary" id="twSummary"></div>
      </div>

      <div class="twError" id="twError"></div>
      <div class="twActions">
        <button class="twBtn" id="twBack" style="display:none">Zurueck</button>
        <button class="twBtn twBtn--primary" id="twNext">Weiter</button>
      </div>
    </div>
  </div>

  <!-- V2 W5: Task-Erstellen Modal -->
  <div class="tcOverlay" id="tcOverlay">
    <div class="tcContainer">
      <div class="tcHeader">
        <span class="tcTitle" id="tcTitle">Neue Aufgabe</span>
        <button class="tcClose" id="tcClose">&times;</button>
      </div>
      <label class="tcLabel" for="tcTaskTitle">Was soll gemacht werden?</label>
      <input class="tcInput" type="text" id="tcTaskTitle" placeholder="z.B. Activity-Check implementieren..." maxlength="120" autocomplete="off">
      <label class="tcLabel" for="tcTaskDesc">Details (optional)</label>
      <textarea class="tcTextarea" id="tcTaskDesc" placeholder="Beschreibe was genau getan werden soll..." maxlength="2000" rows="3"></textarea>
      <label class="tcLabel" for="tcAssign">Zuweisen an</label>
      <select class="tcSelect" id="tcAssign">
        <option value="">Noch offen (spaeter zuweisen)</option>
      </select>
      <label class="tcLabel" for="tcPriority">Prioritaet</label>
      <select class="tcSelect" id="tcPriority">
        <option value="1">Normal</option>
        <option value="2">Hoch</option>
        <option value="3">Kritisch</option>
      </select>
      <div class="tcError" id="tcError"></div>
      <div class="tcActions">
        <button class="tcBtn" id="tcCancel">Abbrechen</button>
        <button class="tcBtn tcBtn--primary" id="tcSubmit">Erstellen</button>
      </div>
    </div>
  </div>

  <!-- Organigramm Panel -->
  <div class="orgPanel" id="orgPanel">
    <header class="orgPanel__header">
      <h2>Team</h2>
      <span class="orgPanel__count" id="orgOnlineCount"></span>
      <button class="orgPanel__close" id="orgPanelClose">&times;</button>
    </header>
    <div class="orgPanel__tree" id="orgTree"></div>
  </div>

  <!-- W6: Error-State Modal -->
  <div class="teamModal__overlay" id="teamModalOverlay">
    <div class="teamModal" id="teamModal">
      <div class="teamModal__icon" id="teamModalIcon"></div>
      <div class="teamModal__title" id="teamModalTitle"></div>
      <div class="teamModal__desc" id="teamModalDesc"></div>
      <div class="teamModal__meta" id="teamModalMeta"></div>
      <div class="teamModal__actions" id="teamModalActions"></div>
    </div>
  </div>

  <!-- Task Notification Toast -->
  <div class="taskToast" id="taskToast">
    <span class="taskToast__icon" id="taskToastIcon"></span>
    <div class="taskToast__body">
      <div class="taskToast__title" id="taskToastTitle"></div>
      <div class="taskToast__desc" id="taskToastDesc"></div>
    </div>
    <button class="taskToast__close" id="taskToastClose">&times;</button>
  </div>

  <script>
    const root = document.documentElement;
    const settingsBtn = document.getElementById('settingsBtn');
    const settingsPopup = document.getElementById('settingsPopup');
    const themeOptions = settingsPopup.querySelectorAll('.settingsPopup__option');

    function setTheme(theme){
      root.setAttribute('data-theme', theme);
      localStorage.setItem('bridge_theme', theme);
      themeOptions.forEach(o => {
        const isActive = o.dataset.theme === theme;
        o.classList.toggle('active', isActive);
        o.setAttribute('aria-pressed', isActive);
      });
      settingsPopup.classList.remove('open');
      settingsBtn.setAttribute('aria-expanded', 'false');
    }

    const stored = localStorage.getItem('bridge_theme');
    if(stored) setTheme(stored);
    else { themeOptions[0].classList.add('active'); themeOptions[0].setAttribute('aria-pressed', 'true'); }

    settingsBtn.addEventListener('click', e => {
      e.stopPropagation();
      settingsPopup.classList.toggle('open');
      settingsBtn.setAttribute('aria-expanded', settingsPopup.classList.contains('open'));
    });

    themeOptions.forEach(o => o.addEventListener('click', e => {
      e.stopPropagation();
      setTheme(o.dataset.theme);
    }));

    document.addEventListener('click', e => {
      if(!settingsBtn.contains(e.target) && !settingsPopup.contains(e.target)){
        settingsPopup.classList.remove('open');
        settingsBtn.setAttribute('aria-expanded', 'false');
      }
    });

    // ========== Custom Select Dropdown Logic ==========
    function initCustomSelect(wrapId, triggerId, dropdownId){
      const wrap = document.getElementById(wrapId);
      const trigger = document.getElementById(triggerId);
      const dropdown = document.getElementById(dropdownId);
      if(!wrap || !trigger || !dropdown) return;

      trigger.addEventListener('click', e => {
        e.stopPropagation();
        // Close all other custom selects
        document.querySelectorAll('.customSelect.open').forEach(cs => {
          if(cs !== wrap) cs.classList.remove('open');
        });
        wrap.classList.toggle('open');
      });

      dropdown.addEventListener('click', e => {
        const opt = e.target.closest('.customSelect__option');
        if(!opt) return;
        e.stopPropagation();
        dropdown.querySelectorAll('.customSelect__option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        trigger.textContent = opt.textContent;
        wrap.dataset.value = opt.dataset.value;
        wrap.classList.remove('open');
        // Fire change event for listeners
        wrap.dispatchEvent(new Event('change'));
      });
    }

    // Helper: get value of custom select
    function getCustomSelectValue(wrapId, fallback){
      const el = document.getElementById(wrapId);
      return el ? (el.dataset.value || fallback) : fallback;
    }

    initCustomSelect('leftTargetWrap', 'leftTargetTrigger', 'leftTargetDropdown');
    initCustomSelect('rightTargetWrap', 'rightTargetTrigger', 'rightTargetDropdown');

    // Close custom selects on outside click
    document.addEventListener('click', e => {
      document.querySelectorAll('.customSelect.open').forEach(cs => {
        if(!cs.contains(e.target)) cs.classList.remove('open');
      });
    });

    // Navigation: Sidebar icons
    document.querySelector('.sidebarIcon[title="Neues Projekt"]').addEventListener('click', () => {
      window.location.href = 'project_config.html';
    });
    document.querySelector('.sidebarIcon[title="Organigramm"]').addEventListener('click', () => {
      toggleOrgPanel();
    });
    document.querySelector('.sidebarIcon[title="Aufgaben"]').addEventListener('click', () => {
      // Open task board of active team in control center
      const activeTeam = document.querySelector('.sbProject.active');
      const teamParam = activeTeam ? '?tab=tasks&team=' + encodeURIComponent(activeTeam.dataset.team || '') : '?tab=tasks';
      window.location.href = 'control_center.html' + teamParam;
    });
    document.querySelector('.sidebarIcon[title="Control Center"]').addEventListener('click', () => {
      window.location.href = 'control_center.html';
    });
    document.querySelector('.sbNewBtn').addEventListener('click', () => {
      window.location.href = 'project_config.html';
    });

    // Search Projects → native OS directory picker
    document.querySelector('.sbSearch').addEventListener('click', async () => {
      const sbSearch = document.querySelector('.sbSearch');
      const origText = sbSearch.textContent;
      sbSearch.textContent = 'Dateiauswahl wird geoeffnet...';
      sbSearch.style.pointerEvents = 'none';
      sbSearch.style.opacity = '0.6';
      try {
        const res = await fetch('http://127.0.0.1:9111/pick-directory');
        const data = await res.json();
        if (data.ok && data.path) {
          window.location.href = 'project_config.html?path=' + encodeURIComponent(data.path);
        }
      } catch(e) {
        console.error('pick-directory failed:', e);
      } finally {
        sbSearch.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>Projekte durchsuchen...';
        sbSearch.style.pointerEvents = '';
        sbSearch.style.opacity = '';
      }
    });

    // Attach File [+] → hidden file input + upload to /projects/upload
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.multiple = true;
    fileInput.accept = '*/*';
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);

    let attachPanel = 'left'; // tracks which panel triggered the attach

    document.querySelectorAll('.chatAttach').forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        attachPanel = idx === 0 ? 'left' : 'right';
        fileInput.click();
      });
    });

    fileInput.addEventListener('change', async () => {
      if (!fileInput.files || fileInput.files.length === 0) return;
      const files = Array.from(fileInput.files);
      // Get current project_path from runtime
      let projectPath = '';
      try {
        const rtRes = await fetch('http://127.0.0.1:9111/runtime');
        const rtData = await rtRes.json();
        projectPath = rtData.project_path || '';
      } catch(e) {}
      if (!projectPath) {
        projectPath = '/home/leo/Desktop/CC';
      }
      // Upload via multipart
      const form = new FormData();
      form.append('project_path', projectPath);
      files.forEach(f => form.append('files', f, f.name));
      try {
        const res = await fetch('http://127.0.0.1:9111/projects/upload', { method: 'POST', body: form });
        const data = await res.json();
        if (data.ok && data.uploaded && data.uploaded.length > 0) {
          // Inject file references as chat messages
          const names = data.uploaded.map(u => u.filename).join(', ');
          const panel = attachPanel;
          const to = panel === 'left' ? getCustomSelectValue('leftTargetWrap', 'ordo') : getCustomSelectValue('rightTargetWrap', 'all');
          const content = '[Attached: ' + names + ']';
          // Use sendMessage (defined later) via deferred call
          setTimeout(() => {
            if (typeof sendMessage === 'function') {
              sendMessage('user', to, content, panel);
            }
          }, 0);
        }
      } catch(e) {
        console.error('File upload failed:', e);
      }
      fileInput.value = '';
    });

    // ========== Phase 1: Config + Rendering ==========
    const BRIDGE_CONFIG = {
      apiBase: 'http://127.0.0.1:9111',
      wsUrl: 'ws://127.0.0.1:9112',
      historyLimit: 200,
      pollInterval: 10000
    };
    const API_BASE = BRIDGE_CONFIG.apiBase;
    const WS_URL = BRIDGE_CONFIG.wsUrl;

    const AGENT_LABELS = { user: 'Leo', all_managers: 'Alle Manager' };
    function agentLabel(id){ return AGENT_LABELS[id] || id.charAt(0).toUpperCase() + id.slice(1); }

    // FE29: Management-Agents — fest definiert, immer linkes Panel
    const MANAGEMENT_AGENTS = new Set(['ordo', 'lucy', 'viktor', 'nova']);
    const AGENT_COLORS = {
      'ordo':'#6366f1', 'viktor':'#8b5cf6', 'nova':'#ec4899',
      'lucy':'#f59e0b', 'codex':'#06b6d4', 'frontend':'#22c55e',
      'backend':'#f97316', 'mobile':'#14b8a6',
      'qwen1':'#a855f7', 'qwen2':'#a855f7', 'qwen3':'#a855f7'
    };
    function getAgentColor(id){ return AGENT_COLORS[id] || '#8f8f8f'; }
    function isManagementAgent(id){ return MANAGEMENT_AGENTS.has(id); }

    const leftInner = document.querySelector('#chatMessagesLeft .chatMessagesInner');
    const rightInner = document.querySelector('#chatMessagesRight .chatMessagesInner');
    const leftBox = document.getElementById('chatMessagesLeft');
    const rightBox = document.getElementById('chatMessagesRight');

    // Track rendered message IDs to avoid duplicates
    const renderedIds = new Set();
    // Cache all messages for re-rendering on dropdown change
    const messageCache = [];

    // Track per-agent which panel the user last used to talk to them (persisted)
    let agentPanel = JSON.parse(localStorage.getItem('bridge_agentPanel') || '{}');
    function setAgentPanel(agentId, panel){
      agentPanel[agentId] = panel;
      localStorage.setItem('bridge_agentPanel', JSON.stringify(agentPanel));
    }

    function isLeftPanel(msg){
      // Persistent panel from API meta (survives history/poll)
      if(msg.meta && msg.meta.panel === 'left') return true;
      if(msg.meta && msg.meta.panel === 'right') return false;
      // Client-side panel tag from send functions (immediate render, before WS echo)
      if(msg._panel === 'left') return true;
      if(msg._panel === 'right') return false;
      // FE29: Deterministic routing via MANAGEMENT_AGENTS config
      // Broadcasts to 'all' or 'all_managers' go to their respective panels
      if(msg.to === 'all' || msg.to === 'broadcast') return false;
      if(msg.to === 'all_managers') return true;
      // Conversation context: check agentPanel for the other party
      const other = msg.from === 'user' ? msg.to : (msg.to === 'user' ? msg.from : null);
      if(other && agentPanel[other]) return agentPanel[other] === 'left';
      // Fallback: management agents default to left
      if(msg.from === 'user') return isManagementAgent(msg.to);
      if(msg.to === 'user') return isManagementAgent(msg.from);
      // Agent-to-agent: if BOTH are management agents → left (management discussion)
      if(isManagementAgent(msg.from) && isManagementAgent(msg.to)) return true;
      // Agent-to-agent involving at least one non-management → right
      return false;
    }

    // Typing indicators — ephemeral per agent
    const typingEls = {}; // agentId → DOM element
    function showTyping(agentId){
      removeTyping(agentId);
      const isLeft = isManagementAgent(agentId);
      const container = isLeft ? leftInner : rightInner;
      const scrollEl = isLeft ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);
      const div = document.createElement('div');
      div.className = 'typingIndicator';
      div.innerHTML = '<span class="typingIndicator__dots">' +
        '<span class="typingIndicator__dot"></span>' +
        '<span class="typingIndicator__dot"></span>' +
        '<span class="typingIndicator__dot"></span></span>' +
        agentLabel(agentId) + ' tippt\u2026';
      container.appendChild(div);
      typingEls[agentId] = div;
      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }
    function removeTyping(agentId){
      if(typingEls[agentId]){
        typingEls[agentId].remove();
        delete typingEls[agentId];
      }
    }

    function isNearBottom(el){ return el.scrollHeight - el.scrollTop - el.clientHeight < 60; }

    const timeFmt = new Intl.DateTimeFormat('de-DE', {hour:'2-digit', minute:'2-digit'});
    function formatTime(ts){
      if(!ts) return '';
      const d = new Date(ts);
      if(isNaN(d)) return '';
      const diff = (Date.now() - d.getTime()) / 1000;
      if(diff < 60) return 'gerade eben';
      if(diff < 3600) return 'vor ' + Math.floor(diff/60) + ' Min';
      if(diff < 86400) return timeFmt.format(d);
      return d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit'}) + ' ' + timeFmt.format(d);
    }

    const MAX_CACHE = 500;

    function renderMessage(msg, skipCache){
      // Output_forwarder: ONLY allow type="status" (typing indicator). Everything else is suppressed.
      if(msg.meta && msg.meta.source === 'output_forwarder'){
        if(msg.meta.type === 'status'){
          showTyping(msg.from);
        }
        return; // Never render forwarder messages as chat bubbles
      }
      // Hide system/internal messages from chat UI (still delivered to agents internally)
      if(msg.from === 'system' || msg.from === 'watcher') return;
      if(msg.meta && msg.meta.type === 'context_restore') return;
      if(msg.content && (msg.content.startsWith('[CONTEXT RESTORE]') || msg.content.startsWith('[WARN]'))) return;

      // Prose or any real message from agent → remove their typing indicator
      if(msg.from && msg.from !== 'user') removeTyping(msg.from);

      if(!skipCache){
        // Prevent duplicates in cache (race: WebSocket echo vs HTTP response)
        const existing = msg.id ? messageCache.find(m => m.id === msg.id) : null;
        if(existing){
          // Merge _panel tag from later arrival
          if(msg._panel && !existing._panel) existing._panel = msg._panel;
        } else {
          messageCache.push(msg);
          // Evict oldest entries to prevent memory leak
          while(messageCache.length > MAX_CACHE){
            const removed = messageCache.shift();
            if(removed.id) renderedIds.delete(removed.id);
          }
        }
      }
      if(msg.id && renderedIds.has(msg.id)) return;
      if(msg.id) renderedIds.add(msg.id);

      const isLeft = isLeftPanel(msg);

      // FE14/FE28: Sidebar-Projekt-Filter — beide Panels
      if(sidebarProjectFilter && boardProjectsCache){
        const projMembers = new Set();
        boardProjectsCache.forEach(p => {
          if(p.name === sidebarProjectFilter){
            (p.teams || []).forEach(t => (t.members || []).forEach(m => projMembers.add(m.id || m)));
          }
        });
        projMembers.add('user'); // User-Nachrichten immer zeigen
        if(!projMembers.has(msg.from) && !projMembers.has(msg.to)) return;
      }

      const container = isLeft ? leftInner : rightInner;
      const scrollEl = isLeft ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);

      const div = document.createElement('div');
      const isForwarder = msg.meta && (msg.meta.source === 'output_forwarder' || msg.meta.auto_capture === true) && msg.meta.type !== 'prose';
      
      // Show reply indicator if this message is a reply
      if(msg.meta && msg.meta.reply_to){
        const replyRef = document.createElement('div');
        replyRef.className = 'msgReplyRef';
        replyRef.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>' +
          '<span>Antwort</span>';
        div.appendChild(replyRef);
      }
      
      if(msg.from === 'user'){
        div.className = 'chatMsg chatMsg--user';
        // FE29: Always show direction label in left panel (multiple managers)
        const uLabel = document.createElement('span');
        uLabel.className = 'agentLabel';
        uLabel.textContent = agentLabel('user') + ' → ' + agentLabel(msg.to);
        div.appendChild(uLabel);
      } else {
        div.className = 'chatMsg chatMsg--agent';
        const label = document.createElement('span');
        label.className = 'agentLabel';
        // FE29: Show direction for both panels (multi-conversation context)
        label.textContent = agentLabel(msg.from) + (msg.to && msg.to !== 'user' ? ' → ' + agentLabel(msg.to) : '');
        div.appendChild(label);
      }
      if(isForwarder) div.classList.add('chatMsg--forwarder');

      const text = document.createTextNode(msg.content);
      div.appendChild(text);
      const ts = formatTime(msg.timestamp);
      if(ts){
        const timeEl = document.createElement('span');
        timeEl.className = 'msgTime';
        timeEl.textContent = ts;
        div.appendChild(timeEl);
      }
      // Action buttons — outside the message box in a wrapper row
      if(!isForwarder){
        const row = document.createElement('div');
        row.className = 'msgRow ' + (msg.from === 'user' ? 'msgRow--user' : 'msgRow--agent');

        const actions = document.createElement('div');
        actions.className = 'msgActions';

        // Reply button — only on agent messages, not on user's own
        if(msg.from !== 'user'){
          const replyTarget = msg.from;
          const replyBtn = document.createElement('button');
          replyBtn.className = 'replyBtn';
          replyBtn.title = 'Antworten';
          replyBtn.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>';
          replyBtn.addEventListener('click', e => {
            e.stopPropagation();
            openReplyPopup(row, replyTarget, msg.content, msg.id, isLeft);
          });
          actions.appendChild(replyBtn);
        }

        // Copy button
        const copyBtn = document.createElement('button');
        copyBtn.className = 'copyBtn';
        copyBtn.title = 'Kopieren';
        copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        copyBtn.addEventListener('click', e => {
          e.stopPropagation();
          navigator.clipboard.writeText(msg.content).then(() => {
            copyBtn.classList.add('copyBtn--done');
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(() => {
              copyBtn.classList.remove('copyBtn--done');
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
            }, 1500);
          });
        });

        actions.appendChild(copyBtn);
        row.appendChild(div);
        row.appendChild(actions);
        container.appendChild(row);
      } else {
        container.appendChild(div);
      }

      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }

    // ========== Reply Popup Logic ==========
    let activeReplyPopup = null;
    let activeReplyMsgId = null;

    function openReplyPopup(row, target, quote, msgId, isLeft){
      closeReplyPopup();
      const shortQuote = quote.length > 80 ? quote.substring(0, 80) + '\u2026' : quote;
      const popup = document.createElement('div');
      popup.className = 'replyPopup';
      // Build popup via DOM — no innerHTML with user content (XSS prevention)
      const header = document.createElement('div');
      header.className = 'replyPopup__header';
      const recipient = document.createElement('div');
      recipient.className = 'replyPopup__recipient';
      const dot = document.createElement('span');
      dot.className = 'replyPopup__dot';
      const recipientText = document.createElement('span');
      recipientText.innerHTML = 'Antwort an <strong>' + agentLabel(target) + '</strong>';
      recipient.append(dot, recipientText);
      const closeBtn = document.createElement('button');
      closeBtn.className = 'replyPopup__close';
      closeBtn.title = 'Schliessen';
      closeBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>';
      header.append(recipient, closeBtn);
      const quoteEl = document.createElement('div');
      quoteEl.className = 'replyPopup__quote';
      quoteEl.textContent = shortQuote; // textContent = safe, no XSS
      const inputWrap = document.createElement('div');
      inputWrap.className = 'replyPopup__inputWrap';
      const textarea = document.createElement('textarea');
      textarea.className = 'replyPopup__input';
      textarea.rows = 1;
      textarea.placeholder = 'Nachricht an ' + agentLabel(target) + '...';
      const sendBtn = document.createElement('button');
      sendBtn.className = 'replyPopup__send';
      sendBtn.title = 'Senden';
      sendBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M22 2L11 13"/><polygon points="22 2 15 22 11 13 2 9"/></svg>';
      inputWrap.append(textarea, sendBtn);
      popup.append(header, quoteEl, inputWrap);

      document.body.appendChild(popup);
      activeReplyPopup = popup;
      activeReplyMsgId = msgId;

      // Position popup next to the reply button
      const btn = row.querySelector('.replyBtn');
      const rect = btn.getBoundingClientRect();
      const popupW = 280;
      const isUserMsg = row.classList.contains('msgRow--user');
      let left, top;
      if(isUserMsg){
        left = rect.left - popupW - 8;
      } else {
        left = rect.right + 8;
      }
      top = rect.top;
      // Keep within viewport
      if(left < 8) left = 8;
      if(left + popupW > window.innerWidth - 8) left = window.innerWidth - popupW - 8;
      if(top + 160 > window.innerHeight) top = window.innerHeight - 168;
      if(top < 8) top = 8;
      popup.style.left = left + 'px';
      popup.style.top = top + 'px';

      const input = popup.querySelector('.replyPopup__input');
      setTimeout(() => input.focus(), 30);

      input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 64) + 'px';
      });
      input.addEventListener('keydown', e => {
        if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); submitReply(target, input, isLeft); }
        if(e.key === 'Escape') closeReplyPopup();
      });
      popup.querySelector('.replyPopup__close').addEventListener('click', e => {
        e.stopPropagation(); closeReplyPopup();
      });
      popup.querySelector('.replyPopup__send').addEventListener('click', e => {
        e.stopPropagation(); submitReply(target, input, isLeft);
      });
    }

    function submitReply(target, input, isLeft){
      const text = input.value.trim();
      if(!text) return;
      const panel = isLeft ? 'left' : 'right';
      setAgentPanel(target, panel);
      sendMessage('user', target, text, panel, activeReplyMsgId);
      closeReplyPopup();
    }

    function closeReplyPopup(){
      if(activeReplyPopup){ activeReplyPopup.remove(); activeReplyPopup = null; }
    }

    document.addEventListener('click', e => {
      if(activeReplyPopup && !activeReplyPopup.contains(e.target) && !e.target.closest('.replyBtn')){
        closeReplyPopup();
      }
    });

    function clearStaticMessages(){
      leftInner.innerHTML = '';
      rightInner.innerHTML = '';
    }

    // ========== Error Helpers ==========
    function showError(panel, text){
      const container = panel === 'left' ? leftInner : rightInner;
      const scrollEl = panel === 'left' ? leftBox : rightBox;
      const wasNear = isNearBottom(scrollEl);
      const div = document.createElement('div');
      div.className = 'chatMsg chatMsg--error';
      div.textContent = text;
      container.appendChild(div);
      if(wasNear) scrollEl.scrollTop = scrollEl.scrollHeight;
    }

    // WS Disconnect Banner (fixed position, overlays full page top)
    const wsBanner = document.createElement('div');
    wsBanner.className = 'wsBanner';
    wsBanner.setAttribute('role', 'alert');
    wsBanner.setAttribute('aria-live', 'assertive');
    wsBanner.setAttribute('aria-atomic', 'true');
    wsBanner.textContent = 'Verbindung unterbrochen — Nachrichten werden nicht live aktualisiert';
    document.body.appendChild(wsBanner);

    function setWsBanner(visible){
      wsBanner.classList.toggle('wsBanner--visible', visible);
    }

    // ========== Phase 2: Backend-Anbindung ==========
    async function sendMessage(from, to, content, panel, replyTo){
      try {
        const payload = {from, to, content};
        if(panel) payload.meta = {panel};
        if(replyTo) {
          if(!payload.meta) payload.meta = {};
          payload.meta.reply_to = replyTo;
        }
        const res = await fetch(API_BASE + '/send', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if(data.ok && data.message){
          if(panel) data.message._panel = panel;
          renderMessage(data.message);
        } else {
          showError(panel || 'left', 'Senden fehlgeschlagen: ' + (data.error || 'Unbekannter Fehler'));
        }
      } catch(e){
        console.error('Send failed:', e);
        showError(panel || 'left', 'Senden fehlgeschlagen — Server nicht erreichbar');
      }
    }

    async function loadHistory(){
      try {
        const res = await fetch(API_BASE + '/history?limit=' + BRIDGE_CONFIG.historyLimit);
        const data = await res.json();
        if(data.messages){
          data.messages.forEach(m => renderMessage(m));
        }
      } catch(e){ console.error('History load failed:', e); }
    }

    // Left panel send (Management Board: user → assi)
    const leftInput = document.querySelector('.chatInput--left textarea');
    const leftSend = document.querySelector('.chatInput--left .chatSend');

    function sendLeftMsg(){
      const text = leftInput.value.trim();
      if(!text) return;
      const to = getCustomSelectValue('leftTargetWrap', 'ordo');
      if(to === 'all_managers'){
        sendMessage('user', 'all_managers', text, 'left');
      } else {
        setAgentPanel(to, 'left');
        sendMessage('user', to, text, 'left');
      }
      leftInput.value = '';
      leftInput.style.height = 'auto';
    }

    leftSend.addEventListener('click', sendLeftMsg);
    leftInput.addEventListener('keydown', e => {
      if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendLeftMsg(); }
    });

    // Right panel send (Team Board: user → selected target)
    const rightInput = document.querySelector('.chatInput--right textarea');
    const rightSend = document.querySelector('.chatInput--right .chatSend');

    function sendRightMsg(){
      const text = rightInput.value.trim();
      if(!text) return;
      const to = getCustomSelectValue('rightTargetWrap', 'all');
      if(to === 'all_team'){
        // FE30: Broadcast to selected team members
        const members = getSelectedTeamMembers();
        if(members){
          members.forEach(m => {
            setAgentPanel(m, 'right');
            sendMessage('user', m, text, 'right');
          });
        }
      } else if(to === 'all'){
        Object.keys(agentPanel).forEach(k => setAgentPanel(k, 'right'));
        sendMessage('user', to, text, 'right');
      } else {
        setAgentPanel(to, 'right');
        sendMessage('user', to, text, 'right');
      }
      rightInput.value = '';
      rightInput.style.height = 'auto';
    }

    rightSend.addEventListener('click', sendRightMsg);
    rightInput.addEventListener('keydown', e => {
      if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendRightMsg(); }
    });

    // ========== Phase 3: WebSocket Live-Updates ==========
    let ws = null;
    let wsRetry = 1000;

    function connectWebSocket(){
      ws = new WebSocket(WS_URL);
      ws.onopen = () => {
        wsRetry = 1000;
        updateConnectionDot(true);
        setWsBanner(false);
      };
      ws.onmessage = ev => {
        try {
          const data = JSON.parse(ev.data);
          if(data.type === 'message' && data.message) renderMessage(data.message);
          if(data.type === 'agent_status') pollAgentStatus();
          if(data.type === 'agent_registered') pollAgentStatus();
          if(data.type === 'approval_request') { showApprovalToast(data.data || data); updateApprovalBadge(); }
          if(data.type === 'approval_decided') { removeApprovalCard(data.data || data); updateApprovalBadge(); showApprovalFeedback((data.data||data).decision); }
          // W6: Task event notifications
          if(data.type && data.type.startsWith('task_') || data.type === 'scope_lock_conflict' || data.type === 'agent_stale' || data.type === 'lead_offline'){
            handleTaskEvent(data);
          }
        } catch(e){}
      };
      ws.onclose = () => {
        updateConnectionDot(false);
        setWsBanner(true);
        setTimeout(connectWebSocket, wsRetry);
        wsRetry = Math.min(wsRetry * 2, 30000);
      };
      ws.onerror = () => ws.close();
    }

    // ========== Phase 4: Agent-Status + FE30 Team-Tabs ==========
    let agentStatusCache = []; // all agents from /agents
    let selectedTeam = null; // {project, team} or null

    // ========== Agent-Start per Chip-Klick ==========
    const startingAgents = new Map(); // agentId → {startedAt, timeoutId, fastPollId}

    async function startAgent(agentId){
      if(startingAgents.has(agentId)) return;
      // POST /agents/{agent_id}/start — requires {from: "user"}
      try {
        const res = await fetch(API_BASE + '/agents/' + agentId + '/start', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({from: 'user'})
        });
        const data = await res.json();
        if(data.status === 'already_running') return; // no spinner needed
      } catch(e){
        // Endpoint may not exist yet — continue with spinner
      }
      // Immediately update chip dot to spinner
      const dot = document.querySelector('#mgmtMemberBar .memberChip[data-agent="' + agentId + '"] .memberChip__dot');
      if(dot){ dot.classList.remove('memberChip__dot--error'); dot.classList.add('memberChip__dot--starting'); }
      // Task 2: Progress text under chip
      const chip = document.querySelector('#mgmtMemberBar .memberChip[data-agent="' + agentId + '"]');
      let progEl = null;
      if(chip){
        progEl = document.createElement('span');
        progEl.className = 'memberChip__progress';
        progEl.textContent = 'Startet...';
        chip.appendChild(progEl);
      }
      const progressSteps = [[5000,'Lädt...'], [15000,'Verbindet...'], [25000,'Dauert länger...']];
      const progressTimers = progressSteps.map(([ms, txt]) => setTimeout(() => { if(progEl) progEl.textContent = txt; }, ms));
      // Fast poll every 3s until agent is active
      const fastPollId = setInterval(async () => {
        await pollAgentStatus();
        if(getAgentStatus(agentId) === 'active') clearStartingAgent(agentId);
      }, 3000);
      // 30s fallback
      const timeoutId = setTimeout(() => {
        clearStartingAgent(agentId);
        showStartHint(agentId);
      }, 30000);
      startingAgents.set(agentId, { startedAt: Date.now(), timeoutId, fastPollId, progressTimers });
    }

    function clearStartingAgent(agentId){
      const entry = startingAgents.get(agentId);
      if(!entry) return;
      clearTimeout(entry.timeoutId);
      clearInterval(entry.fastPollId);
      if(entry.progressTimers) entry.progressTimers.forEach(t => clearTimeout(t));
      startingAgents.delete(agentId);
      // Remove progress text
      const chip = document.querySelector('#mgmtMemberBar .memberChip[data-agent="' + agentId + '"]');
      const prog = chip && chip.querySelector('.memberChip__progress');
      if(prog) prog.remove();
    }

    function showStartHint(agentId){
      const name = agentLabel(agentId);
      // Task 3: Show error state on the chip itself
      const dot = document.querySelector('#mgmtMemberBar .memberChip[data-agent="' + agentId + '"] .memberChip__dot');
      if(dot){
        dot.classList.remove('memberChip__dot--starting');
        dot.classList.add('memberChip__dot--error');
        dot.title = 'Nicht gestartet. Klick zum erneuten Versuch.';
        dot.style.cursor = 'pointer';
        const retry = () => { dot.classList.remove('memberChip__dot--error'); dot.title = ''; dot.removeEventListener('click', retry); startAgent(agentId); };
        dot.addEventListener('click', retry);
      }
      // Remove progress text if present
      const chip = document.querySelector('#mgmtMemberBar .memberChip[data-agent="' + agentId + '"]');
      const prog = chip && chip.querySelector('.memberChip__progress');
      if(prog) prog.remove();
      // Chat hint (kept for context)
      const container = document.getElementById('chatMessagesLeft');
      if(!container) return;
      const inner = container.querySelector('.chatMessagesInner');
      if(!inner) return;
      const hint = document.createElement('div');
      hint.className = 'chatMsg chatMsg--agent';
      hint.style.cssText = 'opacity:.7; font-size:11px; cursor:pointer; padding:6px 10px;';
      const hintLabel = document.createElement('span');
      hintLabel.className = 'agentLabel';
      hintLabel.style.color = '#f59e0b';
      hintLabel.textContent = 'System';
      const hintText = document.createElement('span');
      hintText.innerHTML = name + ' antwortet nicht — <u>Erneut versuchen?</u>';
      hint.append(hintLabel, hintText);
      hint.addEventListener('click', () => {
        hint.remove();
        startAgent(agentId);
      });
      const wasNear = isNearBottom(container);
      inner.appendChild(hint);
      if(wasNear) container.scrollTop = container.scrollHeight;
    }

    function getAgentStatus(agentId){
      const a = agentStatusCache.find(x => x.agent_id === agentId);
      if(!a) return 'dead';
      if(a.status === 'running') return 'active';
      if(a.status === 'waiting') return 'idle';
      return 'dead';
    }

    let chatActivityCache = {}; // agentId → {action, description}

    async function fetchChatActivities(){
      try {
        const res = await fetch(API_BASE + '/activity', {signal: AbortSignal.timeout(3000)});
        if(!res.ok) return;
        const data = await res.json();
        if(data.activities && Array.isArray(data.activities)){
          const map = {};
          data.activities.forEach(a => { map[a.agent_id] = {action: a.action || '', description: a.description || ''}; });
          chatActivityCache = map;
        }
      } catch(e){ /* keep cache */ }
    }

    function renderMgmtMemberBar(mgmtTeams){
      const header = document.getElementById('boardHeaderLeft');
      const bar = document.getElementById('mgmtMemberBar');
      if(!header || !bar) return;
      // Collect unique management members
      const seen = new Set();
      const members = [];
      mgmtTeams.forEach(t => t.members.forEach(m => { if(!seen.has(m)){ seen.add(m); members.push(m); } }));
      if(members.length === 0){ header.classList.remove('boardHeader--expanded'); bar.innerHTML = ''; return; }
      bar.innerHTML = members.map(m => {
        const st = getAgentStatus(m);
        const isStarting = startingAgents.has(m);
        const orgInfo = orgchartAgentMap[m];
        const isDeactivated = orgInfo && orgInfo.active === false;
        const dotColor = isDeactivated ? '#999' : isStarting ? '#f59e0b' : st === 'active' ? '#22c55e' : st === 'idle' ? '#f59e0b' : '#ef4444';
        const dotClass = 'memberChip__dot' + (isStarting ? ' memberChip__dot--starting' : '');
        const chipClass = 'memberChip' + (isDeactivated ? ' memberChip--deactivated' : '');
        const role = getDisplayRole(m);
        const tooltip = isDeactivated ? ' title="Deaktiviert"' : '';
        return '<span class="' + chipClass + '" data-agent="' + m + '"' + tooltip + '>' +
          '<span class="' + dotClass + '" style="background:' + dotColor + '"></span>' +
          '<span class="memberChip__name">' + getDisplayName(m) + '</span>' +
          (role ? '<span class="memberChip__role">' + role + '</span>' : '') +
          '</span>';
      }).join('');
      header.classList.add('boardHeader--expanded');
      // Click on chip → select in left dropdown + auto-start if offline
      bar.querySelectorAll('.memberChip').forEach(chip => {
        chip.addEventListener('click', () => {
          const agentId = chip.dataset.agent;
          // Select as chat target
          const wrap = document.getElementById('leftTargetWrap');
          if(wrap) {
            wrap.dataset.value = agentId;
            document.getElementById('leftTargetTrigger').textContent = getDisplayName(agentId);
            wrap.querySelectorAll('.customSelect__option').forEach(o => {
              o.classList.toggle('selected', o.dataset.value === agentId);
            });
          }
          // Task 1: Pulse feedback if agent already running
          const st = getAgentStatus(agentId);
          if(st === 'active' || st === 'idle'){
            const dot = chip.querySelector('.memberChip__dot');
            if(dot){ dot.classList.remove('memberChip__dot--pulse'); void dot.offsetWidth; dot.classList.add('memberChip__dot--pulse'); dot.addEventListener('animationend', () => dot.classList.remove('memberChip__dot--pulse'), {once:true}); }
          }
          // Auto-start if agent is offline
          if(st === 'dead' && !startingAgents.has(agentId)){
            startAgent(agentId);
          }
        });
      });
      // Adjust left chat top
      const chatLeft = document.querySelector('.chatMessages--left');
      if(chatLeft) requestAnimationFrame(() => { chatLeft.style.top = (header.offsetHeight + 12) + 'px'; });
    }

    function renderTeamTabs(){
      const container = document.getElementById('teamTabs');
      if(!container) return;

      // Build teams from boardProjectsCache — filter out management teams (belong LEFT)
      const allTeams = [];
      const mgmtTeams = [];
      if(boardProjectsCache){
        boardProjectsCache.forEach(p => {
          (p.teams || []).forEach(t => {
            const members = (t.members || []).map(m => m.id || m);
            const isMgmt = members.length > 0 && members.every(m => MANAGEMENT_AGENTS.has(m));
            if(isMgmt) { mgmtTeams.push({project: p.name, team: t.name, members}); }
            else { allTeams.push({project: p.name, team: t.name, members}); }
          });
        });
      }
      // Collect all agents already in a team (mgmt or regular)
      const assignedIds = new Set();
      mgmtTeams.forEach(t => t.members.forEach(m => assignedIds.add(m)));
      allTeams.forEach(t => t.members.forEach(m => assignedIds.add(m)));

      // Add unassigned active agents to a synthetic "Weitere" team
      const unassigned = agentStatusCache
        .filter(a => !assignedIds.has(a.agent_id) && a.agent_id !== 'user' && !MANAGEMENT_AGENTS.has(a.agent_id))
        .map(a => a.agent_id);
      if(unassigned.length > 0){
        allTeams.push({project: '', team: 'Weitere', members: unassigned});
      }

      const teams = allTeams;

      // Render management agents in LEFT header
      renderMgmtMemberBar(mgmtTeams);

      if(teams.length === 0){
        container.innerHTML = '';
        return;
      }

      // Render team tabs
      let html = '';
      teams.forEach(t => {
        const isActive = selectedTeam && selectedTeam.project === t.project && selectedTeam.team === t.team;
        const online = t.members.filter(m => getAgentStatus(m) === 'active').length;
        html += '<span class="teamTab' + (isActive ? ' teamTab--active' : '') +
          '" data-project="' + t.project + '" data-team="' + t.team + '">' +
          t.team + ' <span class="teamTab__count">' + online + '/' + t.members.length + '</span></span>';
      });
      container.innerHTML = html;

      // Click handlers
      container.querySelectorAll('.teamTab').forEach(tab => {
        tab.addEventListener('click', () => {
          const proj = tab.dataset.project;
          const team = tab.dataset.team;
          if(selectedTeam && selectedTeam.project === proj && selectedTeam.team === team){
            selectedTeam = null; // Deselect → collapse
          } else {
            selectedTeam = {project: proj, team: team};
          }
          renderTeamTabs();
          updateRightDropdownForTeam();
        });
      });

      // Member Bar — inline im Header, keine Overlay-Panel
      const header = document.getElementById('boardHeaderRight');
      const bar = document.getElementById('memberBar');
      if(header && bar){
        if(!selectedTeam){
          header.classList.remove('boardHeader--expanded');
          bar.innerHTML = '';
        } else {
          const t = teams.find(x => x.project === selectedTeam.project && x.team === selectedTeam.team);
          if(t){
            const currentTarget = getCustomSelectValue('rightTargetWrap', '');
            bar.innerHTML = t.members.map(m => {
              const st = getAgentStatus(m);
              const dotColor = st === 'active' ? '#22c55e' : st === 'idle' ? '#f59e0b' : '#ef4444';
              const agentInfo = agentStatusCache.find(a => a.agent_id === m);
              const role = agentInfo && agentInfo.role ? agentInfo.role : '';
              const shortRole = role ? role.split(' ')[0] : '';
              const isSelected = currentTarget === m;
              return '<span class="memberChip' + (isSelected ? ' memberChip--selected' : '') + '" data-agent="' + m + '">' +
                '<span class="memberChip__dot" style="background:' + dotColor + '"></span>' +
                '<span class="memberChip__name">' + agentLabel(m) + '</span>' +
                (shortRole ? '<span class="memberChip__role">' + shortRole + '</span>' : '') +
                '</span>';
            }).join('');
            header.classList.add('boardHeader--expanded');
            // Click on chip → select agent in dropdown
            bar.querySelectorAll('.memberChip').forEach(chip => {
              chip.addEventListener('click', () => {
                const agentId = chip.dataset.agent;
                const wrap = document.getElementById('rightTargetWrap');
                if(wrap) {
                  wrap.dataset.value = agentId;
                  document.getElementById('rightTargetTrigger').textContent = agentLabel(agentId);
                  wrap.querySelectorAll('.customSelect__option').forEach(o => {
                    o.classList.toggle('selected', o.dataset.value === agentId);
                  });
                }
                bar.querySelectorAll('.memberChip').forEach(c => c.classList.remove('memberChip--selected'));
                chip.classList.add('memberChip--selected');
              });
            });
          } else {
            header.classList.remove('boardHeader--expanded');
            bar.innerHTML = '';
          }
        }
        // Adjust chat top to match header height
        const chatRight = document.querySelector('.chatMessages--right');
        if(chatRight){
          requestAnimationFrame(() => {
            chatRight.style.top = (header.offsetHeight + 12) + 'px';
          });
        }
      }
    }

    function getSelectedTeamMembers(){
      if(!selectedTeam || !boardProjectsCache) return null;
      for(const p of boardProjectsCache){
        if(p.name === selectedTeam.project){
          for(const t of (p.teams || [])){
            if(t.name === selectedTeam.team){
              return (t.members || []).map(m => m.id || m);
            }
          }
        }
      }
      return null;
    }

    function updateRightDropdownForTeam(){
      const members = getSelectedTeamMembers();
      const activeAgents = agentStatusCache.filter(a => a.status !== 'disconnected');

      if(!members){
        // No team selected — show all agents
        const rightOpts = [{value:'all', label:'Alle'}].concat(
          activeAgents.map(a => ({value:a.agent_id, label:agentLabel(a.agent_id)}))
        );
        populateRightDropdown(rightOpts, 'all');
      } else {
        // Team selected — show team members + "Alle (Teamname)"
        const label = 'Alle (' + selectedTeam.team + ')';
        const rightOpts = [{value:'all_team', label: label}].concat(
          members.map(m => ({value:m, label:agentLabel(m)}))
        );
        populateRightDropdown(rightOpts, 'all_team');
      }
    }

    function populateRightDropdown(options, defaultVal){
      const wrap = document.getElementById('rightTargetWrap');
      const trigger = document.getElementById('rightTargetTrigger');
      const dropdown = document.getElementById('rightTargetDropdown');
      if(!wrap || !trigger || !dropdown) return;
      const current = wrap.dataset.value || defaultVal;
      dropdown.innerHTML = '';
      const vals = options.map(o => o.value);
      options.forEach(o => {
        const div = document.createElement('div');
        div.className = 'customSelect__option';
        div.dataset.value = o.value;
        div.textContent = o.label;
        dropdown.appendChild(div);
      });
      let resolved = vals.includes(current) ? current : defaultVal;
      if(!vals.includes(resolved) && options.length) resolved = options[0].value;
      wrap.dataset.value = resolved;
      const selectedOpt = options.find(o => o.value === resolved);
      trigger.textContent = selectedOpt ? selectedOpt.label : resolved;
      dropdown.querySelectorAll('.customSelect__option').forEach(d => {
        d.classList.toggle('selected', d.dataset.value === resolved);
      });
    }

    // Task 5: Grouped online notifications
    let prevOnlineSet = new Set();
    let onlineBatchQueue = [];
    let onlineBatchTimer = null;

    function flushOnlineBatch(){
      onlineBatchTimer = null;
      if(onlineBatchQueue.length === 0) return;
      const names = onlineBatchQueue.map(id => agentLabel(id));
      onlineBatchQueue = [];
      const text = names.length === 1 ? names[0] + ' ist jetzt online.'
        : names.slice(0,-1).join(', ') + ' und ' + names[names.length-1] + ' sind jetzt online.';
      const container = document.getElementById('chatMessagesLeft');
      if(!container) return;
      const inner = container.querySelector('.chatMessagesInner');
      if(!inner) return;
      const msg = document.createElement('div');
      msg.className = 'chatMsg chatMsg--agent';
      msg.style.cssText = 'opacity:.6; font-size:10px; padding:4px 10px; text-align:center;';
      msg.innerHTML = '<span style="color:#22c55e">●</span> ' + text;
      const wasNear = isNearBottom(container);
      inner.appendChild(msg);
      if(wasNear) container.scrollTop = container.scrollHeight;
    }

    async function pollAgentStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        if(!data.agents) return;

        // Populate AGENT_LABELS dynamically from response
        data.agents.forEach(a => {
          if(a.agent_id && a.agent_id !== 'user' && !AGENT_LABELS[a.agent_id]){
            AGENT_LABELS[a.agent_id] = a.agent_id.charAt(0).toUpperCase() + a.agent_id.slice(1);
          }
        });

        // Task 5: Detect newly online agents
        const nowOnline = new Set(data.agents.filter(a => a.status !== 'disconnected').map(a => a.agent_id));
        if(prevOnlineSet.size > 0){
          nowOnline.forEach(id => {
            if(!prevOnlineSet.has(id)){
              onlineBatchQueue.push(id);
              if(onlineBatchTimer) clearTimeout(onlineBatchTimer);
              onlineBatchTimer = setTimeout(flushOnlineBatch, 5000);
            }
          });
        }
        prevOnlineSet = nowOnline;

        agentStatusCache = data.agents;
        const activeAgents = data.agents.filter(a => a.status !== 'disconnected');

        // Clear starting-agents that are now online
        startingAgents.forEach((_, agentId) => {
          const a = data.agents.find(x => x.agent_id === agentId);
          if(a && a.status !== 'disconnected') clearStartingAgent(agentId);
        });

        // FE30: Render team tabs instead of flat agent bar
        renderTeamTabs();

        // Update target dropdowns
        updateTargetDropdown(activeAgents, data.agents);
      } catch(e){
        console.error('Agent status failed:', e);
        const container = document.getElementById('teamTabs');
        if(container) container.innerHTML = '<span class="teamTab" style="color:#ef4444;cursor:default">Verbindung verloren</span>';
      }
    }

    // ========== Projekt-Badge (Task B) ==========
    let boardProjectsCache = null;
    const teamAgentMap = {};

    function buildTeamAgentMap(){
      if(!boardProjectsCache) return;
      boardProjectsCache.forEach(p => {
        (p.teams || []).forEach(t => {
          (t.members || []).forEach(m => {
            if(m.id && !teamAgentMap[m.id]){
              teamAgentMap[m.id] = { name: m.name || m.id, role: m.role || '' };
            }
          });
        });
      });
      // Update AGENT_LABELS with team.json display names
      Object.keys(teamAgentMap).forEach(id => {
        AGENT_LABELS[id] = teamAgentMap[id].name;
      });
    }

    function getDisplayName(agentId){
      if(teamAgentMap[agentId]) return teamAgentMap[agentId].name;
      return agentLabel(agentId);
    }

    function getDisplayRole(agentId){
      if(teamAgentMap[agentId]) return teamAgentMap[agentId].role;
      return '';
    }

    async function fetchBoardProjects(){
      try {
        const res = await fetch(API_BASE + '/board/projects');
        const data = await res.json();
        if(data.projects && data.projects.length > 0){
          boardProjectsCache = data.projects;
          buildTeamAgentMap();
          renderTeamTabs();
        }
      } catch(e){ /* keep cache */ }
    }

    function getAgentProjects(agentId){
      if(!boardProjectsCache || !agentId) return [];
      const projects = [];
      boardProjectsCache.forEach(p => {
        const found = (p.teams || []).some(t => (t.members || []).some(m => m.id === agentId));
        if(found) projects.push(p.name);
      });
      return projects;
    }

    function updateProjectBadge(){
      const badge = document.getElementById('leftProjectBadge');
      if(!badge) return;
      // FE14/FE28: Show sidebar-selected project, fallback to agent's projects
      if(sidebarProjectFilter){
        badge.innerHTML = '<span class="projectBadge__item">' + sidebarProjectFilter + '</span>';
        return;
      }
      const agentId = getCustomSelectValue('leftTargetWrap', '');
      const projects = getAgentProjects(agentId);
      if(projects.length === 0){
        badge.innerHTML = '';
        return;
      }
      badge.innerHTML = projects.map(n => '<span class="projectBadge__item">' + n + '</span>').join('');
    }

    function updateTargetDropdown(agents, allAgents){
      if(!allAgents) allAgents = agents;
      // Helper: populate a custom select dropdown
      function populateCustomSelect(wrapId, triggerId, dropdownId, options, currentVal, defaultVal){
        const wrap = document.getElementById(wrapId);
        const trigger = document.getElementById(triggerId);
        const dropdown = document.getElementById(dropdownId);
        if(!wrap || !trigger || !dropdown) return currentVal;
        const current = wrap.dataset.value || currentVal;
        dropdown.innerHTML = '';
        options.forEach(o => {
          const div = document.createElement('div');
          div.className = 'customSelect__option' + (o.value === current ? ' selected' : '');
          div.dataset.value = o.value;
          div.textContent = o.label;
          dropdown.appendChild(div);
        });
        // Resolve value: keep current if still in list, else fallback
        const vals = options.map(o => o.value);
        let resolved = vals.includes(current) ? current : defaultVal;
        if(!vals.includes(resolved) && options.length) resolved = options[0].value;
        wrap.dataset.value = resolved;
        const selectedOpt = options.find(o => o.value === resolved);
        trigger.textContent = selectedOpt ? selectedOpt.label : resolved;
        // Mark selected
        dropdown.querySelectorAll('.customSelect__option').forEach(d => {
          d.classList.toggle('selected', d.dataset.value === resolved);
        });
        return resolved;
      }

      // FE29: Split agents — management from ALL agents (incl. offline), team from active only
      const mgmtAgents = allAgents.filter(a => isManagementAgent(a.agent_id));

      // FE30: Right panel now managed by updateRightDropdownForTeam()
      updateRightDropdownForTeam();

      // Left panel: "Alle Manager" + management agents only
      const leftOpts = [{value:'all_managers', label:'Alle Manager'}].concat(
        mgmtAgents.map(a => ({value:a.agent_id, label:agentLabel(a.agent_id)}))
      );
      // Temporarily add starting agents that aren't in the list yet
      const leftIds = new Set(leftOpts.map(o => o.value));
      startingAgents.forEach((_, agentId) => {
        if(isManagementAgent(agentId) && !leftIds.has(agentId)){
          leftOpts.push({value: agentId, label: agentLabel(agentId)});
        }
      });
      const prevLeft = getCustomSelectValue('leftTargetWrap', 'ordo');
      const newLeft = populateCustomSelect('leftTargetWrap', 'leftTargetTrigger', 'leftTargetDropdown', leftOpts, prevLeft, 'ordo');
      if(newLeft !== prevLeft) rerenderAll();
      updateProjectBadge();
    }

    // ========== Phase 5: Connection Indicator ==========
    let connDot = null;

    function createConnectionDot(){
      // Connection indicator in right header (not left — member chips show status there)
      const header = document.querySelector('.boardHeader--right');
      if(!header) return;
      connDot = document.createElement('span');
      connDot.className = 'agentBar__dot';
      connDot.style.marginLeft = '4px';
      connDot.title = 'Disconnected';
      updateConnectionDot(false);
      const title = header.querySelector('.boardHeader__title');
      if(title) title.after(connDot);
    }

    function updateConnectionDot(connected){
      if(!connDot) return;
      connDot.className = 'agentBar__dot ' + (connected ? 'agentBar__dot--active' : 'agentBar__dot--dead');
      connDot.title = connected ? 'Connected' : 'Disconnected';
    }

    // ========== Rerender on dropdown change ==========
    function rerenderAll(){
      leftInner.innerHTML = '';
      rightInner.innerHTML = '';
      renderedIds.clear();
      messageCache.forEach(m => renderMessage(m, true));
    }

    // Change listener on leftTarget — rerenders all messages when user switches agent
    document.getElementById('leftTargetWrap').addEventListener('change', rerenderAll);

    // ========== Phase 6: Dynamic Sidebar ==========
    const SB_COLORS = ['#C15F3C','#2B7FD4','#6B9F5B','#D4A14E','#9B6BC1','#E07B53','#4A90D9','#7CB342'];
    const sbStarredList = document.getElementById('sbStarredList');
    const sbProjectList = document.getElementById('sbProjectList');
    const sbActivityList = document.getElementById('sbActivityList');

    function relativeTime(ts) {
      if (!ts) return '';
      const diff = (Date.now() - new Date(ts).getTime()) / 1000;
      if (diff < 60) return 'now';
      if (diff < 3600) return Math.floor(diff/60) + 'm';
      if (diff < 86400) return Math.floor(diff/3600) + 'h';
      if (diff < 604800) return Math.floor(diff/86400) + 'd';
      return Math.floor(diff/604800) + 'w';
    }

    function renderSbItem(name, color, agentDots, meta, isActive) {
      const div = document.createElement('div');
      div.className = 'sbItem' + (isActive ? ' active' : '');
      div.setAttribute('role', 'button');
      div.setAttribute('tabindex', '0');
      div.setAttribute('aria-label', name);
      div.innerHTML =
        '<span class="sbDot" style="background:' + color + '"></span>' +
        '<span class="sbName">' + name + '</span>' +
        (agentDots ? '<span class="sbAgents">' + agentDots + '</span>' : '') +
        (meta ? '<span class="sbMeta">' + meta + '</span>' : '');
      return div;
    }

    // FE14/FE28: Sidebar-Filter — Projekt/Team-Auswahl filtert BEIDE Panels
    let sidebarProjectFilter = null; // project name or null
    let expandedSidebarProjects = new Set(); // which projects are expanded

    function selectSidebarProject(projectName){
      if(sidebarProjectFilter === projectName) {
        sidebarProjectFilter = null; // Deselect
      } else {
        sidebarProjectFilter = projectName;
        expandedSidebarProjects.add(projectName);
      }
      // Update Team Board: auto-select first team of project
      if(sidebarProjectFilter && boardProjectsCache){
        const proj = boardProjectsCache.find(p => p.name === sidebarProjectFilter);
        if(proj && proj.teams && proj.teams.length > 0){
          selectedTeam = {project: proj.name, team: proj.teams[0].name};
        }
      } else {
        selectedTeam = null;
      }
      renderTeamTabs();
      updateRightDropdownForTeam();
      updateProjectBadge();
      renderSidebarProjects();
      rerenderAll();
    }

    function selectSidebarTeam(projectName, teamName){
      sidebarProjectFilter = projectName;
      selectedTeam = {project: projectName, team: teamName};
      renderTeamTabs();
      updateRightDropdownForTeam();
      renderSidebarProjects();
      rerenderAll();
    }

    function renderSidebarProjects(){
      // Starred: show selected project (or first project)
      sbStarredList.innerHTML = '';
      if(boardProjectsCache && boardProjectsCache.length > 0){
        const starred = sidebarProjectFilter
          ? boardProjectsCache.find(p => p.name === sidebarProjectFilter) || boardProjectsCache[0]
          : boardProjectsCache[0];
        const totalMembers = (starred.teams || []).reduce((n, t) => n + (t.members || []).length, 0);
        const onlineCount = (starred.teams || []).reduce((n, t) =>
          n + (t.members || []).filter(m => getAgentStatus(m.id || m) === 'active').length, 0);
        const item = renderSbItem(starred.name, SB_COLORS[0], '', onlineCount + '/' + totalMembers, !!sidebarProjectFilter);
        item.addEventListener('click', () => selectSidebarProject(starred.name));
        sbStarredList.appendChild(item);
      }

      // Projects: all from boardProjectsCache with expandable teams
      sbProjectList.innerHTML = '';
      if(boardProjectsCache){
        boardProjectsCache.forEach((p, i) => {
          const color = SB_COLORS[(i + 1) % SB_COLORS.length];
          const isSelected = sidebarProjectFilter === p.name;
          const isExpanded = expandedSidebarProjects.has(p.name);

          // Project row
          const item = document.createElement('div');
          item.className = 'sbItem sbItem--project' + (isSelected ? ' sbItem--selected' : '');
          item.setAttribute('role', 'button');
          item.setAttribute('tabindex', '0');
          const expandSvg = '<svg class="sbExpandIcon' + (isExpanded ? ' sbExpandIcon--open' : '') +
            '" viewBox="0 0 24 24"><polyline points="9,6 15,12 9,18"/></svg>';
          item.innerHTML = expandSvg +
            '<span class="sbDot" style="background:' + color + '"></span>' +
            '<span class="sbName">' + p.name + '</span>' +
            '<span class="sbMeta">' + (p.teams || []).length + ' Teams</span>';
          item.addEventListener('click', () => selectSidebarProject(p.name));
          sbProjectList.appendChild(item);

          // Teams (expandable)
          if(isExpanded && p.teams){
            const teamsDiv = document.createElement('div');
            teamsDiv.className = 'sbTeams';
            p.teams.forEach(t => {
              const members = (t.members || []).map(m => m.id || m);
              const online = members.filter(m => getAgentStatus(m) === 'active').length;
              const isTeamActive = selectedTeam && selectedTeam.project === p.name && selectedTeam.team === t.name;
              const teamEl = document.createElement('div');
              teamEl.className = 'sbTeamItem' + (isTeamActive ? ' sbTeamItem--active' : '');
              teamEl.innerHTML = t.name + ' <span class="sbTeamItem__count">' + online + '/' + members.length + '</span>';
              teamEl.addEventListener('click', (e) => {
                e.stopPropagation();
                selectSidebarTeam(p.name, t.name);
              });
              teamsDiv.appendChild(teamEl);
            });
            sbProjectList.appendChild(teamsDiv);
          }
        });
      }
    }

    async function loadSidebarProjects() {
      try {
        // Ensure boardProjectsCache is fresh
        await fetchBoardProjects();
        renderSidebarProjects();

        // Activity: show agent activities
        sbActivityList.innerHTML = '';
        try {
          const actRes = await fetch(API_BASE + '/activity');
          const actData = await actRes.json();
          if (actData.activities && actData.activities.length > 0) {
            actData.activities.slice(0, 5).forEach(act => {
              const div = document.createElement('div');
              div.className = 'sbActivity';
              div.innerHTML = '<svg viewBox="0 0 24 24"><polyline points="9,18 15,12 9,6"/></svg>' +
                agentLabel(act.agent_id || '') + ': ' + (act.action || '') + (act.description ? ' — ' + act.description : '');
              sbActivityList.appendChild(div);
            });
          } else {
            sbActivityList.innerHTML = '<div class="sbActivity" style="opacity:0.5">Keine Aktivitaet</div>';
          }
        } catch(e) {
          sbActivityList.innerHTML = '<div class="sbActivity" style="opacity:0.5">Keine Aktivitaet</div>';
        }
      } catch(e) {
        console.error('Sidebar load failed:', e);
        sbStarredList.innerHTML = '<div class="sbActivity" style="opacity:0.5">Projekte konnten nicht geladen werden</div>';
      }
    }

    // ========== Init ==========
    clearStaticMessages();
    createConnectionDot();
    // Load agents first so dropdown is populated, then load history
    fetchChatActivities();
    pollAgentStatus().then(() => loadHistory());
    connectWebSocket();
    loadSidebarProjects();
    fetchBoardProjects().then(updateProjectBadge);
    // Task 4: Fetch orgchart for deactivated-agent info
    (async()=>{ try { const r = await fetch(API_BASE+'/team/orgchart'); if(r.ok){ const d = await r.json(); d.agents.forEach(a=>{orgchartAgentMap[a.id]=a;}); } } catch(e){} })();
    setInterval(pollAgentStatus, BRIDGE_CONFIG.pollInterval);
    setInterval(fetchChatActivities, BRIDGE_CONFIG.pollInterval);
    setInterval(loadSidebarProjects, 30000);
    setInterval(fetchBoardProjects, 30000);

    // Update badge when left dropdown changes
    document.getElementById('leftTargetWrap').addEventListener('change', updateProjectBadge);

    // --- Resize Logik ---
    const sidebarEdge = document.getElementById('sidebarEdge');
    const mainDivider = document.getElementById('mainDivider');
    const sidebarToggle = document.getElementById('sidebarToggle');

    let sw = 14;  // Sidebar-Breite in %
    let dp = 57;  // Divider-Position in %
    let sidebarCollapsed = false;

    function setVars(){
      root.style.setProperty('--sw', sw + '%');
      root.style.setProperty('--dp', dp + '%');
    }

    // Clamp helper
    function clamp(val, min, max){ return Math.min(Math.max(val, min), max); }

    // Generischer Drag-Handler
    function makeDraggable(handle, onDrag, activeClass){
      handle.addEventListener('mousedown', e => {
        e.preventDefault();
        handle.classList.add('active');
        root.classList.add('dragging');
        const onMove = ev => onDrag(ev.clientX / window.innerWidth * 100);
        const onUp = () => {
          handle.classList.remove('active');
          root.classList.remove('dragging');
          window.removeEventListener('mousemove', onMove);
          window.removeEventListener('mouseup', onUp);
        };
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
      });
    }

    // Sidebar-Edge: Sidebar-Breite aendern
    makeDraggable(sidebarEdge, pct => {
      sw = clamp(pct, 4, 30);
      // dp muss rechts von sw bleiben, mindestens sw+10
      dp = clamp(dp, sw + 10, 95);
      sidebarCollapsed = sw <= 5;
      root.classList.toggle('collapsed', sidebarCollapsed);
      setVars();
    });

    // Main-Divider: Divider-Position aendern
    makeDraggable(mainDivider, pct => {
      dp = clamp(pct, sw + 10, 95);
      setVars();
    });

    // Sidebar Collapse Toggle
    sidebarToggle.addEventListener('click', () => {
      sidebarCollapsed = !sidebarCollapsed;
      if(sidebarCollapsed){
        sw = 4;
        dp = clamp(dp, 14, 95);
      } else {
        sw = 14;
        dp = clamp(dp, 24, 95);
      }
      root.classList.toggle('collapsed', sidebarCollapsed);
      sidebarToggle.setAttribute('aria-expanded', !sidebarCollapsed);
      setVars();
    });
    // ═══════ Sidebar Activity Resize Handle ═══════
    (function(){
      const handle = document.getElementById('sbResizeHandle');
      const topPane = document.getElementById('sbTopPane');
      const bottomPane = document.getElementById('sbBottomPane');
      if(!handle || !topPane || !bottomPane) return;

      // Restore saved height
      const saved = localStorage.getItem('bridge_sbActivityH');
      if(saved) bottomPane.style.height = saved + 'px';
      else bottomPane.style.height = '180px';

      handle.addEventListener('mousedown', e => {
        e.preventDefault();
        handle.classList.add('active');
        root.classList.add('dragging-row');
        const startY = e.clientY;
        const startH = bottomPane.offsetHeight;
        const inner = topPane.parentElement;
        const maxH = inner.clientHeight - 80;

        const onMove = ev => {
          const delta = startY - ev.clientY;
          const newH = clamp(startH + delta, 60, maxH);
          bottomPane.style.height = newH + 'px';
        };
        const onUp = () => {
          handle.classList.remove('active');
          root.classList.remove('dragging-row');
          localStorage.setItem('bridge_sbActivityH', bottomPane.offsetHeight);
          window.removeEventListener('mousemove', onMove);
          window.removeEventListener('mouseup', onUp);
        };
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
      });
    })();

    // ═══════ APPROVAL GATE ═══════
    const ACTION_LABELS = {
      email_send:    { text:'Email senden',           icon:'📧' },
      email_delete:  { text:'Email loeschen',         icon:'🗑️' },
      phone_call:    { text:'Anrufen',                icon:'📞' },
      smart_home:    { text:'Smart Home steuern',     icon:'🏠' },
      slack_send:    { text:'Slack-Nachricht senden', icon:'💬' },
      whatsapp_send: { text:'WhatsApp senden',        icon:'📱' },
      file_delete:   { text:'Datei loeschen',         icon:'🗑️' },
      trade_execute: { text:'Trade ausfuehren',       icon:'📈' },
      payment:       { text:'Zahlung ausloesen',      icon:'💳' },
      browser_login: { text:'Website-Login',          icon:'🔑' },
    };
    const EDITABLE_ACTIONS = ['email_send', 'slack_send', 'whatsapp_send'];
    const approvalPending = new Map(); // request_id → data
    const approvalHistory = [];
    let approvalToastTimeout = null;
    let approvalTimerInterval = null;
    let currentToastRequestId = null;

    function getActionLabel(action){ return ACTION_LABELS[action] || { text:action, icon:'⚡' }; }

    function formatCountdown(expiresAt){
      const diff = Math.max(0, Math.floor((new Date(expiresAt) - Date.now()) / 1000));
      const m = Math.floor(diff/60), s = diff%60;
      return m + ':' + String(s).padStart(2,'0');
    }

    // Badge
    function updateApprovalBadge(){
      const countEl = document.getElementById('approvalCount');
      const badge = document.getElementById('approvalBadge');
      const n = approvalPending.size;
      countEl.textContent = n;
      countEl.style.display = n > 0 ? 'flex' : 'none';
      let hasHigh = false;
      approvalPending.forEach(r => { if(r.risk_level === 'high') hasHigh = true; });
      badge.classList.toggle('approvalBadge--pulse', hasHigh);
    }

    // Toast
    function showApprovalToast(data){
      approvalPending.set(data.request_id, data);
      const toast = document.getElementById('approvalToast');
      const label = getActionLabel(data.action);
      document.getElementById('approvalToastTitle').textContent = label.icon + ' ' + label.text;
      document.getElementById('approvalToastDesc').textContent = (data.agent_id || 'Agent') + ': ' + (data.description || data.target || '');
      document.getElementById('approvalToastTimer').textContent = formatCountdown(data.expires_at);
      toast.className = 'approvalToast approvalToast--' + (data.risk_level || 'low') + ' approvalToast--visible';
      currentToastRequestId = data.request_id;

      clearTimeout(approvalToastTimeout);
      clearInterval(approvalTimerInterval);
      approvalTimerInterval = setInterval(() => {
        const el = document.getElementById('approvalToastTimer');
        if(el) el.textContent = formatCountdown(data.expires_at);
      }, 1000);
      approvalToastTimeout = setTimeout(hideApprovalToast, 10000);

      // Update badge + panel
      updateApprovalBadge();
      renderApprovalList();
    }

    function hideApprovalToast(){
      document.getElementById('approvalToast').classList.remove('approvalToast--visible');
      clearInterval(approvalTimerInterval);
      currentToastRequestId = null;
    }

    // Panel
    function toggleApprovalPanel(){
      const panel = document.getElementById('approvalPanel');
      const isOpen = panel.classList.toggle('approvalPanel--open');
      if(isOpen) loadPendingApprovals();
    }

    async function loadPendingApprovals(){
      try {
        const res = await fetch(API_BASE + '/approval/pending');
        if(!res.ok){ renderApprovalList(); return; }
        const json = await res.json();
        const items = json.pending || json.requests || [];
        if(items.length > 0){
          items.forEach(r => approvalPending.set(r.request_id, r));
        }
        updateApprovalBadge();
      } catch(e){}
      renderApprovalList();
    }

    function renderApprovalList(){
      const list = document.getElementById('approvalList');
      const countEl = document.getElementById('panelCount');
      if(approvalPending.size === 0){
        list.innerHTML = '<div class="approvalPanel__empty">Keine offenen Genehmigungen</div>';
        countEl.textContent = '0 offen';
        return;
      }
      countEl.textContent = approvalPending.size + ' offen';
      let html = '';
      approvalPending.forEach((r, id) => {
        const label = getActionLabel(r.action);
        const countdown = formatCountdown(r.expires_at);
        const isUrgent = (new Date(r.expires_at) - Date.now()) < 60000;
        html += '<div class="approvalCard approvalCard--'+(r.risk_level||'low')+'" data-id="'+id+'">'
          + '<div class="approvalCard__risk"></div>'
          + '<div class="approvalCard__header">'
          +   '<span class="approvalCard__icon">'+label.icon+'</span>'
          +   '<span class="approvalCard__action">'+label.text+'</span>'
          +   '<span class="approvalCard__timer'+(isUrgent?' approvalCard__timer--urgent':'')+'">'+countdown+'</span>'
          + '</div>'
          + '<div class="approvalCard__body">'
          +   '<p class="approvalCard__who">'+(r.agent_id||'Agent')+' will '+label.text.toLowerCase()+'</p>'
          +   (r.target ? '<p style="margin:2px 0;opacity:.7">An: '+r.target+'</p>' : '');
        const isEditable = EDITABLE_ACTIONS.includes(r.action) && r.payload;
        if(isEditable){
          const subj = r.payload.subject || '';
          const body = r.payload.body || r.payload.message || '';
          if(subj){
            html += '<label class="approvalCard__label">Betreff</label>'
              + '<input class="approvalCard__editField" id="edit-subject-'+id+'" type="text" value="'+subj.replace(/"/g,'&quot;')+'" data-original="'+subj.replace(/"/g,'&quot;')+'" />';
          }
          if(body){
            html += '<label class="approvalCard__label">Inhalt</label>'
              + '<textarea class="approvalCard__editField approvalCard__editField--body" id="edit-body-'+id+'" rows="5" data-original="'+body.replace(/"/g,'&quot;')+'">'+body.replace(/</g,'&lt;')+'</textarea>';
          }
        } else {
          html += (r.description ? '<div class="approvalCard__preview">'+r.description+'</div>' : '');
        }
        html += '</div>'
          + '<div class="approvalCard__buttons">'
          +   '<button class="approvalCard__btn approvalCard__btn--approve" id="btn-approve-'+id+'" onclick="respondApproval(\''+id+'\',\'approved\')">Genehmigen</button>'
          +   '<button class="approvalCard__btn approvalCard__btn--deny" onclick="respondApproval(\''+id+'\',\'denied\')">Ablehnen</button>'
          + '</div></div>';
      });
      list.innerHTML = html;
      // Bind edit listeners for editable cards
      approvalPending.forEach((r, id) => {
        if(EDITABLE_ACTIONS.includes(r.action) && r.payload) bindEditListeners(id);
      });
    }

    function checkEdited(requestId){
      const subjectEl = document.getElementById('edit-subject-'+requestId);
      const bodyEl = document.getElementById('edit-body-'+requestId);
      const btn = document.getElementById('btn-approve-'+requestId);
      if(!btn) return;
      const subjectChanged = subjectEl && subjectEl.value !== subjectEl.dataset.original;
      const bodyChanged = bodyEl && bodyEl.value !== bodyEl.dataset.original;
      if(subjectChanged || bodyChanged){
        btn.textContent = 'Als editiert senden';
        btn.classList.add('edited');
      } else {
        btn.textContent = 'Genehmigen';
        btn.classList.remove('edited');
      }
    }

    function bindEditListeners(requestId){
      const subjectEl = document.getElementById('edit-subject-'+requestId);
      const bodyEl = document.getElementById('edit-body-'+requestId);
      if(subjectEl) subjectEl.addEventListener('input', () => checkEdited(requestId));
      if(bodyEl) bodyEl.addEventListener('input', () => checkEdited(requestId));
    }

    // Respond (with optional edit step)
    async function respondApproval(requestId, decision){
      try {
        // Step 1: If fields were edited, call edit endpoint first
        if(decision === 'approved'){
          const subjectEl = document.getElementById('edit-subject-'+requestId);
          const bodyEl = document.getElementById('edit-body-'+requestId);
          const subjectChanged = subjectEl && subjectEl.value !== subjectEl.dataset.original;
          const bodyChanged = bodyEl && bodyEl.value !== bodyEl.dataset.original;
          if(subjectChanged || bodyChanged){
            const editPayload = { decided_by:'user', payload:{} };
            if(subjectChanged) editPayload.payload.subject = subjectEl.value;
            if(bodyChanged) editPayload.payload.body = bodyEl.value;
            const editRes = await fetch(API_BASE + '/approval/'+requestId+'/edit', {
              method:'POST', headers:{'Content-Type':'application/json'},
              body: JSON.stringify(editPayload)
            });
            if(!editRes.ok){
              showApprovalFeedback('error');
              return;
            }
          }
        }
        // Step 2: Send approval/denial
        await fetch(API_BASE + '/approval/respond', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ request_id: requestId, decision: decision, decided_by:'user' })
        });
      } catch(e){}
      approvalHistory.unshift({ request_id:requestId, decision, time:new Date().toLocaleTimeString('de',{hour:'2-digit',minute:'2-digit'}), data:approvalPending.get(requestId) });
      if(approvalHistory.length > 10) approvalHistory.pop();
      approvalPending.delete(requestId);
      if(currentToastRequestId === requestId) hideApprovalToast();
      updateApprovalBadge();
      renderApprovalList();
      renderApprovalHistory();
      showApprovalFeedback(decision);
    }

    function removeApprovalCard(data){
      if(data && data.request_id) approvalPending.delete(data.request_id);
      renderApprovalList();
    }

    // History
    function renderApprovalHistory(){
      const el = document.getElementById('approvalHistory');
      if(!approvalHistory.length){ el.innerHTML = '<div style="font-size:11px;color:#888">Noch keine Entscheidungen</div>'; return; }
      el.innerHTML = approvalHistory.map(h => {
        const icon = h.decision === 'approved' ? '✅' : h.decision === 'denied' ? '❌' : '⏱';
        const label = h.data ? getActionLabel(h.data.action).text : '';
        const agent = h.data ? h.data.agent_id : '';
        return '<div class="approvalHistory__item">'+icon+' <span>'+h.time+'</span> <span>'+agent+': '+label+'</span></div>';
      }).join('');
    }

    // Feedback
    function showApprovalFeedback(decision){
      const el = document.getElementById('approvalFeedback');
      const texts = { approved:'Genehmigt — wird ausgefuehrt', denied:'Abgelehnt — Agent informiert', expired:'Abgelaufen — nicht ausgefuehrt', error:'Aenderung konnte nicht gespeichert werden' };
      const icons = { approved:'✅ ', denied:'❌ ', expired:'⏱ ', error:'⚠️ ' };
      el.textContent = (icons[decision]||'') + (texts[decision] || decision);
      el.className = 'approvalFeedback approvalFeedback--' + decision + ' approvalFeedback--visible';
      setTimeout(() => el.classList.remove('approvalFeedback--visible'), 2000);
    }

    // Event Listeners
    document.getElementById('approvalBadge').addEventListener('click', toggleApprovalPanel);
    document.getElementById('panelClose').addEventListener('click', toggleApprovalPanel);
    document.getElementById('toastApprove').addEventListener('click', () => { if(currentToastRequestId) respondApproval(currentToastRequestId, 'approved'); });
    document.getElementById('toastDeny').addEventListener('click', () => { if(currentToastRequestId) respondApproval(currentToastRequestId, 'denied'); });
    document.getElementById('toastDetails').addEventListener('click', () => { hideApprovalToast(); toggleApprovalPanel(); });

    // Panel timer refresh
    setInterval(() => {
      if(document.getElementById('approvalPanel').classList.contains('approvalPanel--open')){
        // Update timers in-place instead of full re-render to preserve edit state
        approvalPending.forEach((r, id) => {
          const timerEl = document.querySelector('.approvalCard[data-id="'+id+'"] .approvalCard__timer');
          if(timerEl){
            timerEl.textContent = formatCountdown(r.expires_at);
            const isUrgent = (new Date(r.expires_at) - Date.now()) < 60000;
            timerEl.classList.toggle('approvalCard__timer--urgent', isUrgent);
          }
        });
      }
      // Expire check
      const now = Date.now();
      approvalPending.forEach((r, id) => {
        if(new Date(r.expires_at) < now){
          approvalHistory.unshift({ request_id:id, decision:'expired', time:new Date().toLocaleTimeString('de',{hour:'2-digit',minute:'2-digit'}), data:r });
          approvalPending.delete(id);
          updateApprovalBadge();
          renderApprovalList();
          renderApprovalHistory();
          showApprovalFeedback('expired');
        }
      });
    }, 5000);

    // Initial load
    renderApprovalHistory();

    // Task 4: Deactivated agent cache from orgchart
    let orgchartAgentMap = {}; // agentId → {active, ...}

    // ========== W1-W3: Teams Panel ==========
    const teamsPanel = document.getElementById('teamsPanel');
    const teamsPanelBody = document.getElementById('teamsPanelBody');
    const teamsPanelTitle = document.getElementById('teamsPanelTitle');
    const teamsPanelBack = document.getElementById('teamsPanelBack');
    const teamsPanelAdd = document.getElementById('teamsPanelAdd');
    document.getElementById('teamsPanelClose').addEventListener('click', () => {
      teamsPanel.classList.remove('teamsPanel--open');
    });
    teamsPanelBack.addEventListener('click', () => {
      teamsPanelBack.style.display = 'none';
      teamsPanelAdd.style.display = '';
      teamsPanelTitle.textContent = 'Meine Teams';
      fetchTeamsDashboard();
    });
    teamsPanelAdd.addEventListener('click', () => {
      // F1: Team-Wizard Modal oeffnen (statt Redirect)
      openTeamWizardModal();
    });

    let teamsCache = [];

    function toggleTeamsPanel(){
      const isOpen = teamsPanel.classList.toggle('teamsPanel--open');
      // Close org panel if open
      if(isOpen) {
        document.getElementById('orgPanel').classList.remove('orgPanel--open');
        teamsPanelBack.style.display = 'none';
        teamsPanelAdd.style.display = '';
        teamsPanelTitle.textContent = 'Meine Teams';
        fetchTeamsDashboard();
      }
    }

    // W1: Teams Dashboard
    async function fetchTeamsDashboard(){
      try {
        const res = await fetch(API_BASE + '/teams');
        if(!res.ok) return;
        const data = await res.json();
        teamsCache = data.teams || [];
        renderTeamsDashboard(teamsCache);
      } catch(e){ teamsPanelBody.innerHTML = '<div style="padding:20px;text-align:center;color:#999;font-size:12px">Teams konnten nicht geladen werden.</div>'; }
    }

    function teamStatusDot(team){
      const online = team.online_count || 0;
      const total = team.member_count || 0;
      if(online === 0) return 'red';
      if(online < total) return 'yellow';
      return 'green';
    }

    function renderTeamsDashboard(teams){
      let html = '';
      teams.forEach(t => {
        const dot = teamStatusDot(t);
        const online = t.online_count || 0;
        const total = t.member_count || 0;
        const lastAct = t.last_activity ? t.last_activity.description : '';
        const leadName = t.lead ? (t.lead.charAt(0).toUpperCase() + t.lead.slice(1)) : '';
        html += '<div class="teamCard" data-team-id="' + t.id + '">'
          + '<div class="teamCard__top">'
          + '<span class="teamCard__dot teamCard__dot--' + dot + '"></span>'
          + '<span class="teamCard__name">' + (t.name || t.id).replace(/</g,'&lt;') + '</span>'
          + '<span class="teamCard__count">' + online + '/' + total + ' online</span>'
          + '</div>'
          + '<div class="teamCard__lead">Leiter: ' + leadName + '</div>'
          + (lastAct ? '<div class="teamCard__activity">' + lastAct.replace(/</g,'&lt;') + '</div>' : '')
          + (t.scope ? '<div class="teamCard__scope">' + t.scope.replace(/</g,'&lt;') + '</div>' : '')
          + '</div>';
      });
      if(teams.length === 0){
        html = '<div style="padding:30px 10px;text-align:center;color:#999;font-size:12px">Keine Teams vorhanden.<br>Erstelle ein Team mit \"+ Neues Team\".</div>';
      }
      teamsPanelBody.innerHTML = html;

      // Bind click → W2 detail
      teamsPanelBody.querySelectorAll('.teamCard').forEach(card => {
        card.addEventListener('click', () => {
          fetchTeamDetail(card.dataset.teamId);
        });
      });
    }

    // W2: Team Detail
    async function fetchTeamDetail(teamId){
      teamsPanelTitle.textContent = 'Laden...';
      teamsPanelBack.style.display = '';
      teamsPanelAdd.style.display = 'none';
      try {
        const res = await fetch(API_BASE + '/teams/' + teamId);
        if(!res.ok){ teamsPanelBody.innerHTML = '<div style="padding:20px;color:#ef4444;font-size:12px">Fehler beim Laden.</div>'; return; }
        const team = await res.json();
        teamsPanelTitle.textContent = team.name || team.id;
        renderTeamDetail(team);
      } catch(e){ teamsPanelBody.innerHTML = '<div style="padding:20px;color:#ef4444;font-size:12px">Netzwerkfehler.</div>'; }
    }

    let _tdCurrentTeam = null;
    let _tdActiveTab = 'members';

    function renderTeamDetail(team){
      _tdCurrentTeam = team;
      _tdActiveTab = 'members';

      const tabsHtml = '<div class="tdTabs">'
        + '<div class="tdTab tdTab--active" data-tab="members">Mitglieder</div>'
        + '<div class="tdTab" data-tab="tasks">Aufgaben</div>'
        + '</div>';

      teamsPanelBody.innerHTML = tabsHtml + '<div id="tdTabContent"></div>';

      // Bind tab clicks
      teamsPanelBody.querySelectorAll('.tdTab').forEach(tab => {
        tab.addEventListener('click', () => {
          _tdActiveTab = tab.dataset.tab;
          teamsPanelBody.querySelectorAll('.tdTab').forEach(t => t.classList.toggle('tdTab--active', t.dataset.tab === _tdActiveTab));
          if(_tdActiveTab === 'members') renderTeamMembers(team);
          else fetchTeamTasks(team.id, team);
        });
      });

      renderTeamMembers(team);
    }

    function renderTeamMembers(team){
      const members = team.members || [];
      let membersHtml = '';
      members.forEach(m => {
        const st = m.status || 'disconnected';
        const si = statusInfo(st);
        const activity = m.activity ? m.activity.description : '';
        const roleLbl = m.role ? (m.role.charAt(0).toUpperCase() + m.role.slice(1)) : '';
        // V2 AUFGABE 3: Check active status from agentStatusCache
        const agentInfo = agentStatusCache.find(a => a.agent_id === (m.id || m.name));
        const isActive = agentInfo ? agentInfo.active !== false : (st !== 'disconnected');
        const pausedClass = isActive ? '' : ' teamDetail__member--paused';
        const dotColor = isActive ? si.color : '#94a3b8';
        const toggleClass = isActive ? '' : ' atToggle--off';
        const toggleLabel = isActive ? 'Aktiv' : 'Pausiert';
        const agentId = (m.id || m.name).replace(/</g,'&lt;');
        const agentName = (m.name || m.id).replace(/</g,'&lt;');
        membersHtml += '<div class="teamDetail__member' + pausedClass + '" data-agent-id="' + agentId + '">'
          + '<span class="teamDetail__memberDot" style="background:' + dotColor + '"></span>'
          + '<div class="teamDetail__memberInfo">'
          + '<div class="teamDetail__memberName">' + agentName + '</div>'
          + '<div class="teamDetail__memberRole">' + roleLbl + '</div>'
          + (activity ? '<div class="teamDetail__memberActivity">' + activity.replace(/</g,'&lt;') + '</div>' : '')
          + '</div>'
          + (m.is_lead ? '<span class="teamDetail__badge">Lead</span>' : '')
          + '<div class="atToggleWrap">'
          + '<div class="atToggle' + toggleClass + '" data-agent-id="' + agentId + '" data-active="' + isActive + '" data-agent-name="' + agentName + '">'
          + '<div class="atToggle__track"></div>'
          + '<div class="atToggle__thumb"></div>'
          + '</div>'
          + '<span class="atToggle__label">' + toggleLabel + '</span>'
          + '</div>'
          + '</div>';
      });

      // Scope tags
      let scopeHtml = '';
      if(team.scope){
        team.scope.split(',').forEach(s => {
          const tag = s.trim();
          if(tag) scopeHtml += '<span class="teamDetail__scopeTag">' + tag.replace(/</g,'&lt;') + '</span>';
        });
      }

      let html = '<div class="teamDetail__section">'
        + '<div class="teamDetail__sectionTitle">Team-Mitglieder (' + members.length + ')</div>'
        + membersHtml
        + '</div>';

      if(scopeHtml){
        html += '<div class="teamDetail__section">'
          + '<div class="teamDetail__sectionTitle">Scope</div>'
          + scopeHtml
          + '</div>';
      }

      document.getElementById('tdTabContent').innerHTML = html;

      // V2 AUFGABE 3: Bind toggle click handlers
      document.querySelectorAll('.atToggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const aid = toggle.dataset.agentId;
          const currentActive = toggle.dataset.active === 'true';
          const name = toggle.dataset.agentName;
          showAgentToggleConfirm(aid, currentActive, name, team);
        });
      });
    }

    // ========== V2 AUFGABE 3: Agent Toggle Functions ==========
    function showAgentToggleConfirm(agentId, currentActive, agentName, team){
      const action = currentActive ? 'pausiert' : 'aktiviert';
      const msg = currentActive
        ? 'Soll <strong>' + agentName + '</strong> pausiert werden?'
        : 'Soll <strong>' + agentName + '</strong> wieder aktiviert werden?';
      const btnClass = currentActive ? 'atConfirmBtn--danger' : 'atConfirmBtn--success';
      const btnLabel = currentActive ? 'Pausieren' : 'Aktivieren';

      const overlay = document.createElement('div');
      overlay.className = 'atConfirmOverlay';
      overlay.innerHTML = '<div class="atConfirmBox">'
        + '<div class="atConfirmMsg">' + msg + '</div>'
        + '<div class="atConfirmActions">'
        + '<button class="atConfirmBtn" id="atConfirmNo">Abbrechen</button>'
        + '<button class="atConfirmBtn ' + btnClass + '" id="atConfirmYes">' + btnLabel + '</button>'
        + '</div></div>';
      document.body.appendChild(overlay);

      const close = () => { if(overlay.parentNode) overlay.remove(); };

      overlay.querySelector('#atConfirmNo').addEventListener('click', close);
      overlay.addEventListener('click', e => { if(e.target === overlay) close(); });
      document.addEventListener('keydown', function escHandler(e){
        if(e.key === 'Escape'){ close(); document.removeEventListener('keydown', escHandler); }
      });

      overlay.querySelector('#atConfirmYes').addEventListener('click', async () => {
        const btn = overlay.querySelector('#atConfirmYes');
        btn.disabled = true;
        btn.textContent = 'Bitte warten...';
        try {
          const newActive = !currentActive;
          const res = await fetch(API_BASE + '/agents/' + encodeURIComponent(agentId) + '/active', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ active: newActive })
          });
          if(!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          close();
          // Toast
          const toastIcon = newActive ? '\u2705' : '\u23F8\uFE0F';
          const toastMsg = newActive
            ? (agentName + ' ist wieder aktiv')
            : (agentName + ' wurde pausiert');
          if(typeof showTaskToast === 'function') showTaskToast({icon: toastIcon, title: toastMsg, desc:'', type: newActive ? 'success' : 'info', duration:4000});
          // Refresh team detail to update UI
          if(_tdCurrentTeam && _tdCurrentTeam.id){
            fetchTeamDetail(_tdCurrentTeam.id);
          }
        } catch(e) {
          btn.disabled = false;
          btn.textContent = btnLabel;
          const errDiv = overlay.querySelector('.atConfirmMsg');
          errDiv.innerHTML += '<div style="color:#ef4444;font-size:11px;margin-top:8px">Fehler: ' + (e.message || 'Unbekannt').replace(/</g,'&lt;') + '</div>';
        }
      });
    }

    // ========== V2 W4: Task-Board ==========
    const TASK_STATE_MAP = {
      created:  { color:'#94a3b8', label:'Offen',          cssClass:'gray',   icon:'\u2B1C' },
      claimed:  { color:'#3b82f6', label:'In Arbeit',      cssClass:'blue',   icon:'\uD83D\uDD04' },
      acked:    { color:'#3b82f6', label:'In Arbeit',      cssClass:'blue',   icon:'\uD83D\uDD04' },
      done:     { color:'#22c55e', label:'Fertig',          cssClass:'green',  icon:'\u2705' },
      partial:  { color:'#f59e0b', label:'Teilweise',       cssClass:'yellow', icon:'\u{1F7E1}' },
      failed:   { color:'#ef4444', label:'Fehlgeschlagen',  cssClass:'red',    icon:'\u274C' }
    };

    function taskStateInfo(task){
      if(task.state === 'done' && task.result_code === 'partial') return TASK_STATE_MAP.partial;
      if(task.state === 'done') return TASK_STATE_MAP.done;
      return TASK_STATE_MAP[task.state] || TASK_STATE_MAP.created;
    }

    function tkRelativeTime(isoStr){
      if(!isoStr) return '';
      const diff = Date.now() - new Date(isoStr).getTime();
      const mins = Math.floor(diff / 60000);
      if(mins < 1) return 'gerade eben';
      if(mins < 60) return 'vor ' + mins + ' Min';
      const hours = Math.floor(mins / 60);
      if(hours < 24) return 'vor ' + hours + 'h';
      const days = Math.floor(hours / 24);
      return 'vor ' + days + 'd';
    }

    async function fetchTeamTasks(teamId, team){
      const content = document.getElementById('tdTabContent');
      if(!content) return;
      content.innerHTML = '<div style="padding:20px;text-align:center;color:#999;font-size:11px">Aufgaben laden...</div>';
      try {
        const res = await fetch(API_BASE + '/task/queue?team=' + encodeURIComponent(teamId));
        if(!res.ok){ content.innerHTML = '<div style="padding:16px;color:#ef4444;font-size:11px">Fehler beim Laden der Aufgaben.</div>'; return; }
        const data = await res.json();
        renderTaskBoard(data.tasks || [], team || _tdCurrentTeam);
      } catch(e){
        content.innerHTML = '<div style="padding:16px;color:#ef4444;font-size:11px">Netzwerkfehler.</div>';
      }
    }

    function renderTaskBoard(tasks, team){
      const content = document.getElementById('tdTabContent');
      if(!content) return;

      // A8: Populate title cache for WebSocket toasts
      tasks.forEach(t => { if(t.task_id && t.title) _taskTitleCache[t.task_id] = t.title; });

      // Categorize tasks into columns
      const inProgress = tasks.filter(t => t.state === 'claimed' || t.state === 'acked');
      const open = tasks.filter(t => t.state === 'created');
      const completed = tasks.filter(t => t.state === 'done' || t.state === 'failed');

      function renderCard(task){
        const si = taskStateInfo(task);
        const title = (task.title || task.payload?.description || 'Ohne Titel').replace(/</g,'&lt;');
        const agentId = task.assigned_to;
        const agentName = agentId ? agentLabel(agentId) : 'Noch nicht zugewiesen';
        const agentSt = agentId && orgchartAgentMap[agentId] ? orgchartAgentMap[agentId].status : 'disconnected';
        const agentDotColor = agentSt === 'running' ? '#22c55e' : agentSt === 'waiting' ? '#f59e0b' : '#94a3b8';
        const time = tkRelativeTime(task.created_at);
        const files = task.payload?.files;
        const priority = task.priority || 1;

        let cardHtml = '<div class="tkCard tkCard--' + si.cssClass + '">'
          + '<div class="tkCard__title">' + title + '</div>'
          + '<div class="tkCard__row">';

        if(agentId){
          cardHtml += '<span class="tkCard__dot" style="background:' + agentDotColor + '"></span>'
            + '<span class="tkCard__agent">' + agentName.replace(/</g,'&lt;') + '</span>';
        } else {
          cardHtml += '<span class="tkCard__agent" style="color:#bbb">' + agentName + '</span>';
        }

        if(time) cardHtml += '<span class="tkCard__time">\u00B7 ' + time + '</span>';

        if(priority === 2) cardHtml += '<span class="tkCard__priority tkCard__priority--high">Hoch</span>';
        if(priority === 3) cardHtml += '<span class="tkCard__priority tkCard__priority--critical">Kritisch</span>';

        cardHtml += '</div>';

        if(files && files.length > 0){
          cardHtml += '<div class="tkCard__files">Dateien: ' + files.map(f => f.replace(/</g,'&lt;')).join(', ') + '</div>';
        }

        if(task.labels && task.labels.length > 0){
          cardHtml += '<div class="tkCard__labels">' + task.labels.map(l => '<span class="tkCard__label">' + l.replace(/</g,'&lt;') + '</span>').join('') + '</div>';
        }

        cardHtml += '</div>';
        return cardHtml;
      }

      function renderColumn(icon, title, items, collapsed){
        let html = '<div class="tkColumn">'
          + '<div class="tkColumnHeader">'
          + '<span class="tkColumnHeader__icon">' + icon + '</span>'
          + title
          + '<span class="tkColumnHeader__count">' + items.length + '</span>'
          + '</div>';
        if(items.length === 0){
          html += '<div class="tkEmpty">Keine Aufgaben</div>';
        } else if(collapsed && items.length > 0){
          html += items.slice(0,2).map(renderCard).join('');
          if(items.length > 2) html += '<div class="tkEmpty" style="cursor:pointer;color:#6366f1" data-action="expand">' + (items.length - 2) + ' weitere anzeigen</div>';
        } else {
          html += items.map(renderCard).join('');
        }
        html += '</div>';
        return html;
      }

      let html = '<div class="tkBoard">'
        + renderColumn('\uD83D\uDD04', 'In Arbeit', inProgress, false)
        + renderColumn('\u2B1C', 'Offen', open, false)
        + renderColumn('\u2705', 'Abgeschlossen', completed, true)
        + '</div>'
        + '<div class="tkAddBtn" id="tkAddBtn">+ Neue Aufgabe</div>';

      content.innerHTML = html;

      // Bind "+ Neue Aufgabe" button
      const addBtn = document.getElementById('tkAddBtn');
      if(addBtn){
        addBtn.addEventListener('click', () => {
          openTaskCreateModal(team);
        });
      }
    }

    // ========== V2 W5: Task-Erstellen Modal ==========
    const tcOverlay = document.getElementById('tcOverlay');
    const tcTitleEl = document.getElementById('tcTitle');
    const tcTaskTitle = document.getElementById('tcTaskTitle');
    const tcTaskDesc = document.getElementById('tcTaskDesc');
    const tcAssign = document.getElementById('tcAssign');
    const tcPriority = document.getElementById('tcPriority');
    const tcError = document.getElementById('tcError');
    const tcSubmit = document.getElementById('tcSubmit');
    const tcCancel = document.getElementById('tcCancel');
    const tcClose = document.getElementById('tcClose');
    let _tcTeam = null;

    function openTaskCreateModal(team){
      _tcTeam = team;
      tcTitleEl.textContent = 'Neue Aufgabe' + (team && team.name ? ' \u2014 ' + team.name : '');
      tcTaskTitle.value = '';
      tcTaskDesc.value = '';
      tcPriority.value = '1';
      tcError.style.display = 'none';
      tcError.textContent = '';

      // Populate assign dropdown with team members
      let opts = '<option value="">Noch offen (spaeter zuweisen)</option>';
      if(team && team.members){
        team.members.forEach(m => {
          const name = (m.name || m.id).replace(/</g,'&lt;');
          const role = m.role ? (' (' + m.role.charAt(0).toUpperCase() + m.role.slice(1) + ')') : '';
          opts += '<option value="' + m.id + '">' + name + role + '</option>';
        });
      }
      tcAssign.innerHTML = opts;

      tcOverlay.classList.add('tcOverlay--open');
      tcTaskTitle.focus();
    }

    function closeTaskCreateModal(){
      tcOverlay.classList.remove('tcOverlay--open');
    }

    tcSubmit.addEventListener('click', async () => {
      tcError.style.display = 'none';
      const title = tcTaskTitle.value.trim();
      if(!title){
        tcError.textContent = 'Bitte gib einen Titel ein.';
        tcError.style.display = 'block';
        tcTaskTitle.focus();
        return;
      }

      tcSubmit.disabled = true;
      tcSubmit.textContent = 'Wird erstellt...';
      try {
        const body = {
          type: 'task',
          title: title,
          description: tcTaskDesc.value.trim(),
          priority: parseInt(tcPriority.value) || 1
        };
        if(_tcTeam && _tcTeam.id) body.team = _tcTeam.id;
        const assignee = tcAssign.value;
        if(assignee) body.assigned_to = assignee;

        const res = await fetch(API_BASE + '/task/create', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(body)
        });
        if(!res.ok){
          const errData = await res.json().catch(() => ({}));
          throw new Error(errData.error || 'Fehler beim Erstellen (Status ' + res.status + ')');
        }
        closeTaskCreateModal();
        showTaskToast({icon:'\u2705', title:'Aufgabe erstellt', desc: title, type:'success', duration:4000});
        // Refresh task board if on tasks tab
        if(_tdActiveTab === 'tasks' && _tdCurrentTeam){
          fetchTeamTasks(_tdCurrentTeam.id, _tdCurrentTeam);
        }
      } catch(e){
        tcError.textContent = e.message || 'Netzwerkfehler — bitte erneut versuchen.';
        tcError.style.display = 'block';
      } finally {
        tcSubmit.disabled = false;
        tcSubmit.textContent = 'Erstellen';
      }
    });

    tcCancel.addEventListener('click', closeTaskCreateModal);
    tcClose.addEventListener('click', closeTaskCreateModal);
    tcOverlay.addEventListener('click', e => { if(e.target === tcOverlay) closeTaskCreateModal(); });
    document.addEventListener('keydown', e => {
      if(e.key === 'Escape' && tcOverlay.classList.contains('tcOverlay--open')) closeTaskCreateModal();
    });

    // Auto-refresh teams every 10s if panel is open and showing dashboard
    setInterval(() => {
      if(teamsPanel.classList.contains('teamsPanel--open') && teamsPanelBack.style.display === 'none'){
        fetchTeamsDashboard();
      }
    }, 10000);

    // ========== Organigramm Tree-View ==========
    const ROLE_LABELS = {
      owner:'Owner', manager:'Manager', assistant:'Assistentin',
      strategist:'Strategin', team_lead:'Team Lead',
      specialist:'Spezialist', junior:'Junior'
    };

    const orgPanel = document.getElementById('orgPanel');
    const orgTree = document.getElementById('orgTree');
    const orgOnlineCount = document.getElementById('orgOnlineCount');
    document.getElementById('orgPanelClose').addEventListener('click', () => {
      orgPanel.classList.remove('orgPanel--open');
    });

    function toggleOrgPanel(){
      const isOpen = orgPanel.classList.toggle('orgPanel--open');
      if(isOpen) fetchOrgChart();
    }

    function buildTree(owner, agents){
      const byParent = {};
      agents.forEach(a => {
        const p = a.reports_to || 'user';
        if(!byParent[p]) byParent[p] = [];
        byParent[p].push(a);
      });

      const online = agents.filter(a => a.status === 'running' || a.status === 'waiting').length;
      const total = agents.filter(a => a.active).length;
      orgOnlineCount.textContent = online + '/' + total + ' online';

      function renderNode(node, isOwner){
        const status = node.status || 'disconnected';
        const inactive = node.active === false;
        const role = ROLE_LABELS[node.role] || node.role;
        const children = byParent[node.id] || [];
        const hasChildren = children.length > 0;
        const nodeId = 'org-' + node.id;

        let html = '<div class="orgNode' + (isOwner ? ' orgNode--owner' : '') + (inactive ? ' orgNode--inactive' : '') + '">';
        if(hasChildren){
          html += '<button class="orgNode__toggle" data-target="' + nodeId + '">&#9660;</button>';
        } else {
          html += '<span style="width:18px;flex-shrink:0"></span>';
        }
        html += '<span class="orgNode__dot orgNode__dot--' + status + '"></span>';
        html += '<div class="orgNode__info">';
        html += '<div class="orgNode__name">' + node.name + '</div>';
        html += '<div class="orgNode__role">' + role + '</div>';
        if(node.activity){
          html += '<div class="orgNode__activity">' + node.activity.replace(/</g,'&lt;') + '</div>';
        }
        html += '</div></div>';

        if(hasChildren){
          html += '<div class="orgChildren" id="' + nodeId + '">';
          children.forEach(c => { html += renderNode(c, false); });
          html += '</div>';
        }
        return html;
      }

      let html = renderNode(owner, true);
      const topLevel = byParent['user'] || [];
      // Owner's direct reports are rendered inside owner's children
      // They are already handled via byParent['user']
      return html;
    }

    async function fetchOrgChart(){
      try {
        const res = await fetch(API_BASE + '/team/orgchart');
        if(!res.ok) return;
        const data = await res.json();
        const ownerNode = Object.assign({}, data.owner, {active:true});
        // Update orgchart agent map for Task 4 (deactivated detection)
        orgchartAgentMap = {};
        data.agents.forEach(a => { orgchartAgentMap[a.id] = a; });
        orgTree.innerHTML = buildTree(ownerNode, data.agents);

        // Bind toggle clicks
        orgTree.querySelectorAll('.orgNode__toggle').forEach(btn => {
          btn.addEventListener('click', () => {
            const target = document.getElementById(btn.dataset.target);
            if(target){
              target.classList.toggle('orgChildren--collapsed');
              btn.innerHTML = target.classList.contains('orgChildren--collapsed') ? '&#9654;' : '&#9660;';
            }
          });
        });
      } catch(e){}
    }

    // Auto-refresh organigramm every 10s if open
    setInterval(() => {
      if(orgPanel.classList.contains('orgPanel--open')) fetchOrgChart();
    }, 10000);

    // ========== Status-Mapping (W6 Requirement #7) ==========
    const STATUS_MAP = {
      running:  { color:'#22c55e', symbol:'\u{1F7E2}', label:'Online' },
      waiting:  { color:'#f59e0b', symbol:'\u{1F7E1}', label:'Wartet' },
      error:    { color:'#ef4444', symbol:'\u{1F534}', label:'Fehler' },
      disconnected: { color:'#94a3b8', symbol:'\u26AA', label:'Offline' },
      stale:    { color:'#f59e0b', symbol:'\u26A0\uFE0F', label:'Reagiert nicht' }
    };
    function statusInfo(st){ return STATUS_MAP[st] || STATUS_MAP.disconnected; }

    // ========== W6: Error-State Modal System ==========
    const teamModalOverlay = document.getElementById('teamModalOverlay');
    const teamModalEl = document.getElementById('teamModal');

    function showTeamModal({icon, title, desc, meta, buttons}){
      document.getElementById('teamModalIcon').textContent = icon || '';
      document.getElementById('teamModalTitle').textContent = title || '';
      document.getElementById('teamModalDesc').textContent = desc || '';
      document.getElementById('teamModalMeta').textContent = meta || '';
      const actionsEl = document.getElementById('teamModalActions');
      actionsEl.innerHTML = '';
      (buttons || []).forEach(b => {
        const btn = document.createElement('button');
        btn.className = 'teamModal__btn' + (b.style ? ' teamModal__btn--' + b.style : '');
        btn.textContent = b.label;
        btn.addEventListener('click', () => { closeTeamModal(); if(b.action) b.action(); });
        actionsEl.appendChild(btn);
      });
      teamModalOverlay.classList.add('teamModal__overlay--open');
    }

    function closeTeamModal(){
      teamModalOverlay.classList.remove('teamModal__overlay--open');
    }
    teamModalOverlay.addEventListener('click', e => { if(e.target === teamModalOverlay) closeTeamModal(); });

    // ========== F1: Susi Team-Wizard Modal ==========
    const twOverlay = document.getElementById('twOverlay');
    const twStepEls = [document.getElementById('twStep0'), document.getElementById('twStep1'), document.getElementById('twStep2')];
    const twStepDots = document.querySelectorAll('.twStepDot');
    const twStepLabel = document.getElementById('twStepLabel');
    const twNameInput = document.getElementById('twName');
    const twDescInput = document.getElementById('twDesc');
    const twLeadList = document.getElementById('twLeadList');
    const twMemberList = document.getElementById('twMemberList');
    const twSummary = document.getElementById('twSummary');
    const twError = document.getElementById('twError');
    const twBack = document.getElementById('twBack');
    const twNext = document.getElementById('twNext');
    const twClose = document.getElementById('twClose');
    let twCurrentStep = 0;
    let twSelectedLead = '';
    let twSelectedMembers = new Set();
    const twStepLabels = ['Schritt 1 von 3 — Name', 'Schritt 2 von 3 — Team', 'Schritt 3 von 3 — Pruefen'];

    function openTeamWizardModal(){
      twCurrentStep = 0;
      twSelectedLead = '';
      twSelectedMembers = new Set();
      twNameInput.value = '';
      twDescInput.value = '';
      twError.style.display = 'none';
      twError.textContent = '';
      twShowStep(0);
      twOverlay.classList.add('twOverlay--open');
      twNameInput.focus();
    }

    function closeTeamWizardModal(){
      twOverlay.classList.remove('twOverlay--open');
    }

    function twShowStep(step){
      twCurrentStep = step;
      twStepEls.forEach((el, i) => {
        el.classList.toggle('twStep--active', i === step);
      });
      twStepDots.forEach((dot, i) => {
        dot.classList.toggle('twStepDot--active', i <= step);
      });
      twStepLabel.textContent = twStepLabels[step];
      twBack.style.display = step === 0 ? 'none' : '';
      twNext.textContent = step === 2 ? 'Team erstellen' : 'Weiter';
      twError.style.display = 'none';

      if(step === 1) twRenderAgentLists();
      if(step === 2) twRenderSummary();
    }

    function twGetAgents(){
      const agents = [];
      Object.keys(orgchartAgentMap).forEach(id => {
        const a = orgchartAgentMap[id];
        if(a.active !== false && id !== 'user') agents.push(a);
      });
      return agents;
    }

    function twRenderAgentLists(){
      const agents = twGetAgents();
      // Lead list (radio)
      twLeadList.innerHTML = agents.map(a => {
        const selected = twSelectedLead === a.id;
        const name = (a.name || a.id).replace(/</g,'&lt;');
        const role = (a.role || '').replace(/</g,'&lt;');
        const dotColor = a.status === 'running' ? '#22c55e' : a.status === 'waiting' ? '#f59e0b' : '#94a3b8';
        return '<div class="twAgentItem' + (selected ? ' twAgentItem--selected' : '') + '" data-agent="' + a.id + '" data-action="lead">'
          + '<span class="twRadio' + (selected ? ' twRadio--checked' : '') + '"></span>'
          + '<span class="twAgentDot" style="background:' + dotColor + '"></span>'
          + '<span class="twAgentName">' + name + '</span>'
          + (role ? '<span class="twAgentRole">' + role + '</span>' : '')
          + '</div>';
      }).join('');

      // Member list (checkbox)
      twMemberList.innerHTML = agents.map(a => {
        const checked = twSelectedMembers.has(a.id);
        const name = (a.name || a.id).replace(/</g,'&lt;');
        const role = (a.role || '').replace(/</g,'&lt;');
        const dotColor = a.status === 'running' ? '#22c55e' : a.status === 'waiting' ? '#f59e0b' : '#94a3b8';
        return '<div class="twAgentItem' + (checked ? ' twAgentItem--selected' : '') + '" data-agent="' + a.id + '" data-action="member">'
          + '<span class="twCheck' + (checked ? ' twCheck--checked' : '') + '"></span>'
          + '<span class="twAgentDot" style="background:' + dotColor + '"></span>'
          + '<span class="twAgentName">' + name + '</span>'
          + (role ? '<span class="twAgentRole">' + role + '</span>' : '')
          + '</div>';
      }).join('');

      // Bind lead clicks
      twLeadList.querySelectorAll('.twAgentItem').forEach(el => {
        el.addEventListener('click', () => {
          twSelectedLead = el.dataset.agent;
          // Auto-add lead to members
          twSelectedMembers.add(twSelectedLead);
          twRenderAgentLists();
        });
      });

      // Bind member clicks
      twMemberList.querySelectorAll('.twAgentItem').forEach(el => {
        el.addEventListener('click', () => {
          const id = el.dataset.agent;
          if(twSelectedMembers.has(id)){
            // Dont uncheck if this is the lead
            if(id !== twSelectedLead) twSelectedMembers.delete(id);
          } else {
            twSelectedMembers.add(id);
          }
          twRenderAgentLists();
        });
      });
    }

    function twRenderSummary(){
      const name = twNameInput.value.trim() || '(kein Name)';
      const desc = twDescInput.value.trim();
      const leadInfo = orgchartAgentMap[twSelectedLead];
      const leadName = leadInfo ? (leadInfo.name || leadInfo.id) : twSelectedLead;
      const memberNames = Array.from(twSelectedMembers).map(id => {
        const a = orgchartAgentMap[id];
        return a ? (a.name || a.id) : id;
      });

      let html = '<div class="twSummaryRow"><span class="twSummaryKey">Teamname</span><span class="twSummaryVal">' + name.replace(/</g,'&lt;') + '</span></div>';
      if(desc) html += '<div class="twSummaryRow"><span class="twSummaryKey">Beschreibung</span><span class="twSummaryVal">' + desc.replace(/</g,'&lt;') + '</span></div>';
      html += '<div class="twSummaryRow"><span class="twSummaryKey">Leitung</span><span class="twSummaryVal">' + leadName.replace(/</g,'&lt;') + '</span></div>';
      html += '<div class="twSummaryRow"><span class="twSummaryKey">Mitglieder</span><span class="twSummaryVal">' + memberNames.map(n => n.replace(/</g,'&lt;')).join(', ') + '</span></div>';
      html += '<div class="twSummaryRow"><span class="twSummaryKey">Anzahl</span><span class="twSummaryVal">' + twSelectedMembers.size + '</span></div>';
      twSummary.innerHTML = html;
    }

    function twShowError(msg){
      twError.textContent = msg;
      twError.style.display = 'block';
    }

    twNext.addEventListener('click', async () => {
      twError.style.display = 'none';
      if(twCurrentStep === 0){
        const name = twNameInput.value.trim();
        if(!name){ twShowError('Bitte gib einen Teamnamen ein.'); twNameInput.focus(); return; }
        twShowStep(1);
      } else if(twCurrentStep === 1){
        if(!twSelectedLead){ twShowError('Bitte waehle eine Teamleitung.'); return; }
        if(twSelectedMembers.size === 0){ twShowError('Bitte waehle mindestens ein Mitglied.'); return; }
        twShowStep(2);
      } else if(twCurrentStep === 2){
        // Submit
        twNext.disabled = true;
        twNext.textContent = 'Wird erstellt...';
        try {
          const body = {
            name: twNameInput.value.trim(),
            lead: twSelectedLead,
            members: Array.from(twSelectedMembers)
          };
          const desc = twDescInput.value.trim();
          if(desc) body.scope = desc;
          const res = await fetch(API_BASE + '/teams', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(body)
          });
          if(!res.ok){
            const errData = await res.json().catch(() => ({}));
            throw new Error(errData.error || 'Fehler beim Erstellen (Status ' + res.status + ')');
          }
          closeTeamWizardModal();
          showTaskToast({icon:'\u2705', title:'Team erstellt', desc:body.name + ' wurde erfolgreich erstellt.', type:'success', duration:4000});
          // Refresh teams dashboard if panel is open
          if(teamsPanel.classList.contains('teamsPanel--open')) fetchTeamsDashboard();
        } catch(e){
          twShowError(e.message || 'Netzwerkfehler — bitte erneut versuchen.');
        } finally {
          twNext.disabled = false;
          twNext.textContent = 'Team erstellen';
        }
      }
    });

    twBack.addEventListener('click', () => {
      if(twCurrentStep > 0) twShowStep(twCurrentStep - 1);
    });

    twClose.addEventListener('click', closeTeamWizardModal);
    twOverlay.addEventListener('click', e => { if(e.target === twOverlay) closeTeamWizardModal(); });
    document.addEventListener('keydown', e => {
      if(e.key === 'Escape' && twOverlay.classList.contains('twOverlay--open')) closeTeamWizardModal();
    });

    // E1: Agent blockiert (STALE)
    function showStaleModal(agentId, lastActivity, lastAction){
      const name = agentLabel(agentId);
      showTeamModal({
        icon:'\u26A0\uFE0F', title: name + ' reagiert nicht',
        desc: 'Letzte Aktion: ' + (lastAction || 'Unbekannt'),
        meta: 'Letzte Aktivitaet: ' + (lastActivity || 'Unbekannt'),
        buttons: [
          { label:'Nachricht senden', action:() => { const w=document.getElementById('leftTargetWrap'); if(w){w.dataset.value=agentId; document.getElementById('leftTargetTrigger').textContent=name;} } },
          { label:'Ordo informieren', style:'primary', action:() => { fetch(API_BASE+'/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({from:'user',to:'ordo',content:name+' reagiert nicht. Bitte pruefen.'})}); } },
          { label:'Stoppen', style:'danger', action:() => { fetch(API_BASE+'/agents/'+agentId+'/stop',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({from:'user'})}); } }
        ]
      });
    }

    // E2: Scope-Lock-Konflikt
    function showScopeLockModal(file, ownerTeam, requestingTeam){
      showTeamModal({
        icon:'\uD83D\uDD12', title:'Datei-Konflikt',
        desc: requestingTeam + ' will ' + file + ' bearbeiten, aber ' + ownerTeam + ' arbeitet daran.',
        buttons: [
          { label:'Warten bis ' + ownerTeam + ' fertig ist' },
          { label:'Ordo bitten die Prioritaet zu klaeren', style:'primary', action:() => { fetch(API_BASE+'/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({from:'user',to:'ordo',content:'Scope-Lock-Konflikt: '+requestingTeam+' braucht '+file+', aber '+ownerTeam+' sperrt es.'})}); } }
        ]
      });
    }

    // E3: Team-Lead offline
    function showLeadOfflineModal(leadId, teamName){
      const name = agentLabel(leadId);
      showTeamModal({
        icon:'\u{1F7E1}', title: name + ' (' + teamName + ' Lead) ist offline',
        desc: 'Sein Team arbeitet weiter an laufenden Tasks. Neue Aufgaben koennen nicht zugewiesen werden.',
        buttons: [
          { label:'Ordo als Vertretung', style:'primary', action:() => { fetch(API_BASE+'/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({from:'user',to:'ordo',content:name+' ist offline. Bitte '+teamName+' koordinieren.'})}); } },
          { label:name + ' starten', action:() => startAgent(leadId) },
          { label:'Abwarten' }
        ]
      });
    }

    // E4: Task fehlgeschlagen
    function showTaskFailedModal(taskTitle, agentId, reason){
      const name = agentLabel(agentId);
      showTeamModal({
        icon:'\u274C', title:'Aufgabe fehlgeschlagen',
        desc: taskTitle + '\nAgent: ' + name + '\nGrund: ' + (reason || 'Unbekannt'),
        buttons: [
          { label:'Details ansehen', style:'primary' },
          { label:'Neu zuweisen' },
          { label:'Schliessen' }
        ]
      });
    }

    // E5: Task abgeschlossen (als Modal)
    function showTaskDoneModal(taskTitle, teamName, agentId, duration){
      const name = agentLabel(agentId);
      showTeamModal({
        icon:'\u2705', title:'Aufgabe abgeschlossen!',
        desc: taskTitle + '\nTeam: ' + teamName + '\nAgent: ' + name + (duration ? '\nDauer: ' + duration : ''),
        buttons: [
          { label:'Details', style:'primary' },
          { label:'OK' }
        ]
      });
    }

    // ========== Task Notification Toast (W6 Requirement #8) ==========
    const taskToastEl = document.getElementById('taskToast');
    let taskToastTimer = null;

    function showTaskToast({icon, title, desc, type, duration}){
      document.getElementById('taskToastIcon').textContent = icon || '\u2139\uFE0F';
      document.getElementById('taskToastTitle').textContent = title || '';
      document.getElementById('taskToastDesc').textContent = desc || '';
      taskToastEl.className = 'taskToast taskToast--' + (type || 'info') + ' taskToast--visible';
      if(taskToastTimer) clearTimeout(taskToastTimer);
      taskToastTimer = setTimeout(() => { taskToastEl.classList.remove('taskToast--visible'); }, duration || 5000);
    }

    document.getElementById('taskToastClose').addEventListener('click', () => {
      taskToastEl.classList.remove('taskToast--visible');
      if(taskToastTimer) clearTimeout(taskToastTimer);
    });

    // WebSocket integration for task events
    // A8: Title cache for toast messages (task_id → title)
    const _taskTitleCache = {};

    function handleTaskEvent(data){
      // A8: Re-render task board on any task state change
      const isTaskEvent = data.type === 'task_created' || data.type === 'task_claimed'
        || data.type === 'task_acked' || data.type === 'task_done' || data.type === 'task_failed';
      if(isTaskEvent && _tdActiveTab === 'tasks' && _tdCurrentTeam){
        fetchTeamTasks(_tdCurrentTeam.id, _tdCurrentTeam);
      }

      if(data.type === 'task_created'){
        const t = data.task || {};
        if(t.task_id && t.title) _taskTitleCache[t.task_id] = t.title;
      }
      if(data.type === 'task_claimed'){
        const title = _taskTitleCache[data.task_id] || '';
        const desc = title ? (title + ' — ' + agentLabel(data.agent_id || '')) : agentLabel(data.agent_id || '');
        showTaskToast({ icon:'\uD83D\uDD04', title:'Aufgabe uebernommen', desc: desc, type:'info', duration:4000 });
      }
      if(data.type === 'task_done'){
        const title = _taskTitleCache[data.task_id] || '';
        const desc = title ? (title + ' — ' + agentLabel(data.agent_id || '')) : agentLabel(data.agent_id || '');
        showTaskToast({ icon:'\u2705', title:'Aufgabe abgeschlossen', desc: desc, type:'info', duration:6000 });
      }
      if(data.type === 'task_failed'){
        const title = _taskTitleCache[data.task_id] || '';
        const desc = title ? (title + ' — ' + (data.error || '')) : (data.error || '');
        showTaskToast({ icon:'\u274C', title:'Aufgabe fehlgeschlagen', desc: desc, type:'error', duration:8000 });
      }
      if(data.type === 'scope_lock_conflict'){
        showTaskToast({ icon:'\uD83D\uDD12', title:'Datei-Konflikt', desc: (data.file || '') + ' ist gesperrt', type:'locked', duration:6000 });
        if(data.file && data.owner_team && data.requesting_team) showScopeLockModal(data.file, data.owner_team, data.requesting_team);
      }
      if(data.type === 'agent_stale'){
        showTaskToast({ icon:'\u26A0\uFE0F', title: agentLabel(data.agent_id || '') + ' reagiert nicht', desc: 'Seit ' + (data.since || '?') + ' keine Aktivitaet', type:'warning', duration:8000 });
        if(data.agent_id) showStaleModal(data.agent_id, data.since, data.last_action);
      }
      if(data.type === 'lead_offline'){
        showTaskToast({ icon:'\u{1F7E1}', title: 'Team-Lead offline', desc: agentLabel(data.lead_id || '') + ' (' + (data.team_name || '') + ')', type:'warning', duration:6000 });
        if(data.lead_id && data.team_name) showLeadOfflineModal(data.lead_id, data.team_name);
      }
    }

  </script>
</body>
</html>
