    /* Derive agents data from projects (for Agent View) */
    function deriveAgentsData(){
      const agentMap = {};
      projectsData.projects.forEach(proj => {
        proj.teams.forEach(team => {
          team.members.forEach(member => {
            if(!agentMap[member.id]){
              agentMap[member.id] = {
                id: member.id, name: member.name, role: member.role,
                status: member.status, projects: []
              };
            }
            const existing = agentMap[member.id];
            if(member.status === 'red') existing.status = 'red';
            else if(member.status === 'yellow' && existing.status !== 'red') existing.status = 'yellow';
            const existingProj = existing.projects.find(p => p.id === proj.id);
            if(existingProj){
              if(!existingProj.teams.includes(team.name)) existingProj.teams.push(team.name);
            } else {
              existing.projects.push({ id: proj.id, name: proj.name, teams: [team.name] });
            }
          });
        });
      });
      return Object.values(agentMap);
    }

    /* State */
    let selectedProjectId = 'bridge-ide';
    let currentView = 'project';

    function tbEscHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    /* Render: Project Sidebar */
    function renderProjectSidebar(){
      const container = document.getElementById('projectList');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;
      projectsData.projects.forEach(proj => {
        // Filter: match project name, team name, or member name/role
        let projMatches = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const projNameMatch = proj.name.toLowerCase().includes(term);
          const teamMatch = proj.teams.some(t => t.name.toLowerCase().includes(term) || t.members.some(m => m.name.toLowerCase().includes(term) || m.role.toLowerCase().includes(term)));
          projMatches = projNameMatch || teamMatch;
        }
        if(!projMatches) return;
        const isSelected = proj.id === selectedProjectId;
        const teamCount = proj.teams.length;
        const uniqueMembers = new Set();
        proj.teams.forEach(t => t.members.forEach(m => uniqueMembers.add(m.id)));
        html += '<div class="projectCard' + (isSelected ? ' selected' : '') + '">';
        html += '<button class="projectCard__toggle' + (isSelected ? ' open' : '') + '" data-project="' + proj.id + '">';
        html += '<svg class="projectCard__arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>';
        html += '<span class="ampelDot ampelDot--' + proj.status + '"></span>';
        html += '<span class="projectCard__name">' + tbEscHtml(proj.name) + '</span>';
        html += '</button>';
        html += '<div class="projectCard__info">' + teamCount + ' Teams &middot; ' + uniqueMembers.size + ' Agents</div>';
        html += '<div class="projectCard__teams' + (isSelected ? ' open' : '') + '">';
        proj.teams.forEach(team => {
          const teamMatches = !hasSearch || team.name.toLowerCase().includes(searchTerm.toLowerCase()) || team.members.some(m => m.name.toLowerCase().includes(searchTerm.toLowerCase()) || m.role.toLowerCase().includes(searchTerm.toLowerCase()));
          if(hasSearch && !teamMatches) return;
          html += '<div class="projectCard__teamItem">';
          html += '<span class="ampelDot ampelDot--' + team.status + ' ampelDot--sm"></span>';
          html += '<span class="projectCard__teamName">' + tbEscHtml(team.name) + '</span>';
          html += '<span class="projectCard__teamCount">' + team.members.length + '</span>';
          html += '</div>';
        });
        html += '</div></div>';
      });
      container.innerHTML = html;
      container.querySelectorAll('.projectCard__toggle').forEach(btn => {
        btn.addEventListener('click', () => selectProject(btn.dataset.project));
      });
    }

    function selectProject(projectId){
      selectedProjectId = projectId;
      renderProjectSidebar();
      renderMainContent();
    }

    /* Render: Main Content */
    function renderMainContent(){
      if(currentView === 'project') renderProjectView();
      else renderAgentView();
      updateTeamBoardMetrics();
    }

    /* Render: Project View */
    function renderProjectView(){
      const proj = projectsData.projects.find(p => p.id === selectedProjectId);
      if(!proj) return;
      document.getElementById('boardProjectName').textContent = proj.name;
      document.getElementById('boardProjectAmpel').className = 'ampelDot ampelDot--' + proj.status;
      document.getElementById('boardTeamCount').textContent = proj.teams.length + ' Teams';
      const container = document.getElementById('teamBoardContent');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;
      proj.teams.forEach((team, idx) => {
        // Filter: match team name or member name/role
        let teamMatches = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const teamNameMatch = team.name.toLowerCase().includes(term);
          const memberMatch = team.members.some(m => m.name.toLowerCase().includes(term) || m.role.toLowerCase().includes(term));
          teamMatches = teamNameMatch || memberMatch;
        }
        if(!teamMatches) return;
        html += '<div class="teamGroupCard" style="animation-delay:' + (idx * 0.08) + 's">';
        html += '<div class="teamGroupCard__header">';
        html += '<span class="ampelDot ampelDot--' + team.status + '"></span>';
        html += '<span class="teamGroupCard__name">' + tbEscHtml(team.name) + '</span>';
        html += '<span class="teamGroupCard__meta">' + team.members.length + ' Agents</span>';
        html += '</div>';
        html += '<div class="teamGroupCard__body">';
        team.members.forEach(member => {
          // Filter individual members
          let memberMatches = true;
          if(hasSearch){
            const term = searchTerm.toLowerCase();
            memberMatches = member.name.toLowerCase().includes(term) || member.role.toLowerCase().includes(term);
          }
          if(!memberMatches) return;
          html += '<div class="agentRow">';
          html += '<span class="ampelDot ampelDot--' + member.status + ' ampelDot--sm"></span>';
          html += '<span class="agentRow__name" style="color:' + getAgentColor(member.id) + '">' + tbEscHtml(member.name) + '</span>';
          html += '<span class="agentRow__role">' + tbEscHtml(member.role) + '</span>';
          if(member.also_in && member.also_in.length > 0){
            html += '<span class="agentRow__alsoIn">';
            member.also_in.forEach(pn => {
              html += '<span class="alsoInBadge">auch in: ' + tbEscHtml(pn) + '</span>';
            });
            html += '</span>';
          }
          html += '</div>';
        });
        html += '</div></div>';
      });
      container.innerHTML = html;
    }

    /* Render: Agent View */
    function renderAgentView(){
      document.getElementById('boardProjectName').textContent = 'Alle Agents';
      document.getElementById('boardProjectAmpel').className = 'ampelDot';
      const agents = deriveAgentsData();
      document.getElementById('boardTeamCount').textContent = agents.length + ' Agents';
      const container = document.getElementById('teamBoardContent');
      let html = '';
      const searchTerm = getSearchTerm();
      const hasSearch = searchTerm.length > 0;
      agents.forEach((agent, idx) => {
        // Filter: match agent name, role, project name, team name
        let matches = true;
        if(hasSearch){
          const term = searchTerm.toLowerCase();
          const nameMatch = agent.name.toLowerCase().includes(term);
          const roleMatch = agent.role.toLowerCase().includes(term);
          const projMatch = agent.projects.some(p => p.name.toLowerCase().includes(term) || p.teams.some(t => t.toLowerCase().includes(term)));
          matches = nameMatch || roleMatch || projMatch;
        }
        if(!matches) return;
        html += '<div class="agentViewCard" style="animation-delay:' + (idx * 0.06) + 's">';
        html += '<span class="ampelDot ampelDot--' + agent.status + '"></span>';
        html += '<div class="agentViewCard__info">';
        html += '<div class="agentViewCard__name" style="color:' + getAgentColor(agent.id) + '">' + tbEscHtml(agent.name) + '</div>';
        html += '<div class="agentViewCard__role">' + tbEscHtml(agent.role) + '</div>';
        html += '<div class="agentViewCard__projects">';
        agent.projects.forEach(proj => {
          const projMatches = !hasSearch || proj.name.toLowerCase().includes(searchTerm.toLowerCase()) || proj.teams.some(t => t.toLowerCase().includes(searchTerm.toLowerCase()));
          if(hasSearch && !projMatches) return;
          html += '<div class="agentViewCard__projectItem">';
          html += '<span class="agentViewCard__projectName">' + tbEscHtml(proj.name) + '</span>';
          html += '<span class="agentViewCard__teams">' + proj.teams.join(', ') + '</span>';
          html += '</div>';
        });
        html += '</div></div></div>';
      });
      container.innerHTML = html;
    }

    /* Search Filter */
    let currentSearchTerm = '';

    function getSearchTerm(){ return currentSearchTerm; }

    function filterBySearch(){
      currentSearchTerm = document.getElementById('teamBoardSearch').value || '';
      renderMainContent();
    }

    document.getElementById('teamBoardSearch').addEventListener('input', filterBySearch);

    /* View Toggle */
    document.getElementById('viewToggle').addEventListener('click', (e) => {
      const btn = e.target.closest('.viewToggle__btn');
      if(!btn) return;
      currentView = btn.dataset.view;
      document.querySelectorAll('.viewToggle__btn').forEach(b => {
        b.classList.toggle('active', b.dataset.view === currentView);
      });
      renderMainContent();
    });

    /* Metrics Update */
    function updateTeamBoardMetrics(){
      const totalProjects = projectsData.projects.length;
      const totalTeams = projectsData.projects.reduce((sum, p) => sum + p.teams.length, 0);
      const agents = deriveAgentsData();
      document.getElementById('metricProjects').textContent = totalProjects;
      document.getElementById('metricTeams').textContent = totalTeams;
      document.getElementById('metricAgents').textContent = agents.length;
      document.getElementById('topProjects').textContent = totalProjects;
      document.getElementById('topTeams').textContent = totalTeams;
      document.getElementById('topAgents').textContent = agents.length;
    }

    /* Fetch Projects from API (polling) */
    async function fetchProjects(){
      try {
        const res = await fetch(API_BASE + '/board/projects', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return false;
        const data = await res.json();
        if(data.projects && data.projects.length > 0){
          projectsData = data;
          renderProjectSidebar();
          renderMainContent();
        }
        return true;
      } catch(e){
        return false;
      }
    }

    /* ═══════════════════════════════════════════
       NEW PROJECT MODAL
    ═══════════════════════════════════════════ */
    const newProjectModal = document.getElementById('newProjectModal');
    const newProjectBtn = document.getElementById('newProjectBtn');
    const newProjectForm = document.getElementById('newProjectForm');
    const newProjectNameInput = document.getElementById('newProjectName');
    const newProjectCancel = document.getElementById('newProjectCancel');

    function generateProjectSlug(name){
      return name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-').replace(/^-|-$/g, '');
    }

    newProjectBtn.addEventListener('click', () => {
      newProjectModal.style.display = 'flex';
      newProjectNameInput.focus();
    });

    newProjectCancel.addEventListener('click', () => {
      newProjectModal.style.display = 'none';
      newProjectNameInput.value = '';
    });

    newProjectModal.addEventListener('click', (e) => {
      if(e.target === newProjectModal){
        newProjectModal.style.display = 'none';
        newProjectNameInput.value = '';
      }
    });

    newProjectForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = newProjectNameInput.value.trim();
      if(!name) return;
      const slug = generateProjectSlug(name);
      const submitBtn = document.getElementById('newProjectSubmit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Erstelle...';
      try {
        const res = await fetch(API_BASE + '/board/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: slug, name: name })
        });
        const data = await res.json();
        if(data.ok || data.project){
          newProjectModal.style.display = 'none';
          newProjectNameInput.value = '';
          await fetchProjects();
          selectProject(slug);
        } else {
          alert('Fehler: ' + (data.error || 'Projekt konnte nicht erstellt werden'));
        }
      } catch(err){
        alert('Fehler beim Erstellen: ' + err.message);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Projekt erstellen';
      }
    });

    /* ═══════════════════════════════════════════
       LIVE BACKEND — WebSocket + Polling
    ═══════════════════════════════════════════ */
    let historyRenderedIds = new Set();

    function connectWebSocket(){
      try {
        ws = new WebSocket(WS_URL);
      } catch(e){ return; }
      ws.onopen = () => {
        wsRetry = 1000;
        console.log('[CC] WebSocket connected');
      };
      ws.onmessage = (e) => {
        try {
          const data = JSON.parse(e.data);
          if(data.type === 'message' && data.message){
            handleLiveMessage(data.message);
          } else if(data.type === 'agent_status'){
            pollAgentStatus();
          } else if(data.type === 'activity' && data.activity){
            const a = data.activity;
            dashAddFeedEntry('tool', agentDisplayName(a.agent_id),
              a.action + (a.target ? ' ' + a.target : ''), a.description || '');
          }
        } catch(err){ console.error('[CC] WS parse error:', err); }
      };
      ws.onclose = () => {
        setTimeout(connectWebSocket, wsRetry);
        wsRetry = Math.min(wsRetry * 2, 30000);
      };
      ws.onerror = () => {};
    }

    function handleLiveMessage(msg){
      if(msg.id && historyRenderedIds.has(msg.id)) return;
      if(msg.id) historyRenderedIds.add(msg.id);
      const from = agentDisplayName(msg.from);
      const to = agentDisplayName(msg.to);
      const text = (msg.content || '').substring(0, 120);
      const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
      dashAddFeedEntry('message', from, text, detail);

      // Packet routing: slot-based for real agents
      const fromSlot = dashSlotAgents.indexOf(msg.from);
      const toSlot = dashSlotAgents.indexOf(msg.to);
      const slotPaths = { '0-1':'pathLA','1-0':'pathLA','0-2':'pathLB','2-0':'pathLB','1-2':'pathAB','2-1':'pathAB' };
      const pathId = slotPaths[fromSlot + '-' + toSlot];
      if(pathId) dashSendPacket(pathId, dashAgentColor(from));

      if(dashSparkData[from]){
        const d = dashSparkData[from];
        if(d.length > 0) d[d.length - 1] += 2;
      }

      if(dashAgentStats[from]){
        dashAgentStats[from].msgs++;
        dashUpdateAgentStats(from);
      }
    }

    async function pollAgentStatus(){
      try {
        const res = await fetch(API_BASE + '/agents');
        const data = await res.json();
        const agents = data.agents || [];
        const active = agents.filter(a => a.status !== 'disconnected');

        // Online count in status dots area (don't overwrite team board metric)

        const dotMap = { teamlead:'dashStatusL', lead:'dashStatusL',
          claude_a:'dashStatusA', agent_a:'dashStatusA',
          claude_b:'dashStatusB', agent_b:'dashStatusB' };
        agents.forEach(a => {
          const dotId = dotMap[a.agent_id];
          if(!dotId) return;
          const color = a.status === 'live' ? '#22c55e' : a.status === 'connecting' ? '#f59e0b' : '#ef4444';
          const el = document.getElementById(dotId);
          if(el) el.setAttribute('fill', color);
        });

        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          const dot = topBarDots[0];
          const label = document.querySelector('.topBar .statusLabel');
          dot.className = 'statusDot';
          if(active.length > 0){
            dot.classList.add('statusDot--live');
            if(label) label.textContent = active.length + ' online';
          } else {
            dot.classList.add('statusDot--connecting');
            if(label) label.textContent = 'Keine Agents';
          }
        }
      } catch(e){
        const topBarDots = document.querySelectorAll('.topBar .statusDot');
        if(topBarDots.length > 0){
          topBarDots[0].className = 'statusDot statusDot--disconnected';
          const label = document.querySelector('.topBar .statusLabel');
          if(label) label.textContent = 'Offline';
        }
      }
    }

    async function loadHistory(){
      try {
        const res = await fetch(API_BASE + '/history?limit=50');
        const data = await res.json();
        const msgs = data.messages || [];
        msgs.forEach(msg => {
          if(msg.id) historyRenderedIds.add(msg.id);
          const from = agentDisplayName(msg.from);
          const to = agentDisplayName(msg.to);
          const text = (msg.content || '').substring(0, 120);
          const detail = msg.to !== 'all' ? '\u2192 ' + to : '';
          dashAddFeedEntry('message', from, text, detail);
        });
        return true;
      } catch(e){
        return false;
      }
    }

    async function tryLiveMode(){
      try {
        const res = await fetch(API_BASE + '/agents', { signal: AbortSignal.timeout(3000) });
        if(!res.ok) return false;
        liveMode = true;
        await populateDashboard();
        await loadHistory();
        connectWebSocket();
        pollAgentStatus();
        setInterval(pollAgentStatus, 5000);
        setInterval(populateDashboard, 10000);
        console.log('[CC] Live mode active');
        return true;
      } catch(e){
        return false;
      }
    }

    /* ═══════════════════════════════════════════
       INIT — Start Both Engines
    ═══════════════════════════════════════════ */
    renderProjectSidebar();
    renderMainContent();

    // Try live backend; fall back to demo if offline
    tryLiveMode().then(live => {
      if(!live){
        console.log('[CC] Backend offline — using demo scenarios');
        setTimeout(dashScheduleNext, 1200);
      }
      // Try fetching live project data
      fetchProjects();
    });

    // Poll projects every 10s
    setInterval(fetchProjects, 10000);

  </script>
</body>
</html>
