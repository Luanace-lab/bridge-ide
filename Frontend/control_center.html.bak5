                { id:'nova', name:'Nova', role:'Kreativ-Strategin', status:'green', also_in:['Bridge IDE','Online Shops'] },
                { id:'lucy', name:'Lucy', role:'Daten-Analyse', status:'yellow', also_in:['Bridge IDE'] }
              ]
