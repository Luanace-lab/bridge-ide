<!doctype html>
<html lang="de" data-theme="warm">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Bridge – Aufgaben</title>
  <style>
    /* ─── Themes (shared, single source) ─── */
    html[data-theme="warm"]{
      --bg:#fbf8f1; --bgFlat:#fbf8f1;
      --sidebar:#c8bfa8; --sbThumb:#b8af98; --sbDark:#8a7f6a;
    }
    html[data-theme="light"]{
      --bg:#ffffff; --bgFlat:#ffffff;
      --sidebar:#d6e8f7; --sbThumb:#b8d4ed; --sbDark:#5a9ac7;
    }
    html[data-theme="rose"]{
      --bg:#fdf2f4; --bgFlat:#fdf2f4;
      --sidebar:#e8c4cc; --sbThumb:#d9adb7; --sbDark:#a3707e;
    }
    html[data-theme="dark"]{
      --bg:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);
      --bgFlat:#161e3a;
      --sidebar:#1e2a42; --sbThumb:#2d3f5e; --sbDark:#8aa4c8;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    html,body{ height:100%; overflow:hidden; }
    body{
      background:var(--bg);
      font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
      color:#3d3d3a;
      display:flex; flex-direction:column;
    }
    html[data-theme="dark"] body{ color:#e7edf5; }

    /* ─── Top Bar ─── */
    .topBar{
      flex-shrink:0;
      display:flex; align-items:center; justify-content:space-between;
      padding:8px 24px;
      background:color-mix(in srgb, var(--sidebar) 18%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      backdrop-filter:blur(12px);
      z-index:10;
    }
    .topBar__left{ display:flex; align-items:center; gap:10px; }
    .topBar__logo{ height:28px; width:auto; }
    .topBar__title{
      font-size:11px; font-weight:700; text-transform:uppercase;
      letter-spacing:.6px; color:var(--sbDark);
    }
    .topBar__liveDot{
      width:7px; height:7px; border-radius:50%; background:#22c55e;
      animation:livePulse 2s ease-in-out infinite;
    }
    @keyframes livePulse{
      0%,100%{ opacity:1; transform:scale(1); }
      50%{ opacity:.5; transform:scale(1.3); }
    }
    .topBar__nav{ display:flex; gap:2px; background:color-mix(in srgb, var(--sidebar) 15%, transparent); border-radius:6px; padding:2px; margin-left:16px; }
    .topBar__navLink{
      font-size:10px; font-weight:500; text-decoration:none;
      padding:4px 10px; border-radius:4px; color:#8f8f8f;
      transition:background .15s, color .15s;
    }
    .topBar__navLink:hover{ background:color-mix(in srgb, var(--sidebar) 25%, transparent); color:#3d3d3a; }
    .topBar__navLink--active{ background:color-mix(in srgb, var(--sidebar) 30%, transparent); color:var(--sbDark); font-weight:600; }
    html[data-theme="dark"] .topBar__navLink{ color:#6b7a8f; }
    html[data-theme="dark"] .topBar__navLink:hover{ color:#e7edf5; }
    html[data-theme="dark"] .topBar__navLink--active{ color:#8aa4c8; }

    .topBar__right{ display:flex; align-items:center; gap:12px; }
    .topBar__stats{
      display:flex; align-items:center; gap:14px;
      font-size:10px; font-weight:500; color:#8f8f8f;
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .topBar__stats{ color:#6b7a8f; }
    .topBar__stats b{ color:#3d3d3a; font-weight:700; }
    html[data-theme="dark"] .topBar__stats b{ color:#e7edf5; }
    .statusDots{ display:flex; align-items:center; gap:6px; }
    .statusDot{ width:8px; height:8px; border-radius:50%; }
    .statusDot--live{ background:#22c55e; }
    .statusDot--connecting{ background:#f59e0b; }
    .statusDot--disconnected{ background:#ef4444; }
    .statusLabel{ font-size:10px; font-weight:500; color:#8f8f8f; }
    html[data-theme="dark"] .statusLabel{ color:#6b7a8f; }
    .themeSwitcher{ display:flex; gap:4px; }
    .themeBtn{
      width:16px; height:16px; border-radius:50%;
      border:2px solid transparent; cursor:pointer;
      transition:border-color .15s ease, transform .15s ease;
    }
    .themeBtn:hover{ transform:scale(1.15); }
    .themeBtn.active{ border-color:var(--sbDark); }
    .themeBtn[data-theme="warm"]{ background:#c8bfa8; }
    .themeBtn[data-theme="light"]{ background:#d6e8f7; }
    .themeBtn[data-theme="rose"]{ background:#e8c4cc; }
    .themeBtn[data-theme="dark"]{ background:#1e2a42; }

    /* ─── Filter Bar ─── */
    .filterBar{
      flex-shrink:0; display:flex; align-items:center; gap:8px;
      padding:8px 24px;
      background:color-mix(in srgb, var(--sidebar) 6%, var(--bgFlat));
      border-bottom:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
    }
    html[data-theme="dark"] .filterBar{
      background:rgba(255,255,255,.02);
      border-bottom-color:rgba(255,255,255,.05);
    }
    .filterBtn{
      font-size:10px; font-weight:500; padding:4px 12px;
      border-radius:4px; border:1px solid color-mix(in srgb, var(--sidebar) 25%, transparent);
      background:transparent; color:#8f8f8f; cursor:pointer;
      transition:all .12s ease;
    }
    .filterBtn:hover{
      background:color-mix(in srgb, var(--sidebar) 12%, var(--bgFlat));
      color:#3d3d3a;
    }
    .filterBtn.active{
      background:var(--sbDark); color:#fff;
      border-color:var(--sbDark);
    }
    html[data-theme="dark"] .filterBtn{ color:#6b7a8f; border-color:rgba(255,255,255,.08); }
    html[data-theme="dark"] .filterBtn:hover{ color:#e7edf5; background:rgba(255,255,255,.06); }
    html[data-theme="dark"] .filterBtn.active{ background:#8aa4c8; color:#0f172a; border-color:#8aa4c8; }
    .filterBar__spacer{ flex:1; }
    .filterBar__count{
      font-size:10px; font-weight:600; color:#8f8f8f;
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .filterBar__count{ color:#6b7a8f; }
    .filterBar__count b{ color:#3d3d3a; font-weight:700; }
    html[data-theme="dark"] .filterBar__count b{ color:#e7edf5; }

    /* ─── Board Layout ─── */
    .boardContainer{
      flex:1; overflow-y:auto; padding:12px 24px 24px;
      scrollbar-width:thin;
      scrollbar-color:color-mix(in srgb, var(--sbDark) 20%, var(--bgFlat)) transparent;
    }

    /* ─── Board Lane ─── */
    .lane{
      margin-bottom:12px;
    }
    .lane__header{
      display:flex; align-items:center; gap:8px;
      padding:6px 0; cursor:pointer; user-select:none;
    }
    .lane__dot{
      width:8px; height:8px; border-radius:50%; flex-shrink:0;
    }
    .lane__title{
      font-size:10px; font-weight:700; text-transform:uppercase;
      letter-spacing:.5px;
    }
    .lane__count{
      font-size:9px; font-weight:600; color:#8f8f8f;
      background:color-mix(in srgb, var(--sidebar) 12%, var(--bgFlat));
      padding:1px 6px; border-radius:8px;
    }
    html[data-theme="dark"] .lane__count{
      background:rgba(255,255,255,.06); color:#6b7a8f;
    }
    .lane__toggle{
      font-size:8px; color:#8f8f8f; transition:transform .2s ease;
    }
    .lane__toggle.collapsed{ transform:rotate(-90deg); }
    .lane__body{
      display:flex; flex-direction:column; gap:4px;
      padding-left:16px;
    }
    .lane__body.collapsed{ display:none; }
    .lane__empty{
      font-size:9px; color:#8f8f8f; font-style:italic;
      padding:8px 0;
    }

    /* Lane colors */
    .lane--urgent .lane__dot{ background:#ef4444; }
    .lane--urgent .lane__title{ color:#ef4444; }
    .lane--high .lane__dot{ background:#f59e0b; }
    .lane--high .lane__title{ color:#f59e0b; }
    .lane--normal .lane__dot{ background:#6366f1; }
    .lane--normal .lane__title{ color:#6366f1; }
    .lane--done .lane__dot{ background:#22c55e; }
    .lane--done .lane__title{ color:#22c55e; }
    .lane--failed .lane__dot{ background:#ef4444; }
    .lane--failed .lane__title{ color:#ef4444; opacity:.7; }

    /* ─── Task Card ─── */
    .taskCard{
      background:color-mix(in srgb, var(--sidebar) 8%, var(--bgFlat));
      border:1px solid color-mix(in srgb, var(--sidebar) 20%, transparent);
      border-radius:8px; padding:8px 12px;
      display:flex; align-items:flex-start; gap:10px;
      transition:background .12s ease, border-color .12s ease;
    }
    .taskCard:hover{
      background:color-mix(in srgb, var(--sidebar) 14%, var(--bgFlat));
    }
    html[data-theme="dark"] .taskCard{
      background:rgba(255,255,255,.03);
      border-color:rgba(255,255,255,.06);
    }
    html[data-theme="dark"] .taskCard:hover{
      background:rgba(255,255,255,.06);
    }
    .taskCard--blocked{
      border-left:3px solid #ef4444;
    }
    .taskCard__priority{
      width:4px; height:100%; min-height:24px; border-radius:2px;
      flex-shrink:0;
    }
    .taskCard__priority--urgent{ background:#ef4444; }
    .taskCard__priority--high{ background:#f59e0b; }
    .taskCard__priority--normal{ background:#6366f1; }
    .taskCard__priority--low{ background:#8f8f8f; }
    .taskCard__content{ flex:1; min-width:0; }
    .taskCard__title{
      font-size:11px; font-weight:600; color:#3d3d3a;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    html[data-theme="dark"] .taskCard__title{ color:#e7edf5; }
    .taskCard__meta{
      display:flex; flex-wrap:wrap; gap:6px; margin-top:3px;
      font-size:8px; color:#8f8f8f;
    }
    html[data-theme="dark"] .taskCard__meta{ color:#6b7a8f; }
    .taskCard__badge{
      display:inline-flex; align-items:center; gap:3px;
      padding:1px 6px; border-radius:4px; font-size:8px; font-weight:600;
    }
    .taskCard__badge--state{
      background:color-mix(in srgb, var(--sidebar) 15%, var(--bgFlat));
      color:var(--sbDark);
    }
    html[data-theme="dark"] .taskCard__badge--state{
      background:rgba(255,255,255,.08); color:#8aa4c8;
    }
    .taskCard__badge--agent{
      background:color-mix(in srgb, #6366f1 10%, var(--bgFlat));
      color:#6366f1;
    }
    html[data-theme="dark"] .taskCard__badge--agent{
      background:rgba(99,102,241,.15); color:#818cf8;
    }
    .taskCard__badge--blocker{
      background:rgba(239,68,68,.1); color:#ef4444;
    }
    html[data-theme="dark"] .taskCard__badge--blocker{
      background:rgba(239,68,68,.15); color:#f87171;
    }
    .taskCard__blocker{
      margin-top:4px; font-size:9px; color:#ef4444;
      padding:3px 6px; border-radius:4px;
      background:rgba(239,68,68,.06);
    }
    html[data-theme="dark"] .taskCard__blocker{
      background:rgba(239,68,68,.1); color:#f87171;
    }
    .taskCard__right{
      display:flex; flex-direction:column; align-items:flex-end; gap:2px;
      flex-shrink:0;
    }
    .taskCard__time{
      font-size:8px; color:#8f8f8f; white-space:nowrap;
    }
    html[data-theme="dark"] .taskCard__time{ color:#6b7a8f; }

    /* ─── Footer ─── */
    .footerBar{
      flex-shrink:0; display:flex; align-items:center; justify-content:space-between;
      padding:6px 24px;
      background:color-mix(in srgb, var(--sidebar) 10%, var(--bgFlat));
      border-top:1px solid color-mix(in srgb, var(--sidebar) 15%, transparent);
      font-size:10px; color:#8f8f8f;
      font-variant-numeric:tabular-nums;
    }
    html[data-theme="dark"] .footerBar{
      background:rgba(255,255,255,.02);
      border-top-color:rgba(255,255,255,.05);
      color:#6b7a8f;
    }
    .footerBar b{ color:#3d3d3a; font-weight:700; }
    html[data-theme="dark"] .footerBar b{ color:#e7edf5; }

    /* ─── WebSocket indicator ─── */
    .wsIndicator{
      width:6px; height:6px; border-radius:50%;
      display:inline-block; margin-right:4px;
    }
    .wsIndicator--connected{ background:#22c55e; }
    .wsIndicator--disconnected{ background:#ef4444; }
  </style>
</head>
<body>
  <!-- ─── Top Bar ─── -->
  <header class="topBar" role="banner">
    <div class="topBar__left">
      <img class="topBar__logo" src="ace_logo.svg" alt="ACE Logo">
      <div class="topBar__liveDot" role="status" aria-label="Live indicator"></div>
      <div class="topBar__title">Aufgaben</div>
      <nav class="topBar__nav" aria-label="Page navigation">
        <a class="topBar__navLink" href="chat.html">Chat</a>
        <a class="topBar__navLink" href="control_center.html">Control Center</a>
        <a class="topBar__navLink topBar__navLink--active" href="tasks.html">Aufgaben</a>
        <a class="topBar__navLink" href="project_config.html">Neues Projekt</a>
      </nav>
    </div>
    <div class="topBar__stats" id="topStats" aria-label="Task statistics">
      <span>Gesamt: <b id="statTotal">0</b></span>
      <span>Offen: <b id="statOpen">0</b></span>
      <span>Erledigt: <b id="statDone">0</b></span>
    </div>
    <div class="topBar__right">
      <div class="statusDots" aria-label="System status">
        <span class="statusDot statusDot--live"></span>
        <span class="statusDot statusDot--connecting"></span>
        <span class="statusLabel" id="wsLabel">Verbinde...</span>
      </div>
      <button class="helpBtn" title="Hilfe & Einfuehrung" aria-label="Hilfe oeffnen" style="background:none;border:1px solid color-mix(in srgb, var(--sbDark) 30%, transparent);border-radius:50%;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--sbDark);opacity:.7;transition:opacity .2s" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.7'" onclick="window.location.href='control_center.html?help=1'">?</button>
      <div class="themeSwitcher" role="group" aria-label="Theme selection">
        <button class="themeBtn" data-theme="warm" title="Theme: Warm" aria-label="Theme: Warm" style="background:#c8bfa8"></button>
        <button class="themeBtn" data-theme="light" title="Theme: Light" aria-label="Theme: Light" style="background:#d6e8f7"></button>
        <button class="themeBtn" data-theme="rose" title="Theme: Rose" aria-label="Theme: Rose" style="background:#e8c4cc"></button>
        <button class="themeBtn" data-theme="dark" title="Theme: Dark" aria-label="Theme: Dark" style="background:#1e2a42"></button>
      </div>
    </div>
  </header>

  <!-- ─── Filter Bar ─── -->
  <div class="filterBar">
    <button class="filterBtn active" data-filter="all">Alle</button>
    <button class="filterBtn" data-filter="open">Offen</button>
    <button class="filterBtn" data-filter="blocked">Blockiert</button>
    <button class="filterBtn" data-filter="done">Erledigt</button>
    <div class="filterBar__spacer"></div>
    <span class="filterBar__count"><b id="filterCount">0</b> Aufgaben</span>
  </div>

  <!-- ─── Board ─── -->
  <div class="boardContainer" id="boardContainer">
    <div class="lane lane--urgent" id="laneUrgent">
      <div class="lane__header" data-lane="urgent">
        <span class="lane__dot"></span>
        <span class="lane__title">Dringend</span>
        <span class="lane__count" id="countUrgent">0</span>
        <span class="lane__toggle">&#9660;</span>
      </div>
      <div class="lane__body" id="bodyUrgent"></div>
    </div>
    <div class="lane lane--high" id="laneHigh">
      <div class="lane__header" data-lane="high">
        <span class="lane__dot"></span>
        <span class="lane__title">Hoch</span>
        <span class="lane__count" id="countHigh">0</span>
        <span class="lane__toggle">&#9660;</span>
      </div>
      <div class="lane__body" id="bodyHigh"></div>
    </div>
    <div class="lane lane--normal" id="laneNormal">
      <div class="lane__header" data-lane="normal">
        <span class="lane__dot"></span>
        <span class="lane__title">Normal</span>
        <span class="lane__count" id="countNormal">0</span>
        <span class="lane__toggle">&#9660;</span>
      </div>
      <div class="lane__body" id="bodyNormal"></div>
    </div>
    <div class="lane lane--done" id="laneDone">
      <div class="lane__header" data-lane="done">
        <span class="lane__dot"></span>
        <span class="lane__title">Erledigt</span>
        <span class="lane__count" id="countDone">0</span>
        <span class="lane__toggle collapsed">&#9660;</span>
      </div>
      <div class="lane__body collapsed" id="bodyDone"></div>
    </div>
    <div class="lane lane--failed" id="laneFailed">
      <div class="lane__header" data-lane="failed">
        <span class="lane__dot"></span>
        <span class="lane__title">Fehlgeschlagen</span>
        <span class="lane__count" id="countFailed">0</span>
        <span class="lane__toggle collapsed">&#9660;</span>
      </div>
      <div class="lane__body collapsed" id="bodyFailed"></div>
    </div>
  </div>

  <!-- ─── Footer ─── -->
  <div class="footerBar">
    <span><span class="wsIndicator wsIndicator--disconnected" id="wsIndicator"></span> <span id="wsLabelFooter">Offline</span></span>
    <span>Aktualisiert: <b id="lastUpdate">--:--:--</b></span>
  </div>

  <script>
    const API_BASE = 'http://127.0.0.1:9111';
    const WS_URL = 'ws://127.0.0.1:9112';

    /* ─── Theme ─── */
    (function(){
      const saved = localStorage.getItem('bridge_theme') || 'warm';
      document.documentElement.setAttribute('data-theme', saved);
      document.querySelectorAll('.themeBtn').forEach(btn => {
        if(btn.dataset.theme === saved) btn.classList.add('active');
        btn.addEventListener('click', () => {
          const t = btn.dataset.theme;
          document.documentElement.setAttribute('data-theme', t);
          localStorage.setItem('bridge_theme', t);
          document.querySelectorAll('.themeBtn').forEach(b => b.classList.toggle('active', b === btn));
        });
      });
    })();

    /* ─── Escape HTML ─── */
    function esc(s){
      if(!s) return '';
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    /* ─── Relative Time ─── */
    function relTime(ts){
      if(!ts) return '';
      const diff = (Date.now() - new Date(ts).getTime()) / 1000;
      if(diff < 60) return 'gerade eben';
      if(diff < 3600) return 'vor ' + Math.floor(diff/60) + ' Min';
      if(diff < 86400) return 'vor ' + Math.floor(diff/3600) + ' Std';
      return 'vor ' + Math.floor(diff/86400) + ' Tagen';
    }

    /* ─── State → German Label ─── */
    const STATE_LABELS = {
      created: 'Neu',
      claimed: 'Uebernommen',
      acked: 'Aktiv',
      done: 'Erledigt',
      failed: 'Fehlgeschlagen'
    };

    /* ─── Agent Label Map ─── */
    const AGENT_LABELS = {
      user: 'Leo', frontend: 'Frontend', backend: 'Backend',
      assi: 'Assi', nova: 'Nova', viktor: 'Viktor',
      kai: 'Kai', jura: 'Jura', ordo: 'Ordo', lucy: 'Lucy'
    };
    function agentLabel(id){ return AGENT_LABELS[id] || id || '?'; }

    /* ─── Board Data ─── */
    let boardData = { board: { created:[], claimed:[], acked:[], done:[], failed:[] }, counts:{}, total:0 };
    let currentFilter = 'all';

    /* ─── Render Task Card ─── */
    function renderTaskCard(task){
      const prio = task.priority || 1;
      const prioClass = prio >= 3 ? 'urgent' : prio === 2 ? 'high' : 'normal';
      const blocked = task.blocker_reason || (task.error && task.state === 'failed');
      const blockerText = task.blocker_reason || task.error || '';
      let html = '<div class="taskCard' + (blocked ? ' taskCard--blocked' : '') + '" data-id="' + esc(task.task_id) + '">';
      html += '<div class="taskCard__priority taskCard__priority--' + prioClass + '"></div>';
      html += '<div class="taskCard__content">';
      html += '<div class="taskCard__title">' + esc(task.title || task.task_id) + '</div>';
      html += '<div class="taskCard__meta">';
      html += '<span class="taskCard__badge taskCard__badge--state">' + esc(STATE_LABELS[task.state] || task.state) + '</span>';
      if(task.assigned_to){
        html += '<span class="taskCard__badge taskCard__badge--agent">' + esc(agentLabel(task.assigned_to)) + '</span>';
      }
      if(task.team){
        html += '<span>' + esc(task.team) + '</span>';
      }
      if(task.created_by){
        html += '<span>von ' + esc(agentLabel(task.created_by)) + '</span>';
      }
      html += '</div>';
      if(blockerText){
        html += '<div class="taskCard__blocker">' + esc(blockerText) + '</div>';
      }
      html += '</div>';
      html += '<div class="taskCard__right">';
      html += '<div class="taskCard__time">' + relTime(task.created_at) + '</div>';
      html += '</div>';
      html += '</div>';
      return html;
    }

    /* ─── Sort tasks by priority (high first) ─── */
    function sortByPriority(tasks){
      return tasks.slice().sort((a,b) => (b.priority||1) - (a.priority||1));
    }

    /* ─── Render Board ─── */
    function renderBoard(){
      const b = boardData.board || {};
      // Combine open states
      const allOpen = [].concat(b.created||[], b.claimed||[], b.acked||[]);
      const done = b.done || [];
      const failed = b.failed || [];

      // Split by priority
      const urgent = sortByPriority(allOpen.filter(t => (t.priority||1) >= 3));
      const high = sortByPriority(allOpen.filter(t => (t.priority||1) === 2));
      const normal = sortByPriority(allOpen.filter(t => (t.priority||1) <= 1));

      // Apply filter
      let visibleUrgent = urgent, visibleHigh = high, visibleNormal = normal;
      let visibleDone = done, visibleFailed = failed;

      if(currentFilter === 'open'){
        visibleDone = []; visibleFailed = [];
      } else if(currentFilter === 'blocked'){
        visibleUrgent = urgent.filter(t => t.blocker_reason);
        visibleHigh = high.filter(t => t.blocker_reason);
        visibleNormal = normal.filter(t => t.blocker_reason);
        visibleDone = []; visibleFailed = [];
      } else if(currentFilter === 'done'){
        visibleUrgent = []; visibleHigh = []; visibleNormal = [];
        visibleFailed = [];
      }

      // Render lanes
      renderLane('Urgent', visibleUrgent);
      renderLane('High', visibleHigh);
      renderLane('Normal', visibleNormal);
      renderLane('Done', visibleDone);
      renderLane('Failed', visibleFailed);

      // Update counts
      document.getElementById('countUrgent').textContent = visibleUrgent.length;
      document.getElementById('countHigh').textContent = visibleHigh.length;
      document.getElementById('countNormal').textContent = visibleNormal.length;
      document.getElementById('countDone').textContent = visibleDone.length;
      document.getElementById('countFailed').textContent = visibleFailed.length;

      // Stats
      const total = (boardData.total || 0);
      const doneCount = (boardData.counts && boardData.counts.done) || 0;
      const openCount = total - doneCount - ((boardData.counts && boardData.counts.failed) || 0);
      document.getElementById('statTotal').textContent = total;
      document.getElementById('statOpen').textContent = openCount;
      document.getElementById('statDone').textContent = doneCount;

      const visibleTotal = visibleUrgent.length + visibleHigh.length + visibleNormal.length + visibleDone.length + visibleFailed.length;
      document.getElementById('filterCount').textContent = visibleTotal;

      // Update time
      const now = new Date();
      document.getElementById('lastUpdate').textContent =
        String(now.getHours()).padStart(2,'0') + ':' +
        String(now.getMinutes()).padStart(2,'0') + ':' +
        String(now.getSeconds()).padStart(2,'0');

      // Show/hide empty lanes
      ['laneUrgent','laneHigh','laneNormal','laneDone','laneFailed'].forEach(id => {
        const lane = document.getElementById(id);
        const body = lane.querySelector('.lane__body');
        const count = parseInt(lane.querySelector('.lane__count').textContent);
        lane.style.display = (count === 0 && currentFilter !== 'all') ? 'none' : '';
      });
    }

    function renderLane(name, tasks){
      const bodyId = 'body' + name;
      const body = document.getElementById(bodyId);
      if(!body) return;
      if(tasks.length === 0){
        body.innerHTML = '<div class="lane__empty">Keine Aufgaben</div>';
        return;
      }
      body.innerHTML = tasks.map(renderTaskCard).join('');
    }

    /* ─── Lane Toggle ─── */
    document.querySelectorAll('.lane__header').forEach(header => {
      header.addEventListener('click', () => {
        const body = header.nextElementSibling;
        const toggle = header.querySelector('.lane__toggle');
        body.classList.toggle('collapsed');
        toggle.classList.toggle('collapsed');
      });
    });

    /* ─── Filter Buttons ─── */
    document.querySelectorAll('.filterBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentFilter = btn.dataset.filter;
        document.querySelectorAll('.filterBtn').forEach(b => b.classList.toggle('active', b === btn));
        renderBoard();
      });
    });

    /* ─── Fetch Board Data ─── */
    async function fetchBoard(){
      try {
        const res = await fetch(API_BASE + '/task/queue?view=board&include_blockers=true', {
          signal: AbortSignal.timeout(5000)
        });
        if(!res.ok) return;
        boardData = await res.json();
        renderBoard();
      } catch(e){ /* keep last data */ }
    }

    /* ─── WebSocket ─── */
    let ws = null;
    function connectWS(){
      try {
        ws = new WebSocket(WS_URL);
        ws.onopen = () => {
          document.getElementById('wsIndicator').className = 'wsIndicator wsIndicator--connected';
          document.getElementById('wsLabel').textContent = 'Live';
          document.getElementById('wsLabelFooter').textContent = 'Live';
          document.querySelector('.statusDot--live').style.display = '';
          document.querySelector('.statusDot--connecting').style.display = 'none';
        };
        ws.onclose = () => {
          document.getElementById('wsIndicator').className = 'wsIndicator wsIndicator--disconnected';
          document.getElementById('wsLabel').textContent = 'Offline';
          document.getElementById('wsLabelFooter').textContent = 'Offline';
          document.querySelector('.statusDot--live').style.display = 'none';
          document.querySelector('.statusDot--connecting').style.display = '';
          setTimeout(connectWS, 3000);
        };
        ws.onerror = () => { ws.close(); };
        ws.onmessage = ev => {
          try {
            const data = JSON.parse(ev.data);
            const taskEvents = ['task_created','task_claimed','task_acked','task_done','task_failed'];
            if(taskEvents.includes(data.type)){
              // Refetch board on task events
              fetchBoard();
            }
          } catch(e){}
        };
      } catch(e){
        setTimeout(connectWS, 3000);
      }
    }

    /* ─── Init ─── */
    fetchBoard();
    connectWS();
    setInterval(fetchBoard, 10000);
  </script>
</body>
</html>
